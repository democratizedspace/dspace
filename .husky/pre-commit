#!/bin/sh

echo "Running pre-commit hooks"
if command -v pwsh >/dev/null 2>&1; then
  pwsh -NoProfile -ExecutionPolicy Bypass -File .husky/pre-commit.ps1
elif command -v powershell >/dev/null 2>&1; then
  powershell -NoProfile -ExecutionPolicy Bypass -File .husky/pre-commit.ps1
else
  echo "PowerShell not found, falling back to bash script"
  cd frontend
  echo "Running linting and tests on modified files..."
  npx lint-staged
fi
