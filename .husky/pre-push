#!/bin/sh

if command -v pwsh >/dev/null 2>&1; then
  pwsh -NoProfile -ExecutionPolicy Bypass -File .husky/pre-push.ps1
elif command -v powershell >/dev/null 2>&1; then
  powershell -NoProfile -ExecutionPolicy Bypass -File .husky/pre-push.ps1
else
  echo "Running pre-push checks..."

  # Skip linting checks
  # echo "Running code quality checks..."
  # npm run check || exit 1

  # Run unit tests
  echo "Running unit tests..."
  cd frontend && npx jest || exit 1
  
  # Temporarily skip e2e tests
  echo "Skipping e2e tests for now..."
  # npm run test:e2e || exit 1
  
  cd ..

  echo "✅ All pre-push checks passed!"
  exit 0
fi 