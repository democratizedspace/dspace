{
  "name": "dspace",
  "version": "3.0.0",
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": "20 || >=22"
  },
  "main": "index.js",
  "scripts": {
    "pretest": "node frontend/scripts/build-processes.mjs",
    "pretest:root": "node frontend/scripts/build-processes.mjs",
    "dev": "cd frontend && npm run dev",
    "test": "npm run test:pr",
    "test:root": "vitest run --config vitest.config.mts --testTimeout 20000 --maxWorkers=1",
    "coverage": "vitest run --config vitest.config.mts --coverage",
    "test:watch": "cd frontend && npm run test:watch",
    "test:e2e": "cd frontend && npm run test:e2e",
    "test:e2e:coverage": "cd frontend && npm run test:e2e:coverage",
    "test:e2e:groups": "cd frontend && npm run test:e2e:groups",
    "test:e2e:custom": "cd frontend && npm run test:e2e:custom",
    "test:quick": "cd frontend && npm run test:quick",
    "test:pr": "node run-tests.js",
    "test:ci": "npm run build && npm run verify:chat-build-stamp && cross-env SKIP_E2E=1 npm run test:pr",
    "test:docs-rag": "node scripts/test-docs-rag.mjs",
    "check": "cd frontend && npm run check",
    "itemValidation": "cd frontend && npm run itemValidation",
    "lint": "cd frontend && npm run lint",
    "lint:fix": "cd frontend && npm run lint:fix",
    "format": "cd frontend && npm run format",
    "format:check": "cd frontend && npm run format:check",
    "format:check:frontend-canary": "npx prettier --check frontend/__tests__/offlineWorkerRegistration.test.js",
    "type-check": "tsc --noEmit",
    "build:docs-rag": "node scripts/build-docs-rag-index.mjs",
    "build": "node scripts/build-with-sha.mjs",
    "verify:chat-build-stamp": "node scripts/verify-chat-build-stamp.mjs",
    "link-check": "node scripts/link-check.mjs",
    "quest:count": "node scripts/compareQuestCount.mjs",
    "gen:quest-tree": "node scripts/gen-quest-tree.mjs",
    "generate:item-map": "node scripts/generate-item-dependencies.js",
    "new-quests:update": "node scripts/update-new-quests.mjs",
    "hardening:validate": "node frontend/scripts/validate-hardening.mjs",
    "hardening:fix": "node frontend/scripts/fix-hardening.mjs",
    "qa:smoke": "npm run type-check && npm run link-check && npm run itemValidation && npm run test:quest-validation && npm run test:ci",
    "audit:ci": "npm audit --omit=dev --audit-level=high && npm --prefix frontend install --package-lock-only --ignore-scripts && npm --prefix frontend audit --omit=dev --audit-level=high && rm frontend/package-lock.json",
    "ci:install": "HUSKY=0 pnpm install --frozen-lockfile --reporter=append-only",
    "db:benchmark": "node frontend/scripts/db-benchmark.js",
    "backup": "node scripts/backup.mjs",
    "helm:lint": "helm lint charts/dspace",
    "helm:template": "helm template dspace charts/dspace -f charts/dspace/values.dev.yaml",
    "test:quest-validation": "npm run test:root -- tests/questDialogueValidation.test.ts tests/questCompletableItems.test.ts tests/runTestsQuestRegression.test.ts",
    "spellcheck": "cspell --no-progress --no-summary \"docs/**/*.md\" \"frontend/src/pages/docs/**/*.md\" \"README.md\" \"AGENTS.md\"",
    "qa:remote-smoke": "node scripts/run-remote-smoke.mjs",
    "qa:remote-migration": "npx -y node@20 scripts/run-remote-migration.mjs",
    "qa:remote-completionist-award-iii": "npx -y node@20 scripts/run-remote-completionist-award-iii.mjs",
    "generate-quest": "cd frontend && npm run generate-quest",
    "preview": "cd frontend && npm run preview",
    "lint:a11y": "cd frontend && npm run lint:a11y",
    "dev:legacy": "npm run dev",
    "playwright:install": "npm --prefix frontend run playwright:install"
  },
  "devDependencies": {
    "@jest/globals": "^29.5.0",
    "@playwright/test": "^1.51.0",
    "@sveltejs/vite-plugin-svelte": "^4.0.4",
    "@testing-library/jest-dom": "^5.17.0",
    "@testing-library/svelte": "^5.2.8",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^29.5.14",
    "@types/node": "^24.3.0",
    "@types/prismjs": "^1.26.5",
    "@typescript-eslint/parser": "^8.39.0",
    "@vitest/coverage-v8": "^3.2.4",
    "ajv": "^8.12.0",
    "chart.js": "^4.5.0",
    "chartjs-node-canvas": "^5.0.0",
    "cross-env": "^10.1.0",
    "cspell": "^8.17.5",
    "estree-walker": "^3.0.3",
    "fake-indexeddb": "^6.1.0",
    "github-slugger": "^2.0.0",
    "glob": "13.0.6",
    "jest": "^29.7.0",
    "jsdom": "^26.1.0",
    "minisearch": "^7.2.0",
    "prettier": "^3.4.2",
    "prettier-plugin-svelte": "^2.10.1",
    "prism-svelte": "^0.5.0",
    "prismjs": "^1.30.0",
    "svelte": "^5.46.0",
    "ts-jest": "^29.4.1",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4",
    "wait-on": "^7.0.1",
    "yaml": "^2.8.1",
    "zimmerframe": "^1.1.4"
  },
  "dependencies": {
    "@dspace/feature-flags": "file:packages/feature-flags",
    "openai": "^5.16.0"
  },
  "overrides": {
    "esbuild": "0.25.8",
    "@esbuild/linux-x64": "0.25.8",
    "glob": "13.0.6"
  },
  "pnpm": {
    "overrides": {
      "esbuild": "0.25.8",
      "@esbuild/linux-x64": "0.25.8",
      "glob": "13.0.6"
    }
  },
  "license": "MIT"
}
