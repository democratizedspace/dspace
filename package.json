{
  "name": "dspace",
  "version": "3.0.0",
  "engines": {
    "node": ">=18 <22"
  },
  "main": "index.js",
  "scripts": {
    "postinstall": "if [ -d .git ]; then husky install; fi",
    "dev": "pnpm --filter ./frontend dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "test:frontend:watch": "pnpm --filter ./frontend test:watch",
    "test:e2e": "pnpm --filter ./frontend test:e2e",
    "test:e2e:coverage": "pnpm --filter ./frontend test:e2e:coverage",
    "test:e2e:groups": "pnpm --filter ./frontend test:e2e:groups",
    "test:e2e:custom": "pnpm --filter ./frontend test:e2e:custom",
    "test:quick": "pnpm --filter ./frontend test:quick",
    "test:pr": "node run-tests.js",
    "check": "pnpm --filter ./frontend check",
    "itemValidation": "pnpm --filter ./frontend itemValidation",
    "lint": "pnpm --filter ./frontend lint",
    "lint:fix": "pnpm --filter ./frontend lint:fix",
    "format": "pnpm --filter ./frontend format",
    "type-check": "tsc --noEmit",
    "build": "pnpm --filter ./frontend build",
    "quest:count": "node scripts/compareQuestCount.js",
    "generate:item-map": "node scripts/generate-item-dependencies.js",
    "new-quests:update": "node scripts/update-new-quests-v3.js"
  },
  "devDependencies": {
    "@jest/globals": "^29.5.0",
    "@sveltejs/vite-plugin-svelte": "^6.1.0",
    "@testing-library/svelte": "^5.2.8",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^29.5.6",
    "@types/node": "^24.1.0",
    "@vitest/coverage-v8": "^3.2.4",
    "ajv": "^8.12.0",
    "chart.js": "^4.5.0",
    "chartjs-node-canvas": "^5.0.0",
    "fake-indexeddb": "^6.0.0",
    "glob": "^7.2.3",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jsdom": "^26.1.0",
    "prettier-plugin-svelte": "^3.4.0",
    "ts-jest": "^29.1.1",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "openai": "^3.2.1"
  },
  "license": "MIT"
}
