{
  "id": null,
  "title": "DSpace Overview",
  "timezone": "browser",
  "panels": [
    {
      "type": "graph",
      "title": "Service Up",
      "targets": [
        {
          "expr": "up{job=\"dspace\"}",
          "legendFormat": "dspace"
        }
      ]
    },
    {
      "type": "graph",
      "title": "Error Rate",
      "targets": [
        {
          "expr": "rate(http_requests_total{job=\"dspace\",status=~\"5..\"}[5m])/rate(http_requests_total{job=\"dspace\"}[5m])",
          "legendFormat": "5xx rate"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit"
        },
        "overrides": []
      },
      "yaxes": [
        {
          "format": "percentunit",
          "min": 0,
          "max": 1
        },
        {
          "format": "short"
        }
      ]
    },
    {
      "type": "graph",
      "title": "99th Percentile Latency",
      "targets": [
        {
          "expr": "histogram_quantile(0.99,sum by (le) (rate(http_request_duration_seconds_bucket{job=\"dspace\"}[5m])))",
          "legendFormat": "p99 latency"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "yaxes": [
        {
          "format": "s"
        },
        {
          "format": "short"
        }
      ]
    }
  ],
  "schemaVersion": 36,
  "version": 1,
  "refresh": "5s"
}
