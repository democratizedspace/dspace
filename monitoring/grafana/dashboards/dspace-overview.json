{
  "uid": "dspace-overview",
  "id": null,
  "title": "DSpace Overview",
  "timezone": "browser",
  "panels": [
    {
      "type": "graph",
      "title": "Service Up",
      "targets": [
        {
          "expr": "up{job=\"dspace\"}",
          "legendFormat": "dspace"
        }
      ]
    },
    {
      "type": "graph",
      "title": "Error Rate",
      "targets": [
        {
          "expr": "rate(http_requests_total{job=\"dspace\",status=~\"5..\"}[5m])/rate(http_requests_total{job=\"dspace\"}[5m])",
          "legendFormat": "5xx rate"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit"
        },
        "overrides": []
      },
      "yaxes": [
        {"format": "percentunit", "min": 0, "max": 1},
        {"format": "short"}
      ]
    }
  ],
  "schemaVersion": 36,
  "version": 1,
  "refresh": "5s"
}
