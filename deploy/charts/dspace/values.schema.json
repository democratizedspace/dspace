{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "image",
    "ingress",
    "resources",
    "service",
    "serviceMonitor",
    "env",
    "metrics"
  ],
  "properties": {
    "env": {
      "type": "string",
      "enum": ["dev", "int", "prod"],
      "description": "Deployment environment identifier used for policy and validation gates."
    },
    "image": {
      "type": "object",
      "additionalProperties": true,
      "required": ["repository"],
      "properties": {
        "repository": {
          "type": "string",
          "minLength": 1
        },
        "tag": {
          "type": "string",
          "minLength": 1
        },
        "digest": {
          "type": "string",
          "pattern": "^sha256:[A-Fa-f0-9]{64}$"
        }
      }
    },
    "ingress": {
      "type": "object",
      "additionalProperties": true,
      "required": ["enabled", "hosts"],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "hosts": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": true,
            "required": ["host"],
            "properties": {
              "host": {
                "type": "string",
                "format": "hostname"
              }
            }
          }
        }
      }
    },
    "resources": {
      "type": "object",
      "additionalProperties": true,
      "required": ["requests", "limits"],
      "properties": {
        "requests": {
          "type": "object",
          "additionalProperties": false,
          "patternProperties": {
            ".*": {
              "type": "string"
            }
          }
        },
        "limits": {
          "type": "object",
          "additionalProperties": false,
          "patternProperties": {
            ".*": {
              "type": "string"
            }
          }
        }
      }
    },
    "service": {
      "type": "object",
      "additionalProperties": true,
      "required": ["port"],
      "properties": {
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        }
      }
    },
    "serviceMonitor": {
      "type": "object",
      "additionalProperties": true,
      "required": ["enabled"],
      "properties": {
        "enabled": {
          "type": "boolean"
        }
      }
    },
    "metrics": {
      "type": "object",
      "additionalProperties": true,
      "required": ["enabled"],
      "properties": {
        "enabled": {
          "type": "boolean"
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "env": {
            "const": "prod"
          }
        },
        "required": ["env"]
      },
      "then": {
        "properties": {
          "image": {
            "required": ["digest"]
          }
        }
      }
    }
  ]
}
