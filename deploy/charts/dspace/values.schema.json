{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "env": {
      "type": "string",
      "enum": ["dev", "int", "prod"]
    },
    "image": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "repository": {
          "type": "string",
          "minLength": 1
        },
        "digest": {
          "type": "string",
          "pattern": "^$|^sha256:[A-Fa-f0-9]{64}$"
        },
        "tag": {
          "type": "string"
        }
      },
      "required": ["repository"]
    },
    "ingress": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "hosts": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "host": {
                "type": "string",
                "pattern": "^(?:[a-zA-Z0-9](?:[a-zA-Z0-9-]{0,61}[a-zA-Z0-9])?\\.)+[A-Za-z]{2,}$"
              }
            },
            "required": ["host"]
          }
        }
      },
      "required": ["enabled", "hosts"]
    },
    "resources": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "requests": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "cpu": { "type": "string" },
            "memory": { "type": "string" }
          },
          "required": ["cpu", "memory"]
        },
        "limits": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "cpu": { "type": "string" },
            "memory": { "type": "string" }
          },
          "required": ["cpu", "memory"]
        }
      },
      "required": ["requests", "limits"]
    },
    "service": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "port": {
          "type": "integer",
          "minimum": 1
        }
      },
      "required": ["port"]
    },
    "serviceMonitor": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": {
          "type": "boolean"
        }
      },
      "required": ["enabled"]
    },
    "metrics": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": {
          "type": "boolean"
        }
      },
      "required": ["enabled"]
    },
    "terminationGracePeriodSeconds": {
      "type": "integer",
      "minimum": 5,
      "maximum": 600
    },
    "alerts": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": {
          "type": "boolean"
        }
      }
    }
  },
  "required": ["image", "ingress", "resources", "service", "serviceMonitor", "env", "metrics"],
  "allOf": [
    {
      "if": {
        "properties": {
          "env": { "const": "prod" }
        }
      },
      "then": {
        "properties": {
          "image": {
            "required": ["digest"],
            "properties": {
              "digest": {
                "type": "string",
                "pattern": "^sha256:[A-Fa-f0-9]{64}$"
              }
            }
          }
        }
      }
    }
  ]
}
