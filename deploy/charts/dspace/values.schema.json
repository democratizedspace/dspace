{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "env": {
      "type": "string",
      "enum": ["dev", "int", "prod"],
      "description": "Deployment environment identifier."
    },
    "image": {
      "type": "object",
      "properties": {
        "repository": {
          "type": "string",
          "minLength": 1
        },
        "digest": {
          "type": "string",
          "pattern": "^sha256:[A-Fa-f0-9]{64}$"
        },
        "tag": {
          "type": "string"
        }
      },
      "required": ["repository"],
      "additionalProperties": true
    },
    "ingress": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "hosts": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "properties": {
              "host": {
                "type": "string",
                "pattern": "^(?=.{1,253}$)(?!-)([A-Za-z0-9-]{1,63}\.)+[A-Za-z]{2,}$"
              }
            },
            "required": ["host"],
            "additionalProperties": true
          }
        }
      },
      "required": ["enabled", "hosts"],
      "additionalProperties": true
    },
    "service": {
      "type": "object",
      "properties": {
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        }
      },
      "required": ["port"],
      "additionalProperties": true
    },
    "resources": {
      "type": "object",
      "properties": {
        "requests": {
          "type": "object",
          "properties": {
            "cpu": {
              "type": "string",
              "minLength": 1
            },
            "memory": {
              "type": "string",
              "minLength": 1
            }
          },
          "required": ["cpu", "memory"],
          "additionalProperties": true
        },
        "limits": {
          "type": "object",
          "properties": {
            "cpu": {
              "type": "string",
              "minLength": 1
            },
            "memory": {
              "type": "string",
              "minLength": 1
            }
          },
          "required": ["cpu", "memory"],
          "additionalProperties": true
        }
      },
      "required": ["requests", "limits"],
      "additionalProperties": true
    },
    "serviceMonitor": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        }
      },
      "required": ["enabled"],
      "additionalProperties": true
    },
    "metrics": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        }
      },
      "required": ["enabled"],
      "additionalProperties": true
    },
    "alerts": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        }
      },
      "required": ["enabled"],
      "additionalProperties": true
    }
  },
  "required": [
    "env",
    "image",
    "ingress",
    "resources",
    "service",
    "serviceMonitor",
    "metrics"
  ],
  "allOf": [
    {
      "if": {
        "properties": {
          "env": {
            "const": "prod"
          }
        }
      },
      "then": {
        "properties": {
          "image": {
            "required": ["digest"]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "serviceMonitor": {
            "properties": {
              "enabled": {
                "const": true
              }
            },
            "required": ["enabled"]
          }
        }
      },
      "then": {
        "properties": {
          "metrics": {
            "properties": {
              "enabled": {
                "const": true
              }
            },
            "required": ["enabled"]
          }
        }
      }
    }
  ]
}
