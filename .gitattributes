# Enforce consistent line endings
* text=auto eol=lf

# Keep Windows scripts with CRLF endings
*.bat eol=crlf
*.cmd eol=crlf
*.ps1 eol=crlf

# Treat binary assets as binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.avif binary
*.ico binary
*.bmp binary
*.pdf binary
*.zip binary
*.gz binary
*.tar binary
*.tgz binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
