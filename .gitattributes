* text=auto eol=lf

# Preserve Windows-friendly endings for scripts executed by cmd/PowerShell
*.bat eol=crlf
*.cmd eol=crlf
*.ps1 eol=crlf

# Treat binary assets as binary to avoid line-ending churn
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.bmp binary
*.mp3 binary
*.mp4 binary
*.ogg binary
*.zip binary
*.gz binary
*.bz2 binary
*.ttf binary
*.otf binary
*.eot binary
*.woff binary
*.woff2 binary
