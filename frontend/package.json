{
    "name": "dspace",
    "version": "2.1",
    "description": "A free and open source web-based space exploration idle game",
    "scripts": {
        "dev": "astro dev --host 0.0.0.0 --port=3002",
        "start": "astro dev --host 0.0.0.0 --port=$PORT",
        "build": "astro build",
        "preview": "astro preview",
        "astro": "astro",
        "test": "jest",
        "clean:test-artifacts": "node scripts/clean-test-artifacts.js",
        "test:e2e": "npm run clean:test-artifacts && playwright test && npm run clean:test-artifacts",
        "test:e2e:debug": "PWDEBUG=1 playwright test",
        "test:e2e:ui": "playwright test --ui",
        "test:all": "node -e \"process.platform === 'win32' ? require('child_process').spawn('cmd', ['/c', 'echo Running tests (ESLint and Prettier checks included) && npm test && npm run test:e2e'], {stdio: 'inherit'}) : require('child_process').spawn('bash', ['-c', 'echo \\'Running tests (ESLint and Prettier checks included)\\' && npm test && npm run test:e2e'], {stdio: 'inherit'})\"",
        "test:all:verbose": "node -e \"process.platform === 'win32' ? require('child_process').execSync('powershell -File .\\\\scripts\\\\run-tests.ps1', {stdio: 'inherit'}) : require('child_process').execSync('bash ./scripts/run-tests.sh', {stdio: 'inherit'})\"",
        "coverage": "npx jest --coverage",
        "lint": "eslint . --ext .js,.ts,.svelte",
        "lint:fix": "eslint . --ext .js,.ts,.svelte --fix",
        "format": "prettier --write \"**/*.{js,ts,svelte,json,md}\"",
        "format:check": "prettier --check \"**/*.{js,ts,svelte,json,md}\"",
        "check": "npm run lint && npm run format:check",
        "sync": "node scripts/sync-package.js",
        "postinstall": "npm run sync",
        "prepare": "husky"
    },
    "devDependencies": {
        "@astrojs/svelte": "^2.1.0",
        "@babel/core": "^7.26.9",
        "@babel/eslint-parser": "^7.26.8",
        "@babel/plugin-syntax-import-assertions": "^7.26.0",
        "@babel/preset-env": "^7.26.9",
        "@playwright/test": "^1.51.0",
        "@testing-library/jest-dom": "^5.17.0",
        "@testing-library/svelte": "^5.2.7",
        "@typescript-eslint/eslint-plugin": "^5.62.0",
        "@typescript-eslint/parser": "^5.59.0",
        "ajv": "^8.12.0",
        "astro": "^2.3.2",
        "babel-jest": "^29.6.2",
        "eslint": "^8.42.0",
        "eslint-plugin-svelte3": "^4.0.0",
        "husky": "^9.1.7",
        "jest": "^29.4.3",
        "jest-environment-jsdom": "^29.7.0",
        "lint-staged": "^15.5.0",
        "postcss-scss": "^4.0.7",
        "prettier": "^2.8.8",
        "prettier-plugin-svelte": "^2.10.1",
        "svelte": "^3.50.1",
        "svelte-jester": "^2.3.2",
        "svelte-switch-case": "^2.0.0",
        "text-encoding": "^0.7.0",
        "typescript": "~5.1.6"
    },
    "dependencies": {
        "@algolia/client-search": "^4.13.1",
        "@astrojs/netlify": "^2.2.2",
        "@astrojs/node": "^5.1.1",
        "@astrojs/vercel": "^3.2.5",
        "@types/node": "^18.0.0",
        "astro-seo": "^0.7.4",
        "autoprefixer": "^10.4.14",
        "cssnano": "^6.0.1",
        "date-fns": "^2.30.0",
        "dompurify": "^3.0.2",
        "highlight.js": "^11.8.0",
        "jsdom": "^21.1.1",
        "markdown-it": "^13.0.1",
        "marked": "^4.3.0",
        "node-fetch": "^3.3.1",
        "openai": "^3.2.1",
        "postcss": "^8.4.23",
        "pretty-date": "^0.2.0",
        "remarkable": "^2.0.1"
    }
}
