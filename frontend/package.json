{
    "name": "dspace",
    "version": "3.0.0",
    "type": "module",
    "description": "A free and open source web-based space exploration idle game",
    "scripts": {
        "prebuild": "node scripts/build-processes.mjs",
        "pretest": "node scripts/build-processes.mjs",
        "dev": "astro dev --host 0.0.0.0 --port=3002",
        "dev:safe": "concurrently \"npm run dev\" \"npm run fix-artifacts\"",
        "fix-artifacts": "node scripts/fix-artifact-error.js",
        "start": "astro dev --host 0.0.0.0 --port=$PORT",
        "build": "astro build",
        "preview": "astro preview --host 0.0.0.0 --port=3002",
        "astro": "astro",
        "setup-test-env": "node scripts/setup-test-env.js",
        "test": "npm run setup-test-env && vitest run -c ../vitest.config.ts --passWithNoTests",
        "test:watch": "npm run setup-test-env && vitest -c ../vitest.config.ts",
        "test:e2e": "npm run setup-test-env && playwright test",
        "test:e2e:debug": "npm run setup-test-env && PWDEBUG=1 playwright test",
        "test:e2e:ui": "npm run setup-test-env && playwright test --ui",
        "test:all": "npm run check && npm run test && npm run test:e2e:groups",
        "test:quick": "npm test && npm run test:e2e:fast",
        "test:e2e:coverage": "npm run setup-test-env && c8 -o coverage/e2e --reporter=lcov --reporter=text playwright test",
        "test:e2e:groups": "npm run setup-test-env && node scripts/run-test-groups.mjs",
        "test:e2e:custom": "npm run setup-test-env && playwright test custom-content.spec.ts",
        "test:e2e:quests": "npm run setup-test-env && playwright test quests.spec.ts",
        "test:e2e:process": "npm run setup-test-env && playwright test process-creation.spec.ts",
        "test:e2e:structure": "npm run setup-test-env && playwright test page-structure.spec.ts",
        "test:e2e:integration": "npm run setup-test-env && playwright test -g \"integrate custom items, processes, and quests\"",
        "test:e2e:fast": "npm run setup-test-env && playwright test --workers=2 page-structure.spec.ts custom-content.spec.ts",
        "coverage": "npm run setup-test-env && vitest run -c ../vitest.config.ts --coverage",
        "itemValidation": "npm run setup-test-env && vitest run --root .. -c vitest.config.ts tests/itemValidation.test.ts",
        "lint": "ESLINT_USE_FLAT_CONFIG=false npx eslint . --max-warnings=0",
        "lint:fix": "ESLINT_USE_FLAT_CONFIG=false npx eslint . --fix",
        "format": "prettier --write \"**/*.{js,ts,svelte,json,md}\"",
        "format:check": "prettier --check \"**/*.{js,ts,svelte,json,md}\"",
        "generate-quest": "node scripts/generate-quest.mjs",
        "seed:custom": "node scripts/seed-custom-content.js",
        "benchmark:db": "node scripts/db-benchmark.js",
        "loadtest:custom-content": "node scripts/custom-content-load-test.js",
        "check": "npm run lint && npm run format:check",
        "sync": "node scripts/sync-package.js",
        "postinstall": "node scripts/postinstall.js"
    },
    "devDependencies": {
        "@astrojs/svelte": "^2.1.0",
        "@babel/core": "^7.26.9",
        "@babel/eslint-parser": "^7.26.8",
        "@babel/plugin-syntax-import-assertions": "^7.26.0",
        "@babel/plugin-transform-runtime": "^7.26.10",
        "@babel/preset-env": "^7.26.9",
        "@jest/globals": "^29.7.0",
        "@playwright/test": "^1.51.0",
        "@testing-library/jest-dom": "^5.17.0",
        "@testing-library/svelte": "^5.2.7",
        "@typescript-eslint/eslint-plugin": "^8.39.0",
        "@typescript-eslint/parser": "^8.39.0",
        "ajv": "^8.12.0",
        "astro": "^2.3.2",
        "babel-jest": "^29.7.0",
        "c8": "^10.1.3",
        "chokidar": "^4.0.3",
        "concurrently": "^9.1.2",
        "eslint": "^9.32.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-svelte3": "^4.0.0",
        "husky": "^9.1.7",
        "image-size": "^2.0.1",
        "jest": "^29.4.3",
        "jest-environment-jsdom": "^29.7.0",
        "lint-staged": "^15.5.0",
        "postcss-scss": "^4.0.7",
        "prettier": "^2.8.8",
        "prettier-plugin-svelte": "^2.10.1",
        "svelte": "^3.59.2",
        "svelte-jester": "^2.3.2",
        "svelte-switch-case": "^2.0.0",
        "text-encoding": "^0.7.0",
        "ts-jest": "^29.2.6",
        "typescript": "~5.1.6"
    },
    "dependencies": {
        "@algolia/client-search": "^4.13.1",
        "@astrojs/node": "^5.1.1",
        "@types/node": "^18.0.0",
        "astro-seo": "^0.7.4",
        "autoprefixer": "^10.4.14",
        "cssnano": "^6.0.1",
        "date-fns": "^2.30.0",
        "dompurify": "^3.0.2",
        "fake-indexeddb": "^6.1.0",
        "highlight.js": "^11.8.0",
        "jsdom": "^21.1.1",
        "markdown-it": "^13.0.1",
        "marked": "^4.3.0",
        "node-fetch": "^3.3.1",
        "openai": "^5.12.2",
        "postcss": "^8.4.23",
        "pretty-date": "^0.2.0",
        "prom-client": "^15.1.0",
        "remarkable": "^2.0.1"
    },
    "license": "MIT"
}
