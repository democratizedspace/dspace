{
    "name": "dspace",
    "version": "3.0.0",
    "type": "module",
    "description": "A free and open source web-based space exploration idle game",
    "scripts": {
        "prebuild": "node scripts/build-processes.mjs",
        "pretest": "node scripts/build-processes.mjs",
        "dev": "astro dev --host 0.0.0.0 --port=3002",
        "dev:safe": "concurrently \"npm run dev\" \"npm run fix-artifacts\"",
        "fix-artifacts": "node scripts/fix-artifact-error.js",
        "start": "astro dev --host 0.0.0.0 --port=$PORT",
        "build": "node scripts/run-astro-build.mjs",
        "preview": "node scripts/ensure-astro-build.mjs && astro preview --host 0.0.0.0 --port=3000",
        "astro": "astro",
        "setup-test-env": "node scripts/setup-test-env.js",
        "test": "node scripts/setup-test-env.js && vitest run -c ../vitest.config.mts --passWithNoTests",
        "test:watch": "node scripts/setup-test-env.js && vitest -c ../vitest.config.mts",
        "test:e2e": "node scripts/setup-test-env.js && playwright test",
        "test:e2e:debug": "node scripts/setup-test-env.js && PWDEBUG=1 playwright test",
        "test:e2e:ui": "node scripts/setup-test-env.js && playwright test --ui",
        "test:all": "npm run check && npm run test && npm run test:e2e:groups",
        "test:quick": "npm test && npm run test:e2e:fast",
        "test:e2e:coverage": "node scripts/setup-test-env.js && c8 -o coverage/e2e --reporter=lcov --reporter=text playwright test",
        "test:e2e:groups": "node scripts/setup-test-env.js && node scripts/run-test-groups.mjs",
        "test:e2e:custom": "node scripts/setup-test-env.js && playwright test custom-content.spec.ts",
        "test:e2e:quests": "node scripts/setup-test-env.js && playwright test quests.spec.ts",
        "test:e2e:process": "node scripts/setup-test-env.js && playwright test process-creation.spec.ts",
        "test:e2e:structure": "node scripts/setup-test-env.js && playwright test page-structure.spec.ts",
        "test:e2e:integration": "node scripts/setup-test-env.js && playwright test -g \"integrate custom items, processes, and quests\"",
        "test:e2e:fast": "node scripts/setup-test-env.js && playwright test --workers=2 page-structure.spec.ts custom-content.spec.ts",
        "coverage": "node scripts/setup-test-env.js && vitest run -c ../vitest.config.mts --coverage",
        "itemValidation": "node scripts/setup-test-env.js && vitest run --root .. -c vitest.config.mts tests/itemValidation.test.ts",
        "lint": "node scripts/a11y-lint.mjs && node -e \"const { spawnSync } = require('node:child_process'); const { addNodeWarningFilterToEnv } = require('../scripts/node-warning-filter.cjs'); const env = addNodeWarningFilterToEnv({ ...process.env, NODE_OPTIONS: ['--disable-warning=ESLintRCWarning', process.env.NODE_OPTIONS || ''].join(' ').trim(), ESLINT_USE_FLAT_CONFIG: 'false' }); const result = spawnSync(process.platform === 'win32' ? 'npx.cmd' : 'npx', ['eslint', '.', '--max-warnings=0'], { stdio: 'inherit', env }); process.exit(result.status ?? 1);\"",
        "lint:a11y": "node scripts/a11y-lint.mjs",
        "lint:fix": "node -e \"const { spawnSync } = require('node:child_process'); const { addNodeWarningFilterToEnv } = require('../scripts/node-warning-filter.cjs'); const env = addNodeWarningFilterToEnv({ ...process.env, NODE_OPTIONS: ['--disable-warning=ESLintRCWarning', process.env.NODE_OPTIONS || ''].join(' ').trim(), ESLINT_USE_FLAT_CONFIG: 'false' }); const result = spawnSync(process.platform === 'win32' ? 'npx.cmd' : 'npx', ['eslint', '.', '--fix'], { stdio: 'inherit', env }); process.exit(result.status ?? 1);\"",
        "format": "prettier --config .prettierrc --write \"**/*.{js,ts,svelte,json,md}\"",
        "format:check": "prettier --config .prettierrc --check \"**/*.{js,ts,svelte,json,md}\"",
        "format:check:canary": "prettier --config .prettierrc --check __tests__/offlineWorkerRegistration.test.js",
        "generate-quest": "node scripts/generate-quest.mjs",
        "seed:custom": "node scripts/seed-custom-content.js",
        "benchmark:db": "node scripts/db-benchmark.js",
        "loadtest:custom-content": "node scripts/custom-content-load-test.js",
        "check": "npm run lint && npm run format:check",
        "sync": "node scripts/sync-package.js",
        "postinstall": "node scripts/postinstall.js",
        "playwright:install": "playwright install --with-deps chromium chromium-headless-shell",
        "perf:quests": "node scripts/setup-test-env.js && node scripts/run-quests-perf.mjs",
        "perf:quests:slowcpu": "node scripts/setup-test-env.js && cross-env QUESTS_TTI_CPU_SLOWDOWN=4 node scripts/run-quests-perf.mjs"
    },
    "devDependencies": {
        "@astrojs/svelte": "^6.0.0",
        "@babel/core": "^7.26.9",
        "@babel/eslint-parser": "^7.26.8",
        "@babel/plugin-syntax-import-assertions": "^7.26.0",
        "@babel/plugin-transform-runtime": "^7.26.10",
        "@babel/preset-env": "^7.26.9",
        "@jest/globals": "^29.7.0",
        "@playwright/test": "^1.51.0",
        "@testing-library/jest-dom": "^5.17.0",
        "@testing-library/svelte": "^5.2.8",
        "@typescript-eslint/eslint-plugin": "^8.39.0",
        "@typescript-eslint/parser": "^8.39.0",
        "astro": "^4.16.19",
        "babel-jest": "^30.3.0",
        "c8": "^10.1.3",
        "chokidar": "^4.0.3",
        "concurrently": "^9.1.2",
        "cross-env": "^10.1.0",
        "eslint": "^9.32.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-svelte": "^3.13.1",
        "husky": "^9.1.7",
        "image-size": "^2.0.1",
        "jest": "^29.4.3",
        "jest-environment-jsdom": "^29.7.0",
        "lint-staged": "^15.5.0",
        "postcss-scss": "^4.0.7",
        "prettier": "^3.4.2",
        "prettier-plugin-svelte": "^3.4.0",
        "prism-svelte": "^0.5.0",
        "svelte": "^5.46.0",
        "svelte-eslint-parser": "^1.4.1",
        "svelte-jester": "^2.3.2",
        "svelte-switch-case": "^2.0.0",
        "text-encoding": "^0.7.0",
        "ts-jest": "^29.2.6",
        "typescript": "^5.9.2"
    },
    "dependencies": {
        "@algolia/client-search": "^4.13.1",
        "@astrojs/node": "^8.3.3",
        "@dspace/feature-flags": "file:../packages/feature-flags",
        "@types/node": "^18.0.0",
        "ajv": "^8.12.0",
        "astro-seo": "^0.7.4",
        "autoprefixer": "^10.4.14",
        "canvas": "^3.1.2",
        "cssnano": "^6.0.1",
        "cytoscape": "^3.33.1",
        "cytoscape-dagre": "^2.5.0",
        "dagre": "^0.8.5",
        "date-fns": "^2.30.0",
        "dompurify": "^3.0.2",
        "fake-indexeddb": "^6.1.0",
        "highlight.js": "^11.8.0",
        "jsdom": "^21.1.1",
        "markdown-it": "^13.0.1",
        "marked": "^4.3.0",
        "minisearch": "^7.2.0",
        "node-fetch": "^3.3.1",
        "openai": "^5.16.0",
        "postcss": "^8.4.23",
        "pretty-date": "^0.2.0",
        "prom-client": "^15.1.0",
        "remarkable": "^2.0.1"
    },
    "license": "MIT"
}
