---
import Page from '../../../components/Page.astro';
import Importer from '../svelte/Importer.svelte';
import { getCookieItemsFromStore } from '../../../utils/migrationCookies.js';

const { newVersion, oldVersion } = Astro.params;

const itemList = getCookieItemsFromStore(Astro.cookies);

const title = `Upgrade from ${oldVersion.toString()} to ${newVersion.toString()}`;
---

<Page title={title} columns="1">
    <Importer itemList={itemList} client:load />
</Page>
