---
import Page from '../../components/Page.astro';
import Chip from '../../components/Chip.astro';
import Card from '../../components/Card.astro';
import { fixMarkdownText } from '../../utils';

const escapeHtml = (value = '') =>
    String(value)
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');

const buildLatestChangelogHtml = (entries = []) => {
    const normalized = entries
        .map((entry) => ({
            slug: entry?.frontmatter?.slug,
            title: entry?.frontmatter?.title,
            tagline: entry?.frontmatter?.tagline ?? '',
            summary: entry?.frontmatter?.summary ?? '',
        }))
        .filter((entry) => entry.slug && entry.title)
        .sort((a, b) => String(b.slug).localeCompare(String(a.slug)));

    if (!normalized.length) {
        return '<p>No release notes are available yet.</p>';
    }

    const latest = normalized[0];
    const taglineSuffix = latest.tagline
        ? `&nbsp;&mdash;&nbsp;${escapeHtml(latest.tagline)}`
        : '';
    const summaryText = typeof latest.summary === 'string'
        ? latest.summary.replace(/\s+/g, ' ').trim()
        : '';
    const summaryHtml = summaryText
        ? `\n        <p>${escapeHtml(summaryText)}</p>`
        : '';

    return `\n<ul aria-label="Latest releases">\n    <li>\n        <a href="/changelog">${escapeHtml(latest.title)}${taglineSuffix}</a>${summaryHtml}\n    </li>\n</ul>`;
};

const buildNotesHtml = (notes = [], currentSlug = '') => {
    if (!Array.isArray(notes) || !notes.length) {
        return '';
    }

    const normalizedSlug = typeof currentSlug === 'string' ? currentSlug : '';

    const normalizedNotes = notes
        .map((note) => {
            if (!note || typeof note !== 'object') {
                return null;
            }

            const rawTitle = note.title;
            const rawDescription = note.description;
            const rawSlug = typeof note.slug === 'string' ? note.slug : '';
            const rawHref = typeof note.href === 'string' ? note.href : '';

            const title = typeof rawTitle === 'string' ? rawTitle.trim() : '';
            const description = typeof rawDescription === 'string' ? rawDescription.trim() : '';
            const targetSlug = rawSlug.trim();
            const href = rawHref.trim() || (targetSlug ? `/changelog#${targetSlug}` : '');

            if (!title || !href) {
                return null;
            }

            if (targetSlug && normalizedSlug && targetSlug <= normalizedSlug) {
                return null;
            }

            return {
                title,
                description,
                href,
            };
        })
        .filter(Boolean);

    if (!normalizedNotes.length) {
        return '';
    }

    const listItemsHtml = normalizedNotes
        .map((note) => {
            const descriptionHtml = note.description
                ? `\n                <p>${escapeHtml(note.description)}</p>`
                : '';
            return `\n            <li>\n                <a href="${escapeHtml(note.href)}">${escapeHtml(note.title)}</a>${descriptionHtml}\n            </li>`;
        })
        .join('');

    return `\n<section class="doc-notes" aria-label="Additional notes">\n    <h2>Notes</h2>\n    <ul>${listItemsHtml}\n    </ul>\n</section>`;
};

const { slug } = Astro.params;
let title, html;

const docs = await Astro.glob('./md/*.md');

const doc = docs.find((doc) => doc.frontmatter.slug === slug);

if (doc) {
    let compiled = doc.compiledContent();

    if (slug === 'changelog') {
        const changelogEntries = await Astro.glob('./md/changelog/*.md');
        const latestHtml = buildLatestChangelogHtml(changelogEntries);
        compiled = compiled.replace('<!--LATEST_RELEASES-->', latestHtml);
    }

    html = fixMarkdownText(compiled);

    const notesHtml = buildNotesHtml(doc.frontmatter.notes, slug);
    if (notesHtml) {
        html = `${html}${notesHtml}`;
    }
    title = doc.frontmatter.title;
}

const slugString = typeof slug === 'string' ? slug : '';
const prettyDocName = slugString
    ? slugString
          .split('-')
          .filter(Boolean)
          .map((part) => part.charAt(0).toUpperCase() + part.slice(1))
          .join(' ')
    : 'Doc';
const docCtaTitle = `Write the ${prettyDocName} doc`;
const newDocUrl = slugString
    ? `https://github.com/democratizedspace/dspace/new/main/frontend/src/pages/docs/md/${slugString}.md`
    : 'https://github.com/democratizedspace/dspace/new/main/frontend/src/pages/docs/md';
---

{
    doc
    ?
    <div>
        <Page title={doc.frontmatter.title} columns="1">
            <div>
                <Chip text="Docs" href="/docs" />
                <span>-></span>
                <Chip text={title} href={`/docs/${slug}`} />
            </div>
            <span set:html={html} />
        </Page>
    </div>
     : 
    <div>
        <Page title="Doc not found" columns="1">
            <Chip text="Docs" href="/docs" />
            <Card
                title={docCtaTitle}
                body={`Should something exist here? Add a file on Github and submit a pull request.`}
                href={newDocUrl}
                image="/assets/quill.jpg"
                imageAlt="Quill pen on paper"
            />
        </Page>
    </div>
}

<style>
    span {
        background-color: white;
        color: black;
        padding: 10px;
        border-radius: 20px;
        overflow: auto;
    }

    .doc-notes {
        margin-top: 2rem;
        padding: 1.5rem;
        border-radius: 16px;
        background-color: #f5f6fb;
        border: 1px solid rgba(16, 24, 40, 0.08);
    }

    .doc-notes h2 {
        margin-top: 0;
        font-size: 1.2rem;
    }

    .doc-notes ul {
        list-style: none;
        margin: 0;
        padding: 0;
    }

    .doc-notes li + li {
        margin-top: 0.75rem;
    }

    .doc-notes a {
        font-weight: 600;
    }
</style>
