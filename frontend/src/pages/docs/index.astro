---
import Page from '../../components/Page.astro';
import DocsIndex from '../../components/svelte/DocsIndex.svelte';
import sections from './json/sections.json';
import { detectDocFeatures } from '../../utils/docsSearchFeatures.js';
import { stripMarkdownToText } from '../../lib/docs/fullTextSearch';

const docModules = await Astro.glob('./md/**/*.md');

const buildDocIndex = async () => {
    const entries = await Promise.all(
        docModules.map(async (doc) => {
            const slug = String(doc?.frontmatter?.slug ?? '').toLowerCase();

            if (!slug) {
                return null;
            }

            try {
                let content;

                if (typeof doc.rawContent === 'function') {
                    content = await doc.rawContent();
                } else if (typeof doc.compiledContent === 'function') {
                    content = await doc.compiledContent();
                } else {
                    throw new Error(`No content loader found for doc slug ${slug}`);
                }

                return [
                    slug,
                    {
                        features: detectDocFeatures(content),
                        bodyText: stripMarkdownToText(content),
                    },
                ];
            } catch (error) {
                console.error(`Failed to build doc search data for doc slug ${slug}`, error);

                if (import.meta.env?.DEV) {
                    throw error;
                }

                return [slug, { features: [], bodyText: '' }];
            }
        })
    );

    const filteredEntries = entries.filter((entry) => Array.isArray(entry));
    return new Map(filteredEntries);
};

const docSearchIndex = await buildDocIndex();
const questTreeModules = await Astro.glob('../quests/json/**/*.json');

const formatSkillLabel = (slug = '') =>
    slug
        .split('-')
        .map((part) => part.charAt(0).toUpperCase() + part.slice(1))
        .join(' ');

const buildSkillLinks = () => {
    const treeSlugs = new Set();

    for (const questTreeModule of questTreeModules) {
        const id = String(questTreeModule?.id ?? '');

        if (!id.includes('/quests/json/')) {
            continue;
        }

        const relativePath = id.split('/quests/json/')[1] ?? '';
        const treeSlug = relativePath.split('/')[0] ?? '';

        if (treeSlug) {
            treeSlugs.add(treeSlug);
        }
    }

    return [...treeSlugs].sort().map((treeSlug) => ({
        title: formatSkillLabel(treeSlug),
        href: `/docs/${treeSlug}`,
    }));
};

const skillLinks = buildSkillLinks();

const getSlugFromHref = (href = '') => {
    const clean = href.split('#')[0].split('?')[0];

    if (!clean.startsWith('/docs/')) {
        return '';
    }

    const trimmed = clean.replace(/^\/docs\//, '').replace(/\/?$/, '');
    return trimmed.toLowerCase();
};

const docsSections = sections.map((section) => {
    const links = section.title === 'Skills' ? skillLinks : section.links;

    return {
        title: section.title,
        links: links.map((link) => {
            const slug = getSlugFromHref(link.href);
            const docData = slug ? docSearchIndex.get(slug) ?? null : null;
            const features = docData?.features ?? [];
            const bodyText = docData?.bodyText ?? '';

            return { ...link, features, bodyText };
        }),
    };
});
---

<Page title="Docs">
    <DocsIndex sections={docsSections} client:load />
</Page>

<style>
    h2 {
        color: var(--color-heading);
    }

    a:hover {
        opacity: 1;
    }

    span {
        background-color: var(--color-surface);
        border-radius: 2rem;
        text-align: justify;
        text-justify: inter-word;
        text-align: center;
        padding: 1rem;
    }
    /* Navbar */

    nav {
        text-align: center;
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        padding: 0px;
    }

    nav a {
        opacity: 0.8;
        background-color: var(--color-pill-active);
        border-radius: 100px;
        color: var(--color-pill-active-text);
        text-decoration: none;
        flex-direction: row;
        padding-left: 5px;
        padding-right: 5px;
        text-align: center;
        white-space: nowrap;
        margin: 5px;
        padding: 10px;
    }

    nav a:hover {
        opacity: 1;
    }

    p {
        background-color: var(--color-surface);
        padding: 15px;
        border-radius: 2rem;
    }
</style>
