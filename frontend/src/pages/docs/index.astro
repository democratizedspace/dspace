<style>
    h2 {
        color: white;
    }

    a:hover {
        opacity: 1;
    }

    span {
        background-color: #2f5b2f;
        border-radius: 2rem;
        text-align: justify;
        text-justify: inter-word;
        text-align: center;
        padding: 1rem;
    }
    /* Navbar */

    nav {
        text-align: center;
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        padding: 0px;
    }

    nav a {
        opacity: 0.8;
        background-color: #84d484;
        border-radius: 100px;
        color: black;
        text-decoration: none;
        flex-direction: row;
        padding-left: 5px;
        padding-right: 5px;
        text-align: center;
        white-space: nowrap;
        margin: 5px;
        padding: 10px;
    }

    nav a:hover {
        opacity: 1;
    }

    p {
        background-color: #2f5b2f;
        padding: 15px;
        border-radius: 2rem;
    }
</style>
