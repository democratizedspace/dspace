---
import Page from '../../components/Page.astro';
import DocsIndex from '../../components/svelte/DocsIndex.svelte';
import sections from './json/sections.json';

/**
 * @typedef {{ hasLink?: boolean, hasImage?: boolean }} DocMetadata
 */

const normalizeHref = (href) => href.toLowerCase().split('#')[0].replace(/\/+$/, '');

const docs = await Astro.glob('./md/*.md');
const docsBySlug = new Map(
    docs
        .map((doc) => {
            const slug = doc && doc.frontmatter && doc.frontmatter.slug
                ? String(doc.frontmatter.slug).toLowerCase()
                : '';
            return [slug, doc];
        })
        .filter(([slug]) => Boolean(slug))
);

const metadataEntries = sections.flatMap((section) =>
    section.links.map(async (link) => {
        if (!link.href.startsWith('/docs/')) {
            return null;
        }

        const normalizedHref = normalizeHref(link.href);
        const slug = normalizedHref.replace(/^\/docs\//, '');
        const doc = docsBySlug.get(slug);

        if (!doc) {
            return null;
        }

        const compiled = await doc.compiledContent();

        return [
            normalizedHref,
            {
                hasLink: compiled.includes('<a '),
                hasImage: /<img\s/i.test(compiled),
            },
        ];
    })
);

/** @type {Record<string, DocMetadata>} */
const metadata = Object.fromEntries(
    (await Promise.all(metadataEntries)).filter((entry) => Array.isArray(entry))
);

const docsSections = sections;

---

<Page title="Docs">
    <DocsIndex sections={docsSections} metadata={metadata} client:load />
</Page>

<style>
    h2 {
        color: var(--color-heading);
    }

    a:hover {
        opacity: 1;
    }

    span {
        background-color: var(--color-surface);
        border-radius: 2rem;
        text-align: justify;
        text-justify: inter-word;
        text-align: center;
        padding: 1rem;
    }
    /* Navbar */

    nav {
        text-align: center;
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        padding: 0px;
    }

    nav a {
        opacity: 0.8;
        background-color: var(--color-pill-active);
        border-radius: 100px;
        color: var(--color-pill-active-text);
        text-decoration: none;
        flex-direction: row;
        padding-left: 5px;
        padding-right: 5px;
        text-align: center;
        white-space: nowrap;
        margin: 5px;
        padding: 10px;
    }

    nav a:hover {
        opacity: 1;
    }

    p {
        background-color: var(--color-surface);
        padding: 15px;
        border-radius: 2rem;
    }
</style>
