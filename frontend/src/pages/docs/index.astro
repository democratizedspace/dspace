---
import Page from '../../components/Page.astro';
import DocsIndex from '../../components/svelte/DocsIndex.svelte';
import sections from './json/sections.json';
import { detectDocFeatures } from '../../utils/docsSearchFeatures.js';
import { getQuestTreesFromModulePaths, mergeSkillLinks } from '../../utils/docsSkillsIndex.js';

const docModules = await Astro.glob('./md/**/*.md');

const buildDocIndex = async () => {
    const entries = await Promise.all(
        docModules.map(async (doc) => {
            const slug = String(doc?.frontmatter?.slug ?? '').toLowerCase();

            if (!slug) {
                return null;
            }

            try {
                let content;

                if (typeof doc.rawContent === 'function') {
                    content = await doc.rawContent();
                } else if (typeof doc.compiledContent === 'function') {
                    content = await doc.compiledContent();
                } else {
                    throw new Error(`No content loader found for doc slug ${slug}`);
                }

                return [
                    slug,
                    {
                        features: detectDocFeatures(content),
                    },
                ];
            } catch (error) {
                console.error(`Failed to build doc search data for doc slug ${slug}`, error);

                if (import.meta.env?.DEV) {
                    throw error;
                }

                return [slug, { features: [] }];
            }
        })
    );

    const filteredEntries = entries.filter((entry) => Array.isArray(entry));
    return new Map(filteredEntries);
};

const docSearchIndex = await buildDocIndex();
const questTreeModules = Object.keys(import.meta.glob('../quests/json/*/*.json'));

const TITLE_OVERRIDES = {
    '3dprinting': '3D Printing',
    ubi: 'UBI',
    devops: 'DevOps',
    firstaid: 'First Aid',
};

const SKILL_SLUG_TREE_ALIASES = {
    'chemistry-lab': 'chemistry',
    'energy-systems': 'energy',
    'first-aid': 'firstaid',
    rockets: 'rocketry',
    'sysadmin-devops': 'sysadmin',
};

const toTitleCase = (value = '') =>
    value
        .split(/[-_\s]+/)
        .filter(Boolean)
        .map((segment) => {
            if (/^\d/.test(segment)) {
                return segment.toUpperCase();
            }

            return segment.charAt(0).toUpperCase() + segment.slice(1);
        })
        .join(' ');

const questSkillLinks = getQuestTreesFromModulePaths(questTreeModules).map((tree) => {
        const href = `/docs/${tree}`;
        const docData = docSearchIndex.get(tree) ?? null;
        const missingDoc = !docData;
        const features = docData?.features ?? [];

        if (missingDoc) {
            console.warn(`Quest tree '${tree}' is missing matching docs page at ${href}`);
        }

        return {
            title: TITLE_OVERRIDES[tree] ?? toTitleCase(tree),
            href,
            slug: tree,
            keywords: missingDoc ? [tree, 'missing-doc'] : [tree],
            features,
        };
    });

const getSlugFromHref = (href = '') => {
    const clean = href.split('#')[0].split('?')[0];

    if (!clean.startsWith('/docs/')) {
        return '';
    }

    const trimmed = clean.replace(/^\/docs\//, '').replace(/\/?$/, '');
    return trimmed.toLowerCase();
};

const docsSections = sections.map((section) => ({
    title: section.title,
    links: section.links.map((link) => {
        const slug = getSlugFromHref(link.href);
        const docData = slug ? docSearchIndex.get(slug) ?? null : null;
        const features = docData?.features ?? [];

        return { ...link, slug, features };
    }),
}));

const docsSectionsWithAllSkills = docsSections.map((section) => {
    if (section.title !== 'Skills') {
        return section;
    }

    return {
        ...section,
        links: mergeSkillLinks({
            curatedLinks: section.links,
            generatedLinks: questSkillLinks,
            aliases: SKILL_SLUG_TREE_ALIASES,
        }),
    };
});
---

<Page title="Docs">
    <DocsIndex
        sections={docsSectionsWithAllSkills}
        fullTextCorpusUrl="/docs/json/fullTextCorpus.json"
        client:load
    />
</Page>

<style>
    h2 {
        color: var(--color-heading);
    }

    a:hover {
        opacity: 1;
    }

    span {
        background-color: var(--color-surface);
        border-radius: 2rem;
        text-align: justify;
        text-justify: inter-word;
        text-align: center;
        padding: 1rem;
    }
    /* Navbar */

    nav {
        text-align: center;
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        padding: 0px;
    }

    nav a {
        opacity: 0.8;
        background-color: var(--color-pill-active);
        border-radius: 100px;
        color: var(--color-pill-active-text);
        text-decoration: none;
        flex-direction: row;
        padding-left: 5px;
        padding-right: 5px;
        text-align: center;
        white-space: nowrap;
        margin: 5px;
        padding: 10px;
    }

    nav a:hover {
        opacity: 1;
    }

    p {
        background-color: var(--color-surface);
        padding: 15px;
        border-radius: 2rem;
    }
</style>
