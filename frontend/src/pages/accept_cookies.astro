---
import Page from '../components/Page.astro';
import Card from '../components/Card.astro';

const redirect = Astro.url.searchParams.get('redirect');
const returnUrl = redirect ?? '/';
---

<Page
    hideHome={true}
    hideSettings={true}
    hideQuests={true}
    message="Progress now saves in your browser storage—no cookies required."
>
    <Card href={returnUrl} title="Return" body="Go back to where you left off." />
</Page>
