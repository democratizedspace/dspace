---
import Page from '../../../components/Page.astro';
import QuestGraphVisualizer from '../../../components/quests/QuestGraphVisualizer.svelte';
import { buildQuestGraph, type QuestData } from '../../../lib/quests/questGraph';

const questData: QuestData[] = [
    {
        path: './json/welcome/howtodoquests.json',
        quest: { title: 'Fixture Root Quest' },
    },
    {
        path: './json/fixtures/parent.json',
        quest: {
            title: 'Fixture Parent Quest',
            requiresQuests: ['welcome/howtodoquests.json'],
        },
    },
    {
        path: './json/fixtures/child.json',
        quest: { title: 'Fixture Child Quest', requiresQuests: ['fixtures/parent.json'] },
    },
    {
        path: './json/fixtures/grandchild.json',
        quest: { title: 'Fixture Grandchild Quest', requiresQuests: ['fixtures/child.json'] },
    },
];

const graph = buildQuestGraph({ quests: questData });
---

<Page title="Quest Graph Fixture: Ancestor Highlights">
    <p>
        This fixture renders a small quest graph for validating ancestor and descendant highlighting
        behaviors.
    </p>
    <QuestGraphVisualizer client:visible graph={graph} />
</Page>
