                    "text": "I already practiced—start quiz"
                }
            ]
        },
        {
            "id": "scan",
            "text": "Export the latest 200 lines for a service with `journalctl -u <service> -n 200` and grab a rolling tail report with `tail -n 100 /var/log/syslog`.",
            "options": [
                {
                    "type": "process",
                    "process": "sysadmin-export-journalctl-report",
                    "text": "Export journalctl report"
                },
                {
                    "type": "process",
