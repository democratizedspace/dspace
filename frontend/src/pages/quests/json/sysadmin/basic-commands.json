        {
            "id": "quiz-2",
            "text": "Which command lists files, including hidden ones, in long format?",
            "options": [
                {
                    "type": "goto",
                    "goto": "quiz-3",
                    "text": "ls -la"
                },
                {
                    "type": "goto",
                    "goto": "retry-2",
                    "text": "cd -la"
                },
                {
                    "type": "goto",
                    "goto": "retry-2",
                    "text": "mkdir -la"
