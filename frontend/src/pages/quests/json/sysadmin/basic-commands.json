    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Ubuntu 24.04 LTS Minimal is rock solid in 2030. Ready to run the command line like a mission operator?",
            "options": [
                {
                    "type": "goto",
                    "goto": "briefing",
                    "text": "Show me the command mission"
                }
            ]
        },
        {
            "id": "briefing",
            "text": "You'll practice navigation and text tooling with `pwd`, `ls`, `cd`, `grep`, `awk`, and `sed`. We will capture outputs so your future self can audit what happened.",
            "options": [
                {
                    "type": "process",
                    "process": "sysadmin-capture-shell-transcript",
                    "text": "Run command drill and generate commands-output.txt"
                },
                {
                    "type": "process",
                    "process": "sysadmin-build-command-cheatsheet",
                    "text": "Summarize grep/awk/sed findings into command-cheatsheet.md"
                },
                {
                    "type": "goto",
                    "goto": "quiz-1",
                    "text": "Artifacts captured\u2014start quiz",
                    "requiresItems": [
                        {
                            "id": "5ed5047d-54fc-4dd7-abb5-7d8d6423ba45",
                            "count": 1
                        },
                        {
                            "id": "92b24135-d667-40be-9684-d2a9e9c3bcf2",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "quiz-1",
            "text": "Quiz 1/5: Which command prints your current working directory?",
            "options": [
                {
                    "type": "goto",
                    "goto": "quiz-2",
                    "text": "pwd"
                },
                {
                    "type": "goto",
                    "goto": "retry-quiz",
                    "text": "ls"
                },
                {
                    "type": "goto",
                    "goto": "retry-quiz",
                    "text": "cd"
                }
            ]
        },
        {
            "id": "quiz-2",
            "text": "Quiz 2/5: You need to list files including hidden dotfiles. Which command works?",
            "options": [
                {
                    "type": "goto",
                    "goto": "quiz-3",
                    "text": "ls -la"
                },
                {
                    "type": "goto",
                    "goto": "retry-quiz",
                    "text": "cat ."
                },
                {
                    "type": "goto",
                    "goto": "retry-quiz",
                    "text": "pwd -h"
                }
            ]
        },
        {
            "id": "quiz-3",
            "text": "Quiz 3/5: Which command searches `/var/log/syslog` for lines containing `ERROR`?",
            "options": [
                {
                    "type": "goto",
                    "goto": "quiz-4",
                    "text": "grep 'ERROR' /var/log/syslog"
                },
                {
                    "type": "goto",
                    "goto": "retry-quiz",
                    "text": "sed '/ERROR/' /var/log/syslog"
                },
                {
                    "type": "goto",
                    "goto": "retry-quiz",
                    "text": "cd ERROR /var/log/syslog"
                }
            ]
        },
        {
            "id": "quiz-4",
            "text": "Quiz 4/5: Which command replaces every `localhost` with `mission-node` in `config.txt` and writes the result to `config-new.txt`?",
            "options": [
                {
                    "type": "goto",
                    "goto": "quiz-5",
                    "text": "sed 's/localhost/mission-node/g' config.txt > config-new.txt"
                },
                {
                    "type": "goto",
                    "goto": "retry-quiz",
                    "text": "awk localhost mission-node config.txt"
                },
                {
                    "type": "goto",
                    "goto": "retry-quiz",
                    "text": "grep -v localhost config.txt > config-new.txt"
                }
            ]
        },
        {
            "id": "quiz-5",
            "text": "Quiz 5/5: Which awk program prints only the first and third columns from `metrics.txt`?",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "awk '{print $1, $3}' metrics.txt"
                },
                {
                    "type": "goto",
                    "goto": "retry-quiz",
                    "text": "awk 'print(1,3)' metrics.txt"
                },
                {
                    "type": "goto",
                    "goto": "retry-quiz",
                    "text": "grep '$1 $3' metrics.txt"
                }
            ]
        },
        {
            "id": "retry-quiz",
            "text": "Close, but not yet. Review the command drill outputs, then retake the quiz when you're ready.",
            "options": [
                {
                    "type": "goto",
                    "goto": "briefing",
                    "text": "Retry from command briefing"
                }
            ]
        },
        {
            "id": "finish",
            "text": "Excellent work. You produced auditable command artifacts and proved you can wield the essentials under pressure.",
