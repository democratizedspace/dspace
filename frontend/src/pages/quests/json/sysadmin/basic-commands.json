{
    "id": "sysadmin/basic-commands",
    "title": "Learn Basic Linux Commands",
    "description": "Practice core shell commands and produce auditable artifacts on an Ubuntu 24.04 LTS node.",
    "image": "/assets/quests/linux_basic_shell_commands.jpg",
