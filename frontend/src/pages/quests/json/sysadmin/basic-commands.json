        {
            "id": "quiz-1",
            "text": "Which command prints your current working directory?",
            "options": [
                {
                    "type": "goto",
                    "goto": "quiz-2",
                    "text": "pwd"
                },
                {
                    "type": "goto",
                    "goto": "retry-1",
                    "text": "ps"
                },
                {
                    "type": "goto",
                    "goto": "retry-1",
                    "text": "df"
                }
