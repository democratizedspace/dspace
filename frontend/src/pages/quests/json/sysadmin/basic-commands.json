                    "text": "Let's begin command drills"
                }
            ]
        },
        {
            "id": "prep",
            "text": "Run this first process to generate a shell transcript file (for example: commands-output.txt with pwd, ls -la, grep, awk, and sed examples).",
            "options": [
                {
                    "type": "process",
                    "process": "sysadmin-basic-generate-shell-transcript",
                    "text": "Create shell transcript artifact"
