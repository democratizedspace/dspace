{
    "id": "hydroponics/nutrient-check",
    "title": "Refresh Nutrient Solution",
    "description": "Top off your hydroponic tub with fresh nutrients while keeping yourself and the plants safe.",
    "image": "/assets/quests/hydroponics_nutrient_solution_refresh.jpg",
    "npc": "/assets/npc/hydro.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Plants quickly deplete minerals in recirculating systems. We'll top off the reservoir so your basil stays strong and avoids nutrient deficiencies.",
            "options": [
                {
                    "type": "goto",
                    "goto": "add",
                    "text": "Sounds good!"
                }
            ]
        },
        {
            "id": "add",
            "text": "Slip on nitrile gloves and safety goggles. Use a 50 mL syringe to measure the manufacturer-recommended dose of hydroponic nutrient solution, dissolve it in a bucket of clean water, then slowly pour it into the reservoir. Keep the submersible water pump running so the solution mixes evenly, wipe up any splashes immediately, and dip a pH strip to confirm the solution is between 5.5 and 6.5.",
            "options": [
                {
                    "type": "process",
                    "process": "refresh-hydroponic-tub",
                    "text": "Mix and circulate."
                },
                {
                    "type": "process",
                    "process": "measure-ec-solution",
                    "text": "Check EC levels."
                },
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Reservoir topped off!",
                    "requiresItems": [
                        {
                            "id": "fc2bb989-f192-4891-8bde-78ae631dae78",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "finish",
            "text": "Great! Mark today's date on the tub, monitor the water level every few days, rinse your measuring tools, wash your hands after mixing, and store nutrients safely away from kids and pets.",
            "options": [
                {
                    "type": "finish",
                    "text": "Thanks!"
                }
            ]
        }
    ],
    "rewards": [
        {
            "id": "978ce094-f4fa-4b55-9e1a-2ea76531989d",
            "count": 1
        }
    ],
    "requiresQuests": ["hydroponics/basil"],
