{
    "id": "hydroponics/pump-install",
    "title": "Install Submersible Pump",
    "description": "Install and validate a reservoir pump loop so nutrients circulate evenly.",
    "image": "/assets/quests/hydroponics_submersible_pump_install.jpg",
    "npc": "/assets/npc/hydro.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Stagnant reservoirs drift fast. We'll install the pump, verify circulation, and keep a rollback path if startup misbehaves.",
            "options": [
                {
                    "type": "goto",
                    "goto": "kit",
                    "text": "Start install workflow."
                }
            ]
        },
        {
            "id": "kit",
            "text": "Gather the pump, ready reservoir, and PPE. Confirm cords stay above splash lines before powering anything.",
            "options": [
                {
                    "type": "goto",
                    "goto": "install",
                    "text": "Kit is assembled and power path is safe.",
                    "requiresItems": [
                        {
                            "id": "584ca717-4ce1-4ca1-bcd3-38272a52768a",
                            "count": 1
                        },
                        {
                            "id": "fc2bb989-f192-4891-8bde-78ae631dae78",
                            "count": 1
                        },
                        {
                            "id": "997eaba9-25ee-43d5-bbdc-5d6adf03adfa",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "install",
            "text": "Seat the pump, route tubing, and secure return flow so the bed doesn't splash or run dry at startup.",
            "options": [
                {
                    "type": "process",
                    "process": "install-submersible-pump",
                    "text": "Install pump assembly"
                },
                {
                    "type": "goto",
                    "goto": "verify",
                    "text": "Installation complete; begin verification.",
                    "requiresItems": [
                        {
                            "id": "4b09d8a3-5dd3-44b8-9fd7-89cc34a34076",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "verify",
            "text": "Run a flow verification window. Pass criteria: stable circulation and no cavitation pulses.",
            "options": [
                {
                    "type": "process",
                    "process": "verify-hydroponic-flow",
                    "text": "Run circulation verification"
                },
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Verification passed; lock in the install.",
                    "requiresItems": [
                        {
                            "id": "bd215e1e-5477-4b2f-8420-0227180a3531",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "rollback",
                    "text": "Flow is unstable or cavitating"
                }
            ]
        },
        {
            "id": "rollback",
            "text": "Rollback branch: power down, reseat intake depth, and check for tubing kinks before restarting. Do not leave the pump dry-running.",
            "options": [
                {
                    "type": "goto",
                    "goto": "install",
                    "text": "Reconfigure and reinstall for another verification pass."
                }
            ]
        },
        {
            "id": "finish",
            "text": "Pump loop commissioned with verification evidence and a documented recovery path.",
            "options": [
                {
                    "type": "finish",
                    "text": "Install complete."
                }
            ]
        }
    ],
