{
    "id": "hydroponics/pump-install",
    "title": "Install Submersible Pump",
    "description": "Install a reservoir pump loop, verify circulation, and recover safely when commissioning fails.",
    "image": "/assets/quests/hydroponics_submersible_pump_install.jpg",
    "npc": "/assets/npc/hydro.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Stagnant reservoirs drift fast. We'll run a full install -> verify -> rollback-ready commissioning sequence.",
            "options": [
                {
                    "type": "goto",
                    "goto": "kit",
                    "text": "Let's commission the loop."
                }
            ]
        },
        {
            "id": "kit",
            "text": "Assemble the pump, ready reservoir, and PPE before wiring anything. Keep hands dry while routing power.",
            "options": [
                {
                    "type": "goto",
                    "goto": "install",
                    "text": "Kit is assembled.",
                    "requiresItems": [
                        {
                            "id": "584ca717-4ce1-4ca1-bcd3-38272a52768a",
                            "count": 1
                        },
                        {
                            "id": "fc2bb989-f192-4891-8bde-78ae631dae78",
                            "count": 1
                        },
                        {
                            "id": "997eaba9-25ee-43d5-bbdc-5d6adf03adfa",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "install",
            "text": "Seat the pump, route return tubing above the waterline, and secure fittings so siphon-back can't flood your floor.",
            "options": [
                {
                    "type": "process",
                    "process": "install-submersible-pump",
                    "text": "Install pump assembly."
                },
                {
                    "type": "goto",
                    "goto": "verify",
                    "text": "Pump is physically installed.",
                    "requiresItems": [
                        {
                            "id": "4b09d8a3-5dd3-44b8-9fd7-89cc34a34076",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "verify",
            "text": "Run a 15 minute flow check. Pass criteria: no cavitation noise, no dry channels, and stable return flow.",
            "options": [
                {
                    "type": "process",
                    "process": "verify-hydroponic-flow",
                    "text": "Run flow verification."
                },
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Verification passed all checks.",
                    "requiresItems": [
                        {
                            "id": "bd215e1e-5477-4b2f-8420-0227180a3531",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "rollback",
                    "text": "Verification failed (noise, dry spot, or leak).",
                    "requiresItems": [
                        {
                            "id": "4b09d8a3-5dd3-44b8-9fd7-89cc34a34076",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "rollback",
            "text": "Recovery protocol: power down, reseat the impeller, clear intake debris, and re-clamp tubing before re-verify. Do not leave the pump running dry.",
            "options": [
                {
                    "type": "goto",
                    "goto": "verify",
                    "text": "Rollback complete; re-run verification.",
                    "requiresItems": [
                        {
                            "id": "4b09d8a3-5dd3-44b8-9fd7-89cc34a34076",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "install",
                    "text": "Rebuild tubing route and try install again."
                }
            ]
        },
        {
            "id": "finish",
            "text": "Commissioned. Log this flow baseline so future drift is obvious.",
            "options": [
                {
                    "type": "finish",
                    "text": "Pump loop commissioned."
                }
            ]
        }
    ],
    "rewards": [
        {
            "id": "b281360b-2ecc-4fea-a248-36a61c5f7399",
            "count": 1
        }
    ],
    "requiresQuests": ["hydroponics/reservoir-refresh"],
    "hardening": {
        "passes": 0,
        "score": 90,
        "emoji": "🛠️",
        "history": []
    }
}
