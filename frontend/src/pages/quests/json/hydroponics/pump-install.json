{
    "id": "hydroponics/pump-install",
    "title": "Install Submersible Pump",
    "description": "Install the pump, verify circulation, and exercise rollback/recovery before sign-off.",
    "image": "/assets/quests/hydroponics_submersible_pump_install.jpg",
    "npc": "/assets/npc/hydro.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Stagnant reservoirs drift fast. We are doing this as install -> verify -> rollback-safe recovery so you can trust the loop.",
            "options": [
                {
                    "type": "goto",
                    "goto": "kit",
                    "text": "Begin install sequence."
                }
            ]
        },
        {
            "id": "kit",
            "text": "Gather pump, clean tub, and PPE. Water + electricity means we do safety checks first.",
            "options": [
                {
                    "type": "goto",
                    "goto": "install",
                    "text": "Kit complete and breaker route identified.",
                    "requiresItems": [
                        {
                            "id": "584ca717-4ce1-4ca1-bcd3-38272a52768a",
                            "count": 1
                        },
                        {
                            "id": "fc2bb989-f192-4891-8bde-78ae631dae78",
                            "count": 1
                        },
                        {
                            "id": "997eaba9-25ee-43d5-bbdc-5d6adf03adfa",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "install",
            "text": "Seat pump below waterline, route tubing, and add a drip loop so cords cannot wick water into outlets.",
            "options": [
                {
                    "type": "process",
                    "process": "install-submersible-pump",
                    "text": "Execute physical install."
                },
                {
                    "type": "goto",
                    "goto": "verify",
                    "text": "Hardware installed.",
                    "requiresItems": [
                        {
                            "id": "4b09d8a3-5dd3-44b8-9fd7-89cc34a34076",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "rollback",
                    "text": "I detected unsafe routing or loose fittings."
                }
            ]
        },
        {
            "id": "verify",
            "text": "Run circulation test and check for steady flow, no cavitation, and no spray near electrical points.",
            "options": [
                {
                    "type": "process",
                    "process": "verify-hydroponic-flow",
                    "text": "Run verification test."
                },
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Verification artifact captured: stable flow.",
                    "requiresItems": [
                        {
                            "id": "bd215e1e-5477-4b2f-8420-0227180a3531",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "rollback",
                    "text": "Verification failed or pump ran dry."
                }
            ]
        },
        {
            "id": "rollback",
            "text": "Rollback path: power down, isolate the pump, dry connectors, and inspect intake for blockage before retry.",
            "options": [
                {
                    "type": "goto",
                    "goto": "reverify",
                    "text": "Rollback complete; ready for controlled retry."
                }
            ]
        },
        {
            "id": "reverify",
            "text": "Re-entry checkpoint: confirm reservoir level and prime status before restoring power.",
            "options": [
                {
                    "type": "process",
                    "process": "verify-hydroponic-flow",
                    "text": "Re-verify after rollback."
                },
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Re-verify passed with stable circulation.",
                    "requiresItems": [
                        {
                            "id": "bd215e1e-5477-4b2f-8420-0227180a3531",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "install",
                    "text": "Still failing; return to install adjustments."
                }
            ]
        },
        {
            "id": "finish",
            "text": "Commissioned. You proved the install and practiced a safe recovery path.",
            "options": [
                {
                    "type": "finish",
                    "text": "Pump loop signed off."
                }
            ]
        }
    ],
    "rewards": [
        {
            "id": "b281360b-2ecc-4fea-a248-36a61c5f7399",
            "count": 1
        }
    ],
    "requiresQuests": ["hydroponics/reservoir-refresh"],
