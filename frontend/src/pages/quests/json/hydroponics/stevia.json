{
    "id": "hydroponics/stevia",
    "title": "Grow Stevia Hydroponically",
    "description": "Grow stevia through staged setup and outcome evidence, with stress recovery checkpoints.",
    "image": "/assets/quests/hydroponic_stevia_starter_tub.jpg",
    "npc": "/assets/npc/hydro.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Stevia is forgiving if we run it in stages. We will prove setup first, then outcome.",
            "options": [
                {
                    "type": "goto",
                    "goto": "setup",
                    "text": "Start staged grow plan."
                }
            ]
        },
        {
            "id": "setup",
            "text": "Soak plugs, sow seeds, and keep a gentle light cycle with humidity cover. Record your setup before waiting.",
            "options": [
                {
                    "type": "process",
                    "process": "germinate-stevia",
                    "text": "Run germination setup."
                },
                {
                    "type": "goto",
                    "goto": "monitor",
                    "text": "Setup artifact ready: seedlings established.",
                    "requiresItems": [
                        {
                            "id": "9b440191-a8be-497c-8b5a-7bbac559413b",
                            "count": 10
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "stress",
                    "text": "Germination is uneven or damping-off appears."
                }
            ]
        },
        {
            "id": "monitor",
            "text": "Transplant to the tub and run the full growth cycle. Watch for wilt, nutrient burn, and light stress.",
            "options": [
                {
                    "type": "process",
                    "process": "grow-stevia",
                    "text": "Run grow-out cycle."
                },
                {
                    "type": "goto",
                    "goto": "outcome",
                    "text": "Outcome artifact ready: harvestable plants present.",
                    "requiresItems": [
                        {
                            "id": "ec5013d0-0701-4ba2-8fcf-7a5797c718b4",
                            "count": 10
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "stress",
                    "text": "Plants show stress signals."
                }
            ]
        },
        {
            "id": "stress",
            "text": "Stress branch: pause feeding changes, verify pH/EC, and trim damaged material before resuming.",
            "options": [
                {
                    "type": "goto",
                    "goto": "setup",
                    "text": "Restart from setup controls."
                },
                {
                    "type": "goto",
                    "goto": "monitor",
                    "text": "Conditions stabilized; resume grow monitoring."
                }
            ]
        },
        {
            "id": "outcome",
            "text": "Harvest leaves and confirm regrowth potential so this is a repeatable production cycle.",
            "options": [
                {
                    "type": "process",
                    "process": "harvest-stevia",
                    "text": "Harvest and stage regrowth."
                },
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Harvest complete and regrowth plan logged."
                }
            ]
        },
        {
            "id": "finish",
            "text": "Sweet run. You validated both setup and outcome with a recovery playbook for setbacks.",
            "options": [
                {
                    "type": "finish",
                    "text": "Stevia cycle complete."
                }
            ]
        }
    ],
    "rewards": [
        {
            "id": "b281360b-2ecc-4fea-a248-36a61c5f7399",
            "count": 1
        }
    ],
    "requiresQuests": ["hydroponics/lettuce"],
