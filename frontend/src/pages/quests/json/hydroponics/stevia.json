{
    "id": "hydroponics/stevia",
    "title": "Grow Stevia Hydroponically",
    "description": "Cultivate stevia plants for a natural sweetener.",
    "image": "/assets/quests/hydroponic_stevia_starter_tub.jpg",
    "npc": "/assets/npc/hydro.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Hydro here. Stevia rewards consistency, so we will stage setup proof, then outcome proof, and keep a stress branch ready.",
            "options": [
                {
                    "type": "goto",
                    "goto": "setup",
                    "text": "Let's run the stevia grow plan."
                }
            ]
        },
        {
            "id": "setup",
            "text": "Prep clean plugs, dechlorinated water, and seed stock before germination. Good setup prevents damping-off later.",
            "options": [
                {
                    "type": "process",
                    "process": "germinate-stevia",
                    "text": "Start germination batch."
                },
                {
                    "type": "goto",
                    "goto": "transfer",
                    "text": "Seedlings are healthy and setup artifact is ready.",
                    "requiresItems": [
                        {
                            "id": "9b440191-a8be-497c-8b5a-7bbac559413b",
                            "count": 10
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "stress",
                    "text": "Seedlings are leggy, moldy, or not germinating evenly."
                }
            ]
        },
        {
            "id": "transfer",
            "text": "Move healthy seedlings into a ready tub with stable light schedule. Verify circulation and nutrient rhythm before long grow run.",
            "options": [
                {
                    "type": "process",
                    "process": "grow-stevia",
                    "text": "Run full grow cycle."
                },
                {
                    "type": "goto",
                    "goto": "harvest",
                    "text": "Outcome artifact ready: harvestable stevia plants.",
                    "requiresItems": [
                        {
                            "id": "ec5013d0-0701-4ba2-8fcf-7a5797c718b4",
                            "count": 10
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "stress",
                    "text": "Wilting, algae bloom, or nutrient burn showed up mid-cycle."
                }
            ]
        },
        {
            "id": "stress",
            "text": "Contingency path: pause feed adjustments, verify pump flow and pH, trim damaged growth, then resume from the most recent stable stage.",
            "options": [
                {
                    "type": "goto",
                    "goto": "setup",
                    "text": "Restart from setup with fresh plugs and seeds."
                },
                {
                    "type": "goto",
                    "goto": "transfer",
                    "text": "System stabilized; resume grow-out.",
                    "requiresItems": [
                        {
                            "id": "9b440191-a8be-497c-8b5a-7bbac559413b",
                            "count": 10
                        }
                    ]
                }
            ]
        },
        {
            "id": "harvest",
            "text": "Harvest only after confirming plant vigor and clean leaves. This closes the loop from setup evidence to output evidence.",
            "options": [
                {
                    "type": "process",
                    "process": "harvest-stevia",
                    "text": "Harvest stevia leaves."
                },
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Harvest complete and quality checks pass.",
                    "requiresItems": [
                        {
                            "id": "c5d9469f-9e86-40c7-8b98-14b8b4ae91ae",
                            "count": 10
                        }
                    ]
                }
            ]
        },
        {
            "id": "finish",
            "text": "Sweet run. You proved setup quality, navigated stress handling, and delivered a verified harvest.",
            "options": [
                {
                    "type": "finish",
                    "text": "Stevia cycle closed with evidence."
                }
            ]
        }
    ],
    "rewards": [
        {
            "id": "b281360b-2ecc-4fea-a248-36a61c5f7399",
            "count": 1
        }
    ],
