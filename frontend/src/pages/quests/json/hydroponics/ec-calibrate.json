{
    "id": "hydroponics/ec-calibrate",
    "title": "Calibrate EC Meter",
    "description": "Calibrate, verify with a logged reading, and loop through correction when drift remains out of range.",
    "image": "/assets/quests/hydroponic_ec_meter_calibration.jpg",
    "npc": "/assets/npc/hydro.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "An accurate EC meter keeps nutrient calls defensible. We'll calibrate, capture evidence, interpret it, and only close when the band is stable.",
            "options": [
                {
                    "type": "goto",
                    "goto": "prep",
                    "text": "Run the full calibration protocol."
                }
            ]
        },
        {
            "id": "prep",
            "text": "Prep check: rinse probe with clean water, blot dry, and verify fresh 1000 ppm solution. Skip contaminated cups and stale solution.",
            "options": [
                {
                    "type": "goto",
                    "goto": "calibrate",
                    "text": "Probe and solution are ready.",
                    "requiresItems": [
                        {
                            "id": "71655665-4a59-41f4-9084-dad4d976df91",
                            "count": 1
                        },
                        {
                            "id": "d3d8bb59-8364-46b2-ad42-c5f56cc72b40",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "troubleshoot",
                    "text": "Probe is dirty or solution quality is questionable."
                }
            ]
        },
        {
            "id": "calibrate",
            "text": "Run calibration to 1000 ppm, then immediately capture a reservoir reading log as evidence. Calibration without a post-check is not complete.",
            "options": [
                {
                    "type": "process",
                    "process": "calibrate-ec-meter",
                    "text": "Calibrate to 1000 ppm.",
                    "requiresItems": [
                        {
                            "id": "71655665-4a59-41f4-9084-dad4d976df91",
                            "count": 1
                        },
                        {
                            "id": "d3d8bb59-8364-46b2-ad42-c5f56cc72b40",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "process",
                    "process": "measure-ec-solution",
                    "text": "Capture post-calibration EC log.",
                    "requiresItems": [
                        {
                            "id": "71655665-4a59-41f4-9084-dad4d976df91",
                            "count": 1
                        },
                        {
                            "id": "fc2bb989-f192-4891-8bde-78ae631dae78",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "interpret",
                    "text": "Log captured; interpret against the acceptance band.",
                    "requiresItems": [
                        {
                            "id": "bc979305-53ef-4be8-9d21-c59e3bfa7f06",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "interpret",
            "text": "Interpretation gate: if the post-calibration check is within your crop band (typically 1.2-1.8 mS/cm), close. If readings drift or bounce outside band, troubleshoot and re-test.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Reading is in range and stable.",
                    "requiresItems": [
                        {
                            "id": "bc979305-53ef-4be8-9d21-c59e3bfa7f06",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "troubleshoot",
                    "text": "Reading is out of range or unstable; run corrective branch.",
                    "requiresItems": [
                        {
                            "id": "bc979305-53ef-4be8-9d21-c59e3bfa7f06",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "troubleshoot",
            "text": "Troubleshooting branch: clean probe tip, remix fresh calibration solution, and avoid touching electrodes. Recalibrate and re-log before any finish attempt.",
            "options": [
                {
                    "type": "goto",
                    "goto": "calibrate",
                    "text": "Corrective actions done; recalibrate and re-test."
                }
            ]
        },
        {
            "id": "finish",
            "text": "Calibration closed with evidence: post-calibration EC log interpreted and confirmed in range.",
            "options": [
                {
                    "type": "finish",
                    "text": "Meter verified and ready."
                }
            ]
        }
    ],
