{
    "id": "hydroponics/ec-calibrate",
    "title": "Calibrate EC Meter",
    "description": "Use calibration solution so readings stay accurate.",
    "image": "/assets/quests/hydroponic_ec_meter_calibration.jpg",
    "npc": "/assets/npc/hydro.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "An accurate EC meter keeps nutrient calls honest. We run baseline measurement, calibration, then verification before this quest can close.",
            "options": [
                {
                    "type": "goto",
                    "goto": "prep",
                    "text": "Run the calibration workflow."
                }
            ]
        },
        {
            "id": "prep",
            "text": "Safety and handling first: rinse the probe, keep the cap solution clean, and never calibrate with a dry or crusted sensor.",
            "options": [
                {
                    "type": "goto",
                    "goto": "baseline",
                    "text": "Probe rinsed and solution staged.",
                    "requiresItems": [
                        {
                            "id": "71655665-4a59-41f4-9084-dad4d976df91",
                            "count": 1
                        },
                        {
                            "id": "d3d8bb59-8364-46b2-ad42-c5f56cc72b40",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "baseline",
            "text": "Capture a pre-calibration EC reading and note it. Then verify with a post-calibration log artifact before this quest can close.",
            "options": [
                {
                    "type": "process",
                    "process": "measure-ec",
                    "text": "Record baseline EC reading.",
                    "requiresItems": [
                        {
                            "id": "71655665-4a59-41f4-9084-dad4d976df91",
                            "count": 1
                        },
                        {
                            "id": "fc2bb989-f192-4891-8bde-78ae631dae78",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "calibrate",
                    "text": "Baseline logged; continue to calibration."
                }
            ]
        },
        {
            "id": "calibrate",
            "text": "Dip in 1000 ppm calibration solution and adjust until the meter matches. Keep the sensor submerged long enough for a stable reading.",
            "options": [
                {
                    "type": "process",
                    "process": "calibrate-ec-meter",
                    "text": "Run calibration adjustment.",
                    "requiresItems": [
                        {
                            "id": "71655665-4a59-41f4-9084-dad4d976df91",
                            "count": 1
                        },
                        {
                            "id": "d3d8bb59-8364-46b2-ad42-c5f56cc72b40",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "verify",
                    "text": "Calibration step complete; verify with a fresh sample."
                }
            ]
        },
        {
            "id": "verify",
            "text": "Take a new EC reading after calibration. Pass only if the 1000 ppm calibration solution reads within 950-1050 ppm; if drift remains outside that band, branch to correction and loop until readings stabilize.",
            "options": [
                {
                    "type": "process",
                    "process": "measure-ec-solution",
                    "text": "Capture post-calibration EC reading.",
                    "requiresItems": [
                        {
                            "id": "71655665-4a59-41f4-9084-dad4d976df91",
                            "count": 1
                        },
                        {
                            "id": "fc2bb989-f192-4891-8bde-78ae631dae78",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "interpret",
                    "text": "Post-calibration reading logged; interpret against the pass band.",
                    "requiresItems": [
                        {
                            "id": "bc979305-53ef-4be8-9d21-c59e3bfa7f06",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "interpret",
            "text": "Interpretation gate: finish only when the post-calibration reading is within 950-1050 ppm (1000 ppm \u00b15%). If the value still drifts outside that pass band, clean and recalibrate before trying again.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Within tolerance; calibration validated.",
                    "requiresItems": [
                        {
                            "id": "bc979305-53ef-4be8-9d21-c59e3bfa7f06",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "corrective",
                    "text": "Still drifting; run corrective cleaning and recalibration."
                }
            ]
        },
        {
            "id": "corrective",
            "text": "Corrective branch: rinse probe, confirm fresh solution, and redo calibration before another verification read.",
            "options": [
                {
                    "type": "goto",
                    "goto": "calibrate",
                    "text": "Corrective actions done; recalibrate now."
                }
            ]
        },
        {
            "id": "finish",
            "text": "Nice work. You closed with baseline evidence, post-calibration proof, and a clear corrective loop for drift.",
            "options": [
                {
                    "type": "finish",
                    "text": "Back to the grow."
                }
            ]
        }
    ],
    "rewards": [
        {
            "id": "5599c466-91e9-46fb-8d8b-11388e4f8f9c",
            "count": 1
        }
    ],
