{
    "id": "hydroponics/ec-calibrate",
    "title": "Calibrate EC Meter",
    "description": "Calibrate, log, interpret, and correct EC meter drift before signing off.",
    "image": "/assets/quests/hydroponic_ec_meter_calibration.jpg",
    "npc": "/assets/npc/hydro.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "An EC meter is only useful when calibration is proven. We'll prep, calibrate, capture a post-calibration reading, and only close after interpretation.",
            "options": [
                {
                    "type": "goto",
                    "goto": "precheck",
                    "text": "Run EC calibration QA sequence."
                }
            ]
        },
        {
            "id": "precheck",
            "text": "Safety gate: use clean cups, rinse probe between fluids, and keep calibration solution uncontaminated.",
            "options": [
                {
                    "type": "goto",
                    "goto": "calibrate",
                    "text": "EC meter and 1000 ppm solution are ready.",
                    "requiresItems": [
                        {
                            "id": "71655665-4a59-41f4-9084-dad4d976df91",
                            "count": 1
                        },
                        {
                            "id": "d3d8bb59-8364-46b2-ad42-c5f56cc72b40",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "recover",
                    "text": "Probe is fouled or solution cup was contaminated."
                }
            ]
        },
        {
            "id": "calibrate",
            "text": "Rinse, immerse, and adjust to the calibration value. Then collect a verification reading from the reservoir instead of trusting a single dial turn.",
            "options": [
                {
                    "type": "process",
                    "process": "calibrate-ec-meter",
                    "text": "Calibrate against 1000 ppm standard.",
                    "requiresItems": [
                        {
                            "id": "71655665-4a59-41f4-9084-dad4d976df91",
                            "count": 1
                        },
                        {
                            "id": "d3d8bb59-8364-46b2-ad42-c5f56cc72b40",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "measure",
                    "text": "Calibration done; capture post-calibration EC log.",
                    "requiresItems": [
                        {
                            "id": "71655665-4a59-41f4-9084-dad4d976df91",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "measure",
            "text": "Measurement gate: take a fresh EC reading and store the log artifact before interpreting. Target band is 1.2-1.8 mS/cm.",
            "options": [
                {
                    "type": "process",
                    "process": "measure-ec-solution",
                    "text": "Capture verification EC reading.",
                    "requiresItems": [
                        {
                            "id": "71655665-4a59-41f4-9084-dad4d976df91",
                            "count": 1
                        },
                        {
                            "id": "fc2bb989-f192-4891-8bde-78ae631dae78",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "interpret",
                    "text": "EC log captured; interpret pass/fail bounds.",
                    "requiresItems": [
                        {
                            "id": "bc979305-53ef-4be8-9d21-c59e3bfa7f06",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "interpret",
            "text": "Interpretation gate: 1.2-1.8 mS/cm passes, 1.0-1.2 or 1.8-2.0 is caution, anything outside is fail and requires correction plus retest.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Reading is in range; close calibration QA.",
                    "requiresItems": [
                        {
                            "id": "bc979305-53ef-4be8-9d21-c59e3bfa7f06",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "recover",
                    "text": "Reading is caution/fail; run correction and retest."
                }
            ]
        },
        {
            "id": "recover",
            "text": "Recovery loop: clean probe, mix reservoir thoroughly, apply a small correction with PPE, wait 10 minutes, then repeat measurement.",
            "options": [
                {
                    "type": "process",
                    "process": "refresh-hydroponic-tub",
                    "text": "Apply controlled correction before retest.",
                    "requiresItems": [
                        {
                            "id": "ef5a843f-0a9d-41e2-b2bc-81fc9f99a150",
                            "count": 1
                        },
                        {
                            "id": "997eaba9-25ee-43d5-bbdc-5d6adf03adfa",
                            "count": 1
                        },
                        {
                            "id": "c9b51052-4594-42d7-a723-82b815ab8cc2",
                            "count": 1
                        },
                        {
                            "id": "584ca717-4ce1-4ca1-bcd3-38272a52768a",
                            "count": 1
                        },
                        {
                            "id": "fc2bb989-f192-4891-8bde-78ae631dae78",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "measure",
                    "text": "Correction complete; capture a fresh EC log."
                }
            ]
        },
        {
            "id": "finish",
            "text": "Nice work. Calibration is backed by a logged reading and interpretation, not guesswork.",
            "options": [
                {
                    "type": "finish",
                    "text": "Meter calibrated with evidence."
                }
            ]
        }
    ],
    "rewards": [
        {
            "id": "b281360b-2ecc-4fea-a248-36a61c5f7399",
            "count": 1
        }
    ],
