{
    "id": "hydroponics/ph-check",
    "title": "Check Solution pH",
    "description": "Measure the nutrient bath's pH and correct it to keep plants happy.",
    "image": "/assets/quests/hydroponics_solution_ph_check.jpg",
    "npc": "/assets/npc/hydro.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Hydro here. Happy roots love a steady pH. We'll measure, interpret, and only close once the log proves we're stable.",
            "options": [
                {
                    "type": "goto",
                    "goto": "prep",
                    "text": "Ready for the pH check."
                }
            ]
        },
        {
            "id": "prep",
            "text": "Safety first: gloves, goggles, and a clean cylinder. Keep acids and bases capped until you're ready to dose.",
            "options": [
                {
                    "type": "goto",
                    "goto": "measure",
                    "text": "PPE and tools are staged.",
                    "requiresItems": [
                        {
                            "id": "997eaba9-25ee-43d5-bbdc-5d6adf03adfa",
                            "count": 1
                        },
                        {
                            "id": "c9b51052-4594-42d7-a723-82b815ab8cc2",
                            "count": 1
                        },
                        {
                            "id": "092dae11-237a-43cc-b342-246aabbba258",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "measure",
            "text": "Run the pH strip test and capture a reading. Target band is 5.5-6.5 for leafy greens.",
            "options": [
                {
                    "type": "process",
                    "process": "measure-ph",
                    "text": "Measure pH"
                },
                {
                    "type": "goto",
                    "goto": "interpret",
                    "text": "Reading captured; interpret result.",
                    "requiresItems": [
                        {
                            "id": "5456a6a5-5da9-46a0-aa4e-a74b6814404a",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "interpret",
            "text": "Interpret the value. In-range (5.5-6.5) can be logged. Out-of-range needs controlled correction and re-test.",
            "options": [
                {
                    "type": "goto",
                    "goto": "log",
                    "text": "It's in range; log stable pH.",
                    "requiresItems": [
                        {
                            "id": "5456a6a5-5da9-46a0-aa4e-a74b6814404a",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "adjust",
                    "text": "Out of range; begin correction loop.",
                    "requiresItems": [
                        {
                            "id": "997eaba9-25ee-43d5-bbdc-5d6adf03adfa",
                            "count": 1
                        },
                        {
                            "id": "c9b51052-4594-42d7-a723-82b815ab8cc2",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "adjust",
            "text": "Dose in small increments, stir fully, and re-test. If the value swings wildly after dosing, pause and inspect reagent age before retrying.",
            "options": [
                {
                    "type": "process",
                    "process": "adjust-ph",
                    "text": "Dose and stir"
                },
                {
                    "type": "goto",
                    "goto": "measure",
                    "text": "Re-test after mixing"
                },
                {
                    "type": "goto",
                    "goto": "troubleshoot",
                    "text": "Reading still unstable after correction"
                }
            ]
        },
        {
            "id": "troubleshoot",
            "text": "Troubleshooting branch: replace stale strips, verify your stir rod and cylinder are clean, then retest before any extra dosing.",
            "options": [
                {
                    "type": "goto",
                    "goto": "measure",
                    "text": "Tools reset; run a fresh measurement."
                }
            ]
        },
        {
            "id": "log",
            "text": "Log the stable reading with timestamp so future drift is obvious.",
            "options": [
                {
                    "type": "process",
                    "process": "log-stable-ph",
                    "text": "Log pH and timestamp"
                },
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Log completed and verified.",
                    "requiresItems": [
                        {
                            "id": "cad7d051-e3fb-4f1c-9d72-358076ee732e",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "finish",
            "text": "Nice control loop. Stable pH plus a written log means fewer nutrient lockout surprises.",
            "options": [
                {
                    "type": "finish",
                    "text": "pH check complete."
                }
            ]
        }
    ],
    "rewards": [
