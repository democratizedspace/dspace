    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Hydro here. Happy roots love steady pH, so we will measure, interpret, and only close when the log proves we're in range.",
            "options": [
                {
                    "type": "goto",
                    "goto": "prep",
                    "text": "Run the pH checklist."
                }
            ]
        },
        {
            "id": "prep",
            "text": "Stage PPE and sampling gear before touching pH chemicals. If strips are expired or unreadable, branch to troubleshooting first.",
            "options": [
                {
                    "type": "goto",
                    "goto": "measure",
                    "text": "Gloves, goggles, and clean sample cylinder are ready.",
