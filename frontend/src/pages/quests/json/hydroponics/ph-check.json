{
    "id": "hydroponics/ph-check",
    "title": "Check Solution pH",
    "description": "Measure the nutrient bath's pH and correct it to keep plants happy.",
    "image": "/assets/quests/hydroponics_solution_ph_check.jpg",
    "npc": "/assets/npc/hydro.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Roots like calm water. Let's check the nutrient bath pH.",
            "options": [
                {
                    "type": "goto",
                    "goto": "measure",
                    "text": "Ready."
                }
            ]
        },
        {
            "id": "measure",
            "text": "Dip a pH strip for a few seconds and compare the color chart. Aim for 5.5–6.5 for leafy greens.",
            "options": [
                {
                    "type": "process",
                    "process": "measure-ph",
                    "text": "Measure pH"
                },
                {
                    "type": "goto",
                    "goto": "adjust",
                    "text": "It's out of range"
                },
                {
                    "type": "goto",
                    "goto": "log",
                    "text": "Reading looks good",
                    "requiresItems": [
                        {
                            "id": "5456a6a5-5da9-46a0-aa4e-a74b6814404a",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "log",
            "text": "Log the stable reading so you can spot drifts later.",
            "options": [
                {
                    "type": "process",
                    "process": "log-stable-ph",
                    "text": "Log the pH and timestamp"
                },
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Logged and synced",
                    "requiresItems": [
                        {
                            "id": "cad7d051-e3fb-4f1c-9d72-358076ee732e",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "adjust",
            "text": "Gloves and goggles on. Add a little pH up or down, stir, and re-test until you're back in range.",
            "options": [
                {
                    "type": "process",
                    "process": "adjust-ph",
                    "text": "Dose and stir"
                },
                {
                    "type": "goto",
                    "goto": "measure",
                    "text": "Re-test"
                }
            ]
        },
        {
            "id": "finish",
            "text": "Nice work! Keep pH between 5.5 and 6.5 and recheck weekly to avoid nutrient lockout.",
            "options": [
                {
                    "type": "finish",
                    "text": "Will do."
                }
            ]
        }
    ],
    "rewards": [],
    "requiresQuests": ["hydroponics/nutrient-check"],
    "hardening": {
        "passes": 0,
        "score": 90,
        "emoji": "🛠️",
        "history": []
    }
}
