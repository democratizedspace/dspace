                            "id": "4f3f5ebf-bbe6-416b-b39f-0c418fd140c7",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "troubleshoot",
                    "text": "Reading still unstable after two adjustments."
