{
    "id": "hydroponics/ph-check",
    "title": "Check Solution pH",
    "description": "Measure the nutrient bath's pH, interpret the reading, and recover safely if it's out of range.",
    "image": "/assets/quests/hydroponics_solution_ph_check.jpg",
    "npc": "/assets/npc/hydro.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Hydro here. Healthy roots need pH between 5.5 and 6.5. We'll measure, interpret, and only close once the result is logged.",
            "options": [
                {
                    "type": "goto",
                    "goto": "measure",
                    "text": "Ready for the pH runbook."
                }
            ]
        },
        {
            "id": "measure",
            "text": "Put on gloves and goggles, pull a sample with the graduated cylinder, and run a fresh strip test.",
            "options": [
                {
                    "type": "process",
                    "process": "measure-ph",
                    "text": "Measure pH now.",
                    "requiresItems": [
                        {
                            "id": "997eaba9-25ee-43d5-bbdc-5d6adf03adfa",
                            "count": 1
                        },
                        {
                            "id": "c9b51052-4594-42d7-a723-82b815ab8cc2",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "interpret",
                    "text": "I have a strip reading.",
                    "requiresItems": [
                        {
                            "id": "5456a6a5-5da9-46a0-aa4e-a74b6814404a",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "interpret",
            "text": "Interpret the strip before touching chemistry: 5.5-6.5 passes. Below 5.5 risks nutrient burn, above 6.5 risks lockout.",
            "options": [
                {
                    "type": "goto",
                    "goto": "log",
                    "text": "Result is in range (5.5-6.5).",
                    "requiresItems": [
                        {
                            "id": "5456a6a5-5da9-46a0-aa4e-a74b6814404a",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "corrective",
                    "text": "Result is out of range (<5.5 or >6.5).",
                    "requiresItems": [
                        {
                            "id": "5456a6a5-5da9-46a0-aa4e-a74b6814404a",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "corrective",
            "text": "Safety check: keep gloves/goggles on, add only a small pH up/down dose, stir thoroughly, then re-test. If the strip keeps drifting, pause dosing and review nutrient concentration before retrying.",
            "options": [
                {
                    "type": "process",
                    "process": "adjust-ph",
                    "text": "Dose and mix a corrective adjustment.",
                    "requiresItems": [
                        {
                            "id": "997eaba9-25ee-43d5-bbdc-5d6adf03adfa",
                            "count": 1
                        },
                        {
                            "id": "c9b51052-4594-42d7-a723-82b815ab8cc2",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "measure",
                    "text": "Run the mandatory re-test."
                }
            ]
        },
        {
            "id": "log",
            "text": "Great. Capture timestamp + reading so you can spot drift before plants show symptoms.",
            "options": [
                {
                    "type": "process",
                    "process": "log-stable-ph",
                    "text": "Log stable pH and timestamp."
                },
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Logged and synced.",
                    "requiresItems": [
                        {
                            "id": "cad7d051-e3fb-4f1c-9d72-358076ee732e",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "finish",
            "text": "Beautiful control loop. Recheck weekly or any time you refresh nutrients.",
            "options": [
                {
                    "type": "finish",
                    "text": "pH loop complete."
                }
            ]
        }
    ],
    "rewards": [
        {
            "id": "b281360b-2ecc-4fea-a248-36a61c5f7399",
            "count": 1
        }
    ],
    "requiresQuests": ["hydroponics/nutrient-check"],
