                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "troubleshoot",
                    "text": "Strip quality is questionable or color chart is hard to read."
                }
            ]
        },
        {
            "id": "measure",
            "text": "Pull a sample and run a pH test. Target 5.5-6.5 for leafy crops.",
            "options": [
                {
                    "type": "process",
