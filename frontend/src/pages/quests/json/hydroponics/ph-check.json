                        {
                            "id": "5456a6a5-5da9-46a0-aa4e-a74b6814404a",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "adjust",
            "text": "Keep PPE on. Dose pH up/down in small increments, stir thoroughly, then route back to measurement for a fresh reading.",
            "options": [
                {
                    "type": "process",
                    "process": "adjust-ph",
                    "text": "Dose and stir.",
