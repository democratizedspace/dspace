                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "interpret",
            "text": "Interpret the reading. If pH is outside 5.5-6.5, correct in small steps and re-test before logging.",
            "options": [
                {
                    "type": "goto",
                    "goto": "adjust",
                    "text": "Out of range; apply correction and retest.",
