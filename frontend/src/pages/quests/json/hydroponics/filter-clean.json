                    ]
                }
            ]
        },
        {
            "id": "baseline",
            "text": "Before cleaning, confirm reduced output so we have a pre-maintenance baseline.",
            "options": [
                {
                    "type": "goto",
                    "goto": "rinse",
                    "text": "Baseline captured; proceed to rinse.",
                    "requiresItems": [
                        {
