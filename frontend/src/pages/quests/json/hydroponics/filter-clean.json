                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "rinse",
            "text": "Squeeze and swish the sponge in dechlorinated water until sludge drops, but do not scrub to a sterile white core.",
            "options": [
                {
                    "type": "process",
                    "process": "rinse-aquarium-filter",
                    "text": "Rinse filter media."
                },
                {
                    "type": "goto",
                    "goto": "restart",
                    "text": "Rinsed core ready for reassembly.",
                    "requiresItems": [
                        {
                            "id": "606c4f47-ca8f-4458-bc7f-0ab2957ef641",
