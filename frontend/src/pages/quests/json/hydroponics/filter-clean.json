{
    "id": "hydroponics/filter-clean",
    "title": "Rinse Grow Bed Filter",
    "description": "Restore sponge filter flow with measurable before/after checks and a contamination recovery loop.",
    "image": "/assets/quests/hydroponics_grow_bed_filter_rinse.jpg",
    "npc": "/assets/npc/hydro.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "The grow bed flow is slowing down. We'll inspect, rinse safely, and confirm oxygen flow rebounds before we close this out.",
            "options": [
                {
                    "type": "goto",
                    "goto": "prep",
                    "text": "Walk me through it."
                }
            ]
        },
        {
            "id": "prep",
            "text": "Use dechlorinated rinse water and PPE only. Chlorinated tap water can wipe the biofilter.",
            "options": [
                {
                    "type": "goto",
                    "goto": "baseline",
                    "text": "I have the cleaning kit.",
                    "requiresItems": [
                        {
                            "id": "496b4ebb-43c8-42d7-a921-fc6ee9d6ae56",
                            "count": 1
                        },
                        {
                            "id": "71efa72a-8c87-4dc2-8e2c-9119bb28fe50",
                            "count": 1
                        },
                        {
                            "id": "997eaba9-25ee-43d5-bbdc-5d6adf03adfa",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "baseline",
            "text": "Confirm the filter is currently restricted so we can prove improvement after cleaning.",
            "options": [
                {
                    "type": "goto",
                    "goto": "rinse",
                    "text": "Baseline restriction confirmed.",
                    "requiresItems": [
                        {
                            "id": "496b4ebb-43c8-42d7-a921-fc6ee9d6ae56",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "rinse",
            "text": "Rinse by squeezing and swishing in dechlorinated water until sludge clears while keeping the bacterial film intact.",
            "options": [
                {
                    "type": "process",
                    "process": "rinse-aquarium-filter",
                    "text": "Rinse filter media now."
                },
                {
                    "type": "goto",
                    "goto": "restart",
                    "text": "Filter core is rinsed.",
                    "requiresItems": [
                        {
                            "id": "606c4f47-ca8f-4458-bc7f-0ab2957ef641",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "restart",
            "text": "Reassemble and restart aeration, then verify the output stream and bubble pattern are steady.",
            "options": [
                {
                    "type": "process",
                    "process": "restart-sponge-filter",
                    "text": "Restart the sponge filter."
                },
                {
                    "type": "goto",
                    "goto": "verify",
                    "text": "Flow is restored.",
                    "requiresItems": [
                        {
                            "id": "6f08e704-1086-4fef-ad0a-f48922a5cfd0",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "verify",
            "text": "If flow remains weak or foul odor persists, treat it as contamination and repeat with fresh rinse water before finishing.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Post-clean flow is steady and odor is clear.",
                    "requiresItems": [
                        {
                            "id": "6f08e704-1086-4fef-ad0a-f48922a5cfd0",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "contamination-recovery",
                    "text": "Still seeing clumps or sour odor; run contamination recovery."
                }
            ]
        },
        {
            "id": "contamination-recovery",
            "text": "Discard dirty rinse water, prepare a fresh dechlorinated bucket, and repeat the rinse + restart sequence before retesting.",
            "options": [
                {
                    "type": "goto",
                    "goto": "rinse",
                    "text": "Fresh rinse water ready; retry cleaning.",
                    "requiresItems": [
                        {
                            "id": "71efa72a-8c87-4dc2-8e2c-9119bb28fe50",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "finish",
            "text": "Perfect maintenance pass. You captured a before/after state and recovered safely when contamination signs appeared.",
            "options": [
                {
                    "type": "finish",
                    "text": "Filter maintenance complete."
                }
            ]
        }
    ],
