                    "process": "restart-sponge-filter",
                    "text": "Restart filter and aeration."
                },
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Post-clean flow is restored.",
                    "requiresItems": [
                        {
                            "id": "6f08e704-1086-4fef-ad0a-f48922a5cfd0",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "contamination",
                    "text": "Flow is still weak or smells off.",
