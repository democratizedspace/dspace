                    ]
                }
            ]
        },
        {
            "id": "finish",
            "text": "Great. A primed stone keeps the reservoir oxygenated.",
            "options": [
                {
                    "type": "finish",
                    "text": "Back to the tub."
                }
            ]
        }
    ],
