{
    "id": "hydroponics/air-stone-soak",
    "title": "Soak Air Stone",
    "description": "Prime the air stone so bubbles stay even.",
    "image": "/assets/quests/hydroponics_air_stone_soak.jpg",
    "npc": "/assets/npc/hydro.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "New air stones shed dust. Give it a soak before it meets the roots.",
            "options": [
                {
                    "type": "goto",
                    "goto": "soak",
                    "text": "What's the method?"
                }
            ]
        },
        {
            "id": "soak",
            "text": "Drop the stone in a bucket of dechlorinated water and wait ten minutes.",
            "options": [
                {
                    "type": "process",
                    "process": "soak-air-stone",
                    "text": "Start the soak"
                },
                {
                    "type": "goto",
                    "goto": "prime",
                    "text": "Stone is hydrated.",
                    "requiresItems": [
                        {
                            "id": "3b094479-ed97-46d6-8cab-ea91752972dd",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "prime",
            "text": "Hook it to a pump in a test bucket and run it for a minute. You want even bubbles across the face.",
            "options": [
                {
                    "type": "process",
                    "process": "prime-air-stone",
                    "text": "Test the airflow"
                },
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Bubbles are even",
                    "requiresItems": [
                        {
                            "id": "bd887124-605d-4268-8a6c-684cb48de1a6",
                            "count": 1
