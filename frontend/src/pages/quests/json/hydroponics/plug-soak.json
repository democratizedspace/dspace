                {
                    "type": "goto",
                    "goto": "prep",
                    "text": "Recovery complete; re-run prep checks."
                }
            ]
        },
        {
            "id": "finish",
            "text": "Great work. You now have consistent starter plugs and a clean handoff for germination and cuttings.",
            "options": [
                {
                    "type": "finish",
                    "text": "Plugs are soak-verified."
                }
            ]
        }
