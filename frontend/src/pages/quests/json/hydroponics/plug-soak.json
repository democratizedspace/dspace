{
    "id": "hydroponics/plug-soak",
    "title": "Soak Starter Plugs",
    "description": "Hydrate starter plugs with safety checks, verification gates, and recovery loops.",
    "image": "/assets/quests/hydroponic_starter_plugs_soaking_tray.jpg",
    "npc": "/assets/npc/hydro.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Rockwool plugs arrive dry and dusty. We stage safe prep, then prove they are fully saturated before seeding.",
            "options": [
                {
                    "type": "goto",
                    "goto": "prep",
                    "text": "Run the starter-plug prep checklist."
                }
            ]
        },
        {
            "id": "prep",
            "text": "Prep gate: collect dechlorinated water and put on gloves + eye protection before handling the plugs.",
            "options": [
                {
                    "type": "goto",
                    "goto": "soak",
                    "text": "Water and PPE are ready.",
                    "requiresItems": [
                        {
                            "id": "71efa72a-8c87-4dc2-8e2c-9119bb28fe50",
                            "count": 1
                        },
                        {
                            "id": "997eaba9-25ee-43d5-bbdc-5d6adf03adfa",
                            "count": 1
                        },
                        {
                            "id": "c9b51052-4594-42d7-a723-82b815ab8cc2",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "recover",
                    "text": "Setup is incomplete or plugs still look brittle."
                }
            ]
        },
        {
            "id": "soak",
            "text": "Run a full soak cycle, then inspect for dry cores before moving to verification.",
            "options": [
                {
                    "type": "process",
                    "process": "rockwool-soak",
                    "text": "Soak the starter plugs."
                },
                {
                    "type": "goto",
                    "goto": "verify",
                    "text": "Soak cycle complete; verify saturation.",
                    "requiresItems": [
                        {
                            "id": "545aeb15-7e8b-489d-be4a-af2a59f447e1",
                            "count": 10
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "recover",
                    "text": "Some plugs still have dry spots."
                }
            ]
        },
        {
            "id": "verify",
            "text": "Verification gate: squeeze-test one sample plug. If moisture is uneven, recover and re-soak before continuing.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "All plugs are evenly saturated and seed-ready.",
                    "requiresItems": [
                        {
                            "id": "545aeb15-7e8b-489d-be4a-af2a59f447e1",
                            "count": 10
                        },
                        {
                            "id": "997eaba9-25ee-43d5-bbdc-5d6adf03adfa",
                            "count": 1
                        },
                        {
                            "id": "c9b51052-4594-42d7-a723-82b815ab8cc2",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "recover",
                    "text": "Moisture is patchy; run corrective soak."
                }
            ]
        },
        {
            "id": "recover",
            "text": "Recovery branch: discard dusty soak water, remix fresh dechlorinated water, and restart from prep so safety and moisture checks are both re-validated.",
            "options": [
                {
                    "type": "goto",
                    "goto": "prep",
                    "text": "Corrective setup complete; retry prep gate."
                },
                {
                    "type": "goto",
                    "goto": "soak",
                    "text": "PPE is still on; re-run soak immediately."
                }
            ]
        },
        {
            "id": "finish",
            "text": "Nice work. You cleared prep evidence, soak evidence, and a troubleshooting path for dry-core plugs.",
            "options": [
                {
                    "type": "finish",
                    "text": "Starter plugs are ready for planting."
                }
            ]
        }
    ],
