{
    "id": "hydroponics/plug-soak",
    "title": "Soak Starter Plugs",
    "description": "Hydrate rockwool cubes so seeds sprout happily.",
    "image": "/assets/quests/hydroponic_starter_plugs_soaking_tray.jpg",
    "npc": "/assets/npc/hydro.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Hydro here. Dry plugs wick unevenly, so we'll stage clean water, soak, then verify saturation before we move on.",
            "options": [
                {
                    "type": "goto",
                    "goto": "prep",
                    "text": "Run the plug-soak checklist."
                }
            ]
        },
        {
            "id": "prep",
            "text": "Prep step: use a clean bucket and dechlorinated water so seedlings avoid chlorine shock. If water looks cloudy, branch to recovery first.",
            "options": [
                {
                    "type": "goto",
                    "goto": "soak",
                    "text": "Bucket is clean and water is clear.",
                    "requiresItems": [
                        {
                            "id": "71efa72a-8c87-4dc2-8e2c-9119bb28fe50",
                            "count": 1
                        },
                        {
                            "id": "78a45c1f-a791-44f1-88f4-dc5059c66c89",
                            "count": 10
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "recover",
                    "text": "Water is cloudy or bucket was contaminated."
                }
            ]
        },
        {
            "id": "soak",
            "text": "Run a full soak cycle and gently press cubes under until no dry core remains.",
            "options": [
                {
                    "type": "process",
                    "process": "rockwool-soak",
                    "text": "Start soak cycle.",
                    "requiresItems": [
                        {
                            "id": "71efa72a-8c87-4dc2-8e2c-9119bb28fe50",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "verify",
                    "text": "Soak cycle complete; verify plug condition.",
                    "requiresItems": [
                        {
                            "id": "545aeb15-7e8b-489d-be4a-af2a59f447e1",
                            "count": 10
                        }
                    ]
                }
            ]
        },
        {
            "id": "verify",
            "text": "Verification: each plug should feel evenly damp, not dripping. If any core is still dry, re-soak before finishing.",
            "options": [
                {
                    "type": "goto",
                    "goto": "soak",
                    "text": "Some cores are still dry; re-soak the batch."
                },
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "All 10 plugs are evenly saturated.",
                    "requiresItems": [
                        {
                            "id": "545aeb15-7e8b-489d-be4a-af2a59f447e1",
                            "count": 10
                        }
                    ]
                }
            ]
        },
        {
            "id": "recover",
            "text": "Recovery path: dump suspect water, rinse tools, and restart with fresh dechlorinated water so microbes do not hitch a ride into your grow.",
