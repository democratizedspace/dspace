{
    "id": "hydroponics/pump-prime",
    "title": "Prime Water Pump",
    "description": "Prep the pump so it doesn't run dry.",
    "image": "/assets/quests/hydroponics_pump_prime.jpg",
    "npc": "/assets/npc/hydro.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Even a good install can fail if air stays trapped. We'll capture before/after evidence and only close when prime holds.",
            "options": [
                {
                    "type": "goto",
                    "goto": "baseline",
                    "text": "Start priming check."
                }
            ]
        },
        {
            "id": "baseline",
            "text": "Record baseline symptoms: sputtering flow, bubble bursts, or dry pump noise. This is your before snapshot.",
            "options": [
                {
                    "type": "goto",
                    "goto": "prime",
                    "text": "Baseline captured; begin priming.",
                    "requiresItems": [
                        {
                            "id": "4b09d8a3-5dd3-44b8-9fd7-89cc34a34076",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "prime",
            "text": "Fill the pump housing, purge trapped air, and run a short cycle to stabilize circulation.",
            "options": [
                {
                    "type": "process",
                    "process": "install-submersible-pump",
                    "text": "Run controlled priming cycle."
                },
                {
                    "type": "goto",
                    "goto": "verify",
                    "text": "Priming cycle complete; verify outcome.",
                    "requiresItems": [
                        {
                            "id": "4b09d8a3-5dd3-44b8-9fd7-89cc34a34076",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "contamination",
                    "text": "Prime fails: flow still sputters or air keeps returning"
                }
            ]
        },
        {
            "id": "contamination",
            "text": "Recovery branch: check intake for debris, top reservoir level, and reseat tubing to prevent air ingestion before re-priming.",
            "options": [
                {
                    "type": "goto",
                    "goto": "prime",
                    "text": "Failure source addressed; re-run prime."
                }
            ]
        },
        {
            "id": "verify",
            "text": "Run post-prime verification. If circulation drops or cavitation returns, loop back and troubleshoot instead of forcing finish.",
            "options": [
                {
                    "type": "process",
                    "process": "verify-hydroponic-flow",
                    "text": "Capture post-prime flow check"
                },
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Before/after evidence confirms steady flow.",
                    "requiresItems": [
                        {
                            "id": "bd215e1e-5477-4b2f-8420-0227180a3531",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "contamination",
                    "text": "Verification failed; return to troubleshooting"
                }
            ]
        },
        {
            "id": "finish",
            "text": "Pump prime validated. You now have a repeatable clean startup routine with evidence and recovery steps.",
            "options": [
                {
                    "type": "finish",
                    "text": "Prime complete."
                }
            ]
        }
    ],
    "rewards": [
