                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "prime",
                    "text": "Verified loop, submerged intake, and PPE confirmed.",
                    "requiresItems": [
                        {
                            "id": "bd215e1e-5477-4b2f-8420-0227180a3531",
                            "count": 1
                        },
                        {
                            "id": "997eaba9-25ee-43d5-bbdc-5d6adf03adfa",
                            "count": 1
                        },
                        {
                            "id": "c9b51052-4594-42d7-a723-82b815ab8cc2",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "recover",
                    "text": "I see large air pockets or sections of the return line that are not fully flooded."
                }
            ]
        },
        {
            "id": "prime",
            "text": "Fill the housing, purge visible air, and run a short wet-start cycle. Stop immediately if the pump chatters dry.",
            "options": [
                {
                    "type": "process",
                    "process": "install-submersible-pump",
                    "text": "Run controlled prime cycle with wet intake."
                },
                {
                    "type": "goto",
                    "goto": "verify",
                    "text": "Prime cycle done; verify circulation artifact.",
                    "requiresItems": [
                        {
                            "id": "4b09d8a3-5dd3-44b8-9fd7-89cc34a34076",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "verify",
                    "text": "Prime cycle done; use existing verification artifact.",
                    "requiresItems": [
                        {
                            "id": "bd215e1e-5477-4b2f-8420-0227180a3531",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "verify",
            "text": "Evidence gate: run flow verification and only close when we have a stable-loop proof artifact.",
            "options": [
                {
                    "type": "process",
                    "process": "verify-hydroponic-flow",
                    "text": "Capture post-prime flow verification."
                },
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Flow is stable after priming.",
                    "requiresItems": [
                        {
                            "id": "bd215e1e-5477-4b2f-8420-0227180a3531",
                            "count": 1
