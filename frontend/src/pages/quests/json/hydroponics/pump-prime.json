    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Priming is a safety step, not a button mash. We confirm pre-checks, run a wet start, then verify stable flow before we close.",
            "options": [
                {
                    "type": "goto",
                    "goto": "precheck",
                    "text": "Run priming checklist."
                }
            ]
        },
        {
            "id": "precheck",
            "text": "Before energizing, confirm the pump loop is installed or already verified, intake is submerged, and PPE is on around splashing electrical gear.",
            "options": [
                {
                    "type": "goto",
                    "goto": "prime",
                    "text": "Installed loop, submerged intake, and PPE confirmed.",
                    "requiresItems": [
                        {
                            "id": "4b09d8a3-5dd3-44b8-9fd7-89cc34a34076",
                            "count": 1
