{
    "id": "hydroponics/temp-check",
    "title": "Check Water Temperature",
    "description": "Measure, log, and interpret reservoir temperature with corrective retest loops.",
    "image": "/assets/quests/hydroponic_reservoir_temp_check.jpg",
    "npc": "/assets/npc/hydro.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Temperature checks need evidence and action thresholds. We will attach, log, interpret, then correct/retest if out of range.",
            "options": [
                {
                    "type": "goto",
                    "goto": "attach",
                    "text": "Run temperature QA sequence."
                }
            ]
        },
        {
            "id": "attach",
            "text": "Mount the strip thermometer where flow is representative, not near a pump hotspot.",
            "options": [
                {
                    "type": "process",
                    "process": "attach-aquarium-thermometer",
                    "text": "Attach thermometer for a stable reading.",
                    "requiresItems": [
                        {
                            "id": "ca7c1069-4ba3-4339-9a10-0b690a690e60",
                            "count": 1
                        },
                        {
                            "id": "8e81b5e5-4aee-402c-bd04-fed9188f8c07",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "measure",
                    "text": "Thermometer mounted; capture temperature log.",
                    "requiresItems": [
                        {
                            "id": "4e8db808-927f-4ac7-9d1f-1c8400c7f5d7",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "measure",
            "text": "Log the observed water temperature and classify it: 65-75\u00b0F pass, 60-64\u00b0F or 76-79\u00b0F caution, outside that is fail.",
            "options": [
                {
                    "type": "process",
                    "process": "log-walstad-temperature",
                    "text": "Record temperature log artifact.",
                    "requiresItems": [
                        {
                            "id": "4e8db808-927f-4ac7-9d1f-1c8400c7f5d7",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "interpret",
                    "text": "Temperature log captured.",
                    "requiresItems": [
                        {
                            "id": "7f9d9d21-a4f2-4c48-b0e5-9a7483ab05d2",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "interpret",
            "text": "Interpret before finishing. Only close when logs show stable pass range across checks.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "In range and stable; close this check.",
                    "requiresItems": [
                        {
                            "id": "7f9d9d21-a4f2-4c48-b0e5-9a7483ab05d2",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "correct",
                    "text": "Caution/fail band detected; apply correction and retest."
                }
            ]
        },
        {
            "id": "correct",
            "text": "Safety gate: avoid thermal shock. Adjust gradually, wait 15 minutes for mixing, then re-log before declaring recovery.",
            "options": [
                {
                    "type": "process",
                    "process": "refresh-hydroponic-tub",
                    "text": "Stabilize reservoir before retest.",
                    "requiresItems": [
                        {
                            "id": "ef5a843f-0a9d-41e2-b2bc-81fc9f99a150",
                            "count": 1
                        },
                        {
                            "id": "997eaba9-25ee-43d5-bbdc-5d6adf03adfa",
                            "count": 1
                        },
                        {
                            "id": "c9b51052-4594-42d7-a723-82b815ab8cc2",
                            "count": 1
                        },
                        {
                            "id": "584ca717-4ce1-4ca1-bcd3-38272a52768a",
                            "count": 1
                        },
                        {
                            "id": "fc2bb989-f192-4891-8bde-78ae631dae78",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "measure",
                    "text": "Correction complete; capture a new temperature log."
                }
            ]
        },
        {
            "id": "finish",
            "text": "Temperature check closed with a recorded log and interpretation. Repeat after major top-off or pump maintenance.",
            "options": [
                {
                    "type": "finish",
                    "text": "Reservoir temperature QA complete."
                }
            ]
        }
    ],
    "rewards": [
