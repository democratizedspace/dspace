{
    "id": "hydroponics/temp-check",
    "title": "Check Water Temperature",
    "description": "Measure, interpret, and log reservoir temperature before closing.",
    "image": "/assets/quests/hydroponic_reservoir_temp_check.jpg",
    "npc": "/assets/npc/hydro.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Warm water stresses roots and pathogens love it. We'll log a reading, interpret against bounds, then correct and re-test if needed.",
            "options": [
                {
                    "type": "goto",
                    "goto": "prep",
                    "text": "Start temperature check."
                }
            ]
        },
        {
            "id": "prep",
            "text": "Attach a clean strip thermometer and verify reservoir circulation before taking a reading.",
            "options": [
                {
                    "type": "process",
                    "process": "attach-aquarium-thermometer",
                    "text": "Attach thermometer strip.",
                    "requiresItems": [
                        {
                            "id": "ca7c1069-4ba3-4339-9a10-0b690a690e60",
                            "count": 1
                        },
                        {
                            "id": "8e81b5e5-4aee-402c-bd04-fed9188f8c07",
                            "count": 1
                        },
                        {
                            "id": "785fa6f3-bb66-4197-a43f-52fea9cebd48",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "measure",
                    "text": "Thermometer attached and readable.",
                    "requiresItems": [
                        {
                            "id": "4e8db808-927f-4ac7-9d1f-1c8400c7f5d7",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "measure",
            "text": "Capture a fresh reading after circulation stabilizes. Target 65-75°F (18-24°C).",
            "options": [
                {
                    "type": "process",
                    "process": "check-aquarium-temperature",
                    "text": "Measure temperature.",
                    "requiresItems": [
                        {
                            "id": "ca7c1069-4ba3-4339-9a10-0b690a690e60",
                            "count": 1
                        },
                        {
                            "id": "4e8db808-927f-4ac7-9d1f-1c8400c7f5d7",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "interpret",
                    "text": "Reading captured; interpret result.",
                    "requiresItems": [
                        {
                            "id": "4e8db808-927f-4ac7-9d1f-1c8400c7f5d7",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "interpret",
            "text": "Interpret now: 65-75°F is pass, 60-65 or 75-78 is caution, below 60 or above 78 requires corrective action and retest.",
            "options": [
                {
                    "type": "goto",
                    "goto": "log",
                    "text": "In range; log and close.",
                    "requiresItems": [
                        {
                            "id": "4e8db808-927f-4ac7-9d1f-1c8400c7f5d7",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "correct",
                    "text": "Out of range; apply correction then retest."
                }
            ]
        },
        {
            "id": "correct",
            "text": "Corrective branch: adjust room airflow or insulation, avoid rapid swings >2°F per hour, and keep pump circulation running during recovery.",
            "options": [
                {
                    "type": "process",
                    "process": "verify-hydroponic-flow",
                    "text": "Verify circulation during correction."
                },
                {
                    "type": "goto",
                    "goto": "measure",
                    "text": "Stabilization window complete; re-measure temperature.",
                    "requiresItems": [
                        {
                            "id": "bd215e1e-5477-4b2f-8420-0227180a3531",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "troubleshoot",
                    "text": "Temp still drifting after two correction windows."
                }
            ]
        },
        {
            "id": "troubleshoot",
            "text": "Troubleshoot: inspect pump cavitation, check ambient heat sources, and confirm reservoir volume wasn't reduced by evaporation before retrying.",
            "options": [
                {
                    "type": "goto",
                    "goto": "prep",
                    "text": "Issues corrected; restart prep and retest."
                },
                {
                    "type": "goto",
                    "goto": "measure",
                    "text": "System stabilized; take a new reading.",
                    "requiresItems": [
                        {
                            "id": "4e8db808-927f-4ac7-9d1f-1c8400c7f5d7",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "log",
            "text": "Record timestamp and reading so trend drift is visible before the next nutrient check.",
            "options": [
                {
                    "type": "process",
                    "process": "log-walstad-temperature",
                    "text": "Log temperature reading.",
                    "requiresItems": [
                        {
                            "id": "4e8db808-927f-4ac7-9d1f-1c8400c7f5d7",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Reading logged and trend reviewed.",
                    "requiresItems": [
                        {
                            "id": "7f9d9d21-a4f2-4c48-b0e5-9a7483ab05d2",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "finish",
            "text": "Temperature check complete with measured evidence, interpretation, and a corrective re-test loop.",
            "options": [
                {
                    "type": "finish",
                    "text": "Reservoir temperature verified and logged."
                }
            ]
        }
    ],
    "rewards": [
        {
            "id": "b281360b-2ecc-4fea-a248-36a61c5f7399",
            "count": 1
        }
    ],
    "requiresQuests": ["hydroponics/nutrient-check"],
