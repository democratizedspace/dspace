{
    "id": "hydroponics/netcup-clean",
    "title": "Clean Net Cups",
    "description": "Sanitize net cups to keep roots disease-free.",
    "image": "/assets/quests/hydroponics_netcup_cleaning.jpg",
    "npc": "/assets/npc/hydro.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Grimy net cups spread trouble fast. We'll log a baseline, sanitize, then verify dryness before storage.",
            "options": [
                {
                    "type": "goto",
                    "goto": "mix",
                    "text": "Start cleaning cycle."
                }
            ]
        },
        {
            "id": "mix",
            "text": "Fill a bucket with dechlorinated water and stage peroxide. Wear gloves and goggles before mixing.",
            "options": [
                {
                    "type": "process",
                    "process": "bucket-water-dechlorinated",
                    "text": "Prepare rinse water"
                },
                {
                    "type": "goto",
                    "goto": "baseline",
                    "text": "Water and reagents are staged.",
                    "requiresItems": [
                        {
                            "id": "71efa72a-8c87-4dc2-8e2c-9119bb28fe50",
                            "count": 1
                        },
                        {
                            "id": "50f2080e-7dd5-4c8d-a764-dfaa02ca59c3",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "baseline",
            "text": "Baseline artifact: identify cups with algae film or trapped roots before washing so you can verify improvement after scrubbing.",
            "options": [
                {
                    "type": "goto",
                    "goto": "soak",
                    "text": "Baseline captured; mix peroxide bath.",
                    "requiresItems": [
                        {
                            "id": "50f2080e-7dd5-4c8d-a764-dfaa02ca59c3",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "contam",
                    "text": "Heavy biofilm detected; need containment first."
                }
            ]
        },
        {
            "id": "soak",
            "text": "Combine peroxide with dechlorinated water and stir until the bath is uniform.",
            "options": [
                {
                    "type": "process",
                    "process": "mix-peroxide-bath",
                    "text": "Mix the peroxide rinse"
                },
                {
                    "type": "goto",
                    "goto": "scrub",
                    "text": "Bath is mixed",
                    "requiresItems": [
                        {
                            "id": "68e50400-fa25-4459-9633-2304a67096c9",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "scrub",
            "text": "Scrub each cup, dip through the bath, then inspect for remaining residue before moving on.",
            "options": [
                {
                    "type": "process",
                    "process": "sanitize-net-cups",
                    "text": "Scrub and soak"
                },
                {
                    "type": "goto",
                    "goto": "dry",
                    "text": "Post-clean artifact: cups are visibly clear.",
                    "requiresItems": [
                        {
                            "id": "6498967e-284e-46ff-bee7-10e3907f60fd",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "contam",
                    "text": "Residue remains or peroxide looks spent."
                }
            ]
        },
        {
            "id": "contam",
            "text": "Contamination branch: discard exhausted bath safely, refresh PPE if splashed, and restart from mix with fresh solution.",
            "options": [
                {
                    "type": "goto",
                    "goto": "mix",
                    "text": "Containment complete; prepare a fresh bath."
                }
            ]
        },
        {
            "id": "dry",
            "text": "Shake off bath and air-dry cups upside down. Do not stack while damp.",
            "options": [
                {
                    "type": "process",
                    "process": "dry-net-cups",
                    "text": "Let them dry"
                },
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Bone dry and ready",
                    "requiresItems": [
                        {
                            "id": "d4a73557-e5a8-458a-80d9-6c1b46667428",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "finish",
            "text": "Great work. Baseline + post-clean artifacts confirm the sanitation cycle actually changed cup condition.",
            "options": [
                {
                    "type": "finish",
                    "text": "Net cups cleaned with verified before/after checks."
                }
            ]
        }
    ],
    "rewards": [
        {
            "id": "b281360b-2ecc-4fea-a248-36a61c5f7399",
            "count": 1
        }
    ],
