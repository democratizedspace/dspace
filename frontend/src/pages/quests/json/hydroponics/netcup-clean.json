{
    "id": "hydroponics/netcup-clean",
    "title": "Clean Net Cups",
    "description": "Run a pre/post sanitation cycle for net cups with contamination recovery checks.",
    "image": "/assets/quests/hydroponics_netcup_cleaning.jpg",
    "npc": "/assets/npc/hydro.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Dirty net cups spread pathogens. We need before/after proof, not just a quick rinse.",
            "options": [
                {
                    "type": "goto",
                    "goto": "precheck",
                    "text": "Start sanitation cycle."
                }
            ]
        },
        {
            "id": "precheck",
            "text": "Inspect cups for residue, roots, or biofilm and stage rinse water + peroxide.",
            "options": [
                {
                    "type": "process",
                    "process": "bucket-water-dechlorinated",
                    "text": "Prepare dechlorinated rinse water."
                },
                {
                    "type": "goto",
                    "goto": "mix",
                    "text": "Pre-clean state documented.",
                    "requiresItems": [
                        {
                            "id": "71efa72a-8c87-4dc2-8e2c-9119bb28fe50",
                            "count": 1
                        },
                        {
                            "id": "50f2080e-7dd5-4c8d-a764-dfaa02ca59c3",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "mix",
            "text": "Mix a measured peroxide bath and keep gloves on to avoid skin irritation.",
            "options": [
                {
                    "type": "process",
                    "process": "mix-peroxide-bath",
                    "text": "Mix sanitation bath."
                },
                {
                    "type": "goto",
                    "goto": "clean",
                    "text": "Bath mixed and labeled.",
                    "requiresItems": [
                        {
                            "id": "68e50400-fa25-4459-9633-2304a67096c9",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "clean",
            "text": "Scrub each cup, soak, then rinse until no film remains. Compare against your pre-clean state.",
            "options": [
                {
                    "type": "process",
                    "process": "sanitize-net-cups",
                    "text": "Perform scrub + soak cycle."
                },
                {
                    "type": "goto",
                    "goto": "verify",
                    "text": "Post-clean state captured.",
                    "requiresItems": [
                        {
                            "id": "6498967e-284e-46ff-bee7-10e3907f60fd",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "contamination",
                    "text": "I still see slime or odor."
                }
            ]
        },
        {
            "id": "contamination",
            "text": "Contamination branch: isolate affected cups, refresh bath, and repeat with longer contact time.",
            "options": [
                {
                    "type": "goto",
                    "goto": "mix",
                    "text": "Remix bath and retry cycle."
                },
                {
                    "type": "goto",
                    "goto": "clean",
                    "text": "Resume cleaning with corrected contact time."
                }
            ]
        },
        {
            "id": "verify",
            "text": "Air-dry upside down and verify the cups are dry, residue-free, and ready for planting.",
            "options": [
                {
                    "type": "process",
                    "process": "dry-net-cups",
                    "text": "Run drying step."
                },
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Dry and verified clean.",
                    "requiresItems": [
                        {
                            "id": "d4a73557-e5a8-458a-80d9-6c1b46667428",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "contamination",
                    "text": "Moisture or residue returned; re-enter recovery path."
                }
            ]
        },
        {
            "id": "finish",
            "text": "Excellent. You produced pre/post evidence and handled contamination safely.",
            "options": [
                {
                    "type": "finish",
                    "text": "Net cups ready."
                }
            ]
        }
    ],
    "rewards": [
        {
            "id": "b281360b-2ecc-4fea-a248-36a61c5f7399",
            "count": 1
        }
    ],
    "requiresQuests": ["hydroponics/tub-scrub"],
