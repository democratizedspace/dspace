{
    "id": "hydroponics/netcup-clean",
    "title": "Clean Net Cups",
    "description": "Sanitize net cups to keep roots disease-free.",
    "image": "/assets/quests/hydroponics_netcup_cleaning.jpg",
    "npc": "/assets/npc/hydro.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Got grimy net cups? A quick scrub prevents root rot.",
            "options": [
                {
                    "type": "goto",
                    "goto": "mix",
                    "text": "Let's clean them."
                }
            ]
        },
        {
            "id": "mix",
            "text": "Fill a bucket with dechlorinated water and mix in 5 mL of 3% hydrogen peroxide.",
            "options": [
                {
                    "type": "process",
                    "process": "bucket-water-dechlorinated",
                    "text": "Prepare rinse water"
                },
                {
                    "type": "goto",
                    "goto": "soak",
                    "text": "Water is ready",
                    "requiresItems": [
                        {
                            "id": "71efa72a-8c87-4dc2-8e2c-9119bb28fe50",
                            "count": 1
                        },
                        {
                            "id": "50f2080e-7dd5-4c8d-a764-dfaa02ca59c3",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "soak",
            "text": "Combine the peroxide with the bucketed water and give it a quick stir.",
            "options": [
                {
                    "type": "process",
                    "process": "mix-peroxide-bath",
                    "text": "Mix the peroxide rinse"
                },
                {
                    "type": "goto",
                    "goto": "scrub",
                    "text": "Bath is mixed",
                    "requiresItems": [
                        {
                            "id": "68e50400-fa25-4459-9633-2304a67096c9",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "scrub",
            "text": "Scrub each net cup, dip it through the peroxide bath, then rinse until no suds remain.",
            "options": [
                {
                    "type": "process",
                    "process": "sanitize-net-cups",
                    "text": "Scrub and soak"
                },
                {
                    "type": "goto",
                    "goto": "dry",
                    "text": "Cups look clean",
                    "requiresItems": [
                        {
                            "id": "6498967e-284e-46ff-bee7-10e3907f60fd",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "soak",
                    "text": "Need to soak again"
                }
            ]
        },
        {
            "id": "dry",
            "text": "Shake off the bath, set the net cups upside-down on a rack, and let them air dry.",
            "options": [
                {
                    "type": "process",
                    "process": "dry-net-cups",
                    "text": "Let them dry"
                },
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Bone dry and ready",
                    "requiresItems": [
                        {
                            "id": "d4a73557-e5a8-458a-80d9-6c1b46667428",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "finish",
            "text": "Great work! Let the cups dry before the next planting.",
            "options": [
                {
                    "type": "finish",
                    "text": "All set."
                }
            ]
        }
    ],
