{
    "id": "hydroponics/bucket_10",
    "title": "Bucket, we'll do it live!",
    "description": "Stage, verify, and troubleshoot a ten-bucket water haul before claiming the award.",
    "image": "/assets/quests/benchy_10.jpg",
    "npc": "/assets/npc/dChat.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Hellooooo adventurer! Water logistics wins harvests. We'll stage ten dechlorinated buckets, verify the count, and recover any spill or mix-up before we close.",
            "options": [
                {
                    "type": "goto",
                    "goto": "prep",
                    "text": "Run the ten-bucket checklist."
                }
            ]
        },
        {
            "id": "prep",
            "text": "Operational check: keep lids on while carrying, protect walkways from splash hazards, and stack no higher than shoulder height.",
            "options": [
                {
                    "type": "process",
                    "process": "stage-ten-buckets",
                    "text": "Stage ten dechlorinated buckets in the work zone."
                },
                {
                    "type": "goto",
                    "goto": "verify",
                    "text": "Ten-bucket haul staged; verify before award.",
                    "requiresItems": [
                        {
                            "id": "86b5d874-a04e-426f-be77-0f7047789faf",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "recover",
                    "text": "A bucket spilled or one was filled with untreated water."
                }
            ]
        },
        {
            "id": "verify",
            "text": "Evidence gate: no award without a confirmed ten-bucket haul artifact and safe staging conditions.",
            "options": [
                {
                    "type": "process",
                    "process": "award-hydro-haul",
                    "text": "Run verified handoff and claim the Hydro Award.",
                    "requiresItems": [
                        {
                            "id": "86b5d874-a04e-426f-be77-0f7047789faf",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Hydro Award logged from verified haul.",
                    "requiresItems": [
                        {
                            "id": "978ce094-f4fa-4b55-9e1a-2ea76531989d",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "recover",
                    "text": "Count or staging failed final check; re-stage safely."
                }
            ]
        },
        {
            "id": "recover",
            "text": "Recovery branch: isolate any contaminated bucket, mop spill paths, and rebuild the stack from confirmed dechlorinated buckets only.",
            "options": [
                {
                    "type": "goto",
                    "goto": "prep",
                    "text": "Recovery done; restage and re-verify the haul."
                }
            ]
        },
        {
            "id": "finish",
            "text": "Ahhh, you're the best, adventurer! Ten-bucket logistics complete with evidence and a safe recovery path.",
            "options": [
                {
                    "type": "finish",
                    "text": "Hydro Award secured."
                }
            ]
        }
    ],
