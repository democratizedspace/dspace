{
    "id": "hydroponics/bucket_10",
    "title": "Bucket, we'll do it live!",
    "description": "Stage a ten-bucket haul with safe lifting checks and recovery if your setup slips.",
    "image": "/assets/quests/benchy_10.jpg",
    "npc": "/assets/npc/dChat.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Hellooooo adventurer! Water mission time. We are staging ten dechlorinated buckets, but we do it safely and we prove the haul before we celebrate.",
            "options": [
                {
                    "type": "goto",
                    "goto": "plan",
                    "text": "Give me the safe haul plan."
                }
            ]
        },
        {
            "id": "plan",
            "text": "Two strategies: batch stack near the tub, or shuttle with a buddy. Either way, keep a clear path and do not carry if your grip or back feels wrong.",
            "options": [
                {
                    "type": "goto",
                    "goto": "haul",
                    "text": "Batch stack near the tub."
                },
                {
                    "type": "goto",
                    "goto": "haul",
                    "text": "Use buddy-shuttle in short trips."
                }
            ]
        },
        {
            "id": "haul",
            "text": "Run the staging process, then verify the evidence item before moving on. If buckets tip or lids leak, branch to recovery first.",
            "options": [
                {
                    "type": "process",
                    "process": "stage-ten-buckets",
                    "text": "Stage the ten buckets"
                },
                {
                    "type": "goto",
                    "goto": "recover",
                    "text": "A bucket tipped, leaked, or blocked the walkway."
                },
                {
                    "type": "goto",
                    "goto": "verify",
                    "text": "Haul staged; verify evidence.",
                    "requiresItems": [
                        {
                            "id": "86b5d874-a04e-426f-be77-0f7047789faf",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "recover",
            "text": "Recovery branch: restack by weight, clear spills, and reset your carry route. No award step until the ten-bucket haul artifact is rebuilt.",
            "options": [
                {
                    "type": "goto",
                    "goto": "haul",
                    "text": "Route is safe again; restage the haul."
                }
            ]
        },
        {
            "id": "verify",
            "text": "Good. The ten-bucket water haul artifact confirms completion of the physical work. Now cash it into the Hydro Award.",
            "options": [
                {
                    "type": "process",
                    "process": "award-hydro-haul",
                    "text": "Claim the Hydro Award",
                    "requiresItems": [
                        {
                            "id": "86b5d874-a04e-426f-be77-0f7047789faf",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Award in hand and haul area is clear.",
                    "requiresItems": [
                        {
                            "id": "978ce094-f4fa-4b55-9e1a-2ea76531989d",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "finish",
            "text": "You did it right: plan, evidence, recovery-ready, then reward. Hydration logistics unlocked!",
            "options": [
                {
                    "type": "finish",
                    "text": "Bucket operation complete."
                }
            ]
        }
    ],
    "rewards": [
