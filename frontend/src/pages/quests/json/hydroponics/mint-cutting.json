    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Mint clones are easy when the setup is controlled. We'll lock setup evidence first, then confirm post-clone stability before finishing.",
            "options": [
                {
                    "type": "goto",
                    "goto": "setup",
                    "text": "Walk me through the mint clone workflow."
                }
            ]
        },
        {
            "id": "setup",
            "text": "Setup evidence gate: stage a soaked plug, dechlorinated water, and PPE before taking the cutting.",
            "options": [
                {
                    "type": "goto",
                    "goto": "clone",
                    "text": "Setup is stable and sanitized.",
                    "requiresItems": [
                        {
                            "id": "71efa72a-8c87-4dc2-8e2c-9119bb28fe50",
                            "count": 1
                        },
                        {
                            "id": "545aeb15-7e8b-489d-be4a-af2a59f447e1",
                            "count": 1
                        },
                        {
                            "id": "997eaba9-25ee-43d5-bbdc-5d6adf03adfa",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "recover",
                    "text": "Setup is rushed or the parent stem looks stressed."
                }
            ]
        },
        {
            "id": "clone",
            "text": "Take a healthy stem and seat it in the soaked plug. Keep humidity up and avoid direct blast from fans.",
            "options": [
                {
                    "type": "process",
                    "process": "clone-mint-cutting",
                    "text": "Clone and plant the cutting."
                },
                {
                    "type": "goto",
                    "goto": "stabilize",
                    "text": "Cutting is planted; begin stabilization checks.",
                    "requiresItems": [
                        {
                            "id": "71efa72a-8c87-4dc2-8e2c-9119bb28fe50",
                            "count": 1
                        },
                        {
                            "id": "545aeb15-7e8b-489d-be4a-af2a59f447e1",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "recover",
                    "text": "Stem wilted or seating failed; branch to recovery."
                }
            ]
        },
        {
            "id": "stabilize",
            "text": "Outcome gate: hold moisture and reservoir stability through an observation window before calling this clone viable.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Cutting stayed turgid and setup remained stable.",
                    "requiresItems": [
                        {
                            "id": "545aeb15-7e8b-489d-be4a-af2a59f447e1",
                            "count": 1
                        },
                        {
                            "id": "fc2bb989-f192-4891-8bde-78ae631dae78",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "recover",
                    "text": "Leaves drooped or plug dried out during stabilization."
                }
            ]
        },
        {
            "id": "recover",
            "text": "Recovery branch: pause cloning, re-soak a fresh plug, trim to a healthier node, and wait before retrying so stress does not compound.",
            "options": [
                {
                    "type": "goto",
                    "goto": "setup",
                    "text": "Recovered and rested; restart setup gate."
                },
                {
                    "type": "goto",
                    "goto": "clone",
                    "text": "Fresh plug is ready; retry cloning path."
                }
            ]
        },
        {
            "id": "finish",
            "text": "Solid propagation cycle: setup evidence, clone execution, and stabilization checks with a stress-recovery loop.",
