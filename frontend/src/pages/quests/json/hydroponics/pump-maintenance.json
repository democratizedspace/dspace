{
    "id": "hydroponics/pump-maintenance",
    "title": "Clean Hydroponic Pump",
    "description": "Keep water moving by cleaning the pump intake.",
    "image": "/assets/hydroponics.jpg",
    "npc": "/assets/npc/hydro.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "The pump's a real workhorse. Let's clean it so flow stays strong.",
            "options": [
                { "type": "goto", "goto": "clean", "text": "I'm on it." }
