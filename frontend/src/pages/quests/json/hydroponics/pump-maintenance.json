                    "requiresItems": [{ "id": "44", "count": 1 }]
                }
            ]
        },
        {
            "id": "finish",
            "text": "Nice! A clean pump keeps water circulating and roots oxygenated.",
            "options": [{ "type": "finish", "text": "Back to growing." }]
        }
    ],
    "rewards": [],
    "requiresQuests": ["hydroponics/reservoir-refresh"]
