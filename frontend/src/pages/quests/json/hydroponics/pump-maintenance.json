            "id": "clean",
            "text": "Unplug the pump and remove the intake cover. Give everything a quick scrub and rinse.",
            "options": [
                { "type": "process", "process": "clean-pump", "text": "Scrubbing away gunk." },
                {
                    "type": "goto",
                    "goto": "finish",
