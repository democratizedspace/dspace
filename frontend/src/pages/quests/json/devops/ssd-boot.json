{
    "id": "devops/ssd-boot",
    "title": "Boot from SSD",
    "description": "Clone to SSD, validate boot order, and recover safely from boot failures.",
    "image": "/assets/quests/devops_pi_ssd_boot.jpg",
    "npc": "/assets/npc/orion.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Now we migrate to SSD for durability and speed. We'll clone, validate boot order, and keep a rollback path if firmware or NVMe detection misbehaves.",
            "options": [
                {
                    "type": "goto",
                    "goto": "preflight",
                    "text": "Run SSD migration preflight.",
                    "requiresItems": [
                        {
                            "id": "e1d61ad5-7f27-4e9b-bfc1-31853d073f5c",
                            "count": 1
                        },
                        {
                            "id": "b93065cb-d91e-4712-8edd-a6cfce5fee45",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "preflight",
            "text": "Safety stop: verify the flashed microSD still boots before cloning and confirm stable power. If baseline boot already fails, repair that first instead of layering SSD changes.",
            "options": [
                {
                    "type": "goto",
                    "goto": "clone",
                    "text": "Baseline confirmed; proceed to clone.",
                    "requiresItems": [
                        {
                            "id": "e1d61ad5-7f27-4e9b-bfc1-31853d073f5c",
                            "count": 1
                        },
                        {
                            "id": "b93065cb-d91e-4712-8edd-a6cfce5fee45",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "start",
                    "text": "Pause migration and restore baseline boot path."
                }
            ]
        },
        {
            "id": "clone",
            "text": "Run `lsblk` to identify the SSD, then `sudo rpi-clone /dev/sda`. Capture the clone summary so partition and UUID changes are documented.",
            "options": [
                {
                    "type": "process",
                    "process": "clone-os-to-ssd",
                    "text": "Clone OS image to SSD."
                },
                {
                    "type": "goto",
                    "goto": "move",
                    "text": "Clone complete with summary evidence.",
                    "requiresItems": [
                        {
                            "id": "4af856b5-b5c1-494f-8037-9b6559785633",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "move",
            "text": "Install SSD in the PoE HAT M.2 slot, set boot order for NVMe/USB, and reboot. Accept only if root filesystem mounts from SSD.",
            "options": [
                {
                    "type": "process",
                    "process": "assemble-pi-node",
                    "text": "Install HAT + SSD and reboot."
                },
                {
                    "type": "goto",
                    "goto": "verify",
                    "text": "Node boots and mounts root from SSD.",
                    "requiresItems": [
                        {
                            "id": "df7e94e2-76b9-4865-b843-2ec21feb258e",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "recover",
                    "text": "Boot order or NVMe detection failed.",
                    "requiresItems": [
                        {
                            "id": "ce140453-c7ef-42c9-b9f9-38acfb4219cf",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "recover",
            "text": "Rollback to microSD boot, re-check EEPROM version, `dtparam=nvme`, and HAT seating. Re-test one variable at a time before attempting SSD boot again.",
            "options": [
                {
                    "type": "goto",
                    "goto": "move",
                    "text": "Recovery complete; retry SSD boot path.",
                    "requiresItems": [
                        {
                            "id": "e1d61ad5-7f27-4e9b-bfc1-31853d073f5c",
                            "count": 1
                        },
                        {
                            "id": "4af856b5-b5c1-494f-8037-9b6559785633",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "verify",
            "text": "Evidence gate: capture `findmnt /` and boot diagnostics to prove rootfs is on SSD and no fallback mount occurred.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Verification evidence confirms stable SSD boot.",
                    "requiresItems": [
                        {
                            "id": "df7e94e2-76b9-4865-b843-2ec21feb258e",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "recover",
                    "text": "Evidence is inconsistent; rerun recovery and retest.",
                    "requiresItems": [
                        {
                            "id": "ce140453-c7ef-42c9-b9f9-38acfb4219cf",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "finish",
            "text": "Nice. Your node boots from SSD with a documented recovery path and verification artifact, not guesswork.",
            "options": [
                {
                    "type": "finish",
                    "text": "Continue to production launch.",
                    "requiresItems": [
                        {
                            "id": "df7e94e2-76b9-4865-b843-2ec21feb258e",
                            "count": 1
                        }
                    ]
                }
            ]
        }
    ],
    "rewards": [
        {
            "id": "b281360b-2ecc-4fea-a248-36a61c5f7399",
            "count": 1
        }
    ],
    "requiresQuests": ["devops/prepare-first-node"],
