{
    "id": "devops/prepare-first-node",
    "title": "Prepare the First Node",
    "description": "Flash the OS, harden baseline access, and verify Docker readiness with rollback checkpoints.",
    "image": "/assets/quests/devops_prepare_first_node_flash_docker.jpg",
    "npc": "/assets/npc/orion.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Let's prep node one with operator discipline: flash clean media, patch safely, and verify Docker before we trust automation.",
            "options": [
                {
                    "type": "process",
                    "process": "flash-sd-card",
                    "text": "Flash Raspberry Pi OS to microSD."
                },
                {
                    "type": "goto",
                    "goto": "safety",
                    "text": "Card flashed and booted.",
                    "requiresItems": [
                        {
                            "id": "e1d61ad5-7f27-4e9b-bfc1-31853d073f5c",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "safety",
            "text": "Before updates, confirm console fallback access and stable power. Safety stop: if you're SSH-only with no local recovery path, do not upgrade firmware yet.",
            "options": [
                {
                    "type": "goto",
                    "goto": "update",
                    "text": "Recovery access confirmed; patch baseline.",
                    "requiresItems": [
                        {
                            "id": "ce140453-c7ef-42c9-b9f9-38acfb4219cf",
                            "count": 1
                        },
                        {
                            "id": "b6fc1ed6-f399-4fdb-9f9d-3913f893f43d",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "start",
                    "text": "Pause and stage safer recovery access first."
                }
            ]
        },
        {
            "id": "update",
            "text": "Run `sudo apt update && sudo apt full-upgrade`, then `sudo rpi-eeprom-update -a`. Capture package and firmware versions in your runbook.",
            "options": [
                {
                    "type": "goto",
                    "goto": "docker",
                    "text": "System patched with version notes recorded.",
                    "requiresItems": [
                        {
                            "id": "ce140453-c7ef-42c9-b9f9-38acfb4219cf",
                            "count": 1
                        },
                        {
                            "id": "b6fc1ed6-f399-4fdb-9f9d-3913f893f43d",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "docker",
            "text": "Install Docker (`sudo apt install -y docker.io docker-compose`), add your user to the docker group, and verify `docker ps` works without sudo.",
            "options": [
                {
                    "type": "goto",
                    "goto": "verify",
                    "text": "Docker installed; verify runtime evidence.",
                    "requiresItems": [
                        {
                            "id": "ce140453-c7ef-42c9-b9f9-38acfb4219cf",
                            "count": 1
                        },
                        {
                            "id": "b6fc1ed6-f399-4fdb-9f9d-3913f893f43d",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "recover",
                    "text": "Docker permissions or daemon health failed.",
                    "requiresItems": [
                        {
                            "id": "b6fc1ed6-f399-4fdb-9f9d-3913f893f43d",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "recover",
            "text": "Classify failure (group membership, daemon not enabled, storage driver mismatch). Apply one fix at a time and re-run the verification command.",
            "options": [
                {
                    "type": "goto",
                    "goto": "verify",
                    "text": "Remediation done; rerun Docker verification.",
                    "requiresItems": [
                        {
                            "id": "b6fc1ed6-f399-4fdb-9f9d-3913f893f43d",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "verify",
            "text": "Evidence gate: verify `docker ps` and a minimal compose dry run both succeed, then log the command output in ops notes.",
            "options": [
                {
                    "type": "goto",
