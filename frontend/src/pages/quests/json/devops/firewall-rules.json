{
    "id": "devops/firewall-rules",
    "title": "Configure Firewall Rules",
    "description": "Lock down network ports to only what you need.",
    "image": "/assets/quests/devops_firewall_rules_config.jpg",
    "npc": "/assets/npc/orion.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Open ports invite trouble. First capture your current access paths so we do not lock ourselves out.",
            "options": [
                {
                    "type": "goto",
                    "goto": "setup",
                    "text": "Access map documented. Apply baseline rules.",
                    "requiresItems": [
                        {
                            "id": "df7e94e2-76b9-4865-b843-2ec21feb258e",
                            "count": 1
                        },
                        {
                            "id": "b6fc1ed6-f399-4fdb-9f9d-3913f893f43d",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "recovery",
                    "text": "I need an SSH recovery plan first."
                }
            ]
        },
        {
            "id": "setup",
            "text": "Install UFW and allow only SSH + HTTPS from approved CIDRs. Set default deny for inbound traffic.",
            "options": [
                {
                    "type": "process",
                    "process": "configure-ufw-firewall",
                    "text": "Apply UFW rules."
                },
                {
                    "type": "goto",
                    "goto": "verify",
                    "text": "Rules applied and node still reachable.",
                    "requiresItems": [
                        {
                            "id": "df7e94e2-76b9-4865-b843-2ec21feb258e",
                            "count": 1
                        },
                        {
                            "id": "b6fc1ed6-f399-4fdb-9f9d-3913f893f43d",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "verify",
            "text": "Run inbound checks from allowed and blocked networks. Capture the allowed ports list as evidence.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Only expected ports respond and SSH remains healthy.",
                    "requiresItems": [
                        {
                            "id": "df7e94e2-76b9-4865-b843-2ec21feb258e",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "recovery",
                    "text": "Unexpected port exposure or SSH instability detected."
                }
            ]
        },
        {
            "id": "recovery",
            "text": "Safety stop: restore last-known-good UFW rules via console, then reapply changes one rule at a time.",
            "options": [
                {
                    "type": "goto",
                    "goto": "setup",
                    "text": "Rollback complete. Reapply rules with narrower scope."
                },
                {
                    "type": "goto",
                    "goto": "start",
                    "text": "Pause and review the access map before retrying."
                }
            ]
        },
        {
            "id": "finish",
            "text": "Nice. Your node now exposes only approved ports, and you validated recovery paths for future rule changes.",
            "options": [
                {
                    "type": "finish",
                    "text": "System secured."
                }
            ]
        }
    ],
    "rewards": [
        {
            "id": "b281360b-2ecc-4fea-a248-36a61c5f7399",
            "count": 1
        }
    ],
    "requiresQuests": ["devops/auto-updates"],
