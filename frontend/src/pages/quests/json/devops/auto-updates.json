{
    "id": "devops/auto-updates",
    "title": "Enable Automatic Updates",
    "description": "Keep your Pi cluster secure with unattended upgrades.",
    "image": "/assets/quests/devops_enable_auto_updates.jpg",
    "npc": "/assets/npc/orion.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Patch storms happen. Plan windows so updates don't surprise the cluster.",
            "options": [
                {
                    "type": "goto",
                    "goto": "window",
                    "text": "Lock in a maintenance window."
                },
                {
                    "type": "goto",
                    "goto": "configure",
                    "text": "I already have a window.",
                    "requiresItems": [
                        {
                            "id": "abaea32a-f8d2-4688-b975-aef2f0276c20",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "window",
            "text": "Pick a quiet slot, notify players, and send reboot notices before installs.",
            "options": [
                {
                    "type": "process",
                    "process": "plan-maintenance-window",
                    "text": "Schedule the window."
                },
                {
                    "type": "goto",
                    "goto": "configure",
                    "text": "Calendar set.",
                    "requiresItems": [
                        {
                            "id": "abaea32a-f8d2-4688-b975-aef2f0276c20",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "configure",
            "text": "Enable unattended-upgrades and align reboots to your window.",
            "options": [
                {
                    "type": "process",
                    "process": "enable-unattended-upgrades",
                    "text": "Apply the policy",
                    "requiresItems": [
                        {
                            "id": "abaea32a-f8d2-4688-b975-aef2f0276c20",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "verify",
                    "text": "Policy in place.",
                    "requiresItems": [
                        {
                            "id": "4c807877-c73b-4b53-b3fc-c354b45c9759",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "verify",
            "text": "Dry run `unattended-upgrades --dry-run --debug`, then watch one reboot alert.",
            "options": [
                {
                    "type": "process",
                    "process": "verify-unattended-updates",
                    "text": "Test and log the run",
                    "requiresItems": [
                        {
                            "id": "4c807877-c73b-4b53-b3fc-c354b45c9759",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Dry run passed.",
                    "requiresItems": [
                        {
                            "id": "532e27d3-a70e-4c5e-b93b-99814bbd6274",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "finish",
            "text": "Updates flow on schedule, nodes reboot cleanly, and logs prove it.",
            "options": [
                {
                    "type": "finish",
                    "text": "Thanks, Orion."
                }
            ]
        }
    ],
    "rewards": [],
    "requiresQuests": [
        "devops/monitoring"
    ],
    "hardening": {
        "passes": 0,
