{
    "id": "devops/auto-updates",
    "title": "Enable Automatic Updates",
    "description": "Keep your Pi cluster secure with unattended upgrades.",
    "image": "/assets/quests/devops_enable_auto_updates.jpg",
    "npc": "/assets/npc/orion.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Software gets old fast. We'll stage unattended upgrades with a canary-first rollout so one bad package does not knock out the whole cluster.",
            "options": [
                {
                    "type": "goto",
                    "goto": "plan",
                    "text": "Draft a rollout plan and maintenance window.",
                    "requiresItems": [
                        {
                            "id": "df7e94e2-76b9-4865-b843-2ec21feb258e",
                            "count": 1
                        },
                        {
                            "id": "b6fc1ed6-f399-4fdb-9f9d-3913f893f43d",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "plan",
            "text": "Set policy first: security repo enabled, maintenance window documented, and canary node selected before broad rollout.",
            "options": [
                {
                    "type": "goto",
                    "goto": "canary",
                    "text": "Plan approved. Configure canary node first.",
                    "process": "configure-unattended-upgrades",
                    "requiresItems": [
                        {
                            "id": "df7e94e2-76b9-4865-b843-2ec21feb258e",
                            "count": 1
                        },
                        {
                            "id": "b6fc1ed6-f399-4fdb-9f9d-3913f893f43d",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "start",
                    "text": "Need to re-check maintenance window and on-call coverage."
                }
            ]
        },
        {
            "id": "canary",
            "text": "Run one canary cycle and capture evidence: held package count, reboot deferral state, and update completion timestamp.",
            "options": [
                {
                    "type": "goto",
                    "goto": "fleet",
                    "text": "Canary passed with clean logs.",
                    "process": "verify-unattended-upgrades",
                    "requiresItems": [
                        {
                            "id": "df7e94e2-76b9-4865-b843-2ec21feb258e",
                            "count": 1
                        },
                        {
                            "id": "d8346735-7f1c-4309-a400-6cf6801534f7",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "rollback",
                    "text": "Canary failed (held packages, reboot loop, or missed window)."
                }
            ]
        },
        {
            "id": "fleet",
            "text": "Promote settings fleet-wide only after canary success, then run one more verification pass to prove patch cadence is stable.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Fleet verification logged with stable cadence.",
                    "process": "verify-unattended-upgrades",
                    "requiresItems": [
                        {
                            "id": "df7e94e2-76b9-4865-b843-2ec21feb258e",
                            "count": 1
                        },
                        {
                            "id": "d8346735-7f1c-4309-a400-6cf6801534f7",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "rollback",
                    "text": "Fleet run exposed anomalies; trigger safety rollback."
                }
            ]
        },
        {
            "id": "rollback",
            "text": "Safety stop: freeze automatic reboots, revert to last-known-good policy, and clear held packages before retrying canary.",
            "options": [
                {
                    "type": "goto",
                    "goto": "canary",
                    "text": "Rollback complete. Re-run canary verification.",
                    "requiresItems": [
                        {
                            "id": "df7e94e2-76b9-4865-b843-2ec21feb258e",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "plan",
                    "text": "Pause rollout and tighten maintenance policy first."
                }
            ]
        },
        {
            "id": "finish",
            "text": "Great work. Updates now follow a canary-backed policy with rollback discipline and evidence at each step.",
            "options": [
                {
                    "type": "finish",
                    "text": "Queue the next maintenance window.",
                    "requiresItems": [
                        {
                            "id": "afd6a926-bd21-4242-ba79-d25fc152de03",
                            "count": 1
                        }
                    ]
                }
            ]
        }
    ],
