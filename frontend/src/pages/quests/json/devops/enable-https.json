                    ]
                }
            ]
        },
        {
            "id": "rollback-verify",
            "text": "Review rollback evidence: if control-plane access and service health are stable, retry cert issuance. If not, hold rollout and refresh lockout-prevention steps.",
            "options": [
                {
                    "type": "goto",
                    "goto": "provision",
                    "text": "Rollback is stable. Retry certificate provisioning.",
                    "requiresItems": [
                        {
                            "id": "d3d0a7bd-e338-48f1-86ab-ddcc3626cecc",
