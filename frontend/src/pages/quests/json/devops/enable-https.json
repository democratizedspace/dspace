{
    "id": "devops/enable-https",
    "title": "Secure the Cluster with HTTPS",
    "description": "Use Let's Encrypt to add TLS encryption to your services.",
    "image": "/assets/quests/devops_enable_https.jpg",
    "npc": "/assets/npc/orion.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Services are running well. Lock them behind HTTPS with a clean cert flow.",
            "options": [
                {
                    "type": "goto",
                    "goto": "dns",
                    "text": "Prep the domain."
                },
                {
                    "type": "goto",
                    "goto": "setup",
                    "text": "DNS already set.",
                    "requiresItems": [
                        {
                            "id": "af648657-73cb-47ee-bedf-b94a85489760",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "dns",
            "text": "Point DNS at the entrypoint and confirm the ACME HTTP challenge works.",
            "options": [
                {
                    "type": "process",
                    "process": "validate-cluster-domain-dns",
                    "text": "Validate DNS"
                },
                {
                    "type": "goto",
                    "goto": "setup",
                    "text": "Domain verified.",
                    "requiresItems": [
                        {
                            "id": "af648657-73cb-47ee-bedf-b94a85489760",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "setup",
            "text": "Use certbot or your ingress to request the cert, install it, and force HTTPS.",
            "options": [
                {
                    "type": "process",
                    "process": "obtain-lets-encrypt-cert",
                    "text": "Request certificate",
                    "requiresItems": [
                        {
                            "id": "af648657-73cb-47ee-bedf-b94a85489760",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "renew",
                    "text": "TLS live.",
                    "requiresItems": [
                        {
                            "id": "69858574-cf03-4524-a50a-66e4af500282",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "renew",
            "text": "Add a timer to renew early and alert if renewal fails.",
            "options": [
                {
                    "type": "process",
                    "process": "configure-cert-renewal",
                    "text": "Wire up renewal",
                    "requiresItems": [
                        {
                            "id": "69858574-cf03-4524-a50a-66e4af500282",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Renewal tested.",
                    "requiresItems": [
                        {
                            "id": "bec8f726-343e-46f3-9973-5866b42102bc",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "finish",
            "text": "Excellent! Traffic is encrypted and renewals run on autopilot.",
            "options": [
                {
                    "type": "finish",
                    "text": "All set"
                }
            ]
        }
    ],
