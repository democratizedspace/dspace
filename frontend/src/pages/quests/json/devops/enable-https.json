                    ]
                },
                {
                    "type": "goto",
                    "goto": "rollback",
                    "text": "Verification failed or users report certificate warnings."
                }
            ]
        },
        {
            "id": "rollback",
            "text": "Safety stop: restore a known-good web config, keep admin access reachable, then capture rollback TLS health output before reissuing certificates.",
            "options": [
                {
                    "type": "process",
                    "process": "verify-https-service",
                    "text": "Capture rollback TLS health output (HTTPS service reachable with expected rollback configuration)."
                },
                {
                    "type": "goto",
                    "goto": "rollback-verify",
                    "text": "Rollback checks captured. Decide whether to retry issuance or pause.",
                    "requiresItems": [
                        {
                            "id": "df7e94e2-76b9-4865-b843-2ec21feb258e",
                            "count": 1
