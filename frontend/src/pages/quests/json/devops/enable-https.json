    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Your services are running well. Before touching certs, confirm you still have console access and a rollback path.",
            "options": [
                {
                    "type": "goto",
                    "goto": "provision",
                    "text": "Console access confirmed. Stage certbot.",
