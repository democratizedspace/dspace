                            "id": "df7e94e2-76b9-4865-b843-2ec21feb258e",
                            "count": 1
                        },
                        {
                            "id": "afd6a926-bd21-4242-ba79-d25fc152de03",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "lockout-plan",
                    "text": "I do not have recovery access yet."
                }
            ]
        },
        {
            "id": "lockout-plan",
            "text": "Good catch. Never flip TLS on a production node without recovery. Validate local console + DNS control first.",
            "options": [
                {
                    "type": "goto",
                    "goto": "start",
                    "text": "Recovery path documented. Continue with certbot."
                }
            ]
        },
        {
            "id": "provision",
            "text": "Open 80/443, prove DNS ownership, and fetch a certbot RSA + ECDSA pair with a post-renew hook.",
            "options": [
                {
                    "type": "goto",
                    "goto": "verify",
                    "text": "Certificates minted.",
                    "process": "request-letsencrypt-cert",
                    "requiresItems": [
                        {
                            "id": "df7e94e2-76b9-4865-b843-2ec21feb258e",
                            "count": 1
                        },
                        {
                            "id": "afd6a926-bd21-4242-ba79-d25fc152de03",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "start",
                    "text": "Need to double-check DNS TXT records."
                }
            ]
        },
        {
            "id": "verify",
            "text": "Run a renewal dry-run and validate browser trust from outside your LAN before closing this task.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "TLS health verified with clean chain and renewal output.",
                    "process": "verify-https-service",
