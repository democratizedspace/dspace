        {
            "id": "safety",
            "text": "Safety checkpoint: keep power disconnected while mounting the HAT and SSD, then verify airflow path is unobstructed before first boot.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Safety checks complete and assembly checklist signed.",
