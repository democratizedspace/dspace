            "text": "Now that SSH is hardened, we'll add Fail2ban with explicit evidence: configure jail policy, validate ban telemetry, and rehearse safe recovery.",
            "options": [
                {
                    "type": "goto",
                    "goto": "stage",
                    "text": "Stage a fail2ban policy.",
                    "requiresItems": [
                        {
                            "id": "df7e94e2-76b9-4865-b843-2ec21feb258e",
                            "count": 1
