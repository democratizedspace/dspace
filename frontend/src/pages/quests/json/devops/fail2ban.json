                        }
                    ]
                }
            ]
        },
        {
            "id": "recover",
            "text": "Classify the failure (clock skew, over-aggressive ban window, missing log backend), capture incident notes, relax thresholds safely, then re-run verification.",
            "options": [
                {
                    "type": "process",
                    "process": "sysadmin-logs-tail-incident-extract",
                    "text": "Record mitigation and rollback details."
                },
                {
                    "type": "goto",
                    "goto": "verify",
                    "text": "Mitigation applied; verify again.",
                    "requiresItems": [
                        {
                            "id": "d00078e7-1098-4f78-9a96-9fa1f6ef615c",
                            "count": 1
                        }
                    ]
                }
            ]
