                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "canary",
                    "text": "Run a canary dry-run before cluster-wide rollout.",
                    "requiresItems": [
                        {
                            "id": "df7e94e2-76b9-4865-b843-2ec21feb258e",
                            "count": 1
                        },
                        {
                            "id": "b6fc1ed6-f399-4fdb-9f9d-3913f893f43d",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "canary",
            "text": "Canary path: apply allowlist and mild ban thresholds on one node, then observe whether trusted admin IPs remain unbanned before full rollout.",
            "options": [
                {
                    "type": "process",
                    "process": "sysadmin-logs-export-journalctl-report",
                    "text": "Capture canary baseline report."
                },
                {
                    "type": "goto",
                    "goto": "stage",
                    "text": "Canary evidence looks safe. Promote policy cluster-wide.",
                    "requiresItems": [
                        {
                            "id": "13061ba3-25af-4548-aab5-eee8bffad8fe",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "recover",
                    "text": "Canary shows lockout risk with evidence captured. Enter recovery before rollout.",
                    "requiresItems": [
                        {
                            "id": "13061ba3-25af-4548-aab5-eee8bffad8fe",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "stage",
            "text": "Set jail thresholds (`maxretry`, `findtime`, `bantime`) and maintain one out-of-band admin path. Safety stop: if this node is your only remote entrypoint, do not enable bans until console fallback is confirmed.",
            "options": [
                {
                    "type": "process",
                    "process": "configure-ufw-firewall",
                    "text": "Apply baseline firewall host policy."
                },
                {
                    "type": "goto",
                    "goto": "verify",
                    "text": "Policy staged; capture ban evidence.",
                    "requiresItems": [
                        {
                            "id": "df7e94e2-76b9-4865-b843-2ec21feb258e",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "verify",
            "text": "Trigger controlled failed logins from a test source and export logs that show ban action plus unban timing. Pass only when legitimate admin access still works.",
            "options": [
                {
                    "type": "process",
                    "process": "sysadmin-logs-export-journalctl-report",
                    "text": "Export fail2ban verification report."
                },
                {
                    "type": "goto",
                    "goto": "policy-tune",
                    "text": "Ban evidence exists, but false positives hit trusted admin sources.",
                    "requiresItems": [
                        {
                            "id": "13061ba3-25af-4548-aab5-eee8bffad8fe",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "recover",
                    "text": "Ban evidence missing or admin access degraded.",
                    "requiresItems": [
                        {
                            "id": "13061ba3-25af-4548-aab5-eee8bffad8fe",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Ban telemetry and admin access both pass.",
                    "requiresItems": [
                        {
                            "id": "13061ba3-25af-4548-aab5-eee8bffad8fe",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "policy-tune",
            "text": "Tune jail policy: add allowlisted admin ranges, reduce bantime for false positives, and document why each threshold changed.",
            "options": [
                {
                    "type": "process",
                    "process": "sysadmin-logs-tail-incident-extract",
                    "text": "Record policy-tuning changes and expected side effects."
                },
                {
                    "type": "goto",
                    "goto": "verify",
                    "text": "Tuning captured. Re-run controlled login failure tests.",
