        {
            "id": "deploy",
            "text": "Run `docker compose up -d --build`, confirm expected services, and keep a shell ready for `docker compose down` rollback if resources spike.",
            "options": [
                {
                    "type": "process",
                    "process": "run-docker-compose",
                    "text": "Build and run containers."
