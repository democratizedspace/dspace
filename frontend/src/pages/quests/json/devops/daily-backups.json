{
    "id": "devops/daily-backups",
    "title": "Configure Daily Backups",
    "description": "Use a cron job to archive your game data each night.",
    "image": "/assets/quests/devops_daily_backups_cron.jpg",
    "npc": "/assets/npc/orion.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Let's protect your work with backup discipline. First choose a retention plan before writing cron automation.",
            "options": [
                {
                    "type": "goto",
                    "goto": "script",
                    "text": "Use daily full backups plus weekly off-site sync.",
                    "requiresItems": [
                        {
                            "id": "849eb5e1-9f63-488b-80d3-913492049090",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "script",
                    "text": "Use daily incremental backups with monthly restore drill.",
                    "requiresItems": [
                        {
                            "id": "849eb5e1-9f63-488b-80d3-913492049090",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "script",
            "text": "Configure cron for nightly `pg_dumpall`, checksum each archive, and mirror the latest dump to external storage.",
            "options": [
                {
                    "type": "process",
                    "process": "configure-daily-backups",
                    "text": "Install backup script and cron schedule."
                },
                {
                    "type": "goto",
                    "goto": "verify",
                    "text": "Backup automation configured.",
                    "requiresItems": [
                        {
                            "id": "849eb5e1-9f63-488b-80d3-913492049090",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "verify",
            "text": "Evidence gate: capture backup logs showing timestamp, checksum status, and restore-test result from the latest archive.",
            "options": [
                {
                    "type": "process",
                    "process": "sysadmin-logs-export-journalctl-report",
                    "text": "Capture backup verification report."
                },
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Logs confirm a good backup and successful restore drill.",
                    "requiresItems": [
                        {
                            "id": "13061ba3-25af-4548-aab5-eee8bffad8fe",
                            "count": 1
                        },
                        {
                            "id": "849eb5e1-9f63-488b-80d3-913492049090",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "recovery",
                    "text": "Missing dump, checksum mismatch, or restore failure detected.",
                    "requiresItems": [
                        {
                            "id": "13061ba3-25af-4548-aab5-eee8bffad8fe",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "recovery",
            "text": "Safety stop: pause pruning jobs, keep the last known-good snapshot read-only, and fix retention scripts before resuming nightly writes.",
            "options": [
                {
                    "type": "process",
                    "process": "sysadmin-logs-tail-incident-extract",
                    "text": "Record the backup incident and corrective actions."
                },
                {
                    "type": "goto",
                    "goto": "verify",
                    "text": "Corrective actions complete. Re-run verification window.",
                    "requiresItems": [
                        {
                            "id": "d00078e7-1098-4f78-9a96-9fa1f6ef615c",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "finish",
            "text": "Backups are now deterministic, verified, and recoverable under failure conditions.",
            "options": [
                {
                    "type": "finish",
                    "text": "Backup plan locked in."
                }
            ]
        }
    ],
