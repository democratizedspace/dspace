    "dialogue": [
        {
            "id": "start",
            "text": "Phoenix here. Suit up: lab coat, nitrile gloves, goggles. In a spill tray, set 100 mL water in a 250 mL beaker with a stir rod, pH strip, and the 37% HCl bottle. Acid goes into water, always.",
            "options": [
                {
                    "type": "goto",
                    "goto": "dilute",
                    "text": "PPE on and workstation ready."
                }
            ]
        },
        {
            "id": "dilute",
            "text": "Slowly trickle 10 mL of HCl down the beaker wall while stirring. Face back, pace slow, then verify with a pH strip.",
            "options": [
                {
                    "type": "process",
                    "process": "wash-hands",
                    "text": "Rinsing any splashes."
                },
                {
                    "type": "goto",
                    "goto": "finish",
