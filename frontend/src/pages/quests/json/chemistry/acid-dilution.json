                {
                    "type": "goto",
                    "goto": "dilute",
                    "text": "Gear on and ready."
                }
            ]
        },
        {
            "id": "dilute",
            "text": "Trickle 10 mL of hydrochloric acid down the beaker wall while stirring. Keep your face back, go slow, and check the mixture with a pH strip.",
