{
    "id": "chemistry/ph-adjustment",
    "title": "Adjust Solution pH",
    "description": "Bring a nutrient solution into range using acid or base.",
    "image": "/assets/quests/chemistry_ph_adjustment_nutrient_solution.jpg",
    "npc": "/assets/npc/phoenix.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Phoenix here. We do this like a lab: baseline reading, controlled adjustment, then verification before we trust the batch.",
            "options": [
                {
                    "type": "goto",
                    "goto": "baseline",
                    "text": "Run baseline measurement with PPE on.",
                    "requiresItems": [
                        {
                            "id": "997eaba9-25ee-43d5-bbdc-5d6adf03adfa",
                            "count": 1
                        },
                        {
                            "id": "c9b51052-4594-42d7-a723-82b815ab8cc2",
                            "count": 1
                        },
                        {
                            "id": "e1714868-aa17-4f04-ac09-13ac4d7ecea0",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "baseline",
            "text": "Capture a pH reading before dosing anything. Record the number so your correction has context.",
            "options": [
                {
                    "type": "process",
                    "process": "measure-ph",
                    "text": "Measure baseline pH."
                },
                {
                    "type": "goto",
                    "goto": "interpret",
                    "text": "Baseline recorded, interpret before adjusting.",
                    "requiresItems": [
                        {
                            "id": "13167d6a-5617-4931-8a6e-6f463c6b8835",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "interpret",
            "text": "Target band is pH 6.0-7.2. If you're inside it, preserve the batch. If outside, do micro-dosing corrections and re-test.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Reading is within 6.0-7.2; no further adjustment needed.",
                    "requiresItems": [
                        {
                            "id": "13167d6a-5617-4931-8a6e-6f463c6b8835",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "adjust",
                    "text": "Out of range: run a correction pass."
                }
            ]
        },
        {
            "id": "adjust",
            "text": "Add tiny doses of pH down or pH up, stir fully, and pause before retesting. No large swings.",
            "options": [
                {
                    "type": "process",
                    "process": "adjust-ph",
                    "text": "Run controlled pH adjustment."
                },
                {
                    "type": "goto",
                    "goto": "retest",
                    "text": "Adjustment complete, collect verification reading.",
                    "requiresItems": [
                        {
                            "id": "997eaba9-25ee-43d5-bbdc-5d6adf03adfa",
                            "count": 1
                        },
                        {
                            "id": "c9b51052-4594-42d7-a723-82b815ab8cc2",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "safety-stop",
                    "text": "Unexpected heat or clouding appeared; pause and secure the bench."
                }
            ]
        },
        {
            "id": "retest",
            "text": "Retest and compare against target band. Re-enter correction loop if still out of range.",
            "options": [
                {
                    "type": "process",
                    "process": "measure-ph",
                    "text": "Take post-adjustment pH reading."
                },
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Verification is inside 6.0-7.2.",
                    "requiresItems": [
                        {
                            "id": "13167d6a-5617-4931-8a6e-6f463c6b8835",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "adjust",
                    "text": "Still out of range; apply another micro-dose and re-test."
                }
            ]
        },
        {
            "id": "safety-stop",
            "text": "Good stop-work call. Rinse exposed surfaces, document the anomaly, and only resume with fresh PPE and tools.",
            "options": [
                {
                    "type": "process",
                    "process": "wash-hands",
                    "text": "Decontaminate and reset."
                },
                {
                    "type": "goto",
                    "goto": "baseline",
                    "text": "Bench reset complete; restart from baseline measurement."
                }
            ]
        },
        {
            "id": "finish",
            "text": "Balanced and verified. You used evidence, not guesswork, and left a reproducible trail.",
            "options": [
                {
                    "type": "finish",
                    "text": "Chemistry in harmony.",
                    "requiresItems": [
                        {
                            "id": "13167d6a-5617-4931-8a6e-6f463c6b8835",
                            "count": 1
                        }
                    ]
                }
            ]
        }
    ],
    "rewards": [
        {
            "id": "b281360b-2ecc-4fea-a248-36a61c5f7399",
            "count": 1
        }
    ],
    "requiresQuests": ["chemistry/buffer-solution"],
