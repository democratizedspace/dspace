                    "goto": "baseline",
                    "text": "Capture baseline and PPE checks."
                }
            ]
        },
        {
            "id": "baseline",
            "text": "Baseline gate: confirm PPE and collect a fresh pH reading before choosing an adjustment strategy.",
            "options": [
                {
                    "type": "process",
                    "process": "measure-ph",
                    "text": "Measure current pH."
                },
                {
                    "type": "goto",
                    "goto": "strategy",
                    "text": "Baseline reading logged and PPE confirmed.",
