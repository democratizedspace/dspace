                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "strategy",
            "text": "Choose a correction route: direct dose for minor drift, or buffered correction if readings keep overshooting.",
            "options": [
                {
                    "type": "goto",
                    "goto": "direct-dose",
                    "text": "Main path: direct micro-dose correction."
                },
                {
                    "type": "goto",
                    "goto": "buffered-correction",
                    "text": "Alternate path: buffered correction for unstable swings."
                }
            ]
        },
        {
            "id": "direct-dose",
            "text": "Add tiny acid/base increments, stir fully, then re-measure. Stop if readings swing more than expected.",
            "options": [
                {
                    "type": "process",
                    "process": "adjust-ph",
                    "text": "Run direct correction pass."
                },
                {
                    "type": "goto",
                    "goto": "interpret",
                    "text": "Correction applied; interpret the new reading.",
                    "requiresItems": [
                        {
                            "id": "13167d6a-5617-4931-8a6e-6f463c6b8835",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "recovery",
                    "text": "Overshoot or unknown contamination detected."
                }
            ]
        },
        {
            "id": "buffered-correction",
            "text": "Use a diluted correction mix to reduce overshoot risk, then re-check after full circulation.",
            "options": [
                {
                    "type": "process",
                    "process": "adjust-ph",
                    "text": "Run buffered correction pass."
                },
                {
                    "type": "goto",
                    "goto": "interpret",
                    "text": "Buffered pass complete; interpret reading.",
                    "requiresItems": [
                        {
                            "id": "13167d6a-5617-4931-8a6e-6f463c6b8835",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "recovery",
                    "text": "Reading still unstable; recover before retry."
                }
            ]
        },
        {
            "id": "interpret",
            "text": "Interpretation gate: accept only if pH is in target range and trend is stable across repeat checks. Otherwise trigger corrective recovery.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Reading is in range and stable.",
                    "requiresItems": [
                        {
                            "id": "13167d6a-5617-4931-8a6e-6f463c6b8835",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "recovery",
                    "text": "Out of range or drifting; run recovery loop."
                }
            ]
        },
        {
            "id": "recovery",
            "text": "Safety stop: halt dosing, flush stirring tools, and confirm reagent labels before any retry. If the second pass still fails, escalate and pause the batch.",
            "options": [
                {
                    "type": "process",
                    "process": "wash-hands",
                    "text": "Run cleanup and reset procedure."
                },
                {
                    "type": "goto",
                    "goto": "baseline",
                    "text": "Reset complete; take a fresh baseline measurement."
                }
            ]
        },
        {
            "id": "finish",
            "text": "Great. You logged baseline evidence, interpreted retest data, and used recovery controls instead of forcing the chemistry.",
            "options": [
                {
                    "type": "finish",
                    "text": "Chemistry in harmony."
                }
            ]
        }
