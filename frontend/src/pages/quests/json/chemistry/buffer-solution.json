                {
                    "type": "process",
                    "process": "chemistry-stage-buffer-formulation",
                    "text": "Run buffer formulation worksheet prep process."
                },
                {
                    "type": "goto",
                    "goto": "choose-path",
                    "text": "Protocol staged and logged; continue experiment.",
