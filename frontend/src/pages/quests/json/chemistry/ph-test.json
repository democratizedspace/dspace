    "dialogue": [
        {
            "id": "start",
            "text": "Before working with reactive solutions, stage PPE and controls. Put on nitrile gloves, goggles, and a lab coat, keep spill neutralizer nearby, and confirm the bench is dry and labeled.",
            "options": [
                {
                    "type": "goto",
                    "goto": "measure",
                    "text": "Safety setup complete\u2014start the pH measurement run."
                }
            ]
        },
        {
            "id": "measure",
            "text": "Dip a fresh strip for one second, compare to the chart immediately, and record the observed value. Keep your face back from the vessel and avoid cross-contaminating the strip packet.",
            "options": [
                {
                    "type": "process",
                    "process": "measure-ph",
                    "text": "Run `measure-ph` and capture a reading artifact."
                },
                {
                    "type": "goto",
                    "goto": "interpret",
                    "text": "I logged a stable reading and kept PPE on.",
                    "requiresItems": [
                        {
                            "id": "5456a6a5-5da9-46a0-aa4e-a74b6814404a",
                            "count": 1
                        },
                        {
                            "id": "997eaba9-25ee-43d5-bbdc-5d6adf03adfa",
                            "count": 1
                        },
                        {
                            "id": "c9b51052-4594-42d7-a723-82b815ab8cc2",
                            "count": 1
                        },
                        {
                            "id": "3455faac-8811-4991-b818-cecb98e8fff7",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "troubleshoot",
                    "text": "Color band is ambiguous or drifting\u2014need troubleshooting."
                }
            ]
        },
        {
            "id": "interpret",
            "text": "Interpret the reading: target operating window is pH 6.0\u20137.5 for this training solution. Choose the branch that matches your logged result.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Reading is in-range (6.0\u20137.5); safe to proceed.",
                    "requiresItems": [
                        {
                            "id": "5456a6a5-5da9-46a0-aa4e-a74b6814404a",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "troubleshoot",
                    "text": "Reading is out-of-range (<6.0 or >7.5); initiate corrective loop."
                }
            ]
        },
        {
            "id": "troubleshoot",
            "text": "Stop and stabilize: cap reagents, wipe spills, and replace gloves if contaminated. Re-mix gently, wait 30 seconds, then retest with a fresh strip. If the second reading still drifts, pause the experiment and escalate.",
            "options": [
                {
                    "type": "goto",
                    "goto": "measure",
                    "text": "Corrective actions complete\u2014retest now."
                },
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Escalated safely and logged a deferred run for supervisor review."
                }
            ]
        },
        {
            "id": "finish",
            "text": "Good lab discipline. You captured measurement evidence, interpreted against explicit bounds, and used a safe recovery path when readings were unreliable.",
            "options": [
                {
                    "type": "finish",
                    "text": "pH check complete."
                }
            ]
        }
