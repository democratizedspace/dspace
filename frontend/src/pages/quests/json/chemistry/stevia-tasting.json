{
    "id": "chemistry/stevia-tasting",
    "title": "Taste Test Stevia Crystals",
    "description": "Evaluate the sweetness of your freshly made stevia crystals.",
    "image": "/assets/quests/stevia-tasting.jpg",
    "npc": "/assets/npc/phoenix.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Your extraction held together, nice work. For tasting, we separate setup evidence from outcome evidence so bias doesn't contaminate decisions.",
            "options": [
                {
                    "type": "goto",
                    "goto": "setup-route",
                    "text": "Gloves and goggles on.",
                    "requiresItems": [
                        {
                            "id": "997eaba9-25ee-43d5-bbdc-5d6adf03adfa",
                            "count": 1
                        },
                        {
                            "id": "c9b51052-4594-42d7-a723-82b815ab8cc2",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "setup-route",
            "text": "Choose your prep route: precision single-sample or comparative panel. Either way, produce a labeled tasting solution artifact first.",
            "options": [
                {
                    "type": "goto",
                    "goto": "precision-setup",
                    "text": "Run precision single-sample prep."
                },
                {
                    "type": "goto",
                    "goto": "panel-setup",
                    "text": "Run comparative panel prep."
                }
            ]
        },
        {
            "id": "precision-setup",
            "text": "Rinse tools, prepare a 1% solution, and label concentration plus timestamp.",
            "options": [
                {
                    "type": "process",
                    "process": "mix-stevia-tasting-solution",
                    "text": "Mix precision tasting solution."
                },
                {
                    "type": "goto",
                    "goto": "outcome-check",
                    "text": "Setup artifact captured; proceed to outcome check.",
                    "requiresItems": [
                        {
                            "id": "d8e22b52-4807-4f8d-b901-5aee64a5770c",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "panel-setup",
            "text": "Prepare stevia and control samples side-by-side so you can compare sweetness onset and aftertaste fairly.",
            "options": [
                {
                    "type": "process",
                    "process": "mix-stevia-tasting-solution",
                    "text": "Mix comparative tasting solution."
                },
                {
                    "type": "goto",
                    "goto": "outcome-check",
                    "text": "Comparative setup ready; move to blind taste logging.",
                    "requiresItems": [
                        {
                            "id": "d8e22b52-4807-4f8d-b901-5aee64a5770c",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "outcome-check",
            "text": "Run blind tasting and log sweetness, aftertaste, and onset timing. Outcome evidence must exist before completion.",
            "options": [
                {
                    "type": "process",
                    "process": "record-stevia-tasting-notes",
                    "text": "Record tasting outcome notes."
                },
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Outcome artifact logged with clear notes.",
                    "requiresItems": [
                        {
                            "id": "fe146f9d-d912-4841-bf1f-1675c3aa93f3",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "recovery",
                    "text": "Panel reported bitterness spike or contaminated cup; run recovery branch."
                }
            ]
        },
        {
            "id": "recovery",
            "text": "Abort the tasting round, sanitize glassware, and re-mix a fresh sample. If two retries fail, defer to next day to avoid palate fatigue bias.",
            "options": [
                {
                    "type": "process",
                    "process": "wash-hands",
                    "text": "Sanitize station and reset protocol."
                },
                {
                    "type": "goto",
                    "goto": "setup-route",
                    "text": "Recovery complete; retry with fresh sample."
                },
                {
                    "type": "goto",
                    "goto": "setup-route",
                    "text": "Defer tasting until next session, then restart with fresh setup evidence."
                }
            ]
        },
        {
            "id": "finish",
            "text": "Great notes. You now have both setup and outcome artifacts to tune extraction toward cleaner sweetness.",
            "options": [
                {
                    "type": "finish",
                    "text": "Ready for the next batch.",
                    "requiresItems": [
                        {
                            "id": "fe146f9d-d912-4841-bf1f-1675c3aa93f3",
                            "count": 1
                        }
                    ]
                }
            ]
        }
    ],
