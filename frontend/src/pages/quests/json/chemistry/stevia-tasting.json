{
    "id": "chemistry/stevia-tasting",
    "title": "Taste Test Stevia Crystals",
    "description": "Evaluate the sweetness of your freshly made stevia crystals.",
    "image": "/assets/quests/dCarbon.jpg",
    "npc": "/assets/npc/phoenix.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Your extraction went well. Let's taste a measured dilution and record the sweetness profile.",
            "options": [
                {
                    "type": "goto",
                    "goto": "setup",
                    "text": "Sure!"
                }
            ]
        },
        {
            "id": "setup",
            "text": "Grab clean glassware and water so your palate reads the stevia, not the sink.",
            "options": [
                {
                    "type": "process",
                    "process": "sink",
                    "text": "Find the tap and rinse your beaker."
                },
                {
                    "type": "goto",
                    "goto": "mix",
                    "text": "Glassware is clean and water is ready.",
                    "requiresItems": [
                        {
                            "id": "799ace33-1336-46c0-904a-9f16778230f1",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "mix",
            "text": "Measure a small dose of stevia crystals into water, stir until fully dissolved, and keep a second rinse cup nearby.",
            "options": [
                {
                    "type": "process",
                    "process": "prepare-stevia-tasting-solution",
                    "text": "Dilute the tasting solution and label the cup."
                },
                {
                    "type": "goto",
                    "goto": "compare",
                    "text": "Solution mixed and clear.",
                    "requiresItems": [
                        {
                            "id": "7a3c69a9-7c14-4f0d-b960-894f69ecaad5",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "compare",
            "text": "Sip the dilution, rinse, then sip again a few minutes later. Note sweetness onset, aftertaste, and any lingering bitterness.",
            "options": [
                {
                    "type": "process",
                    "process": "log-stevia-tasting-notes",
                    "text": "Capture your tasting notes and preferred dilution.",
                    "requiresItems": [
                        {
                            "id": "7a3c69a9-7c14-4f0d-b960-894f69ecaad5",
                            "count": 1
                        },
                        {
                            "id": "70bb8d86-2c4e-4330-9705-371891934686",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Notes logged with your preferred ratio.",
                    "requiresItems": [
                        {
                            "id": "bb8831a3-9279-4973-8849-06a2266f8e70",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "finish",
            "text": "Solid tasting work! Your dilution notes make future batches repeatable and help compare stevia to other sweeteners.",
            "options": [
                {
                    "type": "finish",
                    "text": "Looking forward to it.",
                    "requiresItems": [
                        {
                            "id": "bb8831a3-9279-4973-8849-06a2266f8e70",
                            "count": 1
                        }
                    ]
                }
            ]
        }
    ],
