{
    "id": "chemistry/safe-reaction",
    "title": "Demonstrate a Safe Chemical Reaction",
    "description": "Run a documented baking-soda and vinegar reaction with explicit equipment checks, measured additions, and logged containment outcomes.",
    "image": "/assets/quests/safe_eco_propellant_reaction.jpg",
    "npc": "/assets/npc/phoenix.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Phoenix here. Before any fizz, lay out the exact kit: 250 mL beaker, 100 mL graduated cylinder, nitrile gloves, goggles, and a labeled waste cup.",
            "options": [
                {
                    "type": "process",
                    "process": "chemistry-stage-safe-reaction-bench",
                    "text": "Run bench staging checklist and sign equipment setup sheet."
                },
                {
                    "type": "goto",
                    "goto": "dose",
                    "text": "Bench staged and checklist signed.",
                    "requiresItems": [
                        {
                            "id": "8175bd25-244c-433e-b39d-2af223ccbc91",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "dose",
            "text": "Measure 40 mL vinegar in the cylinder and 5 g sodium bicarbonate on weigh paper. Keep vessel pointed away from faces and vents.",
            "options": [
                {
                    "type": "process",
                    "process": "chemistry-dose-safe-reaction-reagents",
                    "text": "Pre-dose reactants and seal dosing tray."
                },
                {
                    "type": "goto",
                    "goto": "run",
                    "text": "Reagents measured and isolated in dosing tray.",
                    "requiresItems": [
                        {
                            "id": "ab36e88b-285a-4ff3-8abd-d73dbb7c3491",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "run",
            "text": "Charge bicarbonate into vinegar in three additions while swirling. Capture overflow in the secondary beaker and pause if foaming exceeds one third headspace.",
            "options": [
                {
                    "type": "process",
                    "process": "run-safe-fizz-reaction",
                    "text": "Execute controlled fizz reaction run."
                },
                {
                    "type": "goto",
                    "goto": "verify",
                    "text": "Reaction sample captured for verification.",
                    "requiresItems": [
                        {
                            "id": "092afbdb-1c9b-4e08-9498-20e4f2ba5f93",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "verify",
            "text": "Record bubble duration, max foam height, and residue state. Only complete when the reaction log and sample both exist.",
            "options": [
                {
                    "type": "process",
                    "process": "log-safe-reaction",
                    "text": "Write observation log with timing and residue notes."
                },
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Sample + log complete and hazard-free shutdown confirmed.",
                    "requiresItems": [
                        {
                            "id": "092afbdb-1c9b-4e08-9498-20e4f2ba5f93",
                            "count": 1
                        },
                        {
                            "id": "265f7c6d-c345-44af-936c-8bba8ea08de2",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "finish",
            "text": "Excellent. You controlled dosing, documented equipment, and proved the outcome with traceable records.",
            "options": [
                {
                    "type": "finish",
                    "text": "Reaction complete."
                }
            ]
        }
    ],
