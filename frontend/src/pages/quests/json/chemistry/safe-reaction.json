{
    "id": "chemistry/safe-reaction",
    "title": "Demonstrate a Safe Chemical Reaction",
    "description": "Phoenix guides you through PPE checks, reaction prep, and logging for a safe fizz-reaction demo.",
    "image": "/assets/quests/safe_eco_propellant_reaction.jpg",
    "npc": "/assets/npc/phoenix.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Phoenix here. Today we prove control, not chaos: prep safely, pick a reaction route, and log what the chemistry tells you.",
            "options": [
                {
                    "type": "goto",
                    "goto": "safety",
                    "text": "Proceed with lab safety checks."
                }
            ]
        },
        {
            "id": "safety",
            "text": "Before mixing, confirm PPE and clean tools. Gloves, goggles, beaker, and cylinder are non-negotiable.",
            "options": [
                {
                    "type": "goto",
                    "goto": "route-select",
                    "text": "Safety gear is on and tools are ready.",
                    "requiresItems": [
                        {
                            "id": "997eaba9-25ee-43d5-bbdc-5d6adf03adfa",
                            "count": 1
                        },
                        {
                            "id": "c9b51052-4594-42d7-a723-82b815ab8cc2",
                            "count": 1
                        },
                        {
                            "id": "10fab5e7-036b-4f8f-9f35-84117bc8ef09",
                            "count": 1
                        },
                        {
                            "id": "4d1a3894-e471-4483-8ae6-c6e12db1afae",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "route-select",
            "text": "Choose your demonstration mode. Open-beaker is easiest to observe. Controlled-capture emphasizes disciplined gas handling.",
            "options": [
                {
                    "type": "goto",
                    "goto": "open-beaker",
                    "text": "Run open-beaker observation route."
                },
                {
                    "type": "goto",
                    "goto": "controlled-capture",
                    "text": "Run controlled-capture route."
                }
            ]
        },
        {
            "id": "open-beaker",
            "text": "Run the fizz protocol in an open vessel and watch for controlled bubble formation and safe temperature behavior.",
            "options": [
                {
                    "type": "process",
                    "process": "run-safe-fizz-reaction",
                    "text": "Execute open-beaker protocol."
                },
                {
                    "type": "goto",
                    "goto": "verify",
                    "text": "Reaction remained controlled; move to verification and logging."
                },
                {
                    "type": "goto",
                    "goto": "troubleshoot",
                    "text": "Foam rise or splash risk detected; move to recovery path."
                }
            ]
        },
        {
            "id": "controlled-capture",
            "text": "Run a slower dosing cadence focused on consistent gas generation and stable handling.",
            "options": [
                {
                    "type": "process",
                    "process": "run-safe-fizz-reaction",
                    "text": "Execute controlled-capture protocol."
                },
                {
                    "type": "goto",
                    "goto": "verify",
                    "text": "Capture route completed with stable behavior; move to verification and logging."
                },
                {
                    "type": "goto",
                    "goto": "troubleshoot",
                    "text": "Pressure or bubbling looked unstable; stop and troubleshoot."
                }
            ]
        },
        {
            "id": "troubleshoot",
            "text": "Good catch. Pause additions, vent safely, and decontaminate surfaces before any retry. If repeat instability occurs, escalate instead of improvising.",
            "options": [
                {
                    "type": "process",
                    "process": "wash-hands",
                    "text": "Run cleanup and reset protocol."
                },
                {
                    "type": "goto",
                    "goto": "route-select",
                    "text": "Setup stable again; retry using the safer route."
                }
            ]
        },
        {
            "id": "verify",
            "text": "Now document what happened so another tech could reproduce the run and safety checks.",
            "options": [
                {
                    "type": "process",
                    "process": "log-safe-reaction",
                    "text": "Log reaction observations."
                },
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Stable run documented; proceed to closeout.",
                    "requiresItems": [
                        {
                            "id": "10fab5e7-036b-4f8f-9f35-84117bc8ef09",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "finish",
            "text": "Excellent. You demonstrated a reaction with explicit safety controls, reproducible evidence, and a recovery path.",
            "options": [
                {
                    "type": "finish",
                    "text": "Logged and ready for the next experiment.",
                    "requiresItems": [
                        {
                            "id": "10fab5e7-036b-4f8f-9f35-84117bc8ef09",
                            "count": 1
                        }
                    ]
                }
            ]
        }
    ],
