{
    "id": "chemistry/stevia-extraction",
    "title": "Extract Stevia Sweetener",
    "description": "Use simple chemistry to make a sweet extract from stevia leaves.",
    "image": "/assets/quests/testprint.png",
    "npc": "/assets/npc/phoenix.jpg",
    "start": "start",
    "dialogue": [
        {
