                {
                    "type": "process",
                    "process": "extract-stevia",
                    "text": "Run controlled extraction pass."
                },
                {
                    "type": "goto",
                    "goto": "outcome-check",
                    "text": "Extraction evidence captured; evaluate extract clarity.",
                    "requiresItems": [
