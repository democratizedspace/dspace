        },
        {
            "id": "setup-branch",
            "text": "Two valid extraction routes: precision prep (measured batches) or low-tech prep (small pilot steep). Both routes must produce extraction evidence before outcome review.",
            "options": [
                {
                    "type": "goto",
                    "goto": "precision-setup",
                    "text": "Main path: precision prep and measured steep."
                },
                {
                    "type": "goto",
                    "goto": "pilot-setup",
                    "text": "Alternate path: pilot steep for quick viability check."
                }
            ]
        },
        {
            "id": "precision-setup",
            "text": "Dry and crush leaves, label containers, and stage clean filter media. Keep temperature below a full boil to protect glycosides.",
