                    "goto": "contamination-recovery",
                    "text": "Cloudy or scorched notes detected\u2014trigger recovery."
                }
            ]
        },
        {
            "id": "pilot-setup",
            "text": "Run a short pilot steep with a small batch to validate heat and filter pace before full volume.",
            "options": [
                {
                    "type": "process",
                    "process": "extract-stevia",
                    "text": "Run pilot extraction."
                },
                {
                    "type": "goto",
