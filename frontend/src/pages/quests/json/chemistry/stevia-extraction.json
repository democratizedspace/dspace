{
    "id": "chemistry/stevia-extraction",
    "title": "Extract Stevia Sweetener",
    "description": "Produce stevia extract through staged setup and outcome evidence, with contamination recovery safeguards.",
    "image": "/assets/quests/stevia_leaf_extraction_setup.jpg",
    "npc": "/assets/npc/phoenix.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Phoenix here. We are extracting sweetness, not cooking sludge. Choose a prep strategy and prove setup before we call any outcome valid.",
            "options": [
                {
                    "type": "goto",
                    "goto": "lab-protocol",
                    "text": "Ready to execute full lab protocol."
                }
            ]
        },
        {
            "id": "lab-protocol",
            "text": "Run preflight: Soxhlet body or reflux flask, 70% ethanol solvent batch, rotovap trap cooling, and leaf moisture log.",
            "options": [
                {
                    "type": "process",
                    "process": "chemistry-stage-stevia-solvent-extraction",
                    "text": "Run stevia solvent extraction protocol prep process."
                },
                {
                    "type": "goto",
                    "goto": "setup-branch",
                    "text": "Protocol staged and logged; continue experiment.",
                    "requiresItems": [
                        {
                            "id": "8b5f4e3d-a5ab-40d2-9996-751c6c7ce59f",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "setup-branch",
            "text": "Two valid extraction routes: precision prep (measured batches) or low-tech prep (small pilot steep). Both routes must produce extraction evidence before outcome review.",
            "options": [
                {
                    "type": "goto",
                    "goto": "precision-setup",
                    "text": "Main path: precision prep and measured steep."
                },
                {
                    "type": "goto",
                    "goto": "pilot-setup",
                    "text": "Alternate path: pilot steep for quick viability check."
                }
            ]
        },
        {
            "id": "precision-setup",
            "text": "Mill dried leaves to 0.5-1 mm, charge 70% ethanol at 1:8 leaf-to-solvent mass ratio, hold 55-60\u00b0C with reflux, then polish-filter before concentration.",
            "options": [
                {
                    "type": "process",
                    "process": "chemistry-macerate-stevia-leaves",
                    "text": "Macerate stevia leaves in controlled ethanol bath."
                },
                {
                    "type": "process",
                    "process": "extract-stevia",
                    "text": "Recover solvent and concentrate eluate under reduced pressure."
                },
                {
                    "type": "goto",
                    "goto": "outcome-check",
                    "text": "Extraction evidence captured; evaluate extract clarity.",
                    "requiresItems": [
                        {
                            "id": "a7cb182c-f491-4f49-8d36-964886d0d055",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "contamination-recovery",
                    "text": "Cloudy or scorched notes detected\u2014trigger recovery."
                }
            ]
        },
        {
            "id": "pilot-setup",
            "text": "Run a 1/4-scale pilot using identical solvent ratio, agitation cadence, and filter stack to validate yield before full batch.",
            "options": [
                {
                    "type": "process",
                    "process": "chemistry-macerate-stevia-leaves",
                    "text": "Run pilot maceration and primary filtration."
                },
                {
                    "type": "process",
                    "process": "extract-stevia",
                    "text": "Concentrate pilot eluate and recover solvent."
                },
                {
                    "type": "goto",
                    "goto": "outcome-check",
                    "text": "Pilot indicates viable extraction; check outcome evidence.",
                    "requiresItems": [
                        {
                            "id": "a7cb182c-f491-4f49-8d36-964886d0d055",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "contamination-recovery",
                    "text": "Pilot failed or contaminated\u2014enter recovery."
                }
            ]
        },
        {
            "id": "outcome-check",
            "text": "Outcome gate: accept only if extract is clear-to-amber, aromatic, and free of burnt particulates. If not, you must recover and rerun.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Outcome passes quality check; extract is ready.",
