{
    "id": "chemistry/acid-neutralization",
    "title": "Neutralize an Acid Spill",
    "description": "Neutralize an acid spill with staged evidence gates, safe escalation, and a verified re-check.",
    "image": "/assets/quests/acid_spill_neutralization_setup.jpg",
    "npc": "/assets/npc/phoenix.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Acid spill on bench. Choose your approach, but do not rush: isolate the area, PPE on, and keep ignition sources and unprotected hands away.",
            "options": [
                {
                    "type": "goto",
                    "goto": "lab-protocol",
                    "text": "Ready to execute full lab protocol."
                }
            ]
        },
        {
            "id": "lab-protocol",
            "text": "Build the spill perimeter plan, confirm absorbent sequence, and record neutralizer lot before opening the spill kit.",
            "options": [
                {
                    "type": "process",
                    "process": "chemistry-stage-spill-response-kit",
                    "text": "Run acid spill response log prep process."
                },
                {
                    "type": "goto",
                    "goto": "choose-path",
                    "text": "Protocol staged and logged; continue experiment.",
                    "requiresItems": [
                        {
                            "id": "35ebadf1-d4f2-4b68-aa60-2d0bfb5358d1",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "choose-path",
            "text": "Pick a response path. Main path uses a structured spill kit run; alternate path is manual neutralization with tighter checks.",
            "options": [
                {
                    "type": "goto",
                    "goto": "kit-response",
                    "text": "Main path: use spill kit workflow."
                },
                {
                    "type": "goto",
                    "goto": "manual-response",
                    "text": "Alternate path: manual neutralization and strip checks."
                }
            ]
        },
        {
            "id": "kit-response",
            "text": "Deploy absorbent perimeter, add neutralizer in small increments, and watch reaction intensity. Stop immediately if vapor or heat spikes.",
            "options": [
                {
                    "type": "process",
                    "process": "chemistry-neutralize-acid-spill",
                    "text": "Neutralize spill and package residue for disposal."
                },
                {
                    "type": "goto",
                    "goto": "verify",
                    "text": "Kit run complete; verify with pH strip.",
                    "requiresItems": [
                        {
                            "id": "d6238643-7e42-4b40-89c0-15f72f3d3dc3",
                            "count": 1
                        },
                        {
                            "id": "13167d6a-5617-4931-8a6e-6f463c6b8835",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "recovery",
                    "text": "Unexpected fizzing/heat\u2014need recovery protocol."
                }
            ]
        },
        {
            "id": "manual-response",
            "text": "Sprinkle baking soda slowly from the edge inward and avoid splashing. Keep containment in place until fizzing slows, then proceed to verification.",
            "options": [
                {
                    "type": "process",
                    "process": "chemistry-neutralize-acid-spill",
                    "text": "Run controlled manual neutralization and package the neutralized residue."
                },
                {
                    "type": "goto",
                    "goto": "verify",
                    "text": "Manual neutralization complete; proceed to pH verification.",
                    "requiresItems": [
                        {
                            "id": "d6238643-7e42-4b40-89c0-15f72f3d3dc3",
                            "count": 1
                        },
                        {
                            "id": "13167d6a-5617-4931-8a6e-6f463c6b8835",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "recovery",
                    "text": "Manual approach unstable\u2014switch to recovery."
                }
            ]
        },
        {
            "id": "verify",
            "text": "Interpret the verification reading. Pass only when strip indicates near-neutral range and no active reaction remains.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Verification passed: spill zone is neutral and controlled.",
                    "requiresItems": [
                        {
                            "id": "d6238643-7e42-4b40-89c0-15f72f3d3dc3",
                            "count": 1
