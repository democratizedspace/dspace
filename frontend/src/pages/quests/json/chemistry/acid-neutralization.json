                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "recovery",
                    "text": "Verification failed: still acidic/basic or active fizzing."
                }
            ]
        },
        {
            "id": "recovery",
            "text": "Recovery branch: back out, refresh PPE, re-contain the zone, and re-run neutralization in smaller doses. If instability persists after one retry, escalate to supervisor and lock the station.",
            "options": [
                {
                    "type": "goto",
                    "goto": "choose-path",
                    "text": "Recovery complete\u2014retry with selected path."
                },
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Escalated and locked out bench safely pending review.",
                    "requiresItems": [
                        {
                            "id": "35ebadf1-d4f2-4b68-aa60-2d0bfb5358d1",
