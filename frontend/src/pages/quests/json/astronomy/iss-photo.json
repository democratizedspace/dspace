                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "setup",
            "text": "Stage a safe viewing lane with stable footing and no overhead hazards before you start exposure attempts.",
            "options": [
                {
                    "type": "process",
                    "process": "stage-iss-spotting-station",
                    "text": "Stage the spotting station."
                },
                {
                    "type": "goto",
                    "goto": "capture",
                    "text": "Station is stable and aligned.",
                    "requiresItems": [
                        {
                            "id": "bb97e755-4337-4e9d-8063-4a0cff4649b5",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "capture",
            "text": "Capture a timed pass log with exposure notes. A usable attempt should include timestamp, direction, and a streak that is trackable against stars.",
            "options": [
                {
                    "type": "process",
                    "process": "log-iss-pass",
                    "text": "Record this pass attempt."
                },
                {
                    "type": "goto",
                    "goto": "evaluate",
                    "text": "Attempt logged; evaluate quality.",
                    "requiresItems": [
                        {
                            "id": "067aa8eb-b5a4-4bef-a307-7dde10e981f5",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "evaluate",
            "text": "Interpret your result: if streak continuity is clear and framing is stable, pass. If blur, clipping, or mistimed exposure dominates, run the corrective loop.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Quality threshold met (clear ISS streak + logged metadata).",
                    "requiresItems": [
                        {
                            "id": "067aa8eb-b5a4-4bef-a307-7dde10e981f5",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "corrective",
                    "text": "Out-of-range result (blurred or mistimed)."
                }
            ]
        },
        {
            "id": "corrective",
            "text": "Corrective branch: lower vibration, adjust exposure timing, and wait for the next predicted pass before retrying. Abort if footing becomes unsafe.",
            "options": [
                {
                    "type": "process",
                    "process": "check-iss-pass",
                    "text": "Schedule the mandatory re-test window."
                },
                {
                    "type": "goto",
                    "goto": "retest",
                    "text": "Next pass ready for re-test.",
                    "requiresItems": [
                        {
                            "id": "16478015-5213-4b3f-960c-c0fdaaa91297",
