{
    "id": "astronomy/iss-photo",
    "title": "Photograph the ISS",
    "description": "Use a tracking app and tripod phone to capture the ISS streak and log it.",
    "image": "/assets/quests/iss_long_exposure_phone_photo.jpg",
    "npc": "/assets/npc/nova.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "You spotted the ISS before. Ready to capture its trail with a long exposure?",
            "options": [
                {
                    "type": "goto",
                    "goto": "plan",
                    "text": "Let's plan the shot."
                }
            ]
        },
        {
            "id": "plan",
            "text": "Mount your smartphone on a tripod and check an app for the next pass.",
            "options": [
                {
                    "type": "process",
                    "process": "check-iss-pass",
                    "text": "Checking the pass time."
                },
                {
                    "type": "goto",
                    "goto": "setup",
                    "text": "Pass time noted, gear set.",
                    "requiresItems": [
                        {
