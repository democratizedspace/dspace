    "npc": "/assets/npc/nova.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "You spotted the ISS before. Ready for a measured long-exposure run with strict pass/fail thresholds?",
            "options": [
                {
                    "type": "goto",
                    "goto": "plan",
                    "text": "Let's plan the shot."
                }
            ]
        },
        {
            "id": "plan",
