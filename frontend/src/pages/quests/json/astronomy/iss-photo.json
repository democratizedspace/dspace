{
    "id": "astronomy/iss-photo",
    "title": "Photograph the ISS",
    "description": "Use a tracking app and tripod phone to capture the ISS streak and log it.",
    "image": "/assets/quests/iss_long_exposure_phone_photo.jpg",
    "npc": "/assets/npc/nova.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "You spotted the ISS before. Ready to capture its trail with a long exposure?",
            "options": [
                {
                    "type": "goto",
                    "goto": "plan",
                    "text": "Let's plan the shot."
                }
            ]
        },
        {
            "id": "plan",
            "text": "Mount your smartphone on a tripod, clear your walking path, and check an app for the next pass.",
            "options": [
                {
                    "type": "process",
                    "process": "check-iss-pass",
                    "text": "Checking the pass time."
                },
                {
                    "type": "goto",
                    "goto": "capture",
                    "text": "Pass time noted, gear set.",
                    "requiresItems": [
                        {
                            "id": "82577af7-6724-4cb2-8922-f7140e550145",
                            "count": 1
                        },
                        {
                            "id": "49fb255e-a4c3-48e4-bca7-4c3781fdb98b",
                            "count": 1
                        },
                        {
                            "id": "16478015-5213-4b3f-960c-c0fdaaa91297",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "capture",
            "text": "Start a 10-second exposure as the ISS rises. Record start time, end time, and estimated streak length in your mission logbook.",
            "options": [
                {
                    "type": "goto",
                    "goto": "interpret",
                    "text": "Photo saved and logged.",
                    "requiresItems": [
                        {
                            "id": "70bb8d86-2c4e-4330-9705-371891934686",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "retake",
                    "text": "Trail is blurry or too faint to verify."
                }
            ]
        },
        {
            "id": "interpret",
            "text": "Quality gate: pass only if your log shows a clear timestamp pair and your photo shows a continuous streak of about 5-15 seconds against the predicted path.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "My capture meets the 5-15 second clarity check.",
                    "requiresItems": [
                        {
                            "id": "16478015-5213-4b3f-960c-c0fdaaa91297",
                            "count": 1
                        },
                        {
                            "id": "70bb8d86-2c4e-4330-9705-371891934686",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "retake",
                    "text": "Not enough detail—I'll retake with a shorter exposure."
                }
            ]
        },
        {
            "id": "retake",
            "text": "Troubleshooting: shorten exposure to 5-8 seconds, re-level the tripod, and avoid touching the phone during capture. Re-check the pass if the timing shifted.",
            "options": [
                {
                    "type": "process",
                    "process": "check-iss-pass",
                    "text": "Refreshing pass timing before the retake."
                },
                {
                    "type": "goto",
                    "goto": "capture",
                    "text": "Retuning complete—retry capture."
                }
            ]
        },
        {
            "id": "finish",
            "text": "Nice work! You captured humanity's outpost in motion.",
            "options": [
                {
                    "type": "finish",
                    "text": "Can't wait for the next pass."
                }
            ]
        }
    ],
    "rewards": [
        {
            "id": "b281360b-2ecc-4fea-a248-36a61c5f7399",
            "count": 1
        }
    ],
