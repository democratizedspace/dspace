{
    "id": "astronomy/iss-photo",
    "title": "Photograph the ISS",
    "description": "Capture an ISS long-exposure streak, score shot quality against thresholds, and retest if out of range.",
    "image": "/assets/quests/iss_long_exposure_phone_photo.jpg",
    "npc": "/assets/npc/nova.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "You spotted the ISS before. Ready to run a measured long-exposure capture with pass/fail thresholds?",
            "options": [
                {
                    "type": "goto",
                    "goto": "plan",
                    "text": "Let's plan the shot."
                }
            ]
        },
        {
            "id": "plan",
            "text": "Mount your smartphone on a tripod, confirm the next pass window, and stage a safe dark-path setup.",
            "options": [
                {
                    "type": "process",
                    "process": "check-iss-pass",
                    "text": "Pass time checked and logged."
                },
                {
                    "type": "goto",
                    "goto": "capture",
                    "text": "Pass window confirmed, gear is staged.",
                    "requiresItems": [
                        {
                            "id": "82577af7-6724-4cb2-8922-f7140e550145",
                            "count": 1
                        },
                        {
                            "id": "49fb255e-a4c3-48e4-bca7-4c3781fdb98b",
                            "count": 1
                        },
                        {
                            "id": "16478015-5213-4b3f-960c-c0fdaaa91297",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "recovery",
                    "text": "Clouds or glare are building\u2014need a fallback."
                }
            ]
        },
        {
            "id": "capture",
            "text": "Start a 10-second exposure as the ISS rises. Log timestamp and direction immediately after capture.",
            "options": [
                {
                    "type": "process",
                    "process": "write-mission-log-entry",
                    "text": "Shot metadata entered in mission log."
                },
                {
                    "type": "goto",
                    "goto": "interpret",
                    "text": "Photo saved and metadata logged.",
                    "requiresItems": [
                        {
                            "id": "70bb8d86-2c4e-4330-9705-371891934686",
                            "count": 1
                        },
                        {
                            "id": "16478015-5213-4b3f-960c-c0fdaaa91297",
                            "count": 1
                        },
                        {
                            "id": "280ed361-ac70-4ab9-bcd9-aee481790faf",
                            "count": 1
                        },
                        {
                            "id": "aa82b02f-2617-4474-a91b-29647e4a9780",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "recovery",
                    "text": "Trail is smeared or frame missed the pass."
                }
            ]
        },
        {
            "id": "interpret",
            "text": "Quality gate: accept only if streak is continuous and timing error is under 15 seconds. If out of range, retune and retest before completion.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Pass: continuous streak and timing error <15s.",
                    "requiresItems": [
                        {
                            "id": "70bb8d86-2c4e-4330-9705-371891934686",
                            "count": 1
                        },
                        {
                            "id": "280ed361-ac70-4ab9-bcd9-aee481790faf",
                            "count": 1
                        },
                        {
                            "id": "aa82b02f-2617-4474-a91b-29647e4a9780",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "retest",
                    "text": "Fail: timing or framing out of range\u2014run corrective loop."
                }
            ]
        },
        {
            "id": "retest",
            "text": "Corrective branch: stabilize tripod, lower vibration, and re-check pass direction before trying again.",
            "options": [
                {
                    "type": "goto",
                    "goto": "capture",
                    "text": "Corrections applied; retaking the photo."
                },
                {
                    "type": "goto",
                    "goto": "recovery",
                    "text": "Conditions still unstable\u2014switch to recovery plan."
                }
            ]
        },
        {
            "id": "recovery",
            "text": "Safety first: if clouds or footing risk increases, stop and schedule the next pass. Resume only after conditions are safe.",
            "options": [
                {
                    "type": "goto",
                    "goto": "plan",
                    "text": "Conditions improved\u2014replan the session."
                },
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Session aborted safely; logged for follow-up."
                }
            ]
        },
        {
            "id": "finish",
            "text": "Nice work. You used explicit quality thresholds, logged evidence, and handled failed captures with a deterministic retest loop.",
            "options": [
                {
                    "type": "finish",
                    "text": "Can't wait for the next pass."
                }
            ]
        }
    ],
    "rewards": [
