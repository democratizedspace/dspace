{
    "id": "astronomy/iss-photo",
    "title": "Photograph the ISS",
    "description": "Use a tracking app and tripod phone to capture the ISS streak and log it.",
    "image": "/assets/quests/iss_long_exposure_phone_photo.jpg",
    "npc": "/assets/npc/nova.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "You spotted the ISS before. Ready to capture its trail with a long exposure?",
            "options": [
                {
                    "type": "goto",
                    "goto": "plan",
                    "text": "Let's plan the shot."
                }
            ]
        },
        {
            "id": "plan",
            "text": "Mount your smartphone on a tripod and check an app for the next pass. Record expected peak altitude so you can judge if the capture quality is usable.",
            "options": [
                {
                    "type": "process",
                    "process": "check-iss-pass",
                    "text": "Checking the pass time and expected brightness."
                },
                {
                    "type": "goto",
                    "goto": "capture",
                    "text": "Pass time noted, gear set.",
                    "requiresItems": [
                        {
                            "id": "82577af7-6724-4cb2-8922-f7140e550145",
                            "count": 1
                        },
                        {
                            "id": "49fb255e-a4c3-48e4-bca7-4c3781fdb98b",
                            "count": 1
                        },
                        {
                            "id": "16478015-5213-4b3f-960c-c0fdaaa91297",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "capture",
            "text": "Start a 10-second exposure as the ISS rises, keep the phone stable, and log the start/end timestamp in your mission logbook.",
            "options": [
                {
                    "type": "process",
                    "process": "log-iss-pass",
                    "text": "Capture made and exposure details logged."
                },
                {
                    "type": "goto",
                    "goto": "interpret",
                    "text": "Photo saved and telemetry logged.",
                    "requiresItems": [
                        {
                            "id": "067aa8eb-b5a4-4bef-a307-7dde10e981f5",
                            "count": 1
                        },
                        {
                            "id": "70bb8d86-2c4e-4330-9705-371891934686",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "corrective",
                    "text": "Trail is blurred or clipped. I need to correct and re-test."
                }
            ]
        },
        {
            "id": "interpret",
            "text": "Interpret the result: pass if the streak is continuous and timestamp aligns with the predicted pass window; fail if it's broken or offset from the window.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Pass criteria met: continuous streak and matched timing.",
                    "requiresItems": [
                        {
                            "id": "067aa8eb-b5a4-4bef-a307-7dde10e981f5",
                            "count": 1
                        },
                        {
                            "id": "16478015-5213-4b3f-960c-c0fdaaa91297",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "corrective",
                    "text": "Fail criteria hit: motion blur or timing mismatch."
                }
            ]
        },
        {
            "id": "corrective",
            "text": "Troubleshoot safely: tighten tripod legs, shorten exposure if wind gusts, and retime to the next high-elevation pass. Avoid roadside setups and retry only from stable ground.",
            "options": [
                {
                    "type": "goto",
                    "goto": "capture",
                    "text": "Corrections applied. Running another capture pass.",
                    "requiresItems": [
                        {
                            "id": "82577af7-6724-4cb2-8922-f7140e550145",
                            "count": 1
                        },
                        {
                            "id": "49fb255e-a4c3-48e4-bca7-4c3781fdb98b",
                            "count": 1
                        }
                    ]
                }
            ]
        },
