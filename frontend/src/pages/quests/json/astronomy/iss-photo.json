            "text": "Quality gate: accept only if streak is continuous, timing error is under 15 seconds, and heading matches the pass window. Any miss triggers corrective retest.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Pass: streak continuous, timing <15s, heading matches plan.",
