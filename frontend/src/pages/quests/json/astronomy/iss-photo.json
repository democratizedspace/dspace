                            "id": "bb97e755-4337-4e9d-8063-4a0cff4649b5",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "retest",
            "text": "Run the retest capture and compare against your first logged attempt.",
            "options": [
                {
                    "type": "process",
                    "process": "log-iss-pass",
                    "text": "Log the follow-up capture."
                },
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Re-test logged with improved streak quality.",
                    "requiresItems": [
                        {
                            "id": "067aa8eb-b5a4-4bef-a307-7dde10e981f5",
                            "count": 2
                        }
                    ]
                }
            ]
        },
        {
            "id": "finish",
            "text": "Nice work! You captured humanity's outpost in motion.",
            "options": [
                {
                    "type": "finish",
                    "text": "Can't wait for the next pass.",
