{
    "id": "astronomy/iss-photo",
    "title": "Photograph the ISS",
    "description": "Use a tracking app and tripod phone to capture the ISS streak and log it.",
    "image": "/assets/quests/iss_long_exposure_phone_photo.jpg",
    "npc": "/assets/npc/nova.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "You spotted the ISS before. Tonight we need a repeatable capture workflow: predict, stabilize, capture, and verify.",
            "options": [
                {
                    "type": "goto",
                    "goto": "plan",
                    "text": "Let's plan the shot."
                }
            ]
        },
        {
            "id": "plan",
            "text": "Check the pass window, then confirm your tripod lane is clear so no one trips when lights are low.",
            "options": [
                {
                    "type": "process",
                    "process": "check-iss-pass",
                    "text": "Pass window captured in my notes."
                },
                {
                    "type": "goto",
                    "goto": "setup",
                    "text": "Pass time noted, gear set.",
                    "requiresItems": [
                        {
                            "id": "82577af7-6724-4cb2-8922-f7140e550145",
                            "count": 1
                        },
                        {
                            "id": "49fb255e-a4c3-48e4-bca7-4c3781fdb98b",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "setup",
            "text": "Lock exposure settings, brace the tripod, and frame the path. If clouds roll in, do not force a bad run.",
            "options": [
                {
                    "type": "process",
                    "process": "stage-iss-spotting-station",
                    "text": "Rig stabilized and aimed."
                },
                {
                    "type": "goto",
                    "goto": "capture",
                    "text": "Sky is clear and framing is stable.",
                    "requiresItems": [
                        {
                            "id": "bb97e755-4337-4e9d-8063-4a0cff4649b5",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "reschedule",
                    "text": "Cloud deck moved in. I'll run the fallback plan."
                }
            ]
        },
        {
            "id": "reschedule",
            "text": "Abort this pass safely, cap the optics, and queue the next visible pass. Better data beats rushed data.",
            "options": [
                {
                    "type": "process",
                    "process": "check-iss-pass",
                    "text": "Next pass window recorded."
                },
                {
                    "type": "goto",
                    "goto": "setup",
                    "text": "Window updated. I'll re-stage and try again."
                }
            ]
        },
        {
            "id": "capture",
            "text": "Start the long exposure as the ISS rises, then immediately review sharpness and streak continuity.",
            "options": [
                {
                    "type": "process",
                    "process": "log-iss-pass",
                    "text": "Saved capture metadata and path notes."
                },
                {
                    "type": "goto",
                    "goto": "verify",
                    "text": "The frame has a clean streak and timestamp.",
                    "requiresItems": [
                        {
                            "id": "067aa8eb-b5a4-4bef-a307-7dde10e981f5",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "troubleshoot",
                    "text": "Photo is blurred or clipped. Troubleshoot it."
                }
            ]
        },
        {
            "id": "troubleshoot",
            "text": "If blur appears, shorten exposure or tighten tripod joints, then retake only after confirming the path is still clear.",
            "options": [
                {
                    "type": "goto",
                    "goto": "capture",
                    "text": "Stability corrected. Retrying capture."
                }
            ]
        },
        {
            "id": "verify",
            "text": "Final check: log timestamp, direction, and settings in your mission logbook so another observer can reproduce the shot.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Photo saved and logged.",
                    "requiresItems": [
                        {
                            "id": "70bb8d86-2c4e-4330-9705-371891934686",
                            "count": 1
                        },
                        {
                            "id": "067aa8eb-b5a4-4bef-a307-7dde10e981f5",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "finish",
            "text": "Nice work. You built a verifiable capture trail, not just a lucky snapshot.",
            "options": [
                {
                    "type": "finish",
                    "text": "Can't wait for the next pass."
                }
            ]
        }
    ],
    "rewards": [
        {
            "id": "b281360b-2ecc-4fea-a248-36a61c5f7399",
            "count": 1
        }
    ],
    "requiresQuests": ["astronomy/iss-flyover"],
    "hardening": {
        "passes": 0,
        "score": 90,
        "emoji": "\ud83d\udee0\ufe0f",
        "history": []
    }
}
