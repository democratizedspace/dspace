{
    "id": "astronomy/binary-star",
    "title": "Split a Binary Star",
    "description": "Use a basic telescope and planisphere to find Albireo and note its colors.",
    "image": "/assets/quests/binary_star_albireo_observation.jpg",
    "npc": "/assets/npc/nova.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Albireo is a colorful binary in Cygnus. Ready to run a full observe-and-verify pass?",
            "options": [
                {
                    "type": "goto",
                    "goto": "locate",
                    "text": "Point me to the target."
                },
                {
                    "type": "goto",
                    "goto": "safety-check",
                    "text": "Run my setup safety check first."
                }
            ]
        },
        {
            "id": "safety-check",
            "text": "Before dark adaptation, clear your walking path, cap bright screens, and keep your red flashlight at low brightness.",
            "options": [
                {
                    "type": "goto",
                    "goto": "locate",
                    "text": "Path is clear and light discipline is set."
                },
                {
                    "type": "goto",
                    "goto": "start",
                    "text": "I need to pause and make the area safer first."
                }
            ]
        },
        {
            "id": "locate",
            "text": "Trace Cygnus on your planisphere and sketch the star field before you attempt the split.",
            "options": [
                {
                    "type": "process",
                    "process": "identify-constellations",
                    "text": "Logging my finder sketch now."
                },
                {
                    "type": "goto",
                    "goto": "split",
                    "requiresItems": [
                        {
                            "id": "9a72fb16-fc69-45c5-beca-f25c27028977",
                            "count": 1
                        }
                    ],
                    "text": "Sketch complete. I'm ready to split Albireo."
                },
                {
                    "type": "goto",
                    "goto": "recover",
                    "text": "I keep losing Cygnus in the finder."
                }
            ]
        },
        {
            "id": "split",
            "text": "Use low magnification first, then increase power slowly until Albireo resolves into two stars.",
            "options": [
                {
                    "type": "goto",
                    "goto": "interpret",
                    "requiresItems": [
                        {
                            "id": "f439b57a-9df3-4bd9-9b6e-042476ceecf5",
                            "count": 1
                        },
                        {
                            "id": "98f6252e-95c2-468a-b110-69d47604df2c",
                            "count": 1
                        }
                    ],
                    "text": "I can resolve both stars now."
                },
                {
                    "type": "goto",
                    "goto": "recover",
                    "text": "The pair is still a blur."
                }
            ]
        },
        {
            "id": "recover",
            "text": "Recovery protocol: re-focus on a bright reference star, reduce magnification, and verify the mount is stable before retrying.",
            "options": [
                {
                    "type": "goto",
                    "goto": "locate",
                    "text": "Mount and focus corrected; restart the locate step."
                },
                {
                    "type": "goto",
                    "goto": "safety-check",
                    "text": "I'm losing footing or visibility, rerun safety checks."
                }
            ]
        },
        {
            "id": "interpret",
            "text": "Record both color notes (gold + blue) and seeing conditions so your observation can be compared later.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "requiresItems": [
                        {
                            "id": "70bb8d86-2c4e-4330-9705-371891934686",
                            "count": 1
                        }
                    ],
                    "text": "Color notes and conditions logged in my mission logbook."
                }
            ]
        },
        {
            "id": "finish",
            "text": "Great split! Jot the colors in your mission log for future observers.",
            "options": [
                {
                    "type": "finish",
                    "text": "Logged and ready for the next target."
                }
            ]
        }
    ],
    "rewards": [
        {
            "id": "b281360b-2ecc-4fea-a248-36a61c5f7399",
            "count": 1
        }
    ],
    "requiresQuests": ["astronomy/constellations"],
    "hardening": {
        "passes": 0,
        "score": 90,
        "emoji": "\ud83d\udee0\ufe0f",
        "history": []
    }
}
