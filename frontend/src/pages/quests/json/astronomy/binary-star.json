                {
                    "type": "goto",
                    "goto": "locate",
                    "text": "Point me to it."
                }
            ]
        },
        {
            "id": "locate",
            "text": "Trace Cygnus on a planisphere and aim the telescope at Albireo to split them.",
            "options": [
                {
                    "type": "process",
                    "process": "identify-constellations",
                    "text": "Aligning with Cygnus."
                },
                {
                    "type": "goto",
                    "goto": "finish",
                    "requiresItems": [
                        {
                            "id": "f439b57a-9df3-4bd9-9b6e-042476ceecf5",
