    "dialogue": [
        {
            "id": "start",
            "text": "The Perseids are active tonight. Grab a planisphere star chart, preserve night vision with a dim red flashlight, and pick a safe station before we start logging.",
            "options": [
                {
                    "type": "goto",
                    "goto": "observe",
                    "text": "Let's begin the watch session."
                },
                {
                    "type": "goto",
                    "goto": "weather-delay",
                    "text": "Clouds and haze look risky right now."
                }
            ]
        },
        {
            "id": "weather-delay",
            "text": "Fallback plan: if cloud cover, glare, or unsafe footing appears, delay the session. Re-check conditions and schedule another watch window instead of forcing a poor run.",
            "options": [
                {
                    "type": "goto",
                    "goto": "start",
                    "text": "Conditions improved, restart the session safely."
                },
                {
                    "type": "goto",
                    "goto": "follow-up",
                    "text": "Log this as a failed session and plan a follow-up."
                }
            ]
        },
        {
            "id": "observe",
            "text": "Find a clear dark spot away from traffic, orient with the planisphere, and record each meteor's direction and brightness in your mission logbook.",
            "options": [
                {
                    "type": "process",
                    "process": "observe-meteor-shower",
                    "text": "Recording meteors now."
                },
                {
                    "type": "goto",
                    "goto": "interpret",
                    "requiresItems": [
                        {
                            "id": "f439b57a-9df3-4bd9-9b6e-042476ceecf5",
