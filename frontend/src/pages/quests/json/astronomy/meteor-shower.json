        },
        {
            "id": "observe",
            "text": "Set up in a safe, dark spot away from traffic. Use a red flashlight to move around without losing night vision and record each meteor's direction and brightness.",
            "options": [
                {
                    "type": "process",
                    "process": "observe-meteor-shower",
                    "text": "Recording meteors."
                },
                {
                    "type": "goto",
                    "goto": "finish",
                    "requiresItems": [
                        { "id": "134", "count": 1 },
                        { "id": "137", "count": 1 }
                    ],
                    "text": "Observation complete."
                }
            ]
        },
        {
            "id": "finish",
            "text": "Great work! Comparing notes with others helps confirm the shower's peak.",
            "options": [{ "type": "finish", "text": "I'll share my data." }]
        }
    ],
    "rewards": [],
    "requiresQuests": ["astronomy/jupiter-moons"]
