                    ],
                    "text": "Log is complete and ready to share."
                },
                {
                    "type": "goto",
                    "goto": "follow-up",
                    "text": "Log is incomplete; schedule a follow-up run."
                }
            ]
        },
        {
            "id": "follow-up",
            "text": "Recovery branch: rest eyes for 20 minutes, re-check safety around your station, then retry on the next clear pass window.",
            "options": [
                {
                    "type": "goto",
                    "goto": "start",
                    "text": "Ready for the next attempt."
                }
            ]
        },
        {
            "id": "finish",
            "text": "Great work! Comparing notes with others helps confirm the shower's peak. Pack up your gear and watch your footing in the dark.",
            "options": [
                {
                    "type": "finish",
                    "text": "I'll share my data."
                }
            ]
        }
