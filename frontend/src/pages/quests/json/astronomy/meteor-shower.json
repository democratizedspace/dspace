{
    "id": "astronomy/meteor-shower",
    "title": "Document a Meteor Shower",
    "description": "Capture a meteor shower observation log with weather/visibility fallback handling and safety-first reattempts.",
    "hardening": {
        "passes": 0,
        "score": 97,
        "emoji": "🛠️",
        "history": []
    },
    "image": "/assets/quests/meteor_shower_observation_log.jpg",
