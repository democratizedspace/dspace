{
    "id": "astronomy/meteor-shower",
    "title": "Document a Meteor Shower",
    "description": "Check the forecast, pack a dark-sky kit, map the radiant, and log meteor counts before compiling a rate report.",
    "hardening": {
        "passes": 1,
        "score": 95,
        "emoji": "🌀",
        "history": [
