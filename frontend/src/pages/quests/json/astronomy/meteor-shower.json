                "score": 60
            }
        ]
    },
    "image": "/assets/quests/meteor_shower_observation_log.jpg",
    "npc": "/assets/npc/nova.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "The Perseids are active tonight. Let's pick a dark-sky window and keep night vision intact while we tally meteors.",
            "options": [
                {
                    "type": "goto",
                    "goto": "pack",
                    "text": "Locking in a viewing window.",
                    "requiresItems": [
                        {
                            "id": "808f8298-ba98-43d6-907b-1b34a7daffb8",
                            "count": 1
                        },
                        {
                            "id": "70bb8d86-2c4e-4330-9705-371891934686",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "process",
                    "process": "check-aurora-forecast",
                    "text": "Pick a clear, moon-free slot."
                }
            ]
        },
        {
            "id": "pack",
            "text": "Bundle your red flashlight, layers, and plan so you don't fumble in the dark. Clear the ground for trip hazards before you recline.",
            "options": [
                {
                    "type": "process",
                    "process": "pack-dark-sky-kit",
                    "text": "Pack the dark-sky kit."
                },
                {
                    "type": "goto",
                    "goto": "radiant",
                    "text": "Kit packed and footing checked.",
                    "requiresItems": [
                        {
                            "id": "0ce0d0d4-d734-4099-b903-92e9b1c52b05",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "radiant",
            "text": "Use the planisphere and red light to mark the radiant. Stay eyes-only or low magnification and avoid shining beams across anyone else's path.",
            "options": [
                {
                    "type": "process",
                    "process": "identify-constellations",
                    "text": "Sketch the radiant hop."
                },
                {
                    "type": "goto",
                    "goto": "observe",
                    "text": "Radiant mapped and ready.",
                    "requiresItems": [
                        {
                            "id": "b73f795b-7abb-4a0c-950b-7f8ad82012b8",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "observe",
            "text": "Find a clear, dark spot away from traffic. Log each meteor's direction and brightness with your red light shielded, and call out paths so spotters avoid tripping.",
            "options": [
                {
                    "type": "process",
                    "process": "observe-meteor-shower",
                    "text": "Record the streaks."
                },
                {
                    "type": "goto",
                    "goto": "radiant",
                    "text": "Recheck the radiant."
                },
                {
                    "type": "goto",
                    "goto": "report",
                    "requiresItems": [
                        {
                            "id": "6f124d7e-5ee1-46ce-a815-4bfa213f8fa0",
                            "count": 1
                        }
                    ],
                    "text": "Tally looks solid."
                }
            ]
        },
        {
            "id": "report",
            "text": "Convert your notes into a rate with cloud cover and radiant altitude so others can compare. Keep gear stowed before you move around.",
            "options": [
                {
                    "type": "process",
                    "process": "compile-meteor-report",
                    "text": "Crunch the hourly rate."
                },
                {
                    "type": "goto",
                    "goto": "observe",
                    "text": "Log another window."
                },
                {
                    "type": "goto",
                    "goto": "finish",
                    "requiresItems": [
                        {
                            "id": "63008fad-631b-4559-93b1-df22efacc1ea",
                            "count": 1
                        }
                    ],
                    "text": "Report ready to share."
                }
            ]
        },
        {
            "id": "finish",
            "text": "Great work! Comparing reports helps confirm the shower's peak. Pack up carefully and keep lights red on the way out.",
            "options": [
                {
                    "type": "finish",
                    "text": "I'll share my data."
                }
            ]
        }
    ],
