                            "count": 1
                        },
                        {
                            "id": "9a72fb16-fc69-45c5-beca-f25c27028977",
                            "count": 1
                        },
                        {
                            "id": "98f6252e-95c2-468a-b110-69d47604df2c",
                            "count": 1
                        }
                    ],
                    "text": "I captured and logged the shower run."
                },
                {
                    "type": "goto",
                    "goto": "weather-delay",
                    "text": "Visibility dropped mid-session."
                }
            ]
        },
        {
            "id": "interpret",
            "text": "Interpretation check: classify the session as pass only if the log contains timestamps, directions, and at least one brightness note. Otherwise schedule a recovery run.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "requiresItems": [
                        {
                            "id": "70bb8d86-2c4e-4330-9705-371891934686",
                            "count": 1
