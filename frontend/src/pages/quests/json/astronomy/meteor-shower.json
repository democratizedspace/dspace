                            "id": "98f6252e-95c2-468a-b110-69d47604df2c",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "finish",
            "text": "Great work. You produced an observation artifact, interpreted data quality, and handled failed seeing conditions with a safe reattempt loop.",
            "options": [
                {
                    "type": "finish",
                    "text": "Meteor session documented."
                }
            ]
        }
