{
    "id": "astronomy/meteor-shower",
    "title": "Document a Meteor Shower",
    "description": "Safely log meteors during a peak shower using a telescope and red flashlight.",
    "image": "/assets/quests/solar.jpg",
    "npc": "/assets/npc/nova.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "The Perseids are active tonight. Grab your telescope and red flashlight so we can log the show.",
