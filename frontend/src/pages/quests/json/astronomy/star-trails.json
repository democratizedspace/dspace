{
    "id": "astronomy/star-trails",
    "title": "Capture Star Trails",
    "description": "Capture a repeatable star-trail stack with evidence logging, interpretation checks, and weather-safe recovery.",
    "image": "/assets/quests/star_trails_long_exposure_tripod.jpg",
    "npc": "/assets/npc/nova.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "You've mapped constellations; now let's capture their motion. Plan route first or do a quick readiness route?",
            "options": [
                {
                    "type": "goto",
                    "goto": "choose-route",
                    "text": "Show both setup routes.",
                    "requiresItems": [
                        {
                            "id": "98f6252e-95c2-468a-b110-69d47604df2c",
                            "count": 1
                        },
                        {
                            "id": "9a72fb16-fc69-45c5-beca-f25c27028977",
                            "count": 1
                        },
                        {
                            "id": "70bb8d86-2c4e-4330-9705-371891934686",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "choose-route",
            "text": "Both routes require a captured stack and a mission-log interpretation before completion.",
            "options": [
                {
                    "type": "goto",
                    "goto": "plan-route",
                    "text": "Plan-first route (main)."
                },
                {
                    "type": "goto",
                    "goto": "quick-route",
                    "text": "Quick readiness route (alternate)."
                }
            ]
        },
        {
            "id": "plan-route",
            "text": "Draft a seasonal sky window, mark Polaris, and note no-fly intervals before mounting the camera.",
            "options": [
                {
                    "type": "process",
                    "process": "draft-seasonal-star-plan",
                    "text": "Seasonal plan drafted."
                },
                {
                    "type": "goto",
                    "goto": "setup",
                    "text": "Plan and azimuth marks are ready.",
                    "requiresItems": [
                        {
                            "id": "60da6648-c22e-466e-9789-9e1d4635fd46",
                            "count": 1
                        },
                        {
                            "id": "a96ce9ed-b9e0-44e5-bd9f-c068643e6749",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "recovery",
                    "text": "Cloud deck or wind risk is too high."
                }
            ]
        },
        {
            "id": "quick-route",
            "text": "Use a short test frame to validate focus and framing before committing to the full stack.",
            "options": [
                {
                    "type": "process",
                    "process": "align-star-trail-rig",
                    "text": "Quick frame and focus test complete."
                },
                {
                    "type": "goto",
                    "goto": "capture",
                    "text": "Test frame is sharp and orientation is stable.",
                    "requiresItems": [
                        {
                            "id": "49fb255e-a4c3-48e4-bca7-4c3781fdb98b",
                            "count": 1
                        },
                        {
                            "id": "9a72fb16-fc69-45c5-beca-f25c27028977",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "recovery",
                    "text": "Tripod shake or stray light ruined the test frame."
                }
            ]
        },
        {
            "id": "setup",
            "text": "Lock tripod feet, set red-light discipline, and confirm no one is in your camera path.",
            "options": [
                {
                    "type": "process",
                    "process": "align-star-trail-rig",
                    "text": "Rig aligned and stable."
                },
                {
                    "type": "goto",
                    "goto": "capture",
                    "text": "Safety checks done; proceed to full stack.",
                    "requiresItems": [
                        {
                            "id": "60da6648-c22e-466e-9789-9e1d4635fd46",
                            "count": 1
                        },
                        {
                            "id": "9a72fb16-fc69-45c5-beca-f25c27028977",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "capture",
            "text": "Run the long-exposure stack and check that the trail arc is continuous.",
            "options": [
                {
                    "type": "process",
                    "process": "capture-star-trail-stack",
                    "text": "Stack captured."
                },
                {
                    "type": "goto",
                    "goto": "log-evidence",
                    "text": "Arc is continuous and color-balanced.",
                    "requiresItems": [
                        {
                            "id": "dfbd9155-1c06-4951-9a32-4520107a88fb",
                            "count": 1
                        },
                        {
                            "id": "b6fc1ed6-f399-4fdb-9f9d-3913f893f43d",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "recovery",
                    "text": "Arc breaks or sensor noise is too high."
                }
            ]
        },
        {
            "id": "log-evidence",
            "text": "Log exposure length, sky conditions, and trail orientation so the session is reproducible.",
            "options": [
                {
                    "type": "process",
                    "process": "write-mission-log-entry",
                    "text": "Session notes written."
                },
                {
                    "type": "goto",
                    "goto": "interpret",
                    "text": "Move to interpretation.",
                    "requiresItems": [
                        {
                            "id": "70bb8d86-2c4e-4330-9705-371891934686",
                            "count": 1
                        },
                        {
                            "id": "280ed361-ac70-4ab9-bcd9-aee481790faf",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "interpret",
            "text": "Interpretation check: does the final stack support Earth's apparent rotation without major artifacts?",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Yes, interpretation is consistent and documented."
                },
                {
                    "type": "goto",
                    "goto": "recovery",
                    "text": "No, artifacts require a controlled retry."
                }
            ]
        },
        {
            "id": "recovery",
            "text": "Recovery mode: stand down if weather or footing is unsafe, then retry after re-leveling and a fresh test frame.",
            "options": [
                {
                    "type": "goto",
                    "goto": "choose-route",
                    "text": "Safety reset complete; retry from route selection."
                },
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Unsafe to continue tonight; close with a logged follow-up.",
                    "requiresItems": [
                        {
                            "id": "280ed361-ac70-4ab9-bcd9-aee481790faf",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "finish",
            "text": "Beautiful work. Your trail stack now includes reproducible evidence and a safety-aware fallback path.",
            "options": [
                {
                    "type": "finish",
                    "text": "Save to the observing log.",
                    "requiresItems": [
                        {
                            "id": "2ab80a53-6a2a-4e51-b1f7-fa78620a0132",
                            "count": 1
                        }
                    ]
                }
            ]
        }
    ],
