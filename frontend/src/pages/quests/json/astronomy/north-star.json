{
    "id": "astronomy/north-star",
    "title": "Locate the North Star",
    "description": "Use the Big Dipper to spot Polaris for navigation practice.",
    "image": "/assets/quests/north_star_polaris_location.jpg",
    "npc": "/assets/npc/nova.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Polaris anchors the night sky. Grab a planisphere, red flashlight, and your basic telescope so we can trace the pointer stars without ruining night vision.",
            "options": [
                {
                    "type": "process",
                    "process": "dark-adapt-and-plot-pointers",
                    "text": "Match the sky to the planisphere"
                },
                {
                    "type": "goto",
                    "goto": "locate",
                    "text": "Eyes adjusted",
                    "requiresItems": [
                        { "id": "96b7899a-679e-4e3f-86a4-8cd1a2d80445", "count": 1 }
                    ]
                }
            ]
        },
        {
            "id": "locate",
            "text": "Find the Big Dipper, draw a line through its pointer stars, and walk that line to a solitary star that barely drifts—Polaris. Double-check against your chart before you celebrate.",
            "options": [
                {
                    "type": "process",
                    "process": "trace-big-dipper-to-polaris",
                    "text": "Sketch the pointer line",
                    "requiresItems": [
                        { "id": "96b7899a-679e-4e3f-86a4-8cd1a2d80445", "count": 1 }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "confirm",
                    "text": "Pointer line traced",
                    "requiresItems": [
                        { "id": "d38f41b6-40ac-4e1a-9bff-ded38e84ae1b", "count": 1 }
                    ]
                }
            ]
        },
        {
            "id": "confirm",
            "text": "Center Polaris in your eyepiece, nudge the focus, and log the bearing. The steady star should hold still while other field stars drift.",
            "options": [
                {
                    "type": "process",
                    "process": "log-polaris-sighting",
                    "text": "Lock Polaris in the scope",
                    "requiresItems": [
                        { "id": "d38f41b6-40ac-4e1a-9bff-ded38e84ae1b", "count": 1 }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Polaris logged",
                    "requiresItems": [
                        { "id": "bdfbe239-e7a4-4e78-b9b0-5532675b95b2", "count": 1 }
                    ]
                }
            ]
        },
        {
            "id": "finish",
            "text": "Excellent! Polaris now anchors your night sky orientation. Use the same trick to find true north any clear night.",
            "options": [
                {
                    "type": "finish",
                    "text": "Navigation feels easier now.",
                    "requiresItems": [
                        { "id": "bdfbe239-e7a4-4e78-b9b0-5532675b95b2", "count": 1 }
                    ]
                }
            ]
        }
    ],
    "rewards": [],
    "requiresQuests": ["astronomy/constellations"]
}
