{
    "id": "astronomy/north-star",
    "title": "Locate the North Star",
    "description": "Use the Big Dipper to spot Polaris for navigation practice.",
    "image": "/assets/quests/north_star_polaris_location.jpg",
    "npc": "/assets/npc/nova.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Polaris anchors the night sky. Let's identify it to orient ourselves.",
            "options": [
                {
                    "type": "goto",
                    "goto": "setup",
                    "text": "Show me the steps.",
                    "requiresItems": [
                        {
                            "id": "b73f795b-7abb-4a0c-950b-7f8ad82012b8",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "setup",
            "text": "Pick a stable spot with a clear northern view, keep your red light low, and steady the tripod.",
            "options": [
                {
                    "type": "goto",
                    "goto": "locate",
                    "text": "Ready to trace from the Big Dipper."
                }
            ]
        },
        {
            "id": "locate",
            "text": "Use sketches to find the Big Dipper, follow its pointers to Polaris, and keep the tripod steady.",
            "options": [
                {
                    "type": "process",
                    "process": "mark-polaris-alignment",
                    "text": "Tracing to Polaris and noting azimuth."
                },
                {
                    "type": "goto",
                    "goto": "finish",
                    "requiresItems": [{ "id": "6102f07b-384b-437f-b78f-d1e9b5431e97", "count": 1 }],
                    "text": "Polaris spotted."
                }
            ]
        },
        {
            "id": "finish",
            "text": "Excellent! Polaris now anchors your night sky orientation. Keep scans short so you don't wander off-trail.",
            "options": [
                {
                    "type": "finish",
                    "text": "Navigation feels easier now."
                }
            ]
        }
    ],
    "rewards": [
        { "id": "6102f07b-384b-437f-b78f-d1e9b5431e97", "count": 1 }
    ],
    "requiresQuests": ["astronomy/constellations"]
}
