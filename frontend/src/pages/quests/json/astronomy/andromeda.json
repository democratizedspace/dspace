{
    "id": "astronomy/andromeda",
    "title": "Locate the Andromeda Galaxy",
    "description": "Use a planisphere star chart, a red flashlight and a basic telescope to locate our neighboring galaxy while preserving night vision.",
    "image": "/assets/quests/andromeda_galaxy_backyard_hunt.jpg",
    "npc": "/assets/npc/nova.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Nova here. Choose a dark, open spot away from traffic, check the forecast and let your eyes adjust for 15 minutes. Keep screens dim, secure your basic telescope and use a planisphere star chart with a red flashlight to preserve night vision. Ready?",
            "options": [
                {
                    "type": "goto",
                    "goto": "site-plan",
                    "text": "Gear ready.",
                    "requiresItems": [
                        {
                            "id": "98f6252e-95c2-468a-b110-69d47604df2c",
                            "count": 1
                        },
                        {
                            "id": "9a72fb16-fc69-45c5-beca-f25c27028977",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "site-plan",
            "text": "Before you sweep, pick a strategy: stay in your current dark patch or relocate if streetlights or haze are washing out faint targets.",
            "options": [
                {
                    "type": "goto",
                    "goto": "search-main",
                    "text": "Stay put and let my eyes adapt longer."
                },
                {
                    "type": "goto",
                    "goto": "search-relocate",
                    "text": "Relocate to a darker edge of the field first."
                }
            ]
        },
        {
            "id": "search-main",
            "text": "Shield the red flashlight to avoid glare and trace Cassiopeia's W on the star chart. From the midpoint, sweep the basic telescope slowly at low magnification toward a faint smudge. Keep footing sure and never aim near the Sun or aircraft.",
            "options": [
                {
                    "type": "process",
                    "process": "identify-constellations",
                    "text": "Follow the Cassiopeia-to-Andromeda hop."
                },
                {
                    "type": "goto",
                    "goto": "verify",
                    "text": "I logged a charted sweep.",
                    "requiresItems": [
                        {
                            "id": "f439b57a-9df3-4bd9-9b6e-042476ceecf5",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "troubleshoot",
                    "text": "I still can't separate Andromeda from haze."
                }
            ]
        },
        {
            "id": "search-relocate",
            "text": "Good call. Move to a darker line of sight, block nearby light, and repeat the star-hop with the same chart references.",
            "options": [
                {
                    "type": "process",
                    "process": "identify-constellations",
                    "text": "Run a fresh sweep from the darker location."
                },
                {
                    "type": "goto",
                    "goto": "verify",
                    "text": "Relocated sweep logged.",
                    "requiresItems": [
                        {
                            "id": "f439b57a-9df3-4bd9-9b6e-042476ceecf5",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "troubleshoot",
                    "text": "Cloud deck moved in during relocation."
                }
            ]
        },
        {
            "id": "troubleshoot",
            "text": "If contrast is poor, pause 10 minutes, re-check focus on a bright star, and verify no dew on the lens. If footing or visibility becomes unsafe, abort and reschedule.",
            "options": [
                {
                    "type": "goto",
                    "goto": "site-plan",
                    "text": "Conditions recovered; retry with a safer setup."
                }
            ]
        },
        {
            "id": "verify",
            "text": "Interpret what you observed: Andromeda should appear as a diffuse oval smudge that stays fixed relative to nearby stars while scanning.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Shape and position match Andromeda.",
                    "requiresItems": [
                        {
                            "id": "f439b57a-9df3-4bd9-9b6e-042476ceecf5",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "troubleshoot",
                    "text": "Not confident yet; I need another pass."
                }
            ]
        },
        {
            "id": "finish",
            "text": "Nice work! Log the position for next time, cap the telescope, switch off the flashlight and pack your gear before leaving the site.",
            "options": [
                {
                    "type": "finish",
                    "text": "Logging observations.",
                    "requiresItems": [
                        {
                            "id": "f439b57a-9df3-4bd9-9b6e-042476ceecf5",
                            "count": 1
                        }
                    ]
                }
            ]
        }
    ],
    "rewards": [
        {
            "id": "b281360b-2ecc-4fea-a248-36a61c5f7399",
            "count": 1
        }
    ],
