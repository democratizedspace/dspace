{
    "id": "astronomy/andromeda",
    "title": "Locate the Andromeda Galaxy",
    "description": "Use a planisphere star chart, a red flashlight and a basic telescope to locate our neighboring galaxy while preserving night vision.",
    "image": "/assets/quests/andromeda_galaxy_backyard_hunt.jpg",
    "npc": "/assets/npc/nova.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Nova here. Dark skies tonight, but we still need a safe setup before we hunt Andromeda.",
            "options": [
                {
                    "type": "goto",
                    "goto": "prep",
                    "text": "Walk me through the setup."
                }
            ]
        },
        {
            "id": "prep",
            "text": "Pick stable ground away from traffic, dim your screen, and use only red light so your night vision stays intact.",
            "options": [
                {
                    "type": "goto",
                    "goto": "search",
                    "text": "Gear ready and lights dimmed.",
                    "requiresItems": [
                        {
                            "id": "98f6252e-95c2-468a-b110-69d47604df2c",
                            "count": 1
                        },
                        {
                            "id": "9a72fb16-fc69-45c5-beca-f25c27028977",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "search",
            "text": "Trace Cassiopeia's W on the chart, then star-hop with low magnification. If haze or porch lights wash out contrast, pause and recover first.",
            "options": [
                {
                    "type": "process",
                    "process": "identify-constellations",
                    "text": "I mapped the hop path and started sweeping."
                },
                {
                    "type": "goto",
                    "goto": "verify",
                    "text": "I found a faint oval glow to the northwest.",
                    "requiresItems": [
                        {
                            "id": "f439b57a-9df3-4bd9-9b6e-042476ceecf5",
                            "count": 1
                        },
                        {
                            "id": "b73f795b-7abb-4a0c-950b-7f8ad82012b8",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "troubleshoot",
                    "text": "Sky glow is too strong. I need a recovery plan."
                }
            ]
        },
        {
            "id": "troubleshoot",
            "text": "Good call. Move to a darker edge of the site, wait five minutes for your eyes to readapt, and keep the scope capped while relocating to avoid slips.",
            "options": [
                {
                    "type": "goto",
                    "goto": "search",
                    "text": "Repositioned safely. I'll rerun the star-hop."
                }
            ]
        },
        {
            "id": "verify",
            "text": "Before finishing, log the location and orientation so you can reacquire it next session.",
            "options": [
                {
                    "type": "process",
                    "process": "write-mission-log-entry",
                    "text": "Observation logged with time and sky position."
                },
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Log complete. Ready to close out.",
                    "requiresItems": [
                        {
                            "id": "70bb8d86-2c4e-4330-9705-371891934686",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "finish",
            "text": "Great observing. Cap the optics before packing, and leave the site as dark and safe as you found it.",
            "options": [
                {
                    "type": "finish",
                    "text": "Andromeda logged."
                }
            ]
        }
    ],
    "rewards": [
        {
            "id": "b281360b-2ecc-4fea-a248-36a61c5f7399",
            "count": 1
        }
    ],
