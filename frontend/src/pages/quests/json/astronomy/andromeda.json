{
    "id": "astronomy/andromeda",
    "title": "Locate the Andromeda Galaxy",
    "description": "Use a planisphere star chart, a red flashlight and a basic telescope to locate our neighboring galaxy while preserving night vision.",
    "image": "/assets/quests/andromeda_galaxy_backyard_hunt.jpg",
    "npc": "/assets/npc/nova.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Nova here. Choose a dark, open spot away from traffic, check the forecast, and let your eyes adjust for 15 minutes. Keep screens dim, secure your basic telescope, and use a red flashlight to preserve night vision.",
            "options": [
                {
                    "type": "goto",
                    "goto": "plan-route",
                    "text": "Gear ready.",
                    "requiresItems": [
                        {
                            "id": "98f6252e-95c2-468a-b110-69d47604df2c",
                            "count": 1
                        },
                        {
                            "id": "9a72fb16-fc69-45c5-beca-f25c27028977",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "plan-route",
            "text": "Pick your star-hop strategy: follow Cassiopeia's W toward the Andromeda chain, or start at the Great Square of Pegasus. Keep tripod legs clear of walkways and never point optics near the Sun or aircraft.",
            "options": [
                {
                    "type": "goto",
                    "goto": "cassiopeia-route",
                    "text": "Use Cassiopeia as my guide."
                },
                {
                    "type": "goto",
                    "goto": "pegasus-route",
                    "text": "Use Pegasus as my guide."
                },
                {
                    "type": "goto",
                    "goto": "troubleshoot",
                    "text": "Clouds or glare are making this hard."
                }
            ]
        },
        {
            "id": "cassiopeia-route",
            "text": "Trace Cassiopeia's W on the chart, then sweep low magnification slowly until the faint oval glow appears.",
            "options": [
                {
                    "type": "process",
                    "process": "identify-constellations",
                    "text": "Chart and sweep from Cassiopeia."
                },
                {
                    "type": "goto",
                    "goto": "log-and-verify",
                    "text": "I found a faint oval glow.",
                    "requiresItems": [
                        {
                            "id": "70bb8d86-2c4e-4330-9705-371891934686",
                            "count": 1
                        },
                        {
                            "id": "f439b57a-9df3-4bd9-9b6e-042476ceecf5",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "pegasus-route",
            "text": "Use the Great Square of Pegasus to hop to Andromeda's stars, then nudge focus and averted vision until the galaxy haze stabilizes.",
            "options": [
                {
                    "type": "process",
                    "process": "identify-constellations",
                    "text": "Chart and sweep from Pegasus."
                },
                {
                    "type": "goto",
                    "goto": "log-and-verify",
                    "text": "Andromeda is centered.",
                    "requiresItems": [
                        {
                            "id": "70bb8d86-2c4e-4330-9705-371891934686",
                            "count": 1
                        },
                        {
                            "id": "f439b57a-9df3-4bd9-9b6e-042476ceecf5",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "troubleshoot",
            "text": "If haze, moonlight, or stray lights wash out contrast, pause and recover: shield nearby lights, wait 10 more minutes for dark adaptation, or reschedule for a clearer moonless window.",
            "options": [
                {
                    "type": "goto",
                    "goto": "plan-route",
                    "text": "Conditions improved; retry the star hop."
                },
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Rescheduled with notes for a follow-up session.",
                    "requiresItems": [
                        {
                            "id": "98f6252e-95c2-468a-b110-69d47604df2c",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "log-and-verify",
            "text": "Record time, sky condition, and guide stars in your mission logbook. Confirm the glow remains after refocusing to avoid false positives.",
            "options": [
                {
                    "type": "process",
                    "process": "write-mission-log-entry",
                    "text": "Write a verified observation entry."
                },
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Observation verified and logged.",
                    "requiresItems": [
                        {
                            "id": "f439b57a-9df3-4bd9-9b6e-042476ceecf5",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "finish",
            "text": "Nice work! Cap the telescope, switch off the flashlight, and pack out safely before leaving the site.",
            "options": [
                {
                    "type": "finish",
                    "text": "Logging observations."
                }
            ]
        }
    ],
    "rewards": [
