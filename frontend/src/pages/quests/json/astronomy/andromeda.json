{
    "id": "astronomy/andromeda",
    "title": "Locate the Andromeda Galaxy",
    "description": "Star-hop from Cassiopeia, align on Polaris, and log an Andromeda sketch without losing night vision.",
    "image": "/assets/quests/andromeda_galaxy_backyard_hunt.jpg",
    "npc": "/assets/npc/nova.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Nova here. Find a dark, open spot, dim every screen, and let your eyes settle. We'll star-hop to Andromeda and log what you see.",
            "options": [
                {
                    "type": "goto",
                    "goto": "chart-hop",
                    "text": "Red light on, chart in hand.",
                    "requiresItems": [
                        {
                            "id": "98f6252e-95c2-468a-b110-69d47604df2c",
                            "count": 1
                        },
                        {
                            "id": "9a72fb16-fc69-45c5-beca-f25c27028977",
                            "count": 1
                        },
                        {
                            "id": "70bb8d86-2c4e-4330-9705-371891934686",
                            "count": 1
                        },
                        {
                            "id": "f439b57a-9df3-4bd9-9b6e-042476ceecf5",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "chart-hop",
            "text": "Shield the red flashlight and trace Cassiopeia's W. Hop through Mirach and mark your path so you can find M31 again without phones blazing.",
            "options": [
                {
                    "type": "process",
                    "process": "identify-constellations",
                    "text": "Trace the hop in my logbook."
                },
                {
                    "type": "goto",
                    "goto": "align",
                    "requiresItems": [
                        {
                            "id": "b73f795b-7abb-4a0c-950b-7f8ad82012b8",
                            "count": 1
                        }
                    ],
                    "text": "Hop sketched and verified."
                }
            ]
        },
        {
            "id": "align",
            "text": "Level the tripod, follow the Big Dipper pointers, and lock in Polaris so your sweep stays smooth. Keep paths clear while you pace in the dark.",
            "options": [
                {
                    "type": "process",
                    "process": "mark-polaris-alignment",
                    "text": "Plot Polaris and azimuth."
                },
                {
                    "type": "goto",
                    "goto": "chart-hop",
                    "text": "Need to recheck the hop."
                },
                {
                    "type": "goto",
                    "goto": "approach",
                    "text": "Tripod leveled and azimuth noted.",
                    "requiresItems": [
                        {
                            "id": "6102f07b-384b-437f-b78f-d1e9b5431e97",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "approach",
            "text": "Sweep with low magnification until the dim smudge brightens. Sketch the core, note the dust lane hint, and mind your footing while you lean over the eyepiece.",
            "options": [
                {
                    "type": "process",
                    "process": "sketch-andromeda-core",
                    "text": "Make the Andromeda sketch."
                },
                {
                    "type": "goto",
                    "goto": "align",
                    "text": "Realign before sketching."
                },
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Sketch done with dust lane hints.",
                    "requiresItems": [
                        {
                            "id": "f20fe701-4380-4769-aeb8-2674b2f4a37b",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "finish",
            "text": "Nice work! Cap the optics, cover the chart, and note conditions so you can repeat the hop on the next clear night.",
            "options": [
                {
                    "type": "finish",
                    "text": "Logging observations."
                }
            ]
        }
    ],
