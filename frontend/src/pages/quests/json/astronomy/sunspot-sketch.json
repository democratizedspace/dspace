{
    "id": "astronomy/sunspot-sketch",
    "title": "Sketch Sunspots",
    "description": "Run a safe solar-projection workflow with proof logging and a troubleshooting loop before completion.",
    "image": "/assets/quests/solar.jpg",
    "npc": "/assets/npc/nova.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Sunspots are useful data, but we only do this with strict projection safety. Want the quick checklist route or a calibration-first route?",
            "options": [
                {
                    "type": "goto",
                    "goto": "route-select",
                    "text": "Show both setup routes."
                }
            ]
        },
        {
            "id": "route-select",
            "text": "Either route is valid. We finish only after a logged sketch note proving safe projection and visible spot structure.",
            "options": [
                {
                    "type": "goto",
                    "goto": "quick-setup",
                    "text": "Quick safety checklist (main path)."
                },
                {
                    "type": "goto",
                    "goto": "calibration-setup",
                    "text": "Calibrate alignment before sketching (alternate path)."
                }
            ]
        },
        {
            "id": "quick-setup",
            "text": "Set tripod shade, secure projection card, and confirm nobody looks through the eyepiece.",
            "options": [
                {
                    "type": "process",
                    "process": "draft-seasonal-star-plan",
                    "text": "Safety checklist and projection plan drafted."
                },
                {
                    "type": "goto",
                    "goto": "project",
                    "text": "Safety checks complete; begin projection.",
                    "requiresItems": [
                        {
                            "id": "60da6648-c22e-466e-9789-9e1d4635fd46",
                            "count": 1
                        },
                        {
                            "id": "f439b57a-9df3-4bd9-9b6e-042476ceecf5",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "recovery",
                    "text": "Projection card is unstable or people are too close."
                }
            ]
        },
        {
            "id": "calibration-setup",
            "text": "Start at low alignment angle, lock tripod movement, and verify the projection disk stays centered.",
            "options": [
                {
                    "type": "process",
                    "process": "identify-constellations",
                    "text": "Tripod alignment and aiming controls calibrated."
                },
                {
                    "type": "goto",
                    "goto": "project",
                    "text": "Calibration stable; begin sketch run.",
                    "requiresItems": [
                        {
                            "id": "9a72fb16-fc69-45c5-beca-f25c27028977",
                            "count": 1
                        },
                        {
                            "id": "f439b57a-9df3-4bd9-9b6e-042476ceecf5",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "recovery",
                    "text": "Image drift or glare makes projection unreadable."
                }
            ]
        },
        {
            "id": "project",
            "text": "Project the solar disk, sketch visible spot clusters, and include timestamp + orientation arrows in your logbook.",
            "options": [
                {
                    "type": "process",
                    "process": "write-mission-log-entry",
                    "text": "Sunspot sketch notes written in mission log."
                },
                {
                    "type": "goto",
                    "goto": "verify",
                    "text": "Sketch and notes captured.",
                    "requiresItems": [
                        {
                            "id": "70bb8d86-2c4e-4330-9705-371891934686",
                            "count": 1
                        },
                        {
                            "id": "280ed361-ac70-4ab9-bcd9-aee481790faf",
                            "count": 1
                        },
                        {
                            "id": "aa82b02f-2617-4474-a91b-29647e4a9780",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "recovery",
                    "text": "Sketch lacks spot detail or safety control slipped."
                }
            ]
        },
        {
            "id": "recovery",
            "text": "Recovery gate: stop immediately, re-verify no direct viewing, cool the equipment, then restart from route selection.",
            "options": [
                {
                    "type": "goto",
                    "goto": "route-select",
                    "text": "Safety reset complete; retry with a route."
                },
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Unsafe conditions persist; log cancellation and stand down.",
                    "requiresItems": [
                        {
                            "id": "70bb8d86-2c4e-4330-9705-371891934686",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "verify",
            "text": "Verification gate: finish only when timestamp, orientation arrow, and spot grouping notes are all present.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Complete sketch evidence recorded.",
                    "requiresItems": [
                        {
                            "id": "70bb8d86-2c4e-4330-9705-371891934686",
                            "count": 1
                        },
                        {
                            "id": "280ed361-ac70-4ab9-bcd9-aee481790faf",
                            "count": 1
                        },
                        {
                            "id": "aa82b02f-2617-4474-a91b-29647e4a9780",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "recovery",
                    "text": "Missing evidence fields; run recovery and repeat."
                }
            ]
        },
        {
            "id": "finish",
            "text": "Great discipline. You kept solar safety controls active, handled failures, and produced a reproducible sketch record.",
            "options": [
                {
                    "type": "finish",
                    "text": "Solar sketch complete."
                }
            ]
        }
    ],
    "rewards": [
