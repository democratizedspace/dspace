                    "goto": "plan",
                    "text": "Recheck the forecast and revise the plan."
                },
                {
                    "type": "goto",
                    "goto": "setup",
                    "text": "Conditions improved; resume setup.",
                    "requiresItems": [
                        {
                            "id": "60da6648-c22e-466e-9789-9e1d4635fd46",
                            "count": 1
