{
    "id": "astronomy/saturn-rings",
    "title": "Spot Saturn's Rings",
    "description": "Plan the observation window, resolve Saturn's rings, and log evidence with fallback if seeing degrades.",
    "image": "/assets/quests/saturn_rings_planisphere_setup.jpg",
    "npc": "/assets/npc/nova.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Nova here. Saturn is up soon—want the quick point-and-track route or a steadier prep-first setup?",
            "options": [
                {
                    "type": "goto",
                    "goto": "pick-route",
                    "text": "Give me both routes.",
                    "requiresItems": [
                        {
                            "id": "98f6252e-95c2-468a-b110-69d47604df2c",
                            "count": 1
                        },
                        {
                            "id": "f439b57a-9df3-4bd9-9b6e-042476ceecf5",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "pick-route",
            "text": "Both routes must end with logged ring notes. Keep footing clear, use the red light only, and never rush in the dark.",
            "options": [
                {
                    "type": "goto",
                    "goto": "quick-track",
                    "text": "Quick route: center Saturn first, then fine focus."
                },
                {
                    "type": "goto",
                    "goto": "prep-route",
                    "text": "Prep route: lock a timing plan before the view."
                }
            ]
        },
        {
            "id": "quick-track",
            "text": "Sweep low power, center Saturn, then increase magnification slowly until the ring gap separates from the disk.",
            "options": [
                {
                    "type": "goto",
                    "goto": "log-proof",
                    "text": "I can resolve the ring shape and orientation.",
                    "requiresItems": [
                        {
                            "id": "f439b57a-9df3-4bd9-9b6e-042476ceecf5",
                            "count": 1
                        },
                        {
                            "id": "98f6252e-95c2-468a-b110-69d47604df2c",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "troubleshoot",
                    "text": "View is mushy or drifting."
                }
            ]
        },
        {
            "id": "prep-route",
            "text": "Draft a short mission-log timing note first so you can re-acquire Saturn if clouds cut in.",
            "options": [
                {
                    "type": "process",
                    "process": "write-mission-log-entry",
                    "text": "Timing note drafted."
                },
                {
                    "type": "goto",
                    "goto": "log-proof",
                    "text": "Plan complete and rings now resolved.",
                    "requiresItems": [
                        {
                            "id": "70bb8d86-2c4e-4330-9705-371891934686",
                            "count": 1
                        },
                        {
                            "id": "f439b57a-9df3-4bd9-9b6e-042476ceecf5",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "weather-hold",
                    "text": "Cloud deck rolled in before focus locked."
                }
            ]
        },
        {
            "id": "troubleshoot",
            "text": "Recovery loop: reset to lower magnification, re-level the tripod, and verify no nearby glare source is washing contrast.",
            "options": [
                {
                    "type": "goto",
                    "goto": "pick-route",
                    "text": "Stability restored—retry a route."
                },
                {
                    "type": "goto",
                    "goto": "weather-hold",
                    "text": "Seeing is still unstable; postpone safely."
                }
            ]
        },
        {
            "id": "weather-hold",
            "text": "Good call. Record a weather hold and schedule the next attempt window before closing out.",
            "options": [
                {
                    "type": "process",
                    "process": "write-mission-log-entry",
                    "text": "Weather hold logged with retry window."
                },
                {
                    "type": "goto",
                    "goto": "pick-route",
                    "text": "Conditions improved—resume the observation."
                }
            ]
        },
        {
            "id": "log-proof",
            "text": "Evidence gate: log ring tilt + local time so another observer could reproduce the sighting.",
            "options": [
                {
                    "type": "process",
                    "process": "write-mission-log-entry",
                    "text": "Ring notes logged."
                },
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Log includes ring tilt and timestamp.",
                    "requiresItems": [
                        {
                            "id": "70bb8d86-2c4e-4330-9705-371891934686",
                            "count": 1
                        },
                        {
                            "id": "280ed361-ac70-4ab9-bcd9-aee481790faf",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "finish",
            "text": "Nice lock. You handled fallback conditions and finished with reproducible ring evidence.",
            "options": [
                {
                    "type": "finish",
                    "text": "Observation logged."
                }
            ]
        }
    ],
