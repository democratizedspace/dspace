{
    "id": "astronomy/saturn-rings",
    "title": "Spot Saturn's Rings",
    "description": "Plan and execute a Saturn observing session with evidence logging, fallback routing, and safe retry handling.",
    "image": "/assets/quests/saturn_rings_planisphere_setup.jpg",
    "npc": "/assets/npc/nova.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Nova here. Saturn is up tonight. Do you want a chart-first lock or a focus-first tune before ring confirmation?",
            "options": [
                {
                    "type": "goto",
                    "goto": "choose-route",
                    "text": "Brief me on both routes.",
                    "requiresItems": [
                        {
                            "id": "98f6252e-95c2-468a-b110-69d47604df2c",
                            "count": 1
                        },
                        {
                            "id": "f439b57a-9df3-4bd9-9b6e-042476ceecf5",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "choose-route",
            "text": "Both routes require an observation log artifact plus an interpretation check before completion.",
            "options": [
                {
                    "type": "goto",
                    "goto": "chart-route",
                    "text": "Chart-first acquisition (main path)."
                },
                {
                    "type": "goto",
                    "goto": "focus-route",
                    "text": "Focus-first acquisition (alternate path)."
                }
            ]
        },
        {
            "id": "chart-route",
            "text": "Use the planisphere to locate Saturn, center it at low power, then step magnification carefully until the ring plane separates.",
            "options": [
                {
                    "type": "process",
                    "process": "identify-constellations",
                    "text": "Chart lock complete."
                },
                {
                    "type": "goto",
                    "goto": "log-observation",
                    "text": "Ring plane resolved clearly.",
                    "requiresItems": [
                        {
                            "id": "98f6252e-95c2-468a-b110-69d47604df2c",
                            "count": 1
                        },
                        {
                            "id": "f439b57a-9df3-4bd9-9b6e-042476ceecf5",
                            "count": 1
                        },
                        {
                            "id": "9a72fb16-fc69-45c5-beca-f25c27028977",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "recovery",
                    "text": "Image is shimmering or rings still blur into the disk."
                }
            ]
        },
        {
            "id": "focus-route",
            "text": "Run a focus sweep with short pauses for atmospheric steadiness before increasing magnification.",
            "options": [
                {
                    "type": "process",
                    "process": "identify-constellations",
                    "text": "Focus sweep complete."
                },
                {
                    "type": "goto",
                    "goto": "log-observation",
                    "text": "Focus lock holds and the rings are visible.",
                    "requiresItems": [
                        {
                            "id": "f439b57a-9df3-4bd9-9b6e-042476ceecf5",
                            "count": 1
                        },
                        {
                            "id": "9a72fb16-fc69-45c5-beca-f25c27028977",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "recovery",
                    "text": "Seeing collapsed or setup drifted off target."
                }
            ]
        },
        {
            "id": "recovery",
            "text": "Recovery checklist: verify tripod stability, recheck footing, avoid stray white light, and pause if wind gusts make tracking unsafe.",
            "options": [
                {
                    "type": "goto",
                    "goto": "choose-route",
                    "text": "Safety checks passed—retry."
                },
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Unsafe conditions persist; close with a caution log.",
                    "requiresItems": [
                        {
                            "id": "70bb8d86-2c4e-4330-9705-371891934686",
                            "count": 1
                        },
                        {
                            "id": "aa82b02f-2617-4474-a91b-29647e4a9780",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "log-observation",
            "text": "Write down ring tilt impression, seeing quality, and the eyepiece setup so another observer can reproduce the result.",
            "options": [
                {
                    "type": "process",
                    "process": "write-mission-log-entry",
                    "text": "Saturn observation logged."
                },
                {
                    "type": "goto",
                    "goto": "interpret",
                    "text": "Log entry complete.",
                    "requiresItems": [
                        {
                            "id": "70bb8d86-2c4e-4330-9705-371891934686",
                            "count": 1
                        },
                        {
                            "id": "aa82b02f-2617-4474-a91b-29647e4a9780",
                            "count": 1
                        },
                        {
                            "id": "280ed361-ac70-4ab9-bcd9-aee481790faf",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "interpret",
            "text": "Interpretation check: confirm ring separation was sustained and your notes include enough context for a repeat session.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Interpretation passes; session is reproducible.",
                    "requiresItems": [
                        {
                            "id": "aa82b02f-2617-4474-a91b-29647e4a9780",
                            "count": 1
                        },
                        {
                            "id": "9a72fb16-fc69-45c5-beca-f25c27028977",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "recovery",
                    "text": "Too uncertain—run recovery and retry."
                }
            ]
        },
        {
            "id": "finish",
            "text": "Great catch. You resolved Saturn's rings with evidence, interpretation, and safe fallback handling.",
            "options": [
