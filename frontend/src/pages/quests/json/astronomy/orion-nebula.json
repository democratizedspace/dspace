                {
                    "type": "goto",
                    "goto": "troubleshoot",
                    "text": "Log incomplete; re-observe after recovery."
                }
            ]
        },
        {
            "id": "finish",
            "text": "Clean run. You handled fallback windows, captured reproducible evidence, and avoided unsafe forced observing.",
            "options": [
                {
                    "type": "finish",
                    "text": "Logging the observation."
                }
            ]
        }
    ],
