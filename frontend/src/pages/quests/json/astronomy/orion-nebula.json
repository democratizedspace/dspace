                        {
                            "id": "aa82b02f-2617-4474-a91b-29647e4a9780",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "troubleshoot",
                    "text": "Nebula details are too faint to trust."
                }
            ]
        },
        {
            "id": "troubleshoot",
            "text": "Recovery loop: return to low magnification, re-check footing and glare, then retry only when safety and seeing both recover.",
            "options": [
                {
                    "type": "goto",
                    "goto": "setup",
                    "text": "Recovered conditions; retry capture."
                },
                {
                    "type": "goto",
                    "goto": "weather-hold",
                    "text": "Still unstable; defer and reschedule."
                }
            ]
        },
        {
            "id": "interpret",
            "text": "Interpretation gate: close only when the log contains brightness + shape + reference-star notes.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Complete log recorded with all evidence fields.",
                    "requiresItems": [
                        {
                            "id": "70bb8d86-2c4e-4330-9705-371891934686",
                            "count": 1
