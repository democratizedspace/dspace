{
    "id": "astronomy/orion-nebula",
    "title": "Observe the Orion Nebula",
    "description": "Run a structured Orion session with fallback paths, logged evidence, and weather-safe recovery loops.",
    "image": "/assets/quests/orion_nebula_backyard_observation.jpg",
    "npc": "/assets/npc/nova.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Nova here. Orion is up, but the sky can be fickle. Want the belt-hop route or a wide-field pre-scan first?",
            "options": [
                {
                    "type": "goto",
                    "goto": "choose-route",
                    "text": "Give me both approaches.",
                    "requiresItems": [
                        {
                            "id": "98f6252e-95c2-468a-b110-69d47604df2c",
                            "count": 1
                        },
                        {
                            "id": "b73f795b-7abb-4a0c-950b-7f8ad82012b8",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "choose-route",
            "text": "Either path works if you finish with an observation artifact and interpretation note.",
            "options": [
                {
                    "type": "goto",
                    "goto": "belt-route",
                    "text": "Use Orion's belt to drop into the sword (main path)."
                },
                {
                    "type": "goto",
                    "goto": "wide-route",
                    "text": "Run a low-power sweep before tightening focus (alternate path)."
                }
            ]
        },
        {
            "id": "belt-route",
            "text": "Track the belt stars, drop to the sword, and stabilize focus until the nebula glow and core are distinct.",
            "options": [
                {
                    "type": "process",
                    "process": "identify-constellations",
                    "text": "Belt hop complete."
                },
                {
                    "type": "goto",
                    "goto": "log-observation",
                    "text": "Nebula structure is visible and steady.",
                    "requiresItems": [
                        {
                            "id": "98f6252e-95c2-468a-b110-69d47604df2c",
                            "count": 1
                        },
                        {
                            "id": "f439b57a-9df3-4bd9-9b6e-042476ceecf5",
                            "count": 1
                        },
                        {
                            "id": "9a72fb16-fc69-45c5-beca-f25c27028977",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "recovery",
                    "text": "Seeing is unstable or glare washed out the target."
                }
            ]
        },
        {
            "id": "wide-route",
            "text": "Start at lower magnification, confirm Orion's frame, then refocus slowly to separate nebulosity from field stars.",
            "options": [
                {
                    "type": "process",
                    "process": "identify-constellations",
                    "text": "Wide-field scan complete."
                },
                {
                    "type": "goto",
                    "goto": "log-observation",
                    "text": "Glow confirmed after refocus.",
                    "requiresItems": [
                        {
                            "id": "f439b57a-9df3-4bd9-9b6e-042476ceecf5",
                            "count": 1
                        },
                        {
                            "id": "9a72fb16-fc69-45c5-beca-f25c27028977",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "recovery",
                    "text": "Cloud bands or moisture keep degrading contrast."
                }
            ]
        },
        {
            "id": "recovery",
            "text": "Troubleshoot safely: check dew on optics, reduce nearby white light, and reset tripod stance. If weather stays poor, pause the session.",
            "options": [
                {
                    "type": "goto",
                    "goto": "choose-route",
                    "text": "Conditions improved—retry observation."
                },
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Conditions unsafe/poor; close with a deferred-session note.",
                    "requiresItems": [
                        {
                            "id": "70bb8d86-2c4e-4330-9705-371891934686",
                            "count": 1
                        },
                        {
                            "id": "aa82b02f-2617-4474-a91b-29647e4a9780",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "log-observation",
            "text": "Write a mission-log entry with seeing, target position, and one repeatability clue for the next session.",
            "options": [
                {
                    "type": "process",
                    "process": "write-mission-log-entry",
                    "text": "Observation entry drafted."
                },
                {
                    "type": "goto",
                    "goto": "interpret",
                    "text": "Log entry ready for interpretation.",
                    "requiresItems": [
                        {
                            "id": "70bb8d86-2c4e-4330-9705-371891934686",
                            "count": 1
                        },
                        {
                            "id": "aa82b02f-2617-4474-a91b-29647e4a9780",
                            "count": 1
                        },
                        {
                            "id": "280ed361-ac70-4ab9-bcd9-aee481790faf",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "interpret",
            "text": "Interpret the run: verify the nebula signature is distinct and notes are complete enough to repeat next clear night.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Interpretation complete and reproducible.",
                    "requiresItems": [
                        {
                            "id": "aa82b02f-2617-4474-a91b-29647e4a9780",
                            "count": 1
                        },
                        {
                            "id": "9a72fb16-fc69-45c5-beca-f25c27028977",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "recovery",
                    "text": "Notes are incomplete or the signature is uncertain—retry."
                }
            ]
        },
        {
            "id": "finish",
            "text": "Nice work. You handled weather risk, produced evidence, and left a repeatable Orion Nebula record.",
            "options": [
                {
                    "type": "finish",
                    "text": "Nebula session complete."
                }
            ]
        }
    ],
