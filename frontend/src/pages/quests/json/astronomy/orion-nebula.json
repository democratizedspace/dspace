{
    "id": "astronomy/orion-nebula",
    "title": "Observe the Orion Nebula",
    "description": "Run a planned Orion session with seeing fallback, logged nebula evidence, and recovery loops when visibility collapses.",
    "image": "/assets/quests/orion_nebula_backyard_observation.jpg",
    "npc": "/assets/npc/nova.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Nova here. Orion's sword is up, but we'll only run if seeing and site safety are good.",
            "options": [
                {
                    "type": "goto",
                    "goto": "plan-window",
                    "text": "Let's plan the observation window."
                }
            ]
        },
        {
            "id": "plan-window",
            "text": "Draft a short star-hop plan with timing, glare checks, and a fallback slot in case clouds roll in.",
            "options": [
                {
                    "type": "process",
                    "process": "draft-seasonal-star-plan",
                    "text": "Observation plan drafted with fallback timing."
                },
                {
                    "type": "goto",
                    "goto": "setup",
                    "text": "Plan logged; proceed to setup.",
                    "requiresItems": [
                        {
                            "id": "60da6648-c22e-466e-9789-9e1d4635fd46",
                            "count": 1
                        },
                        {
                            "id": "98f6252e-95c2-468a-b110-69d47604df2c",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "weather-hold",
                    "text": "Seeing forecast is unstable; use fallback."
                }
            ]
        },
        {
            "id": "weather-hold",
            "text": "Fallback branch: preserve dark adaptation, avoid slippery routes, and wait for the next usable interval.",
            "options": [
                {
                    "type": "goto",
                    "goto": "plan-window",
                    "text": "Update timing and retry planning."
                },
                {
                    "type": "goto",
                    "goto": "setup",
                    "text": "Window reopened; resume setup.",
                    "requiresItems": [
                        {
                            "id": "60da6648-c22e-466e-9789-9e1d4635fd46",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "setup",
            "text": "Trace Orion, stabilize the tripod, and keep low power until the field is centered.",
            "options": [
                {
                    "type": "process",
                    "process": "identify-constellations",
                    "text": "Orion alignment verified."
                },
                {
                    "type": "goto",
                    "goto": "observe",
                    "text": "Scope stable and sword region centered.",
                    "requiresItems": [
                        {
                            "id": "9a72fb16-fc69-45c5-beca-f25c27028977",
                            "count": 1
                        },
                        {
                            "id": "f439b57a-9df3-4bd9-9b6e-042476ceecf5",
                            "count": 1
                        },
                        {
                            "id": "b73f795b-7abb-4a0c-950b-7f8ad82012b8",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "troubleshoot",
                    "text": "Field drift or glare is too strong."
                }
            ]
        },
        {
            "id": "observe",
            "text": "Log brightness, shape, and nearby stars so the observation has reproducible evidence.",
            "options": [
                {
                    "type": "process",
                    "process": "write-mission-log-entry",
                    "text": "Nebula notes entered in mission log."
                },
                {
                    "type": "goto",
                    "goto": "interpret",
                    "text": "Observation logged; ready to validate.",
                    "requiresItems": [
                        {
                            "id": "70bb8d86-2c4e-4330-9705-371891934686",
                            "count": 1
                        },
                        {
                            "id": "280ed361-ac70-4ab9-bcd9-aee481790faf",
