{
    "id": "astronomy/constellations",
    "title": "Map the Constellations",
    "description": "Identify key star patterns to aid celestial navigation.",
    "image": "/assets/quests/constellation_mapping_logbook.jpg",
    "npc": "/assets/npc/nova.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Great progress so far! Next let's learn the constellations visible this season.",
            "options": [
                {
                    "type": "goto",
                    "goto": "plan",
                    "text": "I'm excited to learn!"
                }
            ]
        },
        {
            "id": "plan",
            "text": "Mark this season's guide stars on the planisphere and keep red light low so you can move safely.",
            "options": [
                {
                    "type": "process",
                    "process": "draft-seasonal-star-plan",
                    "text": "Sketching arrows from guide stars."
                },
                {
                    "type": "goto",
                    "goto": "chart",
                    "text": "Plan is ready—let's star hop.",
                    "requiresItems": [
                        {
                            "id": "60da6648-c22e-466e-9789-9e1d4635fd46",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "chart",
            "text": "Find Orion, Ursa Major, and Cassiopeia, then sketch their bright stars and orientation without stepping into hazards.",
            "options": [
                {
                    "type": "process",
                    "process": "identify-constellations",
                    "text": "Charting patterns..."
                },
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "I can spot them easily now!",
                    "requiresItems": [
                        {
                            "id": "b73f795b-7abb-4a0c-950b-7f8ad82012b8",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "finish",
            "text": "Excellent! These patterns guide spacecraft spotting and future sessions. Keep the sketches handy.",
            "options": [
                {
                    "type": "finish",
                    "text": "Thanks, Nova!"
                }
            ]
        }
    ],
    "rewards": [
        {
            "id": "b73f795b-7abb-4a0c-950b-7f8ad82012b8",
            "count": 1
        }
    ],
    "requiresQuests": ["astronomy/jupiter-moons"]
}
