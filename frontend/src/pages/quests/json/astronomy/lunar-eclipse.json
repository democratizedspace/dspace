{
    "id": "astronomy/lunar-eclipse",
    "title": "Photograph a Lunar Eclipse",
    "description": "Capture images of the Moon as it moves through Earth's shadow.",
    "image": "/assets/quests/lunar_eclipse_astrophotography.jpg",
    "npc": "/assets/npc/nova.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "A total lunar eclipse is visible tonight. We'll run this like an observation drill: prep, capture, review, then decide whether to re-shoot.",
            "options": [
                {
                    "type": "goto",
                    "goto": "prep",
                    "text": "I'll set up my gear."
                }
            ]
        },
        {
            "id": "prep",
            "text": "Level the tripod, lock focus manually, and write your target exposure bracket in the mission logbook before first contact.",
            "options": [
                {
                    "type": "process",
                    "process": "write-mission-log-entry",
                    "text": "Exposure plan logged."
                },
                {
                    "type": "goto",
                    "goto": "capture",
                    "text": "Plan is logged and tripod is stable.",
                    "requiresItems": [
                        {
                            "id": "280ed361-ac70-4ab9-bcd9-aee481790faf",
                            "count": 1
                        },
                        {
                            "id": "49fb255e-a4c3-48e4-bca7-4c3781fdb98b",
                            "count": 1
                        },
                        {
                            "id": "70bb8d86-2c4e-4330-9705-371891934686",
                            "count": 1
                        },
                        {
                            "id": "aa82b02f-2617-4474-a91b-29647e4a9780",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "capture",
            "text": "Attach your camera to the telescope and photograph each eclipse phase with the planned bracket.",
            "options": [
                {
                    "type": "process",
                    "process": "photograph-lunar-eclipse",
                    "text": "Running the capture sequence."
                },
                {
                    "type": "goto",
                    "goto": "review",
                    "requiresItems": [
                        {
                            "id": "f439b57a-9df3-4bd9-9b6e-042476ceecf5",
