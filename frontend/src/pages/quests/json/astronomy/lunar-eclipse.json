                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "finish",
            "text": "Excellent work! Preserve the best frame notes in your logbook so the next eclipse setup starts from proven settings.",
            "options": [
                {
                    "type": "finish",
                    "text": "Capture set archived."
                }
            ]
