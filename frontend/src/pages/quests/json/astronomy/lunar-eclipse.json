                        },
                        {
                            "id": "a96ce9ed-b9e0-44e5-bd9f-c068643e6749",
                            "count": 1
                        }
                    ],
                    "text": "Shots captured\u2014ready for review."
                }
            ]
        },
        {
            "id": "review",
            "text": "Quality check: are crater edges sharp, highlights not clipped, and at least one umbral-phase frame usable?",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Yes\u2014usable set confirmed and logged."
                },
                {
                    "type": "goto",
                    "goto": "retake",
                    "text": "No\u2014blurred, clipped, or missing umbral detail."
                }
            ]
        },
        {
            "id": "retake",
            "text": "Troubleshoot safely: shorten shutter if trails smear, re-check focus with magnified live view, and pause if frost or unstable footing makes operation unsafe.",
            "options": [
                {
                    "type": "goto",
                    "goto": "capture",
                    "text": "Apply corrections and retake the sequence.",
                    "requiresItems": [
                        {
                            "id": "f439b57a-9df3-4bd9-9b6e-042476ceecf5",
                            "count": 1
                        },
                        {
