{
    "id": "astronomy/jupiter-moons",
    "title": "Track Jupiter's Moons",
    "description": "Align carefully, log multiple nights of Galilean moon positions, and stack them into an orbit plot.",
    "image": "/assets/quests/jupiter_moons_orbital_tracking.jpg",
    "npc": "/assets/npc/nova.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "With your telescope assembled, let's watch Jupiter's moons dance. Keep the logbook handy and red light low.",
            "options": [
                {
                    "type": "goto",
                    "goto": "map",
                    "text": "Gear ready and screen dimmed.",
                    "requiresItems": [
                        {
                            "id": "98f6252e-95c2-468a-b110-69d47604df2c",
                            "count": 1
                        },
                        {
                            "id": "9a72fb16-fc69-45c5-beca-f25c27028977",
                            "count": 1
                        },
                        {
                            "id": "70bb8d86-2c4e-4330-9705-371891934686",
                            "count": 1
                        },
                        {
                            "id": "f439b57a-9df3-4bd9-9b6e-042476ceecf5",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "map",
            "text": "Use the planisphere to mark Jupiter's position and nearby bright stars so you can return to it night after night.",
            "options": [
                {
                    "type": "process",
                    "process": "identify-constellations",
                    "text": "Plot Jupiter and reference stars."
                },
                {
                    "type": "goto",
                    "goto": "align",
                    "text": "Hop marked in my log.",
                    "requiresItems": [
                        {
                            "id": "b73f795b-7abb-4a0c-950b-7f8ad82012b8",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "align",
            "text": "Level the tripod, align on Polaris, and make sure the path around your observing spot stays clear in the dark.",
            "options": [
                {
                    "type": "process",
                    "process": "mark-polaris-alignment",
                    "text": "Lock in Polaris."
                },
                {
                    "type": "goto",
                    "goto": "map",
                    "text": "Need to redo the hop."
                },
                {
                    "type": "goto",
                    "goto": "observe",
                    "text": "Alignment noted and ready to track moons.",
                    "requiresItems": [
                        {
                            "id": "6102f07b-384b-437f-b78f-d1e9b5431e97",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "observe",
            "text": "Sketch Io, Europa, Ganymede, and Callisto each night with timestamps. Note clouds, seeing, and any eclipses you catch.",
            "options": [
                {
                    "type": "process",
                    "process": "observe-jupiter-moons",
                    "text": "Log tonight's moon positions."
                },
                {
                    "type": "goto",
                    "goto": "align",
                    "text": "Recenter and align again."
                },
                {
                    "type": "goto",
                    "goto": "chart",
                    "requiresItems": [
                        {
                            "id": "d7c735ea-832a-46e2-b790-439d1d78a656",
                            "count": 1
                        }
                    ],
                    "text": "Ready to plot the tracks."
                }
            ]
        },
        {
            "id": "chart",
            "text": "Stack your nightly sketches into one plot to see the arcs curve. It makes orbital mechanics feel real fast.",
            "options": [
                {
                    "type": "process",
                    "process": "chart-galilean-orbits",
                    "text": "Combine the week of logs."
                },
                {
                    "type": "goto",
                    "goto": "observe",
                    "text": "Gather another night."
                },
                {
                    "type": "goto",
                    "goto": "finish",
                    "requiresItems": [
                        {
                            "id": "7fed13b2-414b-4037-9434-17b6bc7be19f",
                            "count": 1
                        }
                    ],
                    "text": "Orbit plot complete."
                }
            ]
        },
        {
            "id": "finish",
            "text": "Excellent diligence! Tracking these moons builds the skills needed for future navigation challenges.",
            "options": [
                {
                    "type": "finish",
                    "text": "Space feels closer already."
                }
            ]
        }
    ],
    "rewards": [],
