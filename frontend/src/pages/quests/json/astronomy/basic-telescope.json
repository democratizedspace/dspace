        {
            "id": "build",
            "text": "Tape the 50 mm lens to the front as the objective and the 20 mm lens at the back as the eyepiece. Mount the tube securely on the tripod, verify stability, handle glass edges carefully, and never aim at the Sun.",
            "options": [
                {
                    "type": "process",
                    "process": "assemble-basic-telescope",
                    "text": "Putting it together."
                },
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "I can see Jupiter!",
                    "requiresItems": [
