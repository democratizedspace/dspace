                            "id": "f439b57a-9df3-4bd9-9b6e-042476ceecf5",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "finish",
            "text": "Excellent craftsmanship! Regular stargazing will sharpen your navigation skills for future missions. Cap both lenses with masking tape when storing and keep the telescope out of direct sunlight.",
            "options": [
                {
                    "type": "finish",
                    "text": "Thanks, Nova."
                }
            ]
        }
