            ]
        },
        {
            "id": "finish",
            "text": "Excellent craftsmanship. Regular stargazing sharpens navigation. Cap both lenses before storing and keep the telescope away from heat and direct sunlight.",
            "options": [
                {
                    "type": "finish",
                    "text": "Thanks, Nova."
                }
            ]
