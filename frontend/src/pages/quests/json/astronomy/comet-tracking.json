{
    "id": "astronomy/comet-tracking",
    "title": "Track a Visiting Comet",
    "description": "Use your telescope to plot a comet's path across several nights.",
    "image": "/assets/quests/solar.jpg",
    "npc": "/assets/npc/nova.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "A bright comet is passing by. Let's chart its position each evening.",
            "options": [{ "type": "goto", "goto": "observe", "text": "I'll set up." }]
        },
        {
            "id": "observe",
            "text": "Sketch the comet's location relative to nearby stars so we can see how it moves.",
            "options": [
                {
                    "type": "process",
                    "process": "observe-meteor-shower",
                    "text": "Observing"
                },
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Path recorded",
                    "requiresItems": [{ "id": "134", "count": 1 }]
                }
            ]
        },
        {
            "id": "finish",
            "text": "Excellent observations! Comparing notes over multiple nights reveals its orbit.",
            "options": [{ "type": "finish", "text": "Fascinating!" }]
        }
    ],
    "rewards": [],
    "requiresQuests": ["astronomy/meteor-shower"]
}
