                        {
                            "id": "aa82b02f-2617-4474-a91b-29647e4a9780",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "troubleshoot",
                    "text": "Something is missing or inconsistent."
                }
            ]
        },
        {
            "id": "troubleshoot",
            "text": "Recovery path: reset to low magnification, re-check footing and tripod stability, and retry only if visibility is safe.",
            "options": [
                {
                    "type": "goto",
                    "goto": "observe",
                    "text": "Stability restored; retry observation."
                },
                {
                    "type": "goto",
                    "goto": "weather-hold",
                    "text": "Visibility unsafe—defer to the next clear window."
                }
            ]
        },
        {
            "id": "weather-hold",
            "text": "Fallback branch: pause the session, log weather constraints, and return when cloud cover drops and your path remains safe.",
            "options": [
                {
                    "type": "goto",
                    "goto": "plan",
                    "text": "Conditions improved; refresh the plan."
                },
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Session closed safely with a deferral note."
                }
            ]
        },
        {
            "id": "finish",
            "text": "Excellent tracking run. You logged reproducible comet evidence and used a safe recovery loop when conditions shifted.",
            "options": [
                {
                    "type": "finish",
                    "text": "I'll compare this against tomorrow's track."
                }
            ]
        }
    ],
