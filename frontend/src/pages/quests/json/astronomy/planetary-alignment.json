{
    "id": "astronomy/planetary-alignment",
    "title": "Planetary Alignment",
    "description": "Map the ecliptic path, align safely on a tripod, and sketch the rare planetary lineup in your logbook.",
    "image": "/assets/quests/planetary_alignment_star_chart.jpg",
    "npc": "/assets/npc/nova.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Several planets are lining up tonight. We'll need a clean hop, stable tripod, and red light discipline.",
            "options": [
                {
                    "type": "goto",
                    "goto": "map",
                    "text": "Chart, tripod, and logbook are ready.",
                    "requiresItems": [
                        {
                            "id": "98f6252e-95c2-468a-b110-69d47604df2c",
                            "count": 1
                        },
                        {
                            "id": "9a72fb16-fc69-45c5-beca-f25c27028977",
                            "count": 1
                        },
                        {
                            "id": "70bb8d86-2c4e-4330-9705-371891934686",
                            "count": 1
                        },
                        {
                            "id": "f439b57a-9df3-4bd9-9b6e-042476ceecf5",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "map",
            "text": "Trace the ecliptic across your star chart and mark the horizon points. Keep the red light shielded so your eyes stay dark-adapted.",
            "options": [
                {
                    "type": "process",
                    "process": "identify-constellations",
                    "text": "Mark the ecliptic hop."
                },
                {
                    "type": "goto",
                    "goto": "compose",
                    "requiresItems": [
                        {
                            "id": "b73f795b-7abb-4a0c-950b-7f8ad82012b8",
                            "count": 1
                        }
                    ],
                    "text": "Hop plotted and ready to sketch."
                }
            ]
        },
        {
            "id": "compose",
            "text": "Level the tripod, pan slowly along the line, and note color and brightness differences. Keep the area clear so no one bumps the optics.",
            "options": [
                {
                    "type": "process",
                    "process": "sketch-planetary-alignment",
                    "text": "Sketch the lineup."
                },
                {
                    "type": "goto",
                    "goto": "map",
                    "text": "Need to revise the hop."
                },
                {
                    "type": "goto",
                    "goto": "completion",
                    "requiresItems": [
                        {
                            "id": "79df7b33-c1ac-4bbc-aa0b-265a1ffd3104",
                            "count": 1
                        }
                    ],
                    "text": "Sketch finished with labels."
                }
            ]
        },
        {
            "id": "completion",
            "text": "Great work! The planetary lineup is documented.",
            "options": [
                {
                    "type": "finish",
                    "text": "Celestial success!"
                }
            ]
        }
