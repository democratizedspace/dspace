{
    "id": "astronomy/iss-flyover",
    "title": "Spot the ISS",
    "description": "Use a satellite-tracking app and a basic telescope to plan, spot, and log an ISS flyover safely.",
    "hardening": {
        "passes": 4,
        "score": 100,
        "emoji": "💯",
        "history": [
