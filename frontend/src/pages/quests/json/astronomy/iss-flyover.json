    "image": "/assets/quests/iss_flyover_backyard_observation.jpg",
    "npc": "/assets/npc/nova.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "The ISS crosses the sky a few times each week. Let's plan tonight's pass before heading out.",
            "options": [
                {
                    "type": "goto",
                    "goto": "plan",
                    "text": "When should I look?"
                }
            ]
        },
        {
            "id": "plan",
            "text": "Open a tracking app, allow location, and jot the pass time and direction in your logbook.",
            "options": [
                {
                    "type": "process",
                    "process": "check-iss-pass",
                    "text": "The app shows a flyover soon."
                },
                {
                    "type": "goto",
                    "goto": "setup",
                    "text": "Details logged. How do I stage the scope?",
                    "requiresItems": [
                        {
                            "id": "16478015-5213-4b3f-960c-c0fdaaa91297",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "setup",
            "text": "Level the tripod, cap the telescope until the pass starts, clear a safe path, and keep the red flashlight dim for night vision.",
            "options": [
                {
                    "type": "process",
                    "process": "stage-iss-spotting-station",
                    "text": "Tripod is leveled and aimed toward the pass."
                },
                {
                    "type": "goto",
                    "goto": "session-check",
                    "text": "Station is ready for the pass.",
                    "requiresItems": [
                        {
                            "id": "bb97e755-4337-4e9d-8063-4a0cff4649b5",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "session-check",
            "text": "Final pre-pass check: clouds below half coverage, no bright floodlight in your line of sight, and a clear walking path.",
            "options": [
                {
                    "type": "goto",
                    "goto": "observe",
                    "text": "Conditions are safe enough to observe now."
                },
                {
                    "type": "goto",
                    "goto": "fallback",
                    "text": "Clouds or glare make this session unreliable."
                }
            ]
        },
        {
            "id": "observe",
            "text": "Watch the ISS on the predicted path, sweep once it's above trees, and log brightness and duration without blocking paths.",
            "options": [
                {
                    "type": "process",
                    "process": "log-iss-pass",
                    "text": "Logged the arc from horizon to horizon."
                },
                {
                    "type": "goto",
                    "goto": "interpret",
                    "text": "Observation artifact captured.",
                    "requiresItems": [
                        {
                            "id": "067aa8eb-b5a4-4bef-a307-7dde10e981f5",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "interpret",
            "text": "Review your log: if time offset is under two minutes and direction notes match the prediction, the session passes. If not, classify it as a miss and schedule a retry.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Log quality passes and safety notes are complete.",
                    "requiresItems": [
                        {
                            "id": "067aa8eb-b5a4-4bef-a307-7dde10e981f5",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "fallback",
                    "text": "This log is incomplete or timing drifted."
                }
            ]
        },
        {
            "id": "fallback",
            "text": "Fallback mode: move to a darker view line or pick the next predicted pass, then rerun planning before another attempt.",
            "options": [
                {
                    "type": "goto",
                    "goto": "plan",
                    "text": "Schedule another pass window and retry."
                }
            ]
        },
        {
            "id": "finish",
            "text": "Awesome! Cap the telescope, close the app, pack your gear, and watch your footing in the dark.",
            "options": [
                {
                    "type": "finish",
                    "text": "Agreed!"
                }
            ]
        }
    ],
    "rewards": [
        {
            "id": "067aa8eb-b5a4-4bef-a307-7dde10e981f5",
            "count": 1
        }
    ],
    "requiresQuests": ["astronomy/observe-moon"]
}
