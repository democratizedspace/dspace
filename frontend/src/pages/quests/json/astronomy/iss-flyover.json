{
    "id": "astronomy/iss-flyover",
    "title": "Spot the ISS",
    "description": "Plan an ISS pass, capture an observation artifact, and use weather/glare recovery with a scheduled follow-up when needed.",
    "hardening": {
        "passes": 3,
        "emoji": "🛠️",
        "history": [
            {
                "task": "codex-quest-hardening-2025-02-14",
                "date": "2025-02-14",
                "score": 90
            },
            {
                "task": "codex-quest-refresh-2025-02-14",
                "date": "2025-02-14",
                "score": 90
            },
            {
                "task": "codex-quest-upgrade-2025-08-14",
                "date": "2025-08-14",
                "score": 95
            }
        ],
        "score": 95
    },
    "image": "/assets/quests/iss_flyover_backyard_observation.jpg",
    "npc": "/assets/npc/nova.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "The ISS crosses the sky a few times each week. Want the standard station setup or a lighter naked-eye fallback route?",
            "options": [
                {
                    "type": "goto",
                    "goto": "plan",
                    "text": "Let's plan tonight's pass."
                }
            ]
        },
        {
            "id": "plan",
            "text": "Open a tracking app, allow location, and log pass time plus direction. This pass window is your proof gate.",
            "options": [
                {
                    "type": "process",
                    "process": "check-iss-pass",
                    "text": "Pass window written down."
                },
                {
                    "type": "goto",
                    "goto": "choose-observation-mode",
                    "text": "Details logged. Pick an observation mode.",
                    "requiresItems": [
                        {
                            "id": "16478015-5213-4b3f-960c-c0fdaaa91297",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "weather-delay",
                    "text": "Cloud cover or haze may block this pass."
                }
            ]
        },
        {
            "id": "choose-observation-mode",
            "text": "Main path uses the full station. Alternate path uses a safe naked-eye lane when setup time is short.",
            "options": [
                {
                    "type": "goto",
                    "goto": "setup",
                    "text": "Main path: stage the spotting station."
                },
                {
                    "type": "goto",
                    "goto": "observe-quick",
                    "text": "Fallback path: run a naked-eye observation lane."
                }
            ]
        },
        {
            "id": "weather-delay",
            "text": "If visibility is poor, avoid rushing in low light. Re-check the app for the next pass and confirm your walking lane is still clear.",
            "options": [
                {
                    "type": "goto",
                    "goto": "plan",
                    "text": "Conditions changed, let's re-plan safely."
                },
                {
                    "type": "goto",
                    "goto": "follow-up-window",
                    "text": "No clear window tonight—schedule a follow-up pass."
                }
            ]
        },
        {
            "id": "setup",
            "text": "Level the tripod, cap the telescope between checks, clear a safe path, and keep the red flashlight dim for night vision.",
            "options": [
                {
                    "type": "process",
                    "process": "stage-iss-spotting-station",
                    "text": "Tripod is leveled and aimed toward the pass."
                },
                {
                    "type": "goto",
                    "goto": "observe",
                    "text": "Station is ready for the pass.",
                    "requiresItems": [
                        {
                            "id": "bb97e755-4337-4e9d-8063-4a0cff4649b5",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "weather-delay",
                    "text": "Fog rolled in while setting up."
                }
            ]
        },
        {
            "id": "observe-quick",
            "text": "Fallback lane: use naked-eye tracking from a clear horizon and log when the ISS enters and exits your field of view.",
            "options": [
                {
                    "type": "process",
                    "process": "log-iss-pass",
                    "text": "Quick observation logged with start/end direction."
                },
                {
                    "type": "goto",
                    "goto": "interpret",
                    "text": "Quick log complete with direction and duration.",
                    "requiresItems": [
                        {
                            "id": "067aa8eb-b5a4-4bef-a307-7dde10e981f5",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "weather-delay",
                    "text": "Lost the ISS in haze or light pollution."
                }
            ]
        },
        {
            "id": "observe",
            "text": "Watch the ISS on the predicted path, sweep once it is above trees, and log brightness plus duration without blocking walkways.",
            "options": [
                {
                    "type": "process",
                    "process": "log-iss-pass",
                    "text": "Logged the arc from horizon to horizon."
                },
                {
                    "type": "goto",
                    "goto": "interpret",
                    "text": "Entry complete with time and direction.",
                    "requiresItems": [
                        {
                            "id": "067aa8eb-b5a4-4bef-a307-7dde10e981f5",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "weather-delay",
                    "text": "Lost the track in glare or cloud."
                }
            ]
        },
        {
            "id": "interpret",
            "text": "Quality gate: pass time, direction, and duration must all be logged. If any field is missing, classify the miss and rerun setup or fallback mode.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Log has all fields with condition notes.",
                    "requiresItems": [
                        {
                            "id": "067aa8eb-b5a4-4bef-a307-7dde10e981f5",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "choose-observation-mode",
                    "text": "Missing details—retry with explicit mode selection."
                }
            ]
        },
        {
            "id": "follow-up-window",
            "text": "Record a follow-up target window before closing. Safety note: avoid dark-site travel when visibility and footing are both poor.",
            "options": [
                {
                    "type": "process",
                    "process": "write-mission-log-entry",
                    "text": "Follow-up window logged in mission notes."
                },
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Follow-up scheduled and safety note recorded.",
                    "requiresItems": [
                        {
                            "id": "70bb8d86-2c4e-4330-9705-371891934686",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "finish",
            "text": "Awesome. You captured or deferred the pass with explicit evidence, fallback handling, and safe night operations.",
            "options": [
                {
                    "type": "finish",
                    "text": "Agreed!"
                }
            ]
        }
    ],
    "rewards": [
        {
            "id": "067aa8eb-b5a4-4bef-a307-7dde10e981f5",
            "count": 1
        }
    ],
    "requiresQuests": [
        "astronomy/observe-moon"
    ]
}
