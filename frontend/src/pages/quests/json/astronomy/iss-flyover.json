{
    "id": "astronomy/iss-flyover",
    "title": "Spot the ISS",
    "description": "Use a satellite-tracking app and a basic telescope to plan, spot, and log an ISS flyover safely.",
    "hardening": {
        "passes": 4,
        "score": 100,
        "emoji": "💯",
        "history": [
            { "task": "codex-hardening-2025-08-05", "date": "2025-08-05", "score": 60 },
            { "task": "codex-quest-refinement-2025-08-06", "date": "2025-08-06", "score": 80 },
            { "task": "codex-quest-refresh-2025-02-14", "date": "2025-02-14", "score": 90 },
            { "task": "codex-quest-upgrade-2025-08-14", "date": "2025-08-14", "score": 95 }
        ]
    },
    "image": "/assets/quests/iss_flyover_backyard_observation.jpg",
    "npc": "/assets/npc/nova.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "The ISS crosses the sky a few times each week. Let's plan tonight's pass before heading out.",
            "options": [
                {
                    "type": "goto",
                    "goto": "plan",
                    "text": "When should I look?"
                }
            ]
        },
        {
            "id": "plan",
            "text": "Open a tracking app, allow location, and jot the pass time and direction in your logbook.",
            "options": [
                {
                    "type": "process",
                    "process": "check-iss-pass",
                    "text": "The app shows a flyover soon."
                },
                {
                    "type": "goto",
                    "goto": "setup",
                    "text": "Details logged. How do I stage the scope?",
                    "requiresItems": [{ "id": "16478015-5213-4b3f-960c-c0fdaaa91297", "count": 1 }]
                }
            ]
        },
        {
            "id": "setup",
            "text": "Level the tripod, cap the telescope, clear a safe path, and keep the red flashlight dim for night vision.",
            "options": [
                {
                    "type": "process",
                    "process": "stage-iss-spotting-station",
                    "text": "Tripod is leveled and aimed toward the pass."
                },
                {
                    "type": "goto",
                    "goto": "observe",
                    "text": "Station is ready for the pass.",
                    "requiresItems": [{ "id": "bb97e755-4337-4e9d-8063-4a0cff4649b5", "count": 1 }]
                }
            ]
        },
        {
            "id": "observe",
            "text": "Watch the ISS on the predicted path, sweep once it's above trees, and log brightness and duration without blocking paths.",
            "options": [
                {
                    "type": "process",
                    "process": "log-iss-pass",
                    "text": "Logged the arc from horizon to horizon."
                },
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Entry complete with time and direction.",
                    "requiresItems": [{ "id": "067aa8eb-b5a4-4bef-a307-7dde10e981f5", "count": 1 }]
                }
            ]
        },
        {
            "id": "finish",
            "text": "Awesome! Cap the telescope, close the app, pack your gear, and watch your footing in the dark.",
            "options": [
                {
                    "type": "finish",
                    "text": "Agreed!"
                }
            ]
        }
    ],
    "rewards": [{ "id": "067aa8eb-b5a4-4bef-a307-7dde10e981f5", "count": 1 }],
    "requiresQuests": ["astronomy/observe-moon"]
}
