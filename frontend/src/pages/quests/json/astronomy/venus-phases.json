{
    "id": "astronomy/venus-phases",
    "title": "Observe Venus's Phases",
    "description": "Use a planisphere and basic telescope to track Venus through its lunar-like phases.",
    "image": "/assets/quests/venus_phases_telescope_sequence.jpg",
    "npc": "/assets/npc/nova.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Nova here. Venus is bright tonight; let's watch its phase change.",
            "options": [
                {
                    "type": "goto",
                    "goto": "plan",
                    "text": "Ready to aim.",
                    "requiresItems": [
                        { "id": "98f6252e-95c2-468a-b110-69d47604df2c", "count": 1 },
                        { "id": "f439b57a-9df3-4bd9-9b6e-042476ceecf5", "count": 1 },
                        { "id": "70bb8d86-2c4e-4330-9705-371891934686", "count": 1 }
                    ]
                }
            ]
        },
        {
            "id": "plan",
            "text": "Dial the planisphere to tonight's date and see when Venus clears your western horizon.",
            "options": [
                {
                    "type": "process",
                    "process": "plan-venus-phase-window",
                    "goto": "view",
                    "text": "Mark the viewing window in your log.",
                    "requiresItems": [
                        { "id": "98f6252e-95c2-468a-b110-69d47604df2c", "count": 1 },
                        { "id": "70bb8d86-2c4e-4330-9705-371891934686", "count": 1 }
                    ]
                }
            ]
        },
        {
            "id": "view",
            "text": "Find Venus, switch to the lowest-power eyepiece, and rack focus until its crescent snaps into view.",
            "options": [
                {
                    "type": "process",
                    "process": "sketch-venus-phase",
                    "goto": "finish",
                    "text": "Sketch the phase and note sky conditions.",
                    "requiresItems": [
                        { "id": "9a72fb16-fc69-45c5-beca-f25c27028977", "count": 1 },
                        { "id": "f439b57a-9df3-4bd9-9b6e-042476ceecf5", "count": 1 },
                        { "id": "280ed361-ac70-4ab9-bcd9-aee481790faf", "count": 1 }
                    ]
                }
            ]
        },
        {
            "id": "finish",
            "text": "Great observation! Tracking phases helps practice precision focusing.",
            "options": [
                {
                    "type": "finish",
                    "text": "Can't wait for the next phase.",
                    "requiresItems": [
                        { "id": "1c9dd1a5-1c0c-4fba-a3b8-f08f5c0c9c5a", "count": 1 }
                    ]
                }
            ]
        }
    ],
