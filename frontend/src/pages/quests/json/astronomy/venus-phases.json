{
    "id": "astronomy/venus-phases",
    "title": "Observe Venus's Phases",
    "description": "Use a planisphere and basic telescope to plan, view, and sketch Venus's shifting phase.",
    "image": "/assets/quests/venus_phases_telescope_sequence.jpg",
    "npc": "/assets/npc/nova.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Nova here. Venus is bright tonight; let's watch its phase change.",
            "options": [
                {
                    "type": "goto",
                    "goto": "plan",
                    "text": "Ready to aim.",
                    "requiresItems": [
                        {
                            "id": "98f6252e-95c2-468a-b110-69d47604df2c",
                            "count": 1
                        },
                        {
                            "id": "f439b57a-9df3-4bd9-9b6e-042476ceecf5",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "plan",
            "text": "Use the planisphere and an app to pick a time when Venus is high enough for a crisp view and your path is well lit.",
            "options": [
                {
                    "type": "process",
                    "process": "plan-venus-window",
                    "text": "Window chosen and written down."
                },
                {
                    "type": "goto",
                    "goto": "view",
                    "text": "Timing locked—let's observe.",
                    "requiresItems": [
                        {
                            "id": "4b328572-69f2-4fa6-8005-dc64ac434cef",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "view",
            "text": "Set up the telescope on stable ground, center Venus, and adjust focus until the phase edge is sharp. Keep both feet planted and avoid aiming near the horizon glare.",
            "options": [
                {
                    "type": "process",
                    "process": "sketch-venus-phase",
                    "text": "Sketching the illuminated slice."
                },
                {
                    "type": "goto",
                    "goto": "interpret",
                    "text": "Phase measurement recorded.",
                    "requiresItems": [
                        {
                            "id": "85d4fb76-9591-4b70-b88d-e74ff133215d",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "interpret",
            "text": "Interpret the sketch: a clean crescent edge and timestamp match count as pass criteria. If the edge is smeared by haze or misfocus, classify it out-of-range and retest.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Sketch passes clarity and timing thresholds.",
                    "requiresItems": [
                        {
                            "id": "85d4fb76-9591-4b70-b88d-e74ff133215d",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "corrective",
                    "text": "Out-of-range: haze, glare, or poor focus hid the phase edge."
                }
            ]
        },
        {
            "id": "corrective",
            "text": "Corrective loop: wait for steadier air, shield local lights, and re-check tripod tension before taking another sketch. Pause if dew makes footing slick.",
            "options": [
                {
                    "type": "goto",
                    "goto": "view",
                    "text": "Re-test with corrected setup."
                }
            ]
        },
        {
            "id": "finish",
            "text": "Great observation! Tracking phases helps practice precision focusing.",
            "options": [
                {
                    "type": "finish",
                    "text": "Can't wait for the next phase."
                }
            ]
        }
    ],
