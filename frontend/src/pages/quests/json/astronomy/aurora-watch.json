{
    "id": "astronomy/aurora-watch",
    "title": "Watch the Aurora",
    "description": "Pick a safe aurora window, pack red light and layers, and log what you spot.",
    "image": "/assets/quests/aurora_watch_red_flashlight.jpg",
    "npc": "/assets/npc/nova.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Solar winds may trigger auroras tonight. We'll plan first so weather or light pollution does not waste your cold-weather window.",
            "options": [
                {
                    "type": "goto",
                    "goto": "forecast",
                    "text": "I'll check the numbers before bundling up."
                }
            ]
        },
        {
            "id": "forecast",
            "text": "Check Kp forecast, cloud cover, and moon phase. Choose a dark site with safe footing and a buddy check-in plan.",
            "options": [
                {
                    "type": "process",
                    "process": "check-aurora-forecast",
                    "text": "Forecast locked in and written down."
                },
                {
                    "type": "goto",
                    "goto": "kit",
                    "text": "Window picked—what should I pack?",
                    "requiresItems": [
                        {
                            "id": "808f8298-ba98-43d6-907b-1b34a7daffb8",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "fallback-plan",
                    "text": "Clouds or city glow look too strong tonight."
                }
            ]
        },
        {
            "id": "kit",
            "text": "Layer up, clip the red flashlight, text a buddy with your site and return time, and keep your logbook in a dry sleeve.",
            "options": [
                {
                    "type": "process",
                    "process": "pack-dark-sky-kit",
                    "text": "Packing the essentials."
                },
                {
                    "type": "goto",
                    "goto": "observe",
                    "text": "Kit is ready—let's step outside.",
                    "requiresItems": [
                        {
                            "id": "0ce0d0d4-d734-4099-b903-92e9b1c52b05",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "observe",
            "text": "Let eyes adjust, sweep the northern horizon for arcs or curtains, and note color, direction, and time while staying aware of icy or uneven ground.",
            "options": [
                {
                    "type": "process",
                    "process": "log-aurora-sighting",
                    "text": "Logging the shimmering curtains."
                },
                {
                    "type": "goto",
                    "goto": "interpret",
                    "text": "Entry written with colors and timestamps.",
                    "requiresItems": [
                        {
                            "id": "682c9b29-b16f-4cf1-aaad-861a4aa133f4",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "fallback-plan",
                    "text": "No visible aurora yet."
                }
            ]
        },
        {
            "id": "interpret",
            "text": "Interpret your observation: green arcs with stable motion suggest moderate activity; fast-moving reds and purples suggest stronger storms. Note confidence and likely uncertainty sources.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Interpretation added to my logbook.",
                    "requiresItems": [
                        {
                            "id": "682c9b29-b16f-4cf1-aaad-861a4aa133f4",
                            "count": 1
                        },
                        {
                            "id": "98f6252e-95c2-468a-b110-69d47604df2c",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "fallback-plan",
            "text": "Troubleshoot before ending the session: if cloud cover is high, reschedule for the next clear window; if local lights are bright, move farther from glare. Re-check forecasts and set a follow-up watch time.",
            "options": [
                {
                    "type": "process",
                    "process": "check-aurora-forecast",
                    "text": "Schedule a follow-up observation window."
                },
                {
                    "type": "goto",
                    "goto": "observe",
                    "text": "Conditions improved—retry the watch.",
                    "requiresItems": [
                        {
                            "id": "808f8298-ba98-43d6-907b-1b34a7daffb8",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "No sighting tonight, but follow-up session is scheduled.",
                    "requiresItems": [
                        {
                            "id": "808f8298-ba98-43d6-907b-1b34a7daffb8",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "finish",
            "text": "Nice discipline. Warm up, check in with your buddy, and keep conditions notes so your next aurora run starts stronger.",
            "options": [
                {
                    "type": "finish",
                    "text": "I'll watch again soon."
                }
            ]
        }
    ],
    "rewards": [
