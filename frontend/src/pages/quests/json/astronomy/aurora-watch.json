{
    "id": "astronomy/aurora-watch",
    "title": "Watch the Aurora",
    "description": "Pick a safe aurora window, pack red light and layers, and log what you spot.",
    "image": "/assets/quests/aurora_watch_red_flashlight.jpg",
    "npc": "/assets/npc/nova.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Solar winds may trigger auroras tonight. Let's plan before stepping into the cold.",
            "options": [
                {
                    "type": "goto",
                    "goto": "forecast",
                    "text": "I'll check the numbers before bundling up."
                }
            ]
        },
        {
            "id": "forecast",
            "text": "Check an aurora app for Kp, clouds, and a clear hour. Pick a dark spot with safe footing.",
            "options": [
                {
                    "type": "process",
                    "process": "check-aurora-forecast",
                    "text": "Forecast locked in and written down."
                },
                {
                    "type": "goto",
                    "goto": "kit",
                    "text": "Window picked—what should I pack?",
                    "requiresItems": [
                        {
                            "id": "808f8298-ba98-43d6-907b-1b34a7daffb8",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "kit",
            "text": "Layer up, clip the red flashlight, text a buddy with your spot, and keep the logbook dry.",
            "options": [
                {
                    "type": "process",
                    "process": "pack-dark-sky-kit",
                    "text": "Packing the essentials."
                },
                {
                    "type": "goto",
                    "goto": "session-check",
                    "text": "Kit is ready—let's step outside.",
                    "requiresItems": [
                        {
                            "id": "0ce0d0d4-d734-4099-b903-92e9b1c52b05",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "session-check",
            "text": "Final call before observing: if cloud cover rises or roads ice over, switch to fallback mode instead of taking risks.",
            "options": [
                {
                    "type": "goto",
                    "goto": "observe",
                    "text": "Conditions are safe and clear enough to observe."
                },
                {
                    "type": "goto",
                    "goto": "fallback",
                    "text": "Clouded out or unsafe tonight—use the fallback plan."
                }
            ]
        },
        {
            "id": "fallback",
            "text": "Good call. Log the aborted attempt, keep your kit staged, and schedule the next clear-hour window. Safety beats forcing a bad session.",
            "options": [
                {
                    "type": "process",
                    "process": "check-aurora-forecast",
                    "text": "Re-check forecasts and pick a safer window."
                },
                {
                    "type": "goto",
                    "goto": "session-check",
                    "text": "Updated forecast ready—re-evaluate conditions.",
                    "requiresItems": [
                        {
                            "id": "808f8298-ba98-43d6-907b-1b34a7daffb8",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "observe",
            "text": "Let eyes adjust, sweep the northern horizon for arcs or curtains, and note color and time while staying aware of your footing.",
            "options": [
                {
                    "type": "process",
                    "process": "log-aurora-sighting",
                    "text": "Logging the shimmering curtains."
                },
                {
                    "type": "goto",
                    "goto": "verify-log",
                    "text": "Entry written with colors and timestamps.",
                    "requiresItems": [
                        {
                            "id": "682c9b29-b16f-4cf1-aaad-861a4aa133f4",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "verify-log",
            "text": "Before closing, verify your log includes time, color, and horizon direction. Missing fields mean no reproducible observation.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "All fields are complete and readable."
                },
                {
                    "type": "goto",
                    "goto": "observe",
                    "text": "A field is missing—I'll re-log this session."
                }
            ]
        },
        {
            "id": "finish",
            "text": "Nice catch! Your notes help track storms. Warm up, check in with your buddy, and reuse dark sites.",
            "options": [
                {
                    "type": "finish",
                    "text": "I'll watch again soon."
                }
            ]
        }
    ],
    "rewards": [
