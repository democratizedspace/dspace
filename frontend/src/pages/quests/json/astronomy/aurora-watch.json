{
    "id": "astronomy/aurora-watch",
    "title": "Watch the Aurora",
    "description": "Pick a safe aurora window, pack red light and layers, and log what you spot.",
    "image": "/assets/quests/aurora_watch_red_flashlight.jpg",
    "npc": "/assets/npc/nova.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Solar winds may trigger auroras tonight. Let's plan before stepping into the cold.",
            "options": [
                {
                    "type": "goto",
                    "goto": "forecast",
                    "text": "I'll check the numbers before bundling up."
                }
            ]
        },
        {
            "id": "forecast",
            "text": "Check an aurora app for Kp, cloud cover, and a clear hour. Pick a dark spot with safe footing and an indoor warm-up fallback.",
            "options": [
                {
                    "type": "process",
                    "process": "check-aurora-forecast",
                    "text": "Forecast locked in and written down."
                },
                {
                    "type": "goto",
                    "goto": "kit",
                    "text": "Window picked—what should I pack?",
                    "requiresItems": [
                        {
                            "id": "808f8298-ba98-43d6-907b-1b34a7daffb8",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "kit",
            "text": "Layer up, clip the red flashlight, text a buddy with your spot, and keep the logbook dry. If wind chill spikes, abort and re-plan instead of pushing through.",
            "options": [
                {
                    "type": "process",
                    "process": "pack-dark-sky-kit",
                    "text": "Packing the essentials."
                },
                {
                    "type": "goto",
                    "goto": "observe",
                    "text": "Kit is ready—let's step outside.",
                    "requiresItems": [
                        {
                            "id": "0ce0d0d4-d734-4099-b903-92e9b1c52b05",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "observe",
            "text": "Let eyes adjust, scan the northern horizon for arcs or curtains, and note color and time while staying aware of your footing.",
            "options": [
                {
                    "type": "process",
                    "process": "log-aurora-sighting",
                    "text": "Logging the shimmering curtains."
                },
                {
                    "type": "goto",
                    "goto": "interpret",
                    "text": "Entry written with colors and timestamps.",
                    "requiresItems": [
                        {
                            "id": "682c9b29-b16f-4cf1-aaad-861a4aa133f4",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "weather-fallback",
                    "text": "Cloud deck rolled in before I could confirm colors."
                }
            ]
        },
        {
            "id": "weather-fallback",
            "text": "Good call to stop. Re-check Kp and cloud timing, relocate away from light pollution if needed, and schedule a second watch window.",
            "options": [
                {
                    "type": "process",
                    "process": "check-aurora-forecast",
                    "text": "Re-running forecast for a safer follow-up window."
                },
                {
                    "type": "goto",
                    "goto": "observe",
                    "text": "New clear window found—retry observation.",
                    "requiresItems": [
                        {
                            "id": "808f8298-ba98-43d6-907b-1b34a7daffb8",
                            "count": 1
                        },
                        {
                            "id": "0ce0d0d4-d734-4099-b903-92e9b1c52b05",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "interpret",
            "text": "Interpretation check: confirm at least one timestamped color change and one directional note in the log. If either is missing, run one more observation pass.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Log includes timestamps, color shifts, and direction notes.",
                    "requiresItems": [
                        {
                            "id": "682c9b29-b16f-4cf1-aaad-861a4aa133f4",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "weather-fallback",
                    "text": "My notes are incomplete—I'll do a follow-up watch."
                }
            ]
        },
        {
            "id": "finish",
            "text": "Nice catch! Your notes help track storms. Warm up, check in with your buddy, and reuse dark sites.",
            "options": [
                {
                    "type": "finish",
                    "text": "I'll watch again soon."
                }
            ]
        }
    ],
    "rewards": [
        {
            "id": "682c9b29-b16f-4cf1-aaad-861a4aa133f4",
            "count": 1
        }
    ],
