                        },
                        {
                            "id": "aa82b02f-2617-4474-a91b-29647e4a9780",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "recovery",
            "text": "If glare, haze, or path hazards rise, pause immediately. Re-check your path lighting and retry only when the site is safe.",
            "options": [
                {
                    "type": "process",
                    "process": "write-mission-log-entry",
                    "text": "Safety abort reason and site conditions logged."
                },
                {
                    "type": "goto",
                    "goto": "choose-site",
                    "text": "Safety reset complete; choose a route again."
                },
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Abort for safety and log why the session was skipped.",
                    "requiresItems": [
