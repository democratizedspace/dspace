{
    "id": "astronomy/light-pollution",
    "title": "Measure Light Pollution",
    "description": "Run an Orion star-count baseline, interpret visibility bands, and recover with safer fallback locations.",
    "image": "/assets/quests/orion_light_pollution_count.jpg",
    "npc": "/assets/npc/nova.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "We'll compare Orion visibility to a simple baseline. Start at your current site or relocate first?",
            "options": [
                {
                    "type": "goto",
                    "goto": "choose-site",
                    "text": "Let's choose a site plan."
                }
            ]
        },
        {
            "id": "choose-site",
            "text": "Pick your route. Both need a mission-log record before completion.",
            "options": [
                {
                    "type": "goto",
                    "goto": "local-site",
                    "text": "Use current location (main path)."
                },
                {
                    "type": "goto",
                    "goto": "relocate-site",
                    "text": "Relocate to a darker backup site (alternate path)."
                }
            ]
        },
        {
            "id": "local-site",
            "text": "Let your eyes adapt for 15 minutes and use the planisphere to frame Orion before counting stars.",
            "options": [
                {
                    "type": "process",
                    "process": "identify-constellations",
                    "text": "Orion framed with chart support."
                },
                {
                    "type": "goto",
                    "goto": "interpret",
                    "text": "Count logged from current location.",
                    "requiresItems": [
                        {
                            "id": "98f6252e-95c2-468a-b110-69d47604df2c",
                            "count": 1
                        },
                        {
                            "id": "9a72fb16-fc69-45c5-beca-f25c27028977",
                            "count": 1
                        },
                        {
                            "id": "70bb8d86-2c4e-4330-9705-371891934686",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "recovery",
                    "text": "Vehicle glare keeps resetting night vision."
                }
            ]
        },
        {
            "id": "relocate-site",
            "text": "Move to your backup site, confirm clear footing, then repeat the Orion count for a cleaner baseline.",
            "options": [
                {
                    "type": "process",
                    "process": "identify-constellations",
                    "text": "Backup site count complete."
                },
                {
                    "type": "goto",
                    "goto": "interpret",
                    "text": "Backup count logged for comparison.",
                    "requiresItems": [
                        {
                            "id": "98f6252e-95c2-468a-b110-69d47604df2c",
                            "count": 1
                        },
                        {
                            "id": "70bb8d86-2c4e-4330-9705-371891934686",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "recovery",
                    "text": "Haze or unsafe footing at the backup site."
                }
            ]
        },
        {
            "id": "interpret",
            "text": "Interpret the log: 7+ stars means low skyglow, 4-6 moderate, 3 or fewer high pollution. Record which band you observed.",
            "options": [
                {
                    "type": "process",
                    "process": "write-mission-log-entry",
                    "text": "Pollution band documented in mission log."
                },
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Band recorded with site notes and timestamp.",
                    "requiresItems": [
                        {
                            "id": "70bb8d86-2c4e-4330-9705-371891934686",
                            "count": 1
                        },
                        {
