{
    "id": "3dprinting/blob-of-death",
    "title": "Witness a Blob of Death",
    "description": "Skipping a first-layer check lets a failed Z homing extrude in mid-air, engulfing the nozzle in molten plastic.",
    "image": "/assets/quests/blob_of_death_nozzle_fail.jpg",
    "npc": "/assets/npc/sydney.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "You walked away after hitting print, and now the hotend is wrapped in molten plastic. Let's capture what happened and recover the machine safely.",
            "options": [
                {
                    "type": "process",
                    "process": "3dprint-blob-of-death",
                    "text": "Document the blobbed hotend and kill the print"
                },
                {
                    "type": "goto",
                    "goto": "isolate",
                    "text": "I'm staring at the glob right now.",
                    "requiresItems": [
                        {
                            "id": "8896a0ef-edd8-4d19-ac14-19ee66470e54",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "isolate",
            "text": "Power off, let the hotend cool until it's safe to touch, and lay out goggles, pliers, and a fresh nozzle before you dig the heater block free.",
            "options": [
                {
                    "type": "goto",
                    "goto": "clear",
                    "text": "Tools are out and the blob is solid.",
                    "requiresItems": [
                        {
                            "id": "8896a0ef-edd8-4d19-ac14-19ee66470e54",
                            "count": 1
                        },
                        {
                            "id": "c9b51052-4594-42d7-a723-82b815ab8cc2",
                            "count": 1
                        },
                        {
                            "id": "5029f7cb-3359-4153-b7ca-4b53988ac086",
                            "count": 1
                        },
                        {
                            "id": "fbecc523-fb93-4d00-be08-2ed9f53f158c",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "start",
                    "text": "Still cooling; I'll document the mess while I wait."
                }
            ]
        },
        {
            "id": "clear",
            "text": "Snip away the plastic without yanking thermistor or heater wires, then heat just enough to twist out the ruined nozzle and seat the replacement.",
            "options": [
                {
                    "type": "process",
                    "process": "repair-blob-of-death",
                    "text": "Cut the blob free and install the new nozzle",
                    "requiresItems": [
