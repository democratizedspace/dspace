{
    "id": "3dprinting/blob-of-death",
    "title": "Witness a Blob of Death",
    "description": "Skip the first-layer check, watch a blob engulf the hotend, then recover the printer with a new nozzle.",
    "image": "/assets/quests/blob_of_death_nozzle_fail.jpg",
    "npc": "/assets/npc/sydney.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Sydney waves a spool and grins. \"Want to see why we never leave a first layer unattended?\"",
            "options": [
                {
                    "type": "goto",
                    "goto": "prep",
                    "text": "Show me so I never forget.",
                    "requiresItems": [
                        {
                            "id": "8aa6dc27-dc42-4622-ac88-cbd57f48625f",
                            "count": 1
                        },
                        {
                            "id": "58580f6f-f3be-4be0-80b9-f6f8bf0b05a6",
                            "count": 30
                        },
                        {
                            "id": "c9b51052-4594-42d7-a723-82b815ab8cc2",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "prep",
            "text": "You level the bed, put on goggles, and ignore the Z-offset warning. Ready to load filament and start anyway?",
            "options": [
                {
                    "type": "process",
                    "process": "swap-white-pla-filament",
                    "text": "Feed the white PLA and kick off the print without a paper test.",
                    "goto": "ignore"
                }
            ]
        },
        {
            "id": "ignore",
            "text": "You hit start and immediately walk away. With no first-layer check, the nozzle is happily extruding in mid-air.",
            "options": [
                {
                    "type": "process",
                    "process": "3dprint-blob-of-death",
                    "text": "Let it free-spool until the hotend disappears.",
                    "goto": "aftermath"
                }
            ]
        },
        {
            "id": "aftermath",
            "text": "Power is cut. A molten glob entombs the heater block and fan shroud. Time to decide whether this is a souvenir or a rebuild.",
            "options": [
                {
                    "type": "process",
                    "process": "repair-blob-of-death",
                    "text": "Cool the blob, strip the hotend, and install a fresh nozzle.",
                    "goto": "recovered",
                    "requiresItems": [
                        {
                            "id": "8896a0ef-edd8-4d19-ac14-19ee66470e54",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Leave the wreck as a reminder to babysit first layers.",
                    "requiresItems": [
                        {
                            "id": "8896a0ef-edd8-4d19-ac14-19ee66470e54",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "recovered",
            "text": "You remove the plastic shell, swap a new nozzle, clean fans, and re-level. The printer lives—but only because you intervened.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Commit to staying through the first layer.",
                    "requiresItems": [
                        {
                            "id": "8aa6dc27-dc42-4622-ac88-cbd57f48625f",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "finish",
            "text": "You log the failure, the time lost, and the replacement nozzle cost. Next print: eyes on until the first layer sticks.",
            "options": [
                {
                    "type": "finish",
                    "text": "No more molten taffy disasters."
                }
            ]
        }
    ],
    "rewards": [],
    "requiresQuests": [
        "3dprinter/start"
    ],
    "hardening": {
        "passes": 0,
        "score": 95,
        "emoji": "🛠️",
        "history": []
    }
}
