{
    "id": "3dprinting/blob-of-death",
    "title": "Witness a Blob of Death",
    "description": "Skipping a first-layer check lets a failed Z homing extrude in mid-air, engulfing the nozzle in molten plastic.",
    "image": "/assets/quests/blob_of_death_nozzle_fail.jpg",
    "npc": "/assets/npc/sydney.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Skipping a first-layer check? That's how you get a molten sculpture instead of a part. Want a safe look at the failure mode?",
            "options": [
                {
                    "type": "goto",
                    "goto": "prep",
                    "text": "I'll stage the printer and PLA to observe.",
                    "requiresItems": [
                        {
                            "id": "8aa6dc27-dc42-4622-ac88-cbd57f48625f",
                            "count": 1
                        },
                        {
                            "id": "d3590107-25ff-4de5-af3a-46e2497bfc52",
                            "count": 10
                        },
                        {
                            "id": "c9b51052-4594-42d7-a723-82b815ab8cc2",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "prep",
            "text": "Load PLA, skip bed leveling on purpose, and give the job an empty build plate. Keep goggles on while you watch the first layer float in mid-air.",
            "options": [
                {
                    "type": "process",
                    "process": "3dprint-blob-of-death",
                    "text": "Start the doomed print."
                },
                {
                    "type": "goto",
                    "goto": "blob",
                    "text": "The nozzle is wrapped in molten plastic.",
                    "requiresItems": [
                        {
                            "id": "8896a0ef-edd8-4d19-ac14-19ee66470e54",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "blob",
            "text": "Kill power, ventilate, and let the blob cool. Document the mess so you remember why first-layer checks matter.",
            "options": [
                {
                    "type": "goto",
                    "goto": "recover",
                    "text": "Ready to strip the hotend safely.",
                    "requiresItems": [
                        {
                            "id": "8896a0ef-edd8-4d19-ac14-19ee66470e54",
                            "count": 1
                        },
                        {
                            "id": "c9b51052-4594-42d7-a723-82b815ab8cc2",
                            "count": 1
                        },
                        {
                            "id": "fbecc523-fb93-4d00-be08-2ed9f53f158c",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Leaving it as a cautionary showpiece.",
                    "requiresItems": [
                        {
                            "id": "8896a0ef-edd8-4d19-ac14-19ee66470e54",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "recover",
            "text": "Snip the blob away, swap in a fresh nozzle, and rebuild the hotend so you can print safely again.",
            "options": [
                {
                    "type": "process",
                    "process": "repair-blob-of-death",
                    "text": "Cut, unscrew, and install the new nozzle."
                },
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Hotend is reassembled and moves freely.",
                    "requiresItems": [
                        {
                            "id": "8aa6dc27-dc42-4622-ac88-cbd57f48625f",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "finish",
            "text": "You saw the failure, logged the damage, and either preserved the blob for training or restored the printer with a new nozzle.",
            "options": [
                {
                    "type": "finish",
                    "text": "Next time I'll guard that first layer.",
                    "requiresItems": [
                        {
                            "id": "8aa6dc27-dc42-4622-ac88-cbd57f48625f",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "finish",
                    "text": "Lesson learned from the melted artifact.",
                    "requiresItems": [
                        {
                            "id": "8896a0ef-edd8-4d19-ac14-19ee66470e54",
                            "count": 1
                        }
                    ]
                }
            ]
        }
    ],
    "rewards": [],
    "requiresQuests": [
        "3dprinter/start"
    ],
    "hardening": {
        "passes": 0,
        "score": 95,
