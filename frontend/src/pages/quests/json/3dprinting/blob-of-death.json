{
    "id": "3dprinting/blob-of-death",
    "title": "Witness a Blob of Death",
    "description": "Skipping a first-layer check lets a failed Z homing extrude in mid-air, engulfing the nozzle in molten plastic.",
    "image": "/assets/quests/blob_of_death_nozzle_fail.jpg",
    "npc": "/assets/npc/sydney.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Sydney here. Want to see what skipping a first-layer check does and how to rescue the printer afterward?",
            "options": [
                {
                    "type": "goto",
                    "goto": "precheck",
                    "text": "Show me the prep that prevents it."
                },
                {
                    "type": "goto",
                    "goto": "arm",
                    "text": "Skip the checks and tempt fate."
                }
            ]
        },
        {
            "id": "precheck",
            "text": "Level the bed and set Z-offset so the nozzle just kisses paper. This is the minute that saves a hotend later.",
            "options": [
                {
                    "type": "process",
                    "process": "level-3d-printer-bed",
                    "text": "Shim the corners with paper and jog the gantry."
                },
                {
                    "type": "goto",
                    "goto": "arm",
                    "text": "Looks flat—start the risky print anyway.",
                    "requiresItems": [
                        {
                            "id": "8aa6dc27-dc42-4622-ac88-cbd57f48625f",
                            "count": 1
                        },
                        {
                            "id": "58580f6f-f3be-4be0-80b9-f6f8bf0b05a6",
                            "count": 50
                        }
                    ]
                }
            ]
        },
        {
            "id": "arm",
            "text": "Load filament, kick off the print, and walk away. We're intentionally ignoring the first layer to see what happens.",
            "options": [
                {
                    "type": "process",
                    "process": "3dprint-blob-of-death",
                    "text": "Start the job and let the blob form."
                },
                {
                    "type": "goto",
                    "goto": "blobbed",
                    "text": "The hotend vanished under plastic.",
                    "requiresItems": [
                        {
                            "id": "8896a0ef-edd8-4d19-ac14-19ee66470e54",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "blobbed",
            "text": "The heater block is caked. Cut power, let it cool, and suit up before prying anything loose.",
            "options": [
                {
                    "type": "goto",
                    "goto": "strip",
                    "text": "Gear up and start peeling.",
                    "requiresItems": [
                        {
                            "id": "8896a0ef-edd8-4d19-ac14-19ee66470e54",
                            "count": 1
                        },
                        {
                            "id": "c9b51052-4594-42d7-a723-82b815ab8cc2",
                            "count": 1
                        },
                        {
                            "id": "997eaba9-25ee-43d5-bbdc-5d6adf03adfa",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "strip",
            "text": "Warm the blob just enough to pry. Keep goggles on, aim the heat gun away from wiring, and free the heater block.",
            "options": [
                {
                    "type": "process",
                    "process": "strip-blobbed-hotend",
                    "text": "Peel plastic to a bare clogged nozzle."
                },
                {
                    "type": "goto",
                    "goto": "repair",
                    "text": "Blob is off; nozzle is still clogged.",
                    "requiresItems": [
                        {
                            "id": "564a76de-925b-4457-a548-d015168abe0c",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "repair",
            "text": "Swap the nozzle and purge the melt path so the printer is trustworthy again.",
            "options": [
                {
                    "type": "process",
                    "process": "repair-clogged-nozzle",
                    "text": "Install a new nozzle and purge filament."
                },
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Printer is clear and leveled.",
                    "requiresItems": [
                        {
                            "id": "8aa6dc27-dc42-4622-ac88-cbd57f48625f",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "finish",
            "text": "Blob endured, lesson learned: never leave the first layer and always have the tools to recover.",
            "options": [
                {
                    "type": "finish",
                    "text": "I'll guard every first layer now.",
                    "requiresItems": [
                        {
                            "id": "8aa6dc27-dc42-4622-ac88-cbd57f48625f",
                            "count": 1
                        }
                    ]
                }
            ]
        }
    ],
    "rewards": [],
    "requiresQuests": [
        "3dprinter/start"
    ],
    "hardening": {
        "passes": 0,
        "score": 95,
        "emoji": "🛠️",
        "history": []
    }
}
