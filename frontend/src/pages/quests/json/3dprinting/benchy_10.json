                    "type": "goto",
                    "goto": "burst",
                    "text": "Alternate path: short burst run.",
                    "requiresItems": [
                        {
                            "id": "97ec3b0b-1be0-4260-bbaf-62ccb935807e",
                            "count": 1
                        },
                        {
                            "id": "c9b51052-4594-42d7-a723-82b815ab8cc2",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "steady",
            "text": "Print in small batches and inspect hulls every two prints. Record defects and adjustments so the run can be reproduced.",
