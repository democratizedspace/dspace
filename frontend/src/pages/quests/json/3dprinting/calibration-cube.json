                        {
                            "id": "9b985439-3c19-4fa7-b864-34a3c5c33ac4",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "retest",
            "text": "Print and measure the post-adjust cube. Completion requires a retest log that shows all axes in tolerance and notes what changed.",
            "options": [
                {
                    "type": "process",
                    "process": "print-calibration-cube",
                    "text": "Run post-adjust retest print."
                },
                {
                    "type": "process",
                    "process": "measure-calibration-cube",
                    "text": "Log post-adjust retest measurements."
                },
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Retest passed and measurements are documented.",
                    "requiresItems": [
