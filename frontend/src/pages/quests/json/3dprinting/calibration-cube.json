{
    "id": "3dprinting/calibration-cube",
    "title": "Print a Calibration Cube",
    "description": "Print and measure a 20 mm calibration cube to verify your printer's accuracy.",
    "image": "/assets/quests/benchy_25.jpg",
    "npc": "/assets/npc/sydney.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Let's dial in your entry-level FDM 3D printer with a quick 20 mm calibration cube.",
            "options": [
                {
                    "type": "goto",
                    "goto": "print",
                    "text": "Ready to print."
                },
                {
                    "type": "process",
                    "process": "measure-filament-diameter",
                    "text": "How do I measure filament?"
                }
            ]
        },
        {
            "id": "print",
            "text": "Level the build plate, preheat to PLA temps, load 15 g of green PLA filament, slice, and start the print. Wear safety goggles, keep hands clear of the moving nozzle, ensure ventilation, stay nearby, let the cube cool, then lift it off the plate with a print removal scraper.",
            "options": [
                {
                    "type": "process",
                    "process": "print-calibration-cube",
                    "text": "Need printing steps?"
                },
                {
                    "type": "goto",
                    "goto": "measure",
                    "text": "Cube cooled and removed.",
                    "requiresItems": [
                        { "id": "8aa6dc27-dc42-4622-ac88-cbd57f48625f", "count": 1 },
                        { "id": "d3590107-25ff-4de5-af3a-46e2497bfc52", "count": 15 },
                        { "id": "5a80f925-ec0a-4b08-b0e1-3b6b41ccace4", "count": 1 },
                        { "id": "9b985439-3c19-4fa7-b864-34a3c5c33ac4", "count": 1 }
                    ]
                }
            ]
        },
        {
            "id": "measure",
            "text": "Use digital calipers to measure each side; each axis should read 20.00 mm. If dimensions are off, adjust steps per millimeter before reprinting.",
            "options": [
                {
                    "type": "process",
                    "process": "measure-calibration-cube",
                    "text": "Need measuring steps?"
                },
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Dimensions noted.",
                    "requiresItems": [{ "id": "e37c86b0-caaf-485d-b5c1-c15f7029973c", "count": 1 }]
                }
            ]
        },
        {
            "id": "finish",
            "text": "Excellent! Record the measurements and tweak firmware or slicer settings as needed before your next print.",
            "options": [{ "type": "finish", "text": "All set." }]
        }
    ],
