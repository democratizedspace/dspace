{
    "id": "3dprinting/filament-change",
    "title": "Swap Filament",
    "description": "Swap to green PLA on your entry-level FDM printer with goggles, wire cutters, and a 10 g purge.",
    "image": "/assets/quests/filament_swap_green_pla.jpg",
    "npc": "/assets/npc/sydney.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Ready to swap colors? We'll unload the old spool, purge 10 g, and load green PLA\u2014level the bed first so you can verify first-layer adhesion after the swap.",
            "options": [
                {
                    "type": "goto",
                    "goto": "heat",
                    "text": "Leveled and ready to heat.",
                    "requiresItems": [
                        {
                            "id": "a42e441a-5569-490c-86e4-ce711117cd22",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "heat",
            "text": "Power on, preheat to 200 \u00b0C, and move the hotend away from the bed. Keep goggles on and fingers clear of the drive gears while you release the lever.",
            "options": [
                {
                    "type": "process",
                    "process": "swap-green-pla-filament",
                    "text": "Unload and load green PLA.",
                    "requiresItems": [
                        {
                            "id": "a42e441a-5569-490c-86e4-ce711117cd22",
                            "count": 1
                        },
                        {
                            "id": "d3590107-25ff-4de5-af3a-46e2497bfc52",
                            "count": 10
                        },
                        {
                            "id": "c9b51052-4594-42d7-a723-82b815ab8cc2",
                            "count": 1
                        },
                        {
                            "id": "ce92a1a9-c817-40f0-92b1-24aff053903d",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "purge",
                    "text": "Green filament is flowing without bubbles.",
                    "requiresItems": [
                        {
                            "id": "97ec3b0b-1be0-4260-bbaf-62ccb935807e",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "purge",
            "text": "Check that the extruder gears are gripping, clip the stringing, and extrude 20 mm to confirm the feed path is clear.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Swap locked in and purge line is solid.",
                    "requiresItems": [
                        {
                            "id": "97ec3b0b-1be0-4260-bbaf-62ccb935807e",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "finish",
            "text": "Great! Your printer is purged, tensioned, and ready to lay down that fresh green plastic.",
            "options": [
                {
                    "type": "finish",
                    "text": "Time to print!"
                }
            ]
        }
    ],
