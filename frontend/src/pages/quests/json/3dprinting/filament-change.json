{
    "id": "3dprinting/filament-change",
    "title": "Swap Filament",
    "description": "Swap to green PLA on your entry-level FDM printer with goggles, wire cutters, and a 10 g purge.",
    "image": "/assets/quests/filament_swap_green_pla.jpg",
    "npc": "/assets/npc/sydney.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Ready to swap colors? We'll unload the old spool, purge 10 g, and verify first-layer adhesion before we call it done.",
            "options": [
                {
                    "type": "goto",
                    "goto": "heat",
                    "text": "Leveled and ready to heat.",
                    "requiresItems": [
                        {
                            "id": "a42e441a-5569-490c-86e4-ce711117cd22",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "heat",
            "text": "Power on, preheat to 200 °C, and move the hotend away from the bed. Keep goggles on and fingers clear of drive gears while you release the lever.",
            "options": [
                {
                    "type": "process",
                    "process": "swap-green-pla-filament",
                    "text": "Unload and load green PLA.",
                    "requiresItems": [
                        {
                            "id": "a42e441a-5569-490c-86e4-ce711117cd22",
                            "count": 1
                        },
                        {
                            "id": "d3590107-25ff-4de5-af3a-46e2497bfc52",
                            "count": 10
                        },
                        {
                            "id": "c9b51052-4594-42d7-a723-82b815ab8cc2",
                            "count": 1
                        },
                        {
                            "id": "ce92a1a9-c817-40f0-92b1-24aff053903d",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "verify-purge",
                    "text": "Green filament is flowing without bubbles.",
                    "requiresItems": [
                        {
                            "id": "97ec3b0b-1be0-4260-bbaf-62ccb935807e",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "verify-purge",
            "text": "Clip the stringing, extrude 20 mm, then print a short first-layer line. Target: no bubbles, no grinding clicks, and an even line width before continuing.",
            "options": [
                {
                    "type": "goto",
                    "goto": "troubleshoot",
                    "text": "Flow is inconsistent or the line has gaps."
                },
                {
                    "type": "process",
                    "process": "write-mission-log-entry",
                    "text": "Log purge length, nozzle temp, and first-layer result.",
                    "requiresItems": [
                        {
                            "id": "70bb8d86-2c4e-4330-9705-371891934686",
                            "count": 1
                        },
                        {
                            "id": "aa82b02f-2617-4474-a91b-29647e4a9780",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Purge is stable and the first-layer check passed.",
                    "requiresItems": [
                        {
                            "id": "97ec3b0b-1be0-4260-bbaf-62ccb935807e",
                            "count": 1
                        },
                        {
                            "id": "280ed361-ac70-4ab9-bcd9-aee481790faf",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "troubleshoot",
            "text": "Troubleshooting branch: if you hear clicking, trim and reseat filament; if you hear popping, dry filament and lower humidity. Reheat and rerun the purge check before closure.",
            "options": [
                {
                    "type": "goto",
                    "goto": "heat",
                    "text": "Reseated feed path. Run another purge cycle."
                },
                {
                    "type": "goto",
                    "goto": "verify-purge",
                    "text": "I corrected moisture issues. Re-test the first layer."
                }
            ]
        },
        {
            "id": "finish",
            "text": "Great! Your printer is purged, documented, and ready to lay down fresh green plastic.",
            "options": [
                {
                    "type": "finish",
                    "text": "Time to print!"
                }
            ]
        }
    ],
    "rewards": [
