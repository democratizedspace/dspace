                    "type": "goto",
                    "goto": "sprint",
                    "text": "Alternate path: sprint windows and cooldown buffers.",
                    "requiresItems": [
                        {
                            "id": "97ec3b0b-1be0-4260-bbaf-62ccb935807e",
                            "count": 1
                        },
                        {
                            "id": "c9b51052-4594-42d7-a723-82b815ab8cc2",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "steady",
            "text": "Run repeatable batches and stop every 20 prints for hull/bridge checks. Log failures immediately so drift does not contaminate the full run.",
            "options": [
                {
                    "type": "process",
                    "process": "3dprint-benchy",
                    "text": "Run a controlled batch.",
                    "requiresItems": [
