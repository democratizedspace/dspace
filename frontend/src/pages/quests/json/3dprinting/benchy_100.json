{
    "id": "3dprinting/benchy_100",
    "title": "3D Print 100 Benchies",
    "description": "Scale to a 100-Benchy fleet with production evidence, quality checkpoints, and recovery loops.",
    "image": "/assets/quests/benchy_100.jpg",
    "npc": "/assets/npc/phoenix.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Phoenix here. One hundred Benchies is factory work. We'll choose a production strategy, log checkpoints, and only close once the fleet survives inspection.",
            "options": [
                {
                    "type": "goto",
                    "goto": "strategy",
                    "text": "Let's design the print campaign."
                }
            ]
        },
        {
            "id": "strategy",
            "text": "Main path runs steady batches with fixed quality pauses. Alternate path uses sprint windows for throughput, but requires extra anomaly tracking.",
            "options": [
                {
                    "type": "goto",
                    "goto": "steady",
                    "text": "Main path: steady batches with scheduled checks.",
                    "requiresItems": [
                        {
                            "id": "97ec3b0b-1be0-4260-bbaf-62ccb935807e",
                            "count": 1
                        }
                    ]
                },
