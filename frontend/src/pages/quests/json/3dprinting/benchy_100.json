        {
            "id": "sprint",
            "text": "Sprint windows can lift throughput but demand safety discipline: watch nozzle buildup, keep ventilation active, and pause if defect rate spikes.",
            "options": [
                {
                    "type": "process",
                    "process": "3dprint-benchy",
                    "text": "Run sprint production blocks.",
                    "requiresItems": [
