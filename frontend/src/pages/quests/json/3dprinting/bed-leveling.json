{
    "id": "3dprinting/bed-leveling",
    "title": "Level the Print Bed",
    "description": "After power-off and cooling, level the FDM bed with a paper-drag baseline, adjustment pass, and re-test.",
    "image": "/assets/quests/bed_leveling_printer_paper_test.jpg",
    "npc": "/assets/npc/sydney.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Sydney here. Before knobs move, capture a baseline drag check at each corner and center. We only chase numbers after we know where we're starting.",
            "options": [
                {
                    "type": "goto",
                    "goto": "baseline",
                    "text": "Bed is cool, power is off, and paper strips are ready."
                }
            ]
        },
        {
            "id": "baseline",
            "text": "Run one full paper pass across all points. Log where paper slides too freely or snags. Keep fingers clear while the gantry homes, and stop if anything binds.",
            "options": [
                {
                    "type": "process",
                    "process": "level-3d-printer-bed",
                    "text": "Record baseline and run the first leveling pass.",
                    "requiresItems": [
                        {
                            "id": "8aa6dc27-dc42-4622-ac88-cbd57f48625f",
                            "count": 1
                        },
                        {
                            "id": "60409c3f-56cf-4b9e-9e60-ca480d4896d0",
                            "count": 1
                        },
                        {
                            "id": "c9b51052-4594-42d7-a723-82b815ab8cc2",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "adjust",
                    "text": "Baseline notes captured; ready to adjust corners.",
                    "requiresItems": [
                        {
                            "id": "a42e441a-5569-490c-86e4-ce711117cd22",
                            "count": 1
                        },
                        {
                            "id": "60409c3f-56cf-4b9e-9e60-ca480d4896d0",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "adjust",
            "text": "Target tolerance: each point should give the same light paper drag, not free-spin or hard scrape. Adjust opposite corners in tiny steps, then re-home and recheck.",
            "options": [
                {
                    "type": "goto",
                    "goto": "verify",
                    "text": "Post-adjust pass is within tolerance at all five points.",
                    "requiresItems": [
                        {
                            "id": "a42e441a-5569-490c-86e4-ce711117cd22",
                            "count": 1
                        },
                        {
                            "id": "60409c3f-56cf-4b9e-9e60-ca480d4896d0",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "drift",
                    "text": "Readings drift after homing or one corner keeps wandering.",
                    "requiresItems": [
                        {
                            "id": "a42e441a-5569-490c-86e4-ce711117cd22",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "drift",
            "text": "Recovery path: roll back to last-known-good knob positions, inspect wheels and springs, and rerun baseline before touching offsets again. If motion feels rough, power down and service before retry.",
            "options": [
                {
                    "type": "goto",
                    "goto": "baseline",
                    "text": "Rollback complete; rerun baseline and adjustment sequence.",
                    "requiresItems": [
                        {
                            "id": "60409c3f-56cf-4b9e-9e60-ca480d4896d0",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "verify",
            "text": "Heat the nozzle, print a short skirt, and verify center drag still matches the corners. Abort if you smell burning PLA or see nozzle crash marks.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Skirt is even and post-heat drag still meets tolerance.",
                    "requiresItems": [
                        {
                            "id": "a42e441a-5569-490c-86e4-ce711117cd22",
                            "count": 1
                        },
                        {
                            "id": "60409c3f-56cf-4b9e-9e60-ca480d4896d0",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "adjust",
                    "text": "Center drifted after heat; make another micro-adjustment pass.",
                    "requiresItems": [
                        {
                            "id": "a42e441a-5569-490c-86e4-ce711117cd22",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "finish",
            "text": "Bed leveled with baseline and post-adjust evidence captured. Save knob notes so you can recover quickly if the next print drifts.",
            "options": [
                {
                    "type": "finish",
                    "text": "Time to print!"
                }
            ]
        }
    ],
