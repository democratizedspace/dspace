{
    "id": "3dprinting/bed-leveling",
    "title": "Level the Print Bed",
    "description": "After power-off and cooling, level the FDM bed with a sheet of printer paper.",
    "image": "/assets/quests/bed_leveling_printer_paper_test.jpg",
    "npc": "/assets/npc/sydney.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Power down, let it cool, clear crumbs. We level all four corners with a sheet of paper.",
            "options": [
                {
                    "type": "goto",
                    "goto": "prep",
                    "text": "Bed is cool and cleared."
                }
            ]
        },
        {
            "id": "prep",
            "text": "Quarter-turn each wheel, home the axes, wipe the surface. Keep fingers clear while the gantry moves.",
            "options": [
                {
                    "type": "process",
                    "process": "level-3d-printer-bed",
                    "text": "Walk me through each pass.",
                    "requiresItems": [
                        { "id": "8aa6dc27-dc42-4622-ac88-cbd57f48625f", "count": 1 },
                        { "id": "60409c3f-56cf-4b9e-9e60-ca480d4896d0", "count": 1 },
                        { "id": "c9b51052-4594-42d7-a723-82b815ab8cc2", "count": 1 }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "first-layer",
                    "text": "Corners all tug the paper evenly.",
                    "requiresItems": [{ "id": "a42e441a-5569-490c-86e4-ce711117cd22", "count": 1 }]
                }
            ]
        },
        {
            "id": "first-layer",
            "text": "Heat the nozzle, run a single-line skirt, and recheck drag at the center. Light scratch on paper means the first layer sticks.",
            "options": [
                {
                    "type": "goto",
                    "goto": "prep",
                    "text": "Need to tweak another corner."
                },
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Skirt looks even and glossy.",
                    "requiresItems": [{ "id": "a42e441a-5569-490c-86e4-ce711117cd22", "count": 1 }]
                }
            ]
        },
        {
            "id": "finish",
            "text": "Bed is level, skirt is clean. You're ready for longer jobs.",
            "options": [
                {
                    "type": "finish",
                    "text": "Time to print!"
                }
            ]
        }
    ],
