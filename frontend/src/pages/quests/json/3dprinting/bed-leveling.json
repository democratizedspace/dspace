{
    "id": "3dprinting/bed-leveling",
    "title": "Level the Print Bed",
    "description": "After power-off and cooling, level the FDM bed with a sheet of printer paper.",
    "image": "/assets/quests/bed_leveling_printer_paper_test.jpg",
    "npc": "/assets/npc/sydney.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Sydney here. Power off, cool down, and clear crumbs. We will capture a baseline before touching knobs so you can prove the adjustment worked.",
            "options": [
                {
                    "type": "goto",
                    "goto": "baseline",
                    "text": "Machine is cool and safe to handle."
                }
            ]
        },
        {
            "id": "baseline",
            "text": "Run a cold paper pass at all four corners and center. Mark where drag is loose or scraping so we have a before-state record.",
            "options": [
                {
                    "type": "process",
                    "process": "level-3d-printer-bed",
                    "text": "Capture baseline drag checks.",
                    "requiresItems": [
                        {
                            "id": "8aa6dc27-dc42-4622-ac88-cbd57f48625f",
                            "count": 1
                        },
                        {
                            "id": "60409c3f-56cf-4b9e-9e60-ca480d4896d0",
                            "count": 1
                        },
                        {
                            "id": "c9b51052-4594-42d7-a723-82b815ab8cc2",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "adjust",
                    "text": "Baseline notes are logged.",
                    "requiresItems": [
                        {
                            "id": "a42e441a-5569-490c-86e4-ce711117cd22",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "adjust",
            "text": "Adjust only the corners that failed baseline. Quarter-turn max each pass, then re-home and repeat. Keep fingers clear while gantry moves.",
            "options": [
                {
                    "type": "goto",
                    "goto": "retest",
                    "text": "Adjustment pass complete.",
                    "requiresItems": [
                        {
                            "id": "a42e441a-5569-490c-86e4-ce711117cd22",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "rollback",
                    "text": "Readings drifted after I adjusted one corner."
                }
            ]
        },
        {
            "id": "rollback",
            "text": "That drift means a wheel may have over-corrected. Roll back to your last-known-good knob position, re-home, and restart from baseline.",
            "options": [
                {
                    "type": "goto",
                    "goto": "baseline",
                    "text": "Rollback applied; rerun baseline."
                }
            ]
        },
        {
            "id": "retest",
            "text": "Heat nozzle, run a single-line skirt, then verify paper drag again at center and corners. Target: light, even drag at every point.",
            "options": [
                {
                    "type": "goto",
                    "goto": "adjust",
                    "text": "Still outside tolerance; I need one more adjustment pass."
                },
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Post-adjust retest is within tolerance.",
                    "requiresItems": [
                        {
                            "id": "a42e441a-5569-490c-86e4-ce711117cd22",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "finish",
            "text": "Great parity: baseline, adjustment, and retest all logged. Save those knob positions as your new stable profile.",
            "options": [
                {
                    "type": "finish",
                    "text": "Bed is tuned and documented."
                }
            ]
        }
    ],
    "rewards": [
        {
            "id": "b281360b-2ecc-4fea-a248-36a61c5f7399",
            "count": 1
        }
    ],
