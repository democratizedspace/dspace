{
    "id": "3dprinting/retraction-test",
    "title": "Tune Retraction Settings",
    "description": "Print a single Benchy while adjusting retraction to reduce stringing.",
    "image": "/assets/quests/retraction_test_benchy.jpg",
    "npc": "/assets/npc/sydney.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Stringing after that color swap? We'll tune retraction with another Benchy so bridges stay crisp.",
            "options": [
                {
                    "type": "goto",
                    "goto": "setup",
                    "text": "Green PLA is loaded and ready.",
                    "requiresItems": [
                        {
                            "id": "97ec3b0b-1be0-4260-bbaf-62ccb935807e",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "setup",
            "text": "Slice the model with a 1–2 mm retraction distance step between test sections. Keep goggles on and note the settings in your slicer comments.",
            "options": [
                {
                    "type": "process",
                    "process": "tune-retraction-benchy",
                    "text": "Print the stepped Benchy."
                },
                {
                    "type": "goto",
                    "goto": "inspect",
                    "text": "Benchy finished and cooled.",
                    "requiresItems": [
                        {
                            "id": "141581bf-be69-4522-973b-3d22292a85fa",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "safety-stop",
                    "text": "I smell burnt filament or see nozzle ooze piling up.",
                    "requiresItems": [
                        {
                            "id": "141581bf-be69-4522-973b-3d22292a85fa",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "inspect",
            "text": "Check between the mast and cabin for wisps, then measure surface zits with calipers. Record three bridge/stringing observations before deciding.",
            "options": [
                {
                    "type": "goto",
                    "goto": "interpret",
                    "text": "Measurements are logged; compare against thresholds.",
                    "requiresItems": [
                        {
                            "id": "141581bf-be69-4522-973b-3d22292a85fa",
                            "count": 1
                        },
                        {
                            "id": "e37c86b0-caaf-485d-b5c1-c15f7029973c",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "retest",
                    "text": "Stringing still exceeds 2 mm whiskers on bridges.",
                    "requiresItems": [
                        {
                            "id": "141581bf-be69-4522-973b-3d22292a85fa",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "interpret",
            "text": "Pass criteria: no bridge whisker longer than 2 mm and no more than one zit cluster on the cabin roof. Failed bands must be corrected before closure.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Chosen profile meets thresholds and notes are archived.",
                    "requiresItems": [
                        {
                            "id": "141581bf-be69-4522-973b-3d22292a85fa",
                            "count": 1
                        },
                        {
                            "id": "e37c86b0-caaf-485d-b5c1-c15f7029973c",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "retest",
                    "text": "At least one threshold failed; run a corrective pass.",
                    "requiresItems": [
                        {
                            "id": "141581bf-be69-4522-973b-3d22292a85fa",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "retest",
            "text": "Troubleshooting branch: dry filament, lower nozzle temperature 5–10°C, and reduce travel hops before rerunning. Change only one variable per pass.",
            "options": [
                {
                    "type": "goto",
                    "goto": "setup",
                    "text": "Corrective plan logged; rerun the test print.",
                    "requiresItems": [
                        {
                            "id": "97ec3b0b-1be0-4260-bbaf-62ccb935807e",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "safety-stop",
                    "text": "Hotend is leaking or smoke appears; abort and cool down."
                }
            ]
        },
        {
            "id": "safety-stop",
            "text": "Pause the print, power down, and wait for full cool-down before touching the hotend. Ventilate and inspect nozzle seating before retrying.",
            "options": [
                {
                    "type": "goto",
                    "goto": "retest",
                    "text": "Safety checks complete; continue troubleshooting.",
                    "requiresItems": [
                        {
                            "id": "c9b51052-4594-42d7-a723-82b815ab8cc2",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "finish",
            "text": "Great! Keep those slicer notes handy—future prints can start from this dialed-in retraction.",
            "options": [
                {
                    "type": "finish",
                    "text": "Will do."
                }
            ]
        }
    ],
    "rewards": [
        {
            "id": "269d2cfb-25de-417b-8e29-64e80aff934c",
            "count": 1
        }
    ],
    "requiresQuests": [
        "3dprinting/spool-holder"
    ],
