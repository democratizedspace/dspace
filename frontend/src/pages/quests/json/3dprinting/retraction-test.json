{
    "id": "3dprinting/retraction-test",
    "title": "Tune Retraction Settings",
    "description": "Print a single Benchy while adjusting retraction to reduce stringing.",
    "image": "/assets/quests/retraction_test_benchy.jpg",
    "npc": "/assets/npc/sydney.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Stringing after that color swap? We'll tune retraction with a stepped Benchy and lock settings only after measured evidence.",
            "options": [
                {
                    "type": "goto",
                    "goto": "setup",
                    "text": "Green PLA is loaded and ready.",
                    "requiresItems": [
                        {
                            "id": "97ec3b0b-1be0-4260-bbaf-62ccb935807e",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "setup",
            "text": "Slice the model with 1-2 mm retraction steps and fixed travel speed. Keep goggles on while clearing wisps and note settings in slicer comments.",
            "options": [
                {
                    "type": "process",
                    "process": "tune-retraction-benchy",
                    "text": "Print the stepped Benchy.",
                    "requiresItems": [
                        {
                            "id": "97ec3b0b-1be0-4260-bbaf-62ccb935807e",
                            "count": 1
                        },
                        {
                            "id": "c9b51052-4594-42d7-a723-82b815ab8cc2",
                            "count": 1
                        },
                        {
                            "id": "e37c86b0-caaf-485d-b5c1-c15f7029973c",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "inspect",
                    "text": "Benchy finished and cooled.",
                    "requiresItems": [
                        {
                            "id": "141581bf-be69-4522-973b-3d22292a85fa",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "inspect",
            "text": "Measure the worst string span between mast and cabin. Pass band: under 0.30 mm wisps and no bridge sag at your chosen step.",
            "options": [
                {
                    "type": "goto",
                    "goto": "corrective",
                    "text": "Out of range: wisps or zits exceed tolerance.",
                    "requiresItems": [
                        {
                            "id": "e37c86b0-caaf-485d-b5c1-c15f7029973c",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "document",
                    "text": "Measurements are in range and repeatable.",
                    "requiresItems": [
                        {
                            "id": "e37c86b0-caaf-485d-b5c1-c15f7029973c",
                            "count": 1
                        },
                        {
                            "id": "141581bf-be69-4522-973b-3d22292a85fa",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "corrective",
            "text": "Recovery loop: adjust retraction by one step only, keep temp constant, and reprint. If blobs persist, lower temperature 5 °C before another trial.",
            "options": [
                {
                    "type": "goto",
                    "goto": "setup",
                    "text": "Apply adjustments and run another stepped Benchy."
                },
                {
                    "type": "goto",
                    "goto": "inspect",
                    "text": "Recheck after trimming stray strings.",
                    "requiresItems": [
                        {
                            "id": "141581bf-be69-4522-973b-3d22292a85fa",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
