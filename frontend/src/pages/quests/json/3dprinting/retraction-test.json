{
    "id": "3dprinting/retraction-test",
    "title": "Tune Retraction Settings",
    "description": "Print a single Benchy while adjusting retraction to reduce stringing.",
    "image": "/assets/quests/retraction_test_benchy.jpg",
    "npc": "/assets/npc/sydney.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Stringing after that color swap? We'll tune retraction with another Benchy so bridges stay crisp.",
            "options": [
                {
                    "type": "goto",
                    "goto": "setup",
                    "text": "Green PLA is loaded and ready.",
                    "requiresItems": [
                        {
                            "id": "97ec3b0b-1be0-4260-bbaf-62ccb935807e",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "setup",
            "text": "Slice the model with a 1\u20132 mm retraction distance step between test sections. Keep goggles on and note the settings in your slicer comments.",
            "options": [
                {
                    "type": "process",
                    "process": "tune-retraction-benchy",
                    "text": "Print the stepped Benchy.",
                    "requiresItems": [
                        {
                            "id": "97ec3b0b-1be0-4260-bbaf-62ccb935807e",
                            "count": 1
                        },
                        {
                            "id": "c9b51052-4594-42d7-a723-82b815ab8cc2",
                            "count": 1
                        },
                        {
                            "id": "e37c86b0-caaf-485d-b5c1-c15f7029973c",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "inspect",
                    "text": "Benchy finished and cooled.",
                    "requiresItems": [
                        {
                            "id": "141581bf-be69-4522-973b-3d22292a85fa",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "inspect",
            "text": "Check between the mast and cabin for wisps, then measure surface zits with calipers. Note which retraction distance leaves clean arches.",
            "options": [
                {
                    "type": "goto",
                    "goto": "setup",
                    "text": "Run another pass with tweaked settings."
                },
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Stringing is gone and notes are saved.",
                    "requiresItems": [
                        {
                            "id": "141581bf-be69-4522-973b-3d22292a85fa",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "finish",
            "text": "Great! Keep those slicer notes handy\u2014future prints can start from this dialed-in retraction.",
            "options": [
                {
                    "type": "finish",
                    "text": "Will do."
                }
            ]
        }
