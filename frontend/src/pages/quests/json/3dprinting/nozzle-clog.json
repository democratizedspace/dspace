{
    "id": "3dprinting/nozzle-clog",
    "title": "Fix a Clogged Nozzle",
    "description": "Disassemble your printer after a blob of death from skipping the first layer to unclog or replace the nozzle.",
    "image": "/assets/quests/nozzle_clog_disassembly.jpg",
    "npc": "/assets/npc/sydney.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Skipping first-layer checks can snowball into a blob of death. We'll recreate the failure, recover safely, then verify with logged purge snapshots.",
            "options": [
                {
                    "type": "process",
                    "process": "3dprint-nozzle-clog",
                    "text": "Document the failure and trigger a clog state.",
                    "requiresItems": [
                        {
                            "id": "8aa6dc27-dc42-4622-ac88-cbd57f48625f",
                            "count": 1
                        },
                        {
                            "id": "d3590107-25ff-4de5-af3a-46e2497bfc52",
                            "count": 5
                        },
                        {
                            "id": "061fd221-404a-4bd1-9432-3e25b0f17a2c",
                            "count": 50
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "cooldown",
                    "text": "Printer is powered down, ventilated, and cool.",
                    "requiresItems": [
                        {
                            "id": "564a76de-925b-4457-a548-d015168abe0c",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "cooldown",
            "text": "Confirm heaters are off, peel away loose plastic, and keep tools clear of thermistor wires before service.",
            "options": [
                {
                    "type": "process",
                    "process": "repair-clogged-nozzle",
                    "text": "Clear the nozzle and reseat it.",
                    "requiresItems": [
                        {
                            "id": "c9b51052-4594-42d7-a723-82b815ab8cc2",
                            "count": 1
                        },
                        {
                            "id": "5029f7cb-3359-4153-b7ca-4b53988ac086",
                            "count": 1
                        },
                        {
                            "id": "60409c3f-56cf-4b9e-9e60-ca480d4896d0",
                            "count": 1
                        },
                        {
                            "id": "564a76de-925b-4457-a548-d015168abe0c",
                            "count": 1
                        },
                        {
                            "id": "d3590107-25ff-4de5-af3a-46e2497bfc52",
                            "count": 5
                        }
                    ]
                },
                {
                    "type": "process",
                    "process": "replace-brass-nozzle",
                    "text": "Swap in a new nozzle.",
                    "requiresItems": [
                        {
                            "id": "c9b51052-4594-42d7-a723-82b815ab8cc2",
                            "count": 1
                        },
                        {
                            "id": "5029f7cb-3359-4153-b7ca-4b53988ac086",
                            "count": 1
                        },
                        {
                            "id": "fbecc523-fb93-4d00-be08-2ed9f53f158c",
                            "count": 1
                        },
                        {
                            "id": "564a76de-925b-4457-a548-d015168abe0c",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "monitor",
                    "text": "Hotend is rebuilt and ready for monitored purge.",
                    "requiresItems": [
                        {
                            "id": "45f6f1ce-18e4-481d-8635-23ea51e0c2fd",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "monitor",
            "text": "Run three purge snapshots (10 mm each, ~5 minutes apart). Log strand width, skip/click sounds, and smoke/odor status each pass. Pass only if width drift stays under 0.2 mm and all safety checks stay clear.",
            "options": [
                {
                    "type": "goto",
                    "goto": "verify",
                    "text": "Logs show stable flow and no anomalies across all three checks.",
                    "requiresItems": [
                        {
                            "id": "45f6f1ce-18e4-481d-8635-23ea51e0c2fd",
                            "count": 1
                        },
                        {
                            "id": "60409c3f-56cf-4b9e-9e60-ca480d4896d0",
                            "count": 3
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "anomaly",
                    "text": "At least one snapshot failed (skips, smoke, or uneven strand)."
                }
            ]
        },
        {
            "id": "anomaly",
            "text": "Classify anomaly first: partial obstruction (repeat cleaning), thermal creep (cooldown + slower feed), or nozzle damage (replace). Record which class occurred and the corrective action before restarting the monitoring window.",
            "options": [
                {
                    "type": "goto",
                    "goto": "monitor",
                    "text": "Adjusted cooling/feed settings and logged the change; rerun snapshots.",
                    "requiresItems": [
                        {
                            "id": "45f6f1ce-18e4-481d-8635-23ea51e0c2fd",
                            "count": 1
                        },
                        {
                            "id": "60409c3f-56cf-4b9e-9e60-ca480d4896d0",
                            "count": 3
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "cooldown",
                    "text": "Symptoms look like a hard clog; return to teardown and service.",
                    "requiresItems": [
                        {
                            "id": "564a76de-925b-4457-a548-d015168abe0c",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "monitor",
                    "text": "Corrective action applied; start a fresh monitoring window.",
                    "requiresItems": [
                        {
                            "id": "45f6f1ce-18e4-481d-8635-23ea51e0c2fd",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "verify",
            "text": "Finish with a center-paper check and first-layer watch so recovery is safe under load. If either fails, return to anomaly classification instead of forcing completion.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "First layer holds and monitoring log is complete.",
                    "requiresItems": [
                        {
                            "id": "45f6f1ce-18e4-481d-8635-23ea51e0c2fd",
                            "count": 1
                        },
                        {
                            "id": "60409c3f-56cf-4b9e-9e60-ca480d4896d0",
                            "count": 3
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "anomaly",
                    "text": "Verification failed; classify and correct before another monitoring run."
                }
            ]
        },
        {
            "id": "finish",
            "text": "The printer is recovered with a repeatable monitoring record you can reuse the next time flow drifts.",
            "options": [
                {
                    "type": "finish",
                    "text": "Back to printing."
                }
            ]
        }
    ],
