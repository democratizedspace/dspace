                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "monitor",
                    "text": "Hotend is rebuilt and moves smoothly.",
                    "requiresItems": [
                        {
                            "id": "45f6f1ce-18e4-481d-8635-23ea51e0c2fd",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "monitor",
            "text": "Heat to 200 °C, extrude 30 mm, and watch flow for two checks spaced a few minutes apart. Log flow quality, noise, and any pressure spikes.",
            "options": [
                {
                    "type": "process",
                    "process": "write-mission-log-entry",
                    "text": "Log verification readings from both checks.",
