                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "anomaly",
                    "text": "Flow still pulses or clicks under load."
                },
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Flow is stable and first layer passes paper drag check.",
                    "requiresItems": [
                        {
                            "id": "45f6f1ce-18e4-481d-8635-23ea51e0c2fd",
