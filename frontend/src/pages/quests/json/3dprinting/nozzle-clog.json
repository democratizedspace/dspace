                    ]
                }
            ]
        },
        {
            "id": "log-setup",
            "text": "Before purging, stage your log sheet with three rows: timestamp, strand width consistency, and safety notes (smoke/odor/skips). No log template, no restart.",
            "options": [
                {
                    "type": "goto",
                    "goto": "monitor",
                    "text": "Log sheet is staged with all required fields.",
                    "requiresItems": [
                        {
                            "id": "45f6f1ce-18e4-481d-8635-23ea51e0c2fd",
                            "count": 1
                        },
                        {
                            "id": "60409c3f-56cf-4b9e-9e60-ca480d4896d0",
                            "count": 2
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "cooldown",
                    "text": "I missed fields; returning to safe teardown before retesting.",
                    "requiresItems": [
                        {
                            "id": "564a76de-925b-4457-a548-d015168abe0c",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "monitor",
            "text": "Run three purge snapshots (10 mm each, ~5 minutes apart). Each row must include width trend, skip/noise notes, and smoke/odor status before you can pass.",
            "options": [
                {
                    "type": "goto",
                    "goto": "log-setup",
                    "text": "Hotend is rebuilt and ready to prepare the monitoring sheet.",
                    "requiresItems": [
                        {
                            "id": "45f6f1ce-18e4-481d-8635-23ea51e0c2fd",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "verify",
                    "text": "Logs show stable flow and no anomalies across all three checks.",
                    "requiresItems": [
                        {
                            "id": "45f6f1ce-18e4-481d-8635-23ea51e0c2fd",
                            "count": 1
                        },
                        {
                            "id": "60409c3f-56cf-4b9e-9e60-ca480d4896d0",
                            "count": 2
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "anomaly",
                    "text": "At least one snapshot failed (skips, smoke, or uneven strand)."
                }
            ]
        },
        {
            "id": "anomaly",
            "text": "Classify the issue before retry: partial obstruction (repeat cleaning), thermal creep (cooldown + slower feed), or nozzle damage (replace). Re-run the snapshot cadence after correction.",
            "options": [
                {
                    "type": "goto",
                    "goto": "monitor",
                    "text": "Adjusted cooling/feed settings and logged the change; rerun snapshots.",
                    "requiresItems": [
                        {
                            "id": "45f6f1ce-18e4-481d-8635-23ea51e0c2fd",
                            "count": 1
                        },
                        {
                            "id": "60409c3f-56cf-4b9e-9e60-ca480d4896d0",
                            "count": 2
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "cooldown",
                    "text": "Symptoms look like a hard clog; return to teardown and service.",
                    "requiresItems": [
                        {
                            "id": "564a76de-925b-4457-a548-d015168abe0c",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "monitor",
                    "text": "Corrective action applied; start a fresh monitoring window.",
                    "requiresItems": [
                        {
                            "id": "45f6f1ce-18e4-481d-8635-23ea51e0c2fd",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "log-setup",
                    "text": "Restart with a fresh log template before another purge window.",
                    "requiresItems": [
                        {
                            "id": "45f6f1ce-18e4-481d-8635-23ea51e0c2fd",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "verify",
            "text": "Finish with a center-paper check and first-layer watch so the recovery is safe under print load, not just during purges. Keep the completed monitoring sheet with the printer notes.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "First layer holds and monitoring log is complete.",
                    "requiresItems": [
                        {
                            "id": "45f6f1ce-18e4-481d-8635-23ea51e0c2fd",
                            "count": 1
                        },
                        {
                            "id": "60409c3f-56cf-4b9e-9e60-ca480d4896d0",
                            "count": 2
                        }
                    ]
                }
            ]
        },
        {
            "id": "finish",
            "text": "The printer is recovered with a repeatable monitoring record you can reuse the next time flow drifts.",
