{
    "id": "3dprinting/nozzle-clog",
    "title": "Fix a Clogged Nozzle",
    "description": "Disassemble your printer after a blob event, classify the clog, and restore reliable flow with logged verification.",
    "image": "/assets/quests/nozzle_clog_disassembly.jpg",
    "npc": "/assets/npc/sydney.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Skipping the first-layer check let filament pile around the hotend. We'll cool, classify the failure, repair, and verify stable flow before release.",
            "options": [
                {
                    "type": "process",
                    "process": "3dprint-nozzle-clog",
                    "text": "Document the failure and reproduce the clog.",
                    "requiresItems": [
                        {
                            "id": "8aa6dc27-dc42-4622-ac88-cbd57f48625f",
                            "count": 1
                        },
                        {
                            "id": "d3590107-25ff-4de5-af3a-46e2497bfc52",
                            "count": 5
                        },
                        {
                            "id": "061fd221-404a-4bd1-9432-3e25b0f17a2c",
                            "count": 50
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "classify",
                    "text": "Printer is powered down and cool.",
                    "requiresItems": [
                        {
                            "id": "564a76de-925b-4457-a548-d015168abe0c",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "classify",
            "text": "Tag the failure before touching hardware: partial clog (sputter), full clog (no flow), or leak at nozzle threads. Log symptoms and likely cause.",
            "options": [
                {
                    "type": "process",
                    "process": "write-mission-log-entry",
                    "text": "Record symptom class, last print temp, and suspected cause.",
                    "requiresItems": [
                        {
                            "id": "70bb8d86-2c4e-4330-9705-371891934686",
                            "count": 1
                        },
                        {
                            "id": "aa82b02f-2617-4474-a91b-29647e4a9780",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "repair",
                    "text": "Failure class logged. Proceed with safe disassembly.",
                    "requiresItems": [
                        {
                            "id": "564a76de-925b-4457-a548-d015168abe0c",
                            "count": 1
                        },
                        {
                            "id": "280ed361-ac70-4ab9-bcd9-aee481790faf",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
