{
    "id": "3dprinting/cable-clip",
    "title": "Print a Cable Clip",
    "description": "Reduce clutter by 3D printing a simple cable clip.",
    "image": "/assets/quests/cable_clip_print.jpg",
    "npc": "/assets/npc/sydney.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Sydney here. Let's print tidy cable clips, but we'll prep the printer first so they snap cleanly. Goggles on and keep fingers away from the hotend.",
            "options": [
                {
                    "type": "goto",
                    "goto": "prep",
                    "text": "Walk me through the setup."
                }
            ]
        },
        {
            "id": "prep",
            "text": "Level the bed with paper, swap to white PLA, and wipe the plate with isopropyl. Slice four clips with 0.2 mm layers and a small brim for grip.",
            "options": [
                {
                    "type": "process",
                    "process": "level-3d-printer-bed",
                    "text": "Dial in the bed with a paper shim."
                },
                {
                    "type": "process",
                    "process": "swap-white-pla-filament",
                    "text": "Purge to white PLA.",
                    "requiresItems": [
                        {
                            "id": "a42e441a-5569-490c-86e4-ce711117cd22",
                            "count": 1
                        },
                        {
                            "id": "c9b51052-4594-42d7-a723-82b815ab8cc2",
                            "count": 1
                        },
                        {
                            "id": "ce92a1a9-c817-40f0-92b1-24aff053903d",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "print",
                    "text": "Bed leveled and white PLA loaded.",
                    "requiresItems": [
                        {
                            "id": "06b405f2-1728-4428-bc1c-abcf7ef36bcf",
                            "count": 1
                        },
                        {
                            "id": "c9b51052-4594-42d7-a723-82b815ab8cc2",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "print",
            "text": "Preheat, lay down a first-layer test line, then start the clip print. Watch for clean perimeters and pause if stringing appears so you can adjust retraction later.",
            "options": [
                {
                    "type": "process",
                    "process": "3dprint-cable-clips",
                    "text": "Print four cable clips."
                },
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Clips cooled and edges deburred.",
                    "requiresItems": [
                        {
                            "id": "269d2cfb-25de-417b-8e29-64e80aff934c",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "finish",
            "text": "Snap the clips on a desk edge, route USB cables, and note any elephant's foot to tweak Z offset before the next print.",
            "options": [
                {
                    "type": "finish",
                    "text": "Workspace tidy!"
                }
            ]
        }
