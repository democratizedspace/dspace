{
    "id": "3dprinting/x-belt-tension",
    "title": "Tighten the X-axis Belt",
    "description": "Keep your prints sharp by safely tightening a loose X-axis belt.",
    "image": "/assets/quests/x_belt_tension_adjust.jpg",
    "npc": "/assets/npc/sydney.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Noticing layer shifts? We'll run a baseline-adjust-retest loop so you can tension safely instead of overtightening blindly.",
            "options": [
                {
                    "type": "goto",
                    "goto": "baseline",
                    "text": "Printer is powered off, unplugged, and ready for baseline checks."
                }
            ]
        },
        {
            "id": "baseline",
            "text": "Measure current X travel error over 100 mm, note carriage feel, and log baseline values before touching belt hardware.",
            "options": [
                {
                    "type": "goto",
                    "goto": "adjust",
                    "text": "Baseline logged; start adjustment.",
                    "requiresItems": [
                        {
                            "id": "e37c86b0-caaf-485d-b5c1-c15f7029973c",
                            "count": 1
                        },
                        {
                            "id": "60409c3f-56cf-4b9e-9e60-ca480d4896d0",
                            "count": 1
                        },
                        {
                            "id": "a42e441a-5569-490c-86e4-ce711117cd22",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "drift",
                    "text": "Baseline is inconsistent between repeated moves.",
                    "requiresItems": [
                        {
                            "id": "e37c86b0-caaf-485d-b5c1-c15f7029973c",
                            "count": 1
                        },
                        {
                            "id": "60409c3f-56cf-4b9e-9e60-ca480d4896d0",
                            "count": 1
                        },
                        {
                            "id": "a42e441a-5569-490c-86e4-ce711117cd22",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "adjust",
            "text": "Release clamps, tension to a firm twang, then re-square the gantry before locking hardware. Keep force moderate to protect bearings.",
            "options": [
                {
                    "type": "process",
                    "process": "tighten-x-belt",
                    "text": "Apply controlled tension adjustment."
                },
                {
                    "type": "goto",
                    "goto": "retest",
                    "text": "Adjustment complete; run tolerance retest.",
                    "requiresItems": [
                        {
                            "id": "448e9fbb-8464-4799-956d-cc465a4a8376",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "retest",
            "text": "Repeat the 100 mm move test. Pass when error stays within ±0.20 mm and carriage motion remains smooth without chirping.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Tolerance holds and motion is smooth.",
                    "requiresItems": [
                        {
                            "id": "448e9fbb-8464-4799-956d-cc465a4a8376",
                            "count": 1
                        },
                        {
                            "id": "e37c86b0-caaf-485d-b5c1-c15f7029973c",
                            "count": 1
                        },
                        {
                            "id": "60409c3f-56cf-4b9e-9e60-ca480d4896d0",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "drift",
                    "text": "Error drifts or carriage binds outside tolerance.",
                    "requiresItems": [
                        {
                            "id": "448e9fbb-8464-4799-956d-cc465a4a8376",
                            "count": 1
                        },
                        {
                            "id": "e37c86b0-caaf-485d-b5c1-c15f7029973c",
                            "count": 1
                        },
                        {
                            "id": "60409c3f-56cf-4b9e-9e60-ca480d4896d0",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "drift",
            "text": "Use the recovery branch: roll back toward your last-known-good tension, inspect idlers/set screws, and retest after each small change.",
            "options": [
                {
                    "type": "process",
                    "process": "tighten-x-belt",
                    "text": "Apply a corrective micro-adjustment."
                },
                {
                    "type": "goto",
                    "goto": "retest",
                    "text": "Correction made; retesting tolerance.",
                    "requiresItems": [
                        {
                            "id": "448e9fbb-8464-4799-956d-cc465a4a8376",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "finish",
            "text": "Nice work. You reached a measured belt setting with a documented baseline and recovery path for future drift.",
            "options": [
                {
                    "type": "finish",
                    "text": "Time to print!"
                }
            ]
        }
    ],
