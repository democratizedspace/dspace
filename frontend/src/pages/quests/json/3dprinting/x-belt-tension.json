{
    "id": "3dprinting/x-belt-tension",
    "title": "Tighten the X-axis Belt",
    "description": "Keep your prints sharp by safely tightening a loose X-axis belt with baseline, adjustment, and re-test evidence.",
    "image": "/assets/quests/x_belt_tension_adjust.jpg",
    "npc": "/assets/npc/sydney.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Noticing layer shifts? We'll run a baseline → adjust → re-test loop. Power off, unplug, and keep goggles on around sharp hardware.",
            "options": [
                {
                    "type": "goto",
                    "goto": "baseline",
                    "text": "Show me the baseline check."
                }
            ]
        },
        {
            "id": "baseline",
            "text": "Measure belt deflection at center span before touching hardware. Record the reading and carriage feel so we can compare after adjustment.",
            "options": [
                {
                    "type": "process",
                    "process": "write-mission-log-entry",
                    "text": "Log baseline belt reading and observed drift.",
                    "requiresItems": [
                        {
                            "id": "70bb8d86-2c4e-4330-9705-371891934686",
                            "count": 1
                        },
                        {
                            "id": "aa82b02f-2617-4474-a91b-29647e4a9780",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "adjust",
                    "text": "Baseline captured. Start adjustment.",
                    "requiresItems": [
                        {
                            "id": "280ed361-ac70-4ab9-bcd9-aee481790faf",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "adjust",
            "text": "Release clamp screws, tension until firm with a light twang, then re-square the gantry. Do not overtighten—binding bearings fail faster than loose belts.",
            "options": [
                {
                    "type": "process",
                    "process": "tighten-x-belt",
                    "text": "Walk me through each adjustment step.",
                    "requiresItems": [
                        {
                            "id": "a42e441a-5569-490c-86e4-ce711117cd22",
                            "count": 1
                        },
                        {
                            "id": "8299ac3f-c232-46d4-a007-2ad86ec70361",
                            "count": 1
                        },
                        {
                            "id": "c9b51052-4594-42d7-a723-82b815ab8cc2",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "retest",
                    "text": "Adjustment complete. Run the re-test.",
                    "requiresItems": [
                        {
                            "id": "448e9fbb-8464-4799-956d-cc465a4a8376",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "retest",
            "text": "Re-test carriage travel and belt deflection. Tolerance: within ±0.2 mm of target and no audible binding across full X travel.",
            "options": [
                {
                    "type": "goto",
                    "goto": "rollback",
                    "text": "Drift returned or carriage binds during travel.",
                    "requiresItems": [
                        {
                            "id": "448e9fbb-8464-4799-956d-cc465a4a8376",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "post-log",
                    "text": "Re-test passes tolerance and motion checks.",
                    "requiresItems": [
                        {
                            "id": "448e9fbb-8464-4799-956d-cc465a4a8376",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "rollback",
            "text": "Variance branch: roll back a quarter turn to last-known-good tension, re-square the gantry, and rerun baseline if readings keep drifting.",
            "options": [
                {
                    "type": "goto",
                    "goto": "adjust",
                    "text": "Apply rollback and re-test tension."
                },
                {
                    "type": "goto",
                    "goto": "baseline",
                    "text": "Start over from baseline to re-establish reference."
                }
            ]
        },
        {
            "id": "post-log",
            "text": "Record post-adjust measurement, tolerance result, and follow-up inspection interval.",
            "options": [
                {
                    "type": "process",
                    "process": "write-mission-log-entry",
                    "text": "Write post-adjust verification entry.",
                    "requiresItems": [
                        {
                            "id": "70bb8d86-2c4e-4330-9705-371891934686",
                            "count": 1
                        },
                        {
                            "id": "aa82b02f-2617-4474-a91b-29647e4a9780",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Both baseline and post-adjust artifacts are logged.",
                    "requiresItems": [
                        {
                            "id": "448e9fbb-8464-4799-956d-cc465a4a8376",
                            "count": 1
                        },
                        {
                            "id": "280ed361-ac70-4ab9-bcd9-aee481790faf",
                            "count": 2
                        }
                    ]
                }
            ]
        },
        {
            "id": "finish",
            "text": "Nice! Your X-axis tension is calibrated with evidence, and you've got rollback notes if drift returns.",
            "options": [
                {
                    "type": "finish",
                    "text": "Time to print!"
                }
            ]
        }
    ],
    "rewards": [
        {
            "id": "b281360b-2ecc-4fea-a248-36a61c5f7399",
            "count": 1
        }
    ],
    "requiresQuests": ["3dprinting/cable-clip"],
