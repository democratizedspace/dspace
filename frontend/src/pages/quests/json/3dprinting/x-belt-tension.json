{
    "id": "3dprinting/x-belt-tension",
    "title": "Tighten the X-axis Belt",
    "description": "Keep your prints sharp by safely tightening a loose X-axis belt.",
    "image": "/assets/quests/x_belt_tension_adjust.jpg",
    "npc": "/assets/npc/sydney.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Layer shifts are usually tension drift. We will run baseline -> adjust -> re-test, and we only close once tolerance holds.",
            "options": [
                {
                    "type": "goto",
                    "goto": "baseline",
                    "text": "Show me the full calibration loop."
                }
            ]
        },
        {
            "id": "baseline",
            "text": "Power off and unplug. Check carriage travel by hand and record baseline: audible belt twang, visible slack, and whether motion binds near end stops.",
            "options": [
                {
                    "type": "process",
                    "process": "write-mission-log-entry",
                    "text": "Capture baseline belt condition and safety checks."
                },
                {
                    "type": "goto",
                    "goto": "adjust",
                    "text": "Baseline logged. Start adjustment.",
                    "requiresItems": [
                        {
                            "id": "280ed361-ac70-4ab9-bcd9-aee481790faf",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "adjust",
            "text": "Release clamps, tension gradually, re-square gantry, and lock hardware. Stop if carriage binds or belt twang becomes high-pitched and harsh.",
            "options": [
                {
                    "type": "process",
                    "process": "tighten-x-belt",
                    "text": "Perform controlled belt adjustment.",
                    "requiresItems": [
                        {
                            "id": "a42e441a-5569-490c-86e4-ce711117cd22",
                            "count": 1
                        },
                        {
                            "id": "8299ac3f-c232-46d4-a007-2ad86ec70361",
                            "count": 1
                        },
                        {
                            "id": "c9b51052-4594-42d7-a723-82b815ab8cc2",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "retest",
                    "text": "Adjustment complete. Run post-adjust checks.",
                    "requiresItems": [
                        {
                            "id": "448e9fbb-8464-4799-956d-cc465a4a8376",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "rollback",
                    "text": "It feels overtightened or rough. Roll back safely."
                }
            ]
        },
        {
            "id": "retest",
            "text": "Re-test tolerance: smooth left-right travel with no skip, no audible chatter, and no return of layer shift symptoms over a short motion cycle.",
            "options": [
                {
                    "type": "process",
                    "process": "write-mission-log-entry",
                    "text": "Log post-adjust retest results and tolerance verdict."
                },
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Tolerance holds across retest window.",
                    "requiresItems": [
                        {
                            "id": "448e9fbb-8464-4799-956d-cc465a4a8376",
                            "count": 1
                        },
                        {
                            "id": "280ed361-ac70-4ab9-bcd9-aee481790faf",
                            "count": 2
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "rollback",
                    "text": "Drift returned or variance exceeded tolerance."
                }
            ]
        },
        {
            "id": "rollback",
            "text": "Rollback to last-known-good: ease tension a quarter turn, re-square, and inspect idlers before trying again. Never force a binding carriage.",
            "options": [
                {
                    "type": "process",
                    "process": "tighten-x-belt",
                    "text": "Apply rollback adjustment and re-square."
                },
                {
                    "type": "goto",
                    "goto": "retest",
                    "text": "Rollback complete. Re-run tolerance retest.",
                    "requiresItems": [
                        {
                            "id": "448e9fbb-8464-4799-956d-cc465a4a8376",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "finish",
            "text": "Dialed in. Baseline and post-adjust evidence are logged, and the belt holds tolerance under motion.",
            "options": [
                {
                    "type": "finish",
                    "text": "Time to print!"
                }
            ]
        }
    ],
    "rewards": [
        {
            "id": "b281360b-2ecc-4fea-a248-36a61c5f7399",
            "count": 1
        }
    ],
    "requiresQuests": ["3dprinting/cable-clip"],
