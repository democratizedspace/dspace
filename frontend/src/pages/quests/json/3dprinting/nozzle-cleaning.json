{
    "id": "3dprinting/nozzle-cleaning",
    "title": "Clear a Clogged Nozzle",
    "description": "Heat and clean the nozzle to restore smooth extrusion.",
    "image": "/assets/quests/nozzle_cleaning_tools.jpg",
    "npc": "/assets/npc/sydney.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Sydney here. Filament won't flow? Let's safely recreate the clog, then clear it without burning fingertips.",
            "options": [
                {
                    "type": "process",
                    "process": "3dprint-nozzle-clog",
                    "text": "Simulate the jam so I can practice cleanup."
                },
                {
                    "type": "goto",
                    "goto": "clean",
                    "text": "I already have a clogged hotend.",
                    "requiresItems": [
                        {
                            "id": "564a76de-925b-4457-a548-d015168abe0c",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "clean",
            "text": "Preheat to 200 °C, wear goggles, and pull the filament while it’s soft. If the blob is stubborn, remove the nozzle with pliers and swap in a fresh 0.4 mm at temp so it seats cleanly.",
            "options": [
                {
                    "type": "process",
                    "process": "repair-clogged-nozzle",
                    "text": "Disassemble, clear the bore, and reseat the nozzle."
                },
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Flow restored and test extrusion complete.",
                    "requiresItems": [
                        {
                            "id": "45f6f1ce-18e4-481d-8635-23ea51e0c2fd",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "finish",
            "text": "Extrusion is smooth again. Keep goggles nearby, purge a few lines after each swap, and toss worn nozzles instead of fighting them mid-print.",
            "options": [
                {
                    "type": "finish",
                    "text": "Back to printing."
                }
            ]
        }
    ],
    "rewards": [
        {
            "id": "564a76de-925b-4457-a548-d015168abe0c",
            "count": 1
        }
    ],
    "requiresQuests": [
        "3dprinter/start"
    ],
