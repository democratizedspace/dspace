{
    "id": "3dprinting/nozzle-cleaning",
    "title": "Clear a Clogged Nozzle",
    "description": "Heat and clean the nozzle to restore smooth extrusion.",
    "image": "/assets/quests/nozzle_cleaning_tools.jpg",
    "npc": "/assets/npc/sydney.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Sydney here. We are running a clean-room style nozzle recovery: capture a baseline, clean safely, then prove flow is stable before the next print.",
            "options": [
                {
                    "type": "process",
                    "process": "3dprint-nozzle-clog",
                    "text": "Simulate the jam so I can practice cleanup."
                },
                {
                    "type": "goto",
                    "goto": "baseline",
                    "text": "I already have a clogged hotend.",
                    "requiresItems": [
                        {
                            "id": "564a76de-925b-4457-a548-d015168abe0c",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "baseline",
            "text": "Before touching hardware, log what failed: purge behavior, visible residue, and whether the first 20 mm skips. Kill power and let the hotend cool before disassembly.",
            "options": [
                {
                    "type": "process",
                    "process": "write-mission-log-entry",
                    "text": "Record a pre-clean baseline log (symptoms + safety checks)."
                },
                {
                    "type": "goto",
                    "goto": "clean",
                    "text": "Baseline logged. Begin controlled cleaning.",
                    "requiresItems": [
                        {
                            "id": "280ed361-ac70-4ab9-bcd9-aee481790faf",
                            "count": 1
                        },
                        {
                            "id": "564a76de-925b-4457-a548-d015168abe0c",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "clean",
            "text": "Wear goggles, warm to service temperature, and clear debris with pliers. If threads are damaged or flow remains blocked, replace the nozzle instead of forcing it.",
            "options": [
                {
                    "type": "process",
                    "process": "repair-clogged-nozzle",
                    "text": "Disassemble, clear the bore, and reseat the nozzle."
                },
                {
                    "type": "goto",
                    "goto": "verify",
                    "text": "Cleanup complete. Ready for verification.",
                    "requiresItems": [
                        {
                            "id": "45f6f1ce-18e4-481d-8635-23ea51e0c2fd",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "verify",
            "text": "Run three short purge lines at 200 \u00b0C. Pass if all three lines are continuous with no popping or curl-back. If any line fails, classify the failure before retrying.",
            "options": [
                {
                    "type": "process",
                    "process": "write-mission-log-entry",
                    "text": "Log post-clean purge results (line 1-3 continuity + notes)."
                },
                {
                    "type": "goto",
                    "goto": "contamination",
                    "text": "One or more purge lines still fail."
                },
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "All purge lines are stable. Close the incident.",
                    "requiresItems": [
                        {
                            "id": "45f6f1ce-18e4-481d-8635-23ea51e0c2fd",
                            "count": 1
                        },
                        {
                            "id": "280ed361-ac70-4ab9-bcd9-aee481790faf",
                            "count": 2
                        }
                    ]
                }
            ]
        },
        {
            "id": "contamination",
            "text": "Troubleshoot safely: if residue is external, clean and reheat; if under-extrusion persists, swap to a fresh brass nozzle; if filament is burnt, cut back and purge again.",
            "options": [
                {
                    "type": "process",
                    "process": "repair-clogged-nozzle",
                    "text": "Retry the cleaning cycle with tighter debris control."
                },
                {
                    "type": "process",
                    "process": "replace-brass-nozzle",
                    "text": "Replace the nozzle to recover from internal scoring."
                },
                {
                    "type": "goto",
                    "goto": "verify",
                    "text": "Corrective action applied. Re-run verification."
                }
            ]
        },
        {
            "id": "finish",
            "text": "Great recovery. You captured before/after evidence, handled failure safely, and verified stable extrusion before returning to production.",
            "options": [
                {
                    "type": "finish",
                    "text": "Back to printing."
                }
            ]
        }
    ],
    "rewards": [
        {
            "id": "b281360b-2ecc-4fea-a248-36a61c5f7399",
            "count": 1
        }
    ],
    "requiresQuests": ["3dprinting/nozzle-clog"],
