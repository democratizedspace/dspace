{
    "id": "3dprinting/phone-stand",
    "title": "Print a Phone Stand",
    "description": "Practice 3D printing by making a handy phone stand.",
    "image": "/assets/quests/phone_stand_print.jpg",
    "npc": "/assets/npc/sydney.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Sydney here. We're printing a desk phone stand the metaguild can rely on for comms. We'll tune the machine, slice a stable profile, and verify fit so it works in real life.",
            "options": [
                {
                    "type": "goto",
                    "goto": "prep",
                    "text": "Let's prep the printer."
                }
            ]
        },
        {
            "id": "prep",
            "text": "Clear the build plate, wipe with isopropyl, and keep loose sleeves away from the gantry. We want a cool, steady printer before we preheat.",
            "options": [
                {
                    "type": "process",
                    "process": "level-3d-printer-bed",
                    "text": "Paper-level the bed."
                },
                {
                    "type": "process",
                    "process": "swap-white-pla-filament",
                    "text": "Swap to white PLA and purge.",
                    "requiresItems": [
                        {
                            "id": "a42e441a-5569-490c-86e4-ce711117cd22",
                            "count": 1
                        },
                        {
                            "id": "c9b51052-4594-42d7-a723-82b815ab8cc2",
                            "count": 1
                        },
                        {
                            "id": "ce92a1a9-c817-40f0-92b1-24aff053903d",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "slice",
                    "requiresItems": [
                        {
                            "id": "06b405f2-1728-4428-bc1c-abcf7ef36bcf",
                            "count": 1
                        }
                    ],
                    "text": "Bed is trammed and PLA is loaded."
                }
            ]
        },
        {
            "id": "slice",
            "text": "Grab a basic phone stand STL. Orient it so the backrest is flat on the plate, supports off, and add a 4 mm brim if your plate is slick. Slice at 0.2 mm layers, 3 perimeters, 4 top/bottom layers, 20% gyroid infill, 200 °C nozzle, 60 °C bed.",
            "options": [
                {
                    "type": "goto",
                    "goto": "print",
                    "text": "Slicing complete. Start the print."
                }
            ]
        },
        {
            "id": "print",
            "text": "Stay for the first layer. You want smooth, slightly squished lines with no gaps. If the lines look round, lower Z; if they're translucent and rough, raise Z a touch. Let the print finish, then cool the plate before removal.",
            "options": [
                {
                    "type": "process",
                    "process": "print-phone-stand",
                    "text": "Print the phone stand."
                },
                {
                    "type": "goto",
                    "goto": "fit-check",
                    "requiresItems": [
                        {
                            "id": "9018feac-7213-4eef-9654-b06dbd9404ea",
                            "count": 1
                        }
                    ],
                    "text": "Stand printed and cooled."
                }
            ]
        },
        {
            "id": "fit-check",
            "text": "Test fit your phone (with its case). The lip should catch the phone by at least 8 mm. If it rocks, add a thin felt pad or reprint with 105% scale. Trim any elephant's foot with a deburring pass.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Fit looks solid."
                }
            ]
        },
        {
            "id": "finish",
            "text": "Nice work. Log the slice settings you used and stash the stand on your bench. Power down the printer and clear the plate for the next run.",
            "options": [
                {
                    "type": "finish",
                    "text": "Thanks, Sydney!"
                }
            ]
        }
    ],
    "requiresQuests": ["3dprinter/start"],
    "hardening": {
        "passes": 0,
        "score": 90,
        "emoji": "🛠️",
        "history": []
    }
}
