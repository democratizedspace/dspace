{
    "id": "3dprinting/phone-stand",
    "title": "Print a Phone Stand",
    "description": "Practice 3D printing by making a handy phone stand.",
    "image": "/assets/quests/phone_stand_print.jpg",
    "npc": "/assets/npc/sydney.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Sydney here. We will tune the printer, print a stand, then verify fit with measured angle and port clearance before sign-off.",
            "options": [
                {
                    "type": "goto",
                    "goto": "prep",
                    "text": "Let's prep first."
                }
            ]
        },
        {
            "id": "prep",
            "text": "Ventilate, tie back hair, keep sleeves clear. Heat to PLA temps, wipe the nozzle, paper-level the bed with light drag. Clean the plate with isopropyl, then purge to white PLA until the flow is clean.",
            "options": [
                {
                    "type": "process",
                    "process": "level-3d-printer-bed",
                    "text": "Paper-level the bed."
                },
                {
                    "type": "process",
                    "process": "swap-white-pla-filament",
                    "text": "Swap to white PLA and purge.",
                    "requiresItems": [
                        {
                            "id": "a42e441a-5569-490c-86e4-ce711117cd22",
                            "count": 1
                        },
                        {
                            "id": "c9b51052-4594-42d7-a723-82b815ab8cc2",
                            "count": 1
                        },
                        {
                            "id": "ce92a1a9-c817-40f0-92b1-24aff053903d",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "print",
                    "text": "Ready to slice and print.",
                    "requiresItems": [
                        {
                            "id": "06b405f2-1728-4428-bc1c-abcf7ef36bcf",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "print",
            "text": "Slice at 0.2 mm layers, 3 perimeters, 5 top/bottom layers, 15% gyroid infill. Keep supports off unless needed. Watch first layer before committing the full print.",
            "options": [
                {
                    "type": "process",
                    "process": "print-phone-stand",
                    "text": "Print the phone stand."
                },
                {
                    "type": "goto",
                    "goto": "measure",
                    "text": "The stand is finished and cooled; start dimensional checks.",
                    "requiresItems": [
                        {
                            "id": "9018feac-7213-4eef-9654-b06dbd9404ea",
                            "count": 1
                        },
                        {
                            "id": "e37c86b0-caaf-485d-b5c1-c15f7029973c",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "measure",
            "text": "Measure support angle and lip width with calipers. Pass target: 60-70\u00b0 lean and at least 8 mm lip clearance for charging cable access. Record results before finish.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Measurements pass and fit is stable.",
                    "requiresItems": [
                        {
                            "id": "9018feac-7213-4eef-9654-b06dbd9404ea",
                            "count": 1
                        },
                        {
                            "id": "e37c86b0-caaf-485d-b5c1-c15f7029973c",
                            "count": 1
                        },
                        {
                            "id": "60409c3f-56cf-4b9e-9e60-ca480d4896d0",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "rework",
                    "text": "Out of range: angle or clearance failed."
                }
            ]
        },
        {
            "id": "rework",
            "text": "Troubleshooting branch: adjust scale 1-2%, add a brim if base lift is present, then print one verification stand before re-measuring. Power down between retries if you smell overheating.",
            "options": [
                {
                    "type": "process",
                    "process": "print-phone-stand",
                    "text": "Print one corrected verification stand.",
                    "requiresItems": [
                        {
                            "id": "06b405f2-1728-4428-bc1c-abcf7ef36bcf",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "measure",
                    "text": "Verification print cooled; re-measure now.",
                    "requiresItems": [
                        {
                            "id": "9018feac-7213-4eef-9654-b06dbd9404ea",
                            "count": 1
                        },
                        {
                            "id": "e37c86b0-caaf-485d-b5c1-c15f7029973c",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "finish",
            "text": "Great work. You shipped a stand with measured acceptance criteria and a documented recovery loop.",
            "options": [
                {
                    "type": "finish",
                    "text": "Thanks, Sydney!"
                }
            ]
        }
    ],
    "rewards": [
