{
    "id": "3dprinting/phone-stand",
    "title": "Print a Phone Stand",
    "description": "Tune, print, and verify a white PLA phone stand with fit-angle measurements and an out-of-range recovery loop.",
    "image": "/assets/quests/phone_stand_print.jpg",
    "npc": "/assets/npc/sydney.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Sydney here. We'll prep safely, print a phone stand, then prove it meets fit targets before we call it done.",
            "options": [
                {
                    "type": "goto",
                    "goto": "prep",
                    "text": "Let's prep first."
                }
            ]
        },
        {
            "id": "prep",
            "text": "Ventilate, tie back hair, keep sleeves clear, and preheat for PLA. Paper-level the bed, clean the plate with isopropyl, then purge to white PLA until flow is clean.",
            "options": [
                {
                    "type": "process",
                    "process": "level-3d-printer-bed",
                    "text": "Paper-level the bed."
                },
                {
                    "type": "process",
                    "process": "swap-white-pla-filament",
                    "text": "Swap to white PLA and purge.",
                    "requiresItems": [
                        {
                            "id": "a42e441a-5569-490c-86e4-ce711117cd22",
                            "count": 1
                        },
                        {
                            "id": "c9b51052-4594-42d7-a723-82b815ab8cc2",
                            "count": 1
                        },
                        {
                            "id": "ce92a1a9-c817-40f0-92b1-24aff053903d",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "print",
                    "text": "Ready to slice and print.",
                    "requiresItems": [
                        {
                            "id": "06b405f2-1728-4428-bc1c-abcf7ef36bcf",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "print",
            "text": "Slice the Phone Stand STL at 0.2 mm layers, 3 perimeters, 5 top/bottom layers, 15% gyroid infill. Use a 3\u20135 mm brim if adhesion is weak. Watch the first layer and let the print cool before removal.",
            "options": [
                {
                    "type": "process",
                    "process": "print-phone-stand",
                    "text": "Print the phone stand."
                },
                {
                    "type": "goto",
                    "goto": "measure",
                    "text": "The stand is finished and cooled; start fit measurements.",
                    "requiresItems": [
                        {
                            "id": "9018feac-7213-4eef-9654-b06dbd9404ea",
                            "count": 1
                        },
                        {
                            "id": "e37c86b0-caaf-485d-b5c1-c15f7029973c",
                            "count": 1
                        },
                        {
                            "id": "60409c3f-56cf-4b9e-9e60-ca480d4896d0",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "measure",
            "text": "Record two checks in your log: cradle width target 9\u201312 mm and lean angle target 60\u201370\u00b0. Note whether a sample phone sits stable with charging-port clearance.",
            "options": [
                {
                    "type": "goto",
                    "goto": "interpret",
                    "text": "Measurements recorded; interpret pass/fail bounds.",
                    "requiresItems": [
                        {
                            "id": "9018feac-7213-4eef-9654-b06dbd9404ea",
                            "count": 1
                        },
                        {
                            "id": "e37c86b0-caaf-485d-b5c1-c15f7029973c",
                            "count": 1
                        },
                        {
                            "id": "60409c3f-56cf-4b9e-9e60-ca480d4896d0",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "recover",
                    "text": "Fit is out of range or phone wobbles; start corrective branch.",
                    "requiresItems": [
                        {
                            "id": "9018feac-7213-4eef-9654-b06dbd9404ea",
                            "count": 1
                        },
                        {
                            "id": "e37c86b0-caaf-485d-b5c1-c15f7029973c",
                            "count": 1
                        },
                        {
                            "id": "60409c3f-56cf-4b9e-9e60-ca480d4896d0",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "interpret",
            "text": "Pass when the stand holds 60\u201370\u00b0 and keeps the port clear without wobble. If tight, sand lightly; if loose, scale by 1\u20132% and rerun a print test before shipping it.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Within bounds and stable under a 30-second wobble check.",
                    "requiresItems": [
                        {
                            "id": "9018feac-7213-4eef-9654-b06dbd9404ea",
                            "count": 1
                        },
                        {
                            "id": "60409c3f-56cf-4b9e-9e60-ca480d4896d0",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "recover",
                    "text": "Out of bounds; apply correction and rerun measurement.",
                    "requiresItems": [
                        {
                            "id": "9018feac-7213-4eef-9654-b06dbd9404ea",
                            "count": 1
                        },
                        {
                            "id": "60409c3f-56cf-4b9e-9e60-ca480d4896d0",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "recover",
            "text": "Troubleshooting branch: clean brim residue, dry filament if popping occurs, then choose either light sanding (tight fit) or 1\u20132% rescale and reprint (loose fit). Re-measure after each change.",
            "options": [
                {
                    "type": "process",
                    "process": "print-phone-stand",
                    "text": "Run a corrected reprint for fit recovery.",
                    "requiresItems": [
                        {
                            "id": "06b405f2-1728-4428-bc1c-abcf7ef36bcf",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "measure",
                    "text": "Corrective action complete; repeat fit measurements.",
                    "requiresItems": [
                        {
                            "id": "9018feac-7213-4eef-9654-b06dbd9404ea",
                            "count": 1
                        },
                        {
                            "id": "e37c86b0-caaf-485d-b5c1-c15f7029973c",
                            "count": 1
                        },
                        {
                            "id": "60409c3f-56cf-4b9e-9e60-ca480d4896d0",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "finish",
            "text": "Nice work. You validated the stand with measurements, pass/fail interpretation, and a repeatable correction loop.",
            "options": [
                {
                    "type": "finish",
                    "text": "Thanks, Sydney!"
                }
            ]
        }
    ],
