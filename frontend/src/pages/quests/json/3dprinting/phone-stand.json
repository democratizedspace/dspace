{
    "id": "3dprinting/phone-stand",
    "title": "Print a Phone Stand",
    "description": "Practice 3D printing by making a handy phone stand.",
    "image": "/assets/quests/phone_stand_print.jpg",
    "npc": "/assets/npc/sydney.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Sydney here. We'll print a phone stand and validate it with measurements, not guesses.",
            "options": [
                {
                    "type": "goto",
                    "goto": "prep",
                    "text": "Printer is clear and ready to prep."
                }
            ]
        },
        {
            "id": "prep",
            "text": "Dry white PLA if it popped last run. Confirm bed clean, belt tension stable, and calipers nearby before slicing.",
            "options": [
                {
                    "type": "goto",
                    "goto": "print",
                    "text": "Ready to slice and print.",
                    "requiresItems": [
                        {
                            "id": "06b405f2-1728-4428-bc1c-abcf7ef36bcf",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "print",
            "text": "Slice the Phone Stand STL at 0.2 mm layers, 3 perimeters, 5 top/bottom layers, 15% gyroid infill. Supports off unless overhangs demand it. Use a brim only when adhesion is unstable.",
            "options": [
                {
                    "type": "process",
                    "process": "print-phone-stand",
                    "text": "Print the phone stand."
                },
                {
                    "type": "goto",
                    "goto": "measure",
                    "text": "The stand is finished and cooled.",
                    "requiresItems": [
                        {
                            "id": "9018feac-7213-4eef-9654-b06dbd9404ea",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "measure",
            "text": "Measure two checks with calipers: cradle width and base flatness gap. Pass bounds: width 8-14 mm and gap <= 0.8 mm. Record both values before moving on.",
            "options": [
                {
                    "type": "goto",
                    "goto": "interpret",
                    "text": "Measurements logged with pass/fail notes.",
                    "requiresItems": [
                        {
                            "id": "9018feac-7213-4eef-9654-b06dbd9404ea",
                            "count": 1
                        },
                        {
                            "id": "e37c86b0-caaf-485d-b5c1-c15f7029973c",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "interpret",
            "text": "Interpretation gate: if both values are in range, approve. If out of range, choose a correction and re-test.",
            "options": [
                {
                    "type": "goto",
                    "goto": "corrective",
                    "text": "One or more values are out of range."
                },
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Both measurements pass and test fit is stable.",
                    "requiresItems": [
                        {
                            "id": "9018feac-7213-4eef-9654-b06dbd9404ea",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "corrective",
            "text": "Corrective loop: tune scale by 1-2%, add brim for warped bases, or dry filament if surfaces are rough. Reprint, cool, and rerun the same measurement bounds.",
            "options": [
                {
                    "type": "goto",
                    "goto": "print",
                    "text": "Apply corrections and reprint for re-test."
                }
            ]
        },
        {
            "id": "finish",
            "text": "Phone stand qualified. Save the passing dimensions and slicer profile so the next print starts from known-good settings.",
            "options": [
                {
                    "type": "finish",
                    "text": "Stand validated and documented."
                }
            ]
        }
    ],
    "rewards": [
        {
            "id": "b281360b-2ecc-4fea-a248-36a61c5f7399",
            "count": 1
        }
    ],
    "requiresQuests": [
        "3dprinting/filament-change"
    ],
