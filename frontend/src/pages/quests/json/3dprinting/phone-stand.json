{
    "id": "3dprinting/phone-stand",
    "title": "Print a Phone Stand",
    "description": "Practice 3D printing by making a handy phone stand.",
    "image": "/assets/quests/phone_stand_print.jpg",
    "npc": "/assets/npc/sydney.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Sydney here. We will tune the printer, print a stand, then prove fit quality with measured acceptance bounds before sign-off.",
            "options": [
                {
                    "type": "goto",
                    "goto": "prep",
                    "text": "Let's prep first."
                }
            ]
        },
        {
            "id": "prep",
            "text": "Ventilate, tie back hair, and clear sleeves. Heat to PLA temps, wipe nozzle, paper-level with light drag, clean the plate, and purge to white PLA until flow is clean.",
            "options": [
                {
                    "type": "process",
                    "process": "level-3d-printer-bed",
                    "text": "Paper-level the bed."
                },
                {
                    "type": "process",
                    "process": "swap-white-pla-filament",
                    "text": "Swap to white PLA and purge.",
                    "requiresItems": [
                        {
                            "id": "a42e441a-5569-490c-86e4-ce711117cd22",
                            "count": 1
                        },
                        {
                            "id": "c9b51052-4594-42d7-a723-82b815ab8cc2",
                            "count": 1
                        },
                        {
                            "id": "ce92a1a9-c817-40f0-92b1-24aff053903d",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "print",
                    "requiresItems": [
                        {
                            "id": "06b405f2-1728-4428-bc1c-abcf7ef36bcf",
                            "count": 1
                        }
                    ],
                    "text": "Ready to slice and print."
                }
            ]
        },
        {
            "id": "print",
            "text": "Slice the Phone Stand STL at 0.2 mm, 3 perimeters, 5 top/bottom layers, 15% gyroid. Use a 3-5 mm brim if adhesion is weak. Watch first layer, then cool before release.",
            "options": [
                {
                    "type": "process",
                    "process": "print-phone-stand",
                    "text": "Print the phone stand."
                },
                {
                    "type": "goto",
                    "goto": "measure",
                    "requiresItems": [
                        {
                            "id": "9018feac-7213-4eef-9654-b06dbd9404ea",
                            "count": 1
                        },
                        {
                            "id": "e37c86b0-caaf-485d-b5c1-c15f7029973c",
                            "count": 1
                        }
                    ],
                    "text": "Stand is finished; measure it before approval."
                }
            ]
        },
        {
            "id": "measure",
            "text": "Record three checks: lean angle 60-70\u00b0, base warp gap <=1 mm, and cable-slot clearance >=8 mm. Log values before deciding pass/fail.",
            "options": [
                {
                    "type": "process",
                    "process": "write-mission-log-entry",
                    "text": "Record measured fit data and pass/fail notes."
                },
                {
                    "type": "goto",
                    "goto": "interpret",
                    "requiresItems": [
                        {
                            "id": "280ed361-ac70-4ab9-bcd9-aee481790faf",
                            "count": 1
                        },
                        {
                            "id": "9018feac-7213-4eef-9654-b06dbd9404ea",
                            "count": 1
                        }
                    ],
                    "text": "Measurements logged. Interpret results."
                }
            ]
        },
        {
            "id": "interpret",
            "text": "If all bounds pass, ship it. If angle/clearance miss target, choose the corrective branch, reprint, and re-measure before finish unlocks.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Within bounds: approved stand.",
                    "requiresItems": [
                        {
                            "id": "9018feac-7213-4eef-9654-b06dbd9404ea",
                            "count": 1
                        },
                        {
                            "id": "280ed361-ac70-4ab9-bcd9-aee481790faf",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "corrective",
                    "text": "Out of bounds: run corrective loop."
                }
            ]
        },
        {
            "id": "corrective",
            "text": "Too tight: scale XY up 1-2%. Too loose or warped: raise brim and check first-layer adhesion. Reprint, then return to measurement with new data.",
            "options": [
                {
                    "type": "process",
                    "process": "print-phone-stand",
                    "text": "Reprint with corrected settings."
                },
                {
                    "type": "goto",
                    "goto": "measure",
                    "text": "Reprint complete. Re-measure against bounds.",
                    "requiresItems": [
                        {
                            "id": "9018feac-7213-4eef-9654-b06dbd9404ea",
                            "count": 2
                        },
                        {
                            "id": "e37c86b0-caaf-485d-b5c1-c15f7029973c",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "finish",
            "text": "Nice work. You closed the loop with measurable acceptance criteria instead of vibes-only fit checks.",
            "options": [
                {
                    "type": "finish",
                    "text": "Thanks, Sydney!"
                }
            ]
        }
    ],
    "rewards": [
