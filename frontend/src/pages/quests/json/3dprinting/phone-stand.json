{
    "id": "3dprinting/phone-stand",
    "title": "Print a Phone Stand",
    "description": "Practice 3D printing by making a handy phone stand.",
    "image": "/assets/quests/phone_stand_print.jpg",
    "npc": "/assets/npc/sydney.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Sydney here. Let's print a tidy phone stand. We'll tune, slice, then print in white PLA.",
            "options": [
                {
                    "type": "goto",
                    "goto": "prep",
                    "text": "Let's prep first."
                }
            ]
        },
        {
            "id": "prep",
            "text": "Ventilate, tie back hair, sleeves clear. Heat the nozzle to PLA temps, wipe it clean, and paper-level the bed to light drag. Clean the plate with isopropyl, then purge to white PLA until flow is steady.",
            "options": [
                {
                    "type": "process",
                    "process": "level-3d-printer-bed",
                    "text": "Paper-level the bed."
                },
                {
                    "type": "process",
                    "process": "swap-white-pla-filament",
                    "text": "Swap to white PLA and purge.",
                    "requiresItems": [
                        {
                            "id": "a42e441a-5569-490c-86e4-ce711117cd22",
                            "count": 1
                        },
                        {
                            "id": "c9b51052-4594-42d7-a723-82b815ab8cc2",
                            "count": 1
                        },
                        {
                            "id": "ce92a1a9-c817-40f0-92b1-24aff053903d",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "print",
                    "requiresItems": [
                        {
                            "id": "06b405f2-1728-4428-bc1c-abcf7ef36bcf",
                            "count": 1
                        }
                    ],
                    "text": "Ready to slice and print."
                }
            ]
        },
        {
            "id": "print",
            "text": "Open the Phone Stand STL from your community library inventory. Slice at 0.2 mm, 3 perimeters, 5 top/bottom layers, 15% gyroid infill. Lay it flat; skip supports unless your slicer flags a real overhang. Use a 3-5 mm brim if adhesion is weak. PLA at ~200°C nozzle, 60°C bed. Watch the first layer, then let it finish, cool, and flex the bed to release.",
            "options": [
                {
                    "type": "process",
                    "process": "print-phone-stand",
                    "text": "Print the phone stand."
                },
                {
                    "type": "goto",
                    "goto": "finish",
                    "requiresItems": [
                        {
                            "id": "9018feac-7213-4eef-9654-b06dbd9404ea",
                            "count": 1
                        }
                    ],
                    "text": "The stand is finished and cooled!"
                }
            ]
        },
        {
            "id": "finish",
            "text": "Test-fit the phone: 60–70° lean, lip clear of the charging port. Too tight, sand lightly. Too loose, scale 1-2% and reprint. Power down and log settings.",
            "options": [
                {
                    "type": "finish",
                    "text": "Thanks, Sydney!"
                }
            ]
        }
    ],
    "requiresQuests": ["3dprinter/start"],
