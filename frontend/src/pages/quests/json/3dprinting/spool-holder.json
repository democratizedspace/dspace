{
    "id": "3dprinting/spool-holder",
    "title": "Print a Spool Holder",
    "description": "Keep filament tidy by printing a simple spool holder.",
    "image": "/assets/quests/spool_holder_print_setup.jpg",
    "npc": "/assets/npc/sydney.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Sydney here. Filament keeps wandering? We'll print a sturdy spool holder with a baseline check, then validate smooth feed before closure.",
            "options": [
                {
                    "type": "goto",
                    "goto": "prep",
                    "text": "Guide me through prep."
                }
            ]
        },
        {
            "id": "prep",
            "text": "Safety first: goggles on, sleeves clear, and keep fingers off moving belts. Level the bed, purge to white PLA, and confirm belt tension so tall parts stay square.",
            "options": [
                {
                    "type": "process",
                    "process": "level-3d-printer-bed",
                    "text": "Level the bed first."
                },
                {
                    "type": "process",
                    "process": "tighten-x-belt",
                    "text": "Tension the belts so layers stack straight.",
                    "requiresItems": [
                        {
                            "id": "a42e441a-5569-490c-86e4-ce711117cd22",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "process",
                    "process": "swap-white-pla-filament",
                    "text": "Load white PLA and purge 10 grams of filament.",
                    "requiresItems": [
                        {
                            "id": "a42e441a-5569-490c-86e4-ce711117cd22",
                            "count": 1
                        },
                        {
                            "id": "c9b51052-4594-42d7-a723-82b815ab8cc2",
                            "count": 1
                        },
                        {
                            "id": "ce92a1a9-c817-40f0-92b1-24aff053903d",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "print",
                    "text": "Ready to print the spool holder.",
                    "requiresItems": [
                        {
                            "id": "06b405f2-1728-4428-bc1c-abcf7ef36bcf",
                            "count": 1
                        },
                        {
                            "id": "c9b51052-4594-42d7-a723-82b815ab8cc2",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "print",
            "text": "Preheat, run a skirt to confirm flow, then print the holder. Pause immediately if upright wobble or layer split appears.",
            "options": [
                {
                    "type": "process",
                    "process": "3dprint-spool-holder",
                    "text": "Print the spool holder."
                },
                {
                    "type": "goto",
                    "goto": "feed-check",
                    "text": "Holder cooled and mounted for feed testing.",
                    "requiresItems": [
                        {
                            "id": "3721d5e0-a148-4f67-9150-55492873a576",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "feed-check",
            "text": "Run a manual unwind test and measure axle alignment: the spool should rotate without binding for 30 seconds and the arm gap should stay even. Record pass/fail before finish.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Feed is smooth and alignment checks passed.",
                    "requiresItems": [
                        {
                            "id": "3721d5e0-a148-4f67-9150-55492873a576",
                            "count": 1
                        },
                        {
                            "id": "e37c86b0-caaf-485d-b5c1-c15f7029973c",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "recover",
                    "text": "Feed binds or wobble appeared during testing.",
                    "requiresItems": [
                        {
                            "id": "3721d5e0-a148-4f67-9150-55492873a576",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "recover",
            "text": "Recovery loop: retension the X belt, rotate the model 90\u00b0 on the bed, and reprint at slower outer-wall speed. Re-run feed checks before sign-off.",
            "options": [
                {
                    "type": "process",
                    "process": "tighten-x-belt",
                    "text": "Retension before reprint.",
                    "requiresItems": [
                        {
                            "id": "a42e441a-5569-490c-86e4-ce711117cd22",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "process",
                    "process": "3dprint-spool-holder",
                    "text": "Reprint with corrected orientation and speed."
                },
                {
                    "type": "goto",
                    "goto": "feed-check",
                    "text": "Corrective print cooled; rerun feed and alignment checks.",
                    "requiresItems": [
                        {
                            "id": "3721d5e0-a148-4f67-9150-55492873a576",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "finish",
            "text": "Great recovery discipline. Your spool path is stable, documented, and safe for long prints.",
            "options": [
                {
                    "type": "finish",
                    "text": "Spool secured!"
                }
            ]
        }
    ],
    "rewards": [
