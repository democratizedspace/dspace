{
    "id": "3dprinting/spool-holder",
    "title": "Print a Spool Holder",
    "description": "Keep filament tidy by printing a simple spool holder.",
    "image": "/assets/quests/spool_holder_print_setup.jpg",
    "npc": "/assets/npc/sydney.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Sydney here. Filament keeps wandering? Let's print a sturdy spool holder. Clear the bench, wear goggles, and keep the hotend area clear.",
            "options": [
                {
                    "type": "goto",
                    "goto": "prep",
                    "text": "Guide me through prep."
                }
            ]
        },
        {
            "id": "prep",
            "text": "Level the bed, purge to white PLA, and check belt tension so tall parts stay square. Slice with 4 walls and 30% infill for the uprights.",
            "options": [
                {
                    "type": "process",
                    "process": "level-3d-printer-bed",
                    "text": "Level the bed first."
                },
                {
                    "type": "process",
                    "process": "tighten-x-belt",
                    "text": "Tension the belts so layers stack straight.",
                    "requiresItems": [
                        {
                            "id": "a42e441a-5569-490c-86e4-ce711117cd22",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "process",
                    "process": "swap-white-pla-filament",
                    "text": "Load white PLA and purge 10 grams of filament.",
                    "requiresItems": [
                        {
                            "id": "a42e441a-5569-490c-86e4-ce711117cd22",
                            "count": 1
                        },
                        {
                            "id": "c9b51052-4594-42d7-a723-82b815ab8cc2",
                            "count": 1
                        },
                        {
                            "id": "ce92a1a9-c817-40f0-92b1-24aff053903d",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "print",
                    "text": "Ready to print the spool holder.",
                    "requiresItems": [
                        {
                            "id": "06b405f2-1728-4428-bc1c-abcf7ef36bcf",
                            "count": 1
                        },
                        {
                            "id": "c9b51052-4594-42d7-a723-82b815ab8cc2",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "print",
            "text": "Preheat, run a skirt to confirm flow, then start the holder. Check the arms stay flat and pause if any wobble appears.",
            "options": [
                {
                    "type": "process",
                    "process": "3dprint-spool-holder",
                    "text": "Print the spool holder."
                },
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Holder cooled and fits the spool axle.",
