{
    "id": "3dprinting/temperature-tower",
    "title": "Print a Temperature Tower",
    "description": "Find the ideal nozzle temperature by printing a simple calibration tower.",
    "image": "/assets/quests/temperature_tower_calibration.jpg",
    "npc": "/assets/npc/sydney.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Sydney here. Let's dial in that PLA with a staged temperature tower so you know exactly which layers behave.",
            "options": [
                {
                    "type": "goto",
                    "goto": "prep",
                    "text": "Great idea!"
                }
            ]
        },
        {
            "id": "prep",
            "text": "Dry the filament, clean the bed, and set a first-layer Z height you trust before burning hours on calibration.",
            "options": [
                {
                    "type": "process",
                    "process": "level-3d-printer-bed",
                    "text": "Paper-test the corners and jog Z offset."
                },
                {
                    "type": "goto",
                    "goto": "print",
                    "text": "Bed is leveled—ready to slice.",
                    "requiresItems": [
                        {
                            "id": "8aa6dc27-dc42-4622-ac88-cbd57f48625f",
                            "count": 1
                        },
                        {
                            "id": "58580f6f-f3be-4be0-80b9-f6f8bf0b05a6",
                            "count": 30
                        }
                    ]
                }
            ]
        },
        {
            "id": "print",
            "text": "Slice a tower with 5° steps and label each segment in the gcode so you can see stringing and layer shine move in real time.",
            "options": [
                {
                    "type": "process",
                    "process": "print-temperature-tower",
                    "text": "Slice and print the stepped tower."
                },
                {
                    "type": "goto",
                    "goto": "inspect",
                    "text": "Print finished and cool.",
                    "requiresItems": [
                        {
                            "id": "68a8004d-5af0-447d-aad9-22134f2e36ad",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "inspect",
            "text": "Look for glossy layers, weak bridges, and stringing changes between steps. Note the best-looking band and the one that warps.",
            "options": [
                {
                    "type": "process",
                    "process": "score-temperature-tower",
                    "text": "Log which temps win and which fail.",
                    "requiresItems": [
                        {
                            "id": "68a8004d-5af0-447d-aad9-22134f2e36ad",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Notes written with the winning temp circled.",
                    "requiresItems": [
                        {
                            "id": "05f47a22-d247-4ed7-b123-1a4d5f541a23",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "finish",
            "text": "Your tower tells the story: you now have a documented nozzle temperature sweet spot for this filament and machine.",
            "options": [
                {
                    "type": "finish",
                    "text": "Got it, thanks!",
                    "requiresItems": [
                        {
                            "id": "05f47a22-d247-4ed7-b123-1a4d5f541a23",
                            "count": 1
                        }
                    ]
                }
            ]
        }
    ],
    "rewards": [],
