{
    "id": "completionist/catalog",
    "title": "Catalog Your Trophy",
    "description": "Log your Completionist Award II with serial, placement, and a verifiable audit note.",
    "image": "/assets/quests/completionist_catalog_logbook.jpg",
    "npc": "/assets/npc/dChat.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Want to log that shiny award in your inventory so future you can find it? We'll capture the serial and stash a quick photo note.",
            "options": [
                {
                    "type": "goto",
                    "goto": "prep",
                    "text": "Yeah, let's catalog it",
                    "requiresItems": [
                        {
                            "id": "c01676ec-27e5-4a53-9a47-24bf6c5a56a9",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "prep",
            "text": "Set the trophy on a clear surface and capture serial, display location, and date. Keep full serials in your private log only.",
            "options": [
                {
                    "type": "process",
                    "process": "record-completionist-award-entry",
                    "text": "Capture the log entry with a photo"
                },
                {
                    "type": "goto",
                    "goto": "review",
                    "text": "I have an entry ready for review",
                    "requiresItems": [
                        {
                            "id": "c01676ec-27e5-4a53-9a47-24bf6c5a56a9",
                            "count": 1
                        },
                        {
                            "id": "78896eea-e4a6-40d1-9b93-522482b71f4f",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "review",
            "text": "A valid entry needs serial, location, date, and legible photo metadata. Classify defects before you file anything.",
            "options": [
                {
                    "type": "goto",
                    "goto": "audit-cadence",
                    "text": "Entry is complete and readable",
                    "requiresItems": [
                        {
                            "id": "78896eea-e4a6-40d1-9b93-522482b71f4f",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "fix-entry",
                    "text": "Missing fields or blurry photo, I need to correct it"
                }
            ]
        },
        {
            "id": "fix-entry",
            "text": "Good catch. Re-record with stable lighting and complete fields, then rerun review before the record can be accepted.",
            "options": [
                {
                    "type": "process",
                    "process": "record-completionist-award-entry",
                    "text": "Re-record the entry with complete details"
                },
                {
                    "type": "goto",
                    "goto": "review",
                    "text": "Retake complete, review again",
                    "requiresItems": [
                        {
                            "id": "78896eea-e4a6-40d1-9b93-522482b71f4f",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "audit-cadence",
            "text": "Before closure, set a recurring audit reminder so this log stays current. Monthly cadence is enough unless the display moves.",
            "options": [
                {
                    "type": "process",
                    "process": "schedule-quest-reminder",
                    "text": "Create a recurring catalog audit reminder"
                },
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Entry filed and audit cadence scheduled",
                    "requiresItems": [
                        {
                            "id": "78896eea-e4a6-40d1-9b93-522482b71f4f",
                            "count": 1
                        },
                        {
                            "id": "07d9b966-da28-465e-81b6-d6bd774326aa",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "finish",
            "text": "Nice! Future you will thank present you for the tidy, auditable records.",
            "options": [
                {
                    "type": "finish",
                    "text": "Log filed and monitored"
                }
            ]
        }
    ],
    "rewards": [
        {
            "id": "b281360b-2ecc-4fea-a248-36a61c5f7399",
            "count": 1
        }
    ],
    "requiresQuests": ["completionist/v2"],
    "hardening": {
        "passes": 0,
        "score": 90,
        "emoji": "🛠️",
        "history": []
    }
}
