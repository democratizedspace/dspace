{
    "id": "completionist/catalog",
    "title": "Catalog Your Trophy",
    "description": "Log your Completionist Award II with a recorded serial and photo note.",
    "image": "/assets/quests/completionist_catalog_logbook.jpg",
    "npc": "/assets/npc/dChat.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Want to log that shiny award in your inventory so future you can find it? We'll capture the serial and stash a quick photo note.",
            "options": [
                {
                    "type": "goto",
                    "goto": "prep",
                    "text": "Yeah, let's catalog it",
                    "requiresItems": [
                        {
                            "id": "c01676ec-27e5-4a53-9a47-24bf6c5a56a9",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "prep",
            "text": "Set the trophy on a clear surface and grab your logbook so the entry shows the serial, location, and date stamp.",
            "options": [
                {
                    "type": "process",
                    "process": "record-completionist-award-entry",
                    "text": "Capture the log entry with a quick photo"
                },
                {
                    "type": "goto",
                    "goto": "review",
                    "text": "I have an entry ready for review",
                    "requiresItems": [
                        {
                            "id": "c01676ec-27e5-4a53-9a47-24bf6c5a56a9",
                            "count": 1
                        },
                        {
                            "id": "78896eea-e4a6-40d1-9b93-522482b71f4f",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "review",
            "text": "Review the note before filing it. A valid log must include the trophy serial, display location, and today's date so audits are reproducible.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Entry has serial + location + date, filing it now",
                    "requiresItems": [
                        {
                            "id": "78896eea-e4a6-40d1-9b93-522482b71f4f",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "fix-entry",
                    "text": "Missing fields or blurry photo, I need to correct it"
                }
            ]
        },
        {
            "id": "fix-entry",
            "text": "Good catch. Re-shoot the entry in steady light and avoid posting full serials in public channels; keep detailed proof in your private log.",
            "options": [
                {
                    "type": "process",
                    "process": "record-completionist-award-entry",
                    "text": "Re-record the entry with complete details"
                },
                {
                    "type": "goto",
                    "goto": "review",
                    "text": "Retake complete, review again",
                    "requiresItems": [
                        {
                            "id": "78896eea-e4a6-40d1-9b93-522482b71f4f",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "finish",
            "text": "Nice! Future you will thank present you for the tidy records.",
            "options": [
                {
                    "type": "finish",
                    "text": "Log filed and searchable"
                }
            ]
        }
    ],
    "rewards": [
        {
            "id": "b281360b-2ecc-4fea-a248-36a61c5f7399",
            "count": 1
        }
    ],
    "requiresQuests": ["completionist/v2"],
    "hardening": {
        "passes": 0,
        "score": 90,
        "emoji": "\ud83d\udee0\ufe0f",
        "history": []
    }
}
