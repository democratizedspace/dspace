{
    "id": "completionist/catalog",
    "title": "Catalog Your Trophy",
    "description": "Log your Completionist Award II with a recorded serial, storage plan, and audit-ready notes.",
    "image": "/assets/quests/completionist_catalog_logbook.jpg",
    "npc": "/assets/npc/dChat.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Want to log that shiny award so future you can find it fast? We'll capture serial evidence, storage context, and audit-safe notes.",
            "options": [
                {
                    "type": "goto",
                    "goto": "prep",
                    "text": "Yeah, let's catalog it",
                    "requiresItems": [
                        {
                            "id": "c01676ec-27e5-4a53-9a47-24bf6c5a56a9",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "prep",
            "text": "Set the trophy on a clear surface and grab your logbook so the entry includes serial, location, and date.",
            "options": [
                {
                    "type": "process",
                    "process": "record-completionist-award-entry",
                    "text": "Capture the log entry with a quick photo"
                },
                {
                    "type": "goto",
                    "goto": "review",
                    "text": "I have an entry ready for review",
                    "requiresItems": [
                        {
                            "id": "c01676ec-27e5-4a53-9a47-24bf6c5a56a9",
                            "count": 1
                        },
                        {
                            "id": "78896eea-e4a6-40d1-9b93-522482b71f4f",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "review",
            "text": "Review the note before filing it. A valid log includes serial, display location, and date so audits are reproducible.",
            "options": [
                {
                    "type": "goto",
                    "goto": "storage-check",
                    "text": "Entry has serial + location + date, continue to storage check",
                    "requiresItems": [
                        {
                            "id": "78896eea-e4a6-40d1-9b93-522482b71f4f",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "fix-entry",
                    "text": "Missing fields or blurry photo, I need to correct it"
                }
            ]
        },
        {
            "id": "fix-entry",
            "text": "Good catch. Re-shoot the entry in steady light and keep full serial photos in private logs only.",
            "options": [
                {
                    "type": "process",
                    "process": "record-completionist-award-entry",
                    "text": "Re-record the entry with complete details"
                },
                {
                    "type": "goto",
                    "goto": "review",
                    "text": "Retake complete, review again",
                    "requiresItems": [
                        {
                            "id": "78896eea-e4a6-40d1-9b93-522482b71f4f",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "storage-check",
            "text": "Operational check: record where the physical award lives and who can access it. This avoids failed audits when trophies move rooms.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Storage location and access notes are captured",
                    "requiresItems": [
                        {
                            "id": "78896eea-e4a6-40d1-9b93-522482b71f4f",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "recover-storage",
                    "text": "Location is unclear or access notes are missing"
                }
            ]
        },
        {
            "id": "recover-storage",
            "text": "Recovery path: update the log entry with shelf ID/room, then re-run review so metadata and storage context match.",
            "options": [
                {
                    "type": "process",
                    "process": "record-completionist-award-entry",
                    "text": "Re-record with storage metadata"
                },
                {
                    "type": "goto",
                    "goto": "review",
                    "text": "Metadata fixed, review again",
                    "requiresItems": [
                        {
                            "id": "78896eea-e4a6-40d1-9b93-522482b71f4f",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "finish",
            "text": "Nice! Future you will thank present you for keeping trophy records and storage metadata tidy.",
            "options": [
                {
                    "type": "finish",
                    "text": "Log filed and searchable"
                }
            ]
        }
    ],
    "rewards": [
        {
            "id": "b281360b-2ecc-4fea-a248-36a61c5f7399",
            "count": 1
        }
    ],
    "requiresQuests": [
        "completionist/v2"
    ],
    "hardening": {
        "passes": 0,
        "score": 90,
