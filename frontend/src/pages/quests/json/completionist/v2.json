{
    "id": "completionist/v2",
    "title": "Congrats for finishing all the quests!!",
    "description": "Print, plate, verify, and recover safely while assembling a real Completionist Award II.",
    "image": "/assets/quests/completionist_trophy_award.jpg",
    "npc": "/assets/npc/dChat.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "You cleared every quest! Let's fabricate the Completionist Award II with real operator checks so this run is repeatable, not lucky.",
            "options": [
                {
                    "type": "goto",
                    "goto": "safety",
                    "text": "Let's build the real trophy"
                }
            ]
        },
        {
            "id": "safety",
            "text": "Safety preflight: clear flammables from the enclosure, verify first-layer watch, and stage goggles for any bed cleanup or trim work.",
            "options": [
                {
                    "type": "goto",
                    "goto": "prep-printer",
                    "text": "Preflight complete"
                },
                {
                    "type": "goto",
                    "goto": "start",
                    "text": "Need to reset workspace first"
                }
            ]
        },
        {
            "id": "prep-printer",
            "text": "We need a leveled printer and enough filament to chew through a solid core. Ready your green-lit printer before we spin up a long print.",
            "options": [
                {
                    "type": "process",
                    "process": "level-3d-printer-bed",
                    "text": "Re-level the print bed first"
                },
                {
                    "type": "goto",
                    "goto": "print-core",
                    "text": "Printer is leveled and loaded",
                    "requiresItems": [
                        {
                            "id": "a42e441a-5569-490c-86e4-ce711117cd22",
                            "count": 1
                        },
                        {
                            "id": "58580f6f-f3be-4be0-80b9-f6f8bf0b05a6",
                            "count": 150
                        }
                    ]
                }
            ]
        },
        {
            "id": "print-core",
            "text": "Time to print the trophy core with beefy walls and clean layer lines. Babysit the first layer and keep the chamber at temp.",
            "options": [
                {
                    "type": "process",
                    "process": "print-completionist-core",
                    "text": "Start the core print"
                },
                {
                    "type": "goto",
                    "goto": "print-plate",
                    "text": "Core is printed and cool",
                    "requiresItems": [
                        {
                            "id": "0c0db0db-585f-4eca-b0d9-56fbed5ecfb6",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "recover-core",
                    "text": "First layer shifted or warped"
                }
            ]
        },
        {
            "id": "recover-core",
            "text": "Recovery branch: abort the print, clean nozzle and bed, then re-level before restarting the core so warped layers don't propagate.",
            "options": [
                {
                    "type": "process",
                    "process": "level-3d-printer-bed",
                    "text": "Re-level after cleanup"
                },
                {
                    "type": "goto",
                    "goto": "prep-printer",
                    "text": "Recovery complete, retry core path"
                }
            ]
        },
        {
            "id": "print-plate",
            "text": "Let's add a crisp nameplate with the completion date. Swap to a fine layer height for the lettering so it pops when you buff it.",
            "options": [
                {
                    "type": "process",
                    "process": "print-completionist-plate",
                    "text": "Print the engraved plate"
                },
                {
                    "type": "goto",
                    "goto": "assemble",
                    "text": "Plate fits the recess",
                    "requiresItems": [
                        {
                            "id": "0c0db0db-585f-4eca-b0d9-56fbed5ecfb6",
                            "count": 1
                        },
                        {
                            "id": "a0fc23b6-3460-404f-bd16-dfb5700f7326",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "recover-plate",
                    "text": "Lettering smeared or plate fit failed"
                }
            ]
        },
        {
            "id": "recover-plate",
            "text": "Recovery branch: drop layer height, slow walls, and verify plate dimensions before attempting another nameplate run.",
            "options": [
                {
                    "type": "goto",
                    "goto": "print-plate",
                    "text": "Re-tune complete, retry plate print",
                    "requiresItems": [
                        {
                            "id": "0c0db0db-585f-4eca-b0d9-56fbed5ecfb6",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "assemble",
            "text": "Sand the edges, wick in a tiny bead of glue, and press the plate until it seats flush. Let it cure so the award feels like a single piece.",
            "options": [
                {
                    "type": "process",
                    "process": "assemble-completionist-award-ii",
                    "text": "Seat the plate and cure the core"
                },
                {
                    "type": "goto",
                    "goto": "verify",
                    "text": "Award is bonded and cured",
                    "requiresItems": [
                        {
                            "id": "c01676ec-27e5-4a53-9a47-24bf6c5a56a9",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "verify",
            "text": "Verification gate: plate sits flush, glue line is clean, and the award stands without wobble for one minute.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Fit, finish, and stability all passed",
                    "requiresItems": [
                        {
                            "id": "c01676ec-27e5-4a53-9a47-24bf6c5a56a9",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "recover-assembly",
                    "text": "Wobble or adhesive gap detected"
                }
            ]
        },
        {
            "id": "recover-assembly",
            "text": "Pause and recover: remove uncured squeeze-out, clamp square, and allow a full cure window before re-verification.",
            "options": [
                {
                    "type": "process",
                    "process": "assemble-completionist-award-ii",
                    "text": "Re-seat and re-cure the assembly"
                },
                {
                    "type": "goto",
                    "goto": "verify",
                    "text": "Recovery cure complete, verify again",
                    "requiresItems": [
                        {
                            "id": "c01676ec-27e5-4a53-9a47-24bf6c5a56a9",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "finish",
            "text": "Fresh off the build table! That Completionist Award II is now a real artifact, not just a checkbox.",
            "options": [
                {
                    "type": "finish",
                    "text": "Trophy fabricated and ready"
                }
            ]
        }
    ],
    "rewards": [
        {
            "id": "b281360b-2ecc-4fea-a248-36a61c5f7399",
            "count": 1
        }
    ],
    "requiresQuests": [
        "welcome/howtodoquests",
        "ubi/basicincome",
        "3dprinter/start",
        "aquaria/water-testing",
        "energy/solar",
        "rocketry/parachute",
        "hydroponics/basil"
    ],
    "hardening": {
