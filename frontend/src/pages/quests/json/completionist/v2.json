{
    "id": "completionist/v2",
    "title": "Congrats for finishing all the quests!!",
    "description": "Print, verify, and safely assemble a real Completionist Award II for your shelf.",
    "image": "/assets/quests/completionist_trophy_award.jpg",
    "npc": "/assets/npc/dChat.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "You cleared every quest! Let's actually fabricate the Completionist Award II instead of just talking about it.",
            "options": [
                {
                    "type": "goto",
                    "goto": "prep-printer",
                    "text": "Let's build the real trophy"
                }
            ]
        },
        {
            "id": "prep-printer",
            "text": "We need a leveled printer and enough filament to chew through a solid core. Verify bed level before every long print.",
            "options": [
                {
                    "type": "process",
                    "process": "level-3d-printer-bed",
                    "text": "Re-level the print bed first"
                },
                {
                    "type": "goto",
                    "goto": "print-core",
                    "text": "Printer is leveled and loaded",
                    "requiresItems": [
                        {
                            "id": "a42e441a-5569-490c-86e4-ce711117cd22",
                            "count": 1
                        },
                        {
                            "id": "58580f6f-f3be-4be0-80b9-f6f8bf0b05a6",
                            "count": 150
                        }
                    ]
                }
            ]
        },
        {
            "id": "print-core",
            "text": "Print the trophy core with beefy walls and clean layer lines. If adhesion fails or warping starts, stop and correct before wasting filament.",
            "options": [
                {
                    "type": "process",
                    "process": "print-completionist-core",
                    "text": "Start the core print"
                },
                {
                    "type": "goto",
                    "goto": "print-plate",
                    "text": "Core is printed and cool",
                    "requiresItems": [
                        {
                            "id": "0c0db0db-585f-4eca-b0d9-56fbed5ecfb6",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "recover-core",
                    "text": "First layer failed, I need to recover"
                }
            ]
        },
        {
            "id": "recover-core",
            "text": "Recovery path: check nozzle cleanliness, re-level the bed, and restart only after the first layer is stable.",
            "options": [
                {
                    "type": "process",
                    "process": "level-3d-printer-bed",
                    "text": "Re-level and prep for a clean retry"
                },
                {
                    "type": "goto",
                    "goto": "print-core",
                    "text": "Recovery complete, retry core print",
                    "requiresItems": [
                        {
                            "id": "a42e441a-5569-490c-86e4-ce711117cd22",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "print-plate",
            "text": "Now print a crisp nameplate. Use fine layers so letters stay legible and verify fit before glue touches anything.",
            "options": [
                {
                    "type": "process",
                    "process": "print-completionist-plate",
                    "text": "Print the engraved plate"
                },
                {
                    "type": "goto",
                    "goto": "dry-fit",
                    "text": "Plate finished, time for fit check",
                    "requiresItems": [
                        {
                            "id": "a0fc23b6-3460-404f-bd16-dfb5700f7326",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "dry-fit",
            "text": "Do a dry fit before bonding. If the plate rocks, reprint instead of forcing it and cracking the core.",
            "options": [
                {
                    "type": "goto",
                    "goto": "assemble",
                    "text": "Dry fit passes, proceed to assembly",
                    "requiresItems": [
                        {
                            "id": "0c0db0db-585f-4eca-b0d9-56fbed5ecfb6",
                            "count": 1
                        },
                        {
                            "id": "a0fc23b6-3460-404f-bd16-dfb5700f7326",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "print-plate",
                    "text": "Fit failed, reprint plate and retest"
                }
            ]
        },
        {
            "id": "assemble",
            "text": "Sand the edges, apply a tiny glue bead, and cure in a ventilated space. If glue smears onto lettering, pause and clean before curing.",
            "options": [
                {
                    "type": "process",
                    "process": "assemble-completionist-award-ii",
                    "text": "Seat the plate and cure the core"
                },
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Award is bonded, lettering is clean, and cure is complete",
                    "requiresItems": [
                        {
                            "id": "c01676ec-27e5-4a53-9a47-24bf6c5a56a9",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "finish",
            "text": "Fresh off the build table! That Completionist Award II is now a real artifact, not just a checkbox.",
            "options": [
                {
                    "type": "finish",
                    "text": "Trophy fabricated and verified"
                }
            ]
        }
    ],
    "rewards": [
        {
            "id": "b281360b-2ecc-4fea-a248-36a61c5f7399",
            "count": 1
        }
    ],
    "requiresQuests": [
        "welcome/howtodoquests",
        "ubi/basicincome",
        "3dprinter/start",
        "aquaria/water-testing",
        "energy/solar",
        "rocketry/parachute",
        "hydroponics/basil"
    ],
    "hardening": {
        "passes": 0,
        "score": 100,
        "emoji": "🛠️",
        "history": []
    }
}
