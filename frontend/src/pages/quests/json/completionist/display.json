{
    "id": "completionist/display",
    "title": "Show Off Your Trophy",
    "description": "Dust the shelf, polish the award, and mount it where everyone can see.",
    "image": "/assets/quests/completionist_trophy_display_shelf.jpg",
    "npc": "/assets/npc/dChat.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "That award deserves the center of your shelf. Want to set it up with lighting and a dust-free ledge?",
            "options": [
                {
                    "type": "goto",
                    "goto": "dust",
                    "text": "Let's find the perfect spot",
                    "requiresItems": [
