                            "id": "c01676ec-27e5-4a53-9a47-24bf6c5a56a9",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "dust",
            "text": "Clear a shelf and wipe away dust so the trophy doesn't sit on grit. The light bounce will look better too.",
            "options": [
                {
                    "type": "process",
                    "process": "polish-completionist-award",
                    "text": "Clean and buff the trophy"
                },
                {
                    "type": "goto",
                    "goto": "place",
                    "text": "Shelf is dusted and trophy gleams",
                    "requiresItems": [
                        {
                            "id": "1030a6c5-88b9-46e9-b38a-b20d8d326764",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "place",
            "text": "Let's stage it center-right so it's visible at eye height. Add a small backlight or plant for contrast.",
            "options": [
                {
                    "type": "process",
                    "process": "stage-completionist-award",
                    "text": "Mount it on the shelf"
                },
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Award is staged with lighting",
                    "requiresItems": [
                        {
                            "id": "a8120ce3-4a9d-4d49-b955-92bd9d7fbc07",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "finish",
            "text": "Looks amazing! Every hero's story deserves a spotlight.",
            "options": [
                {
                    "type": "finish",
                    "text": "Thanks for the guidance!"
                }
            ]
        }
    ],
