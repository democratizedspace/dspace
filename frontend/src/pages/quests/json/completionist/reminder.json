{
    "id": "completionist/reminder",
    "title": "Check for New Quests",
    "description": "Set and verify a weekly reminder so new quests never sneak past you.",
    "image": "/assets/quests/completionist_new_quests_reminder.jpg",
    "npc": "/assets/npc/dChat.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "More quests are added all the time. Keep an eye on the board so you can maintain that shiny Completionist trophy!",
            "options": [
                {
                    "type": "goto",
                    "goto": "plan-window",
                    "text": "Let's lock in a reminder plan",
                    "requiresItems": [
                        {
                            "id": "c01676ec-27e5-4a53-9a47-24bf6c5a56a9",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "plan-window",
            "text": "Pick a low-noise window with reliable internet, then define a fallback channel in case your main calendar app misses notifications.",
            "options": [
                {
                    "type": "process",
                    "process": "schedule-quest-reminder",
                    "text": "Schedule a weekly reminder in your primary calendar"
                },
                {
                    "type": "goto",
                    "goto": "verify-reminder",
                    "text": "Primary reminder scheduled, continue to verification",
                    "requiresItems": [
                        {
                            "id": "07d9b966-da28-465e-81b6-d6bd774326aa",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "verify-reminder",
            "text": "Run a dry test: does the reminder include the quest board link, weekly cadence, and timezone? If any field is off, don't lock it in yet.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Dry run passed: cadence, link, and timezone are all correct",
                    "requiresItems": [
                        {
                            "id": "07d9b966-da28-465e-81b6-d6bd774326aa",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "recovery",
                    "text": "Something failed (wrong timezone, no link, or muted alerts)"
                }
            ]
        },
        {
            "id": "recovery",
            "text": "Good catch. Enable a backup alert channel and re-run the test before you trust it. Never rely on a single silent reminder.",
            "options": [
                {
                    "type": "process",
                    "process": "schedule-quest-reminder",
                    "text": "Reconfigure reminder and backup alerts"
                },
                {
                    "type": "goto",
                    "goto": "verify-reminder",
                    "text": "Re-test the corrected reminder",
                    "requiresItems": [
                        {
                            "id": "07d9b966-da28-465e-81b6-d6bd774326aa",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "finish",
            "text": "Great! Your reminder loop is resilient and the future Metaguild stays visible on your radar.",
            "options": [
                {
                    "type": "finish",
                    "text": "Reminder verified and resilient"
                }
            ]
        }
    ],
    "rewards": [
        {
            "id": "82b369fe-0ef4-4ca1-881c-14e5a7feeff5",
            "count": 1
        }
    ],
    "requiresQuests": ["completionist/polish"],
    "hardening": {
        "passes": 0,
        "score": 90,
        "emoji": "🛠️",
        "history": []
    }
}
