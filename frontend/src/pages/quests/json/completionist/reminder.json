{
    "id": "completionist/reminder",
    "title": "Check for New Quests",
    "description": "Set a weekly reminder so new quests never sneak past you.",
    "image": "/assets/quests/completionist_new_quests_reminder.jpg",
    "npc": "/assets/npc/dChat.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "More quests are added all the time. Keep an eye on the board so you can maintain that shiny Completionist trophy!",
            "options": [
                {
                    "type": "goto",
                    "goto": "remind",
                    "text": "I'll set up a tracking habit.",
                    "requiresItems": [
                        {
                            "id": "c01676ec-27e5-4a53-9a47-24bf6c5a56a9",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "remind",
            "text": "Use your phone or calendar app to nudge you every week. Capture a day and time, then add a backup note in case your primary alert gets muted.",
            "options": [
                {
                    "type": "process",
                    "process": "schedule-quest-reminder",
                    "text": "Create the weekly quest reminder"
                },
                {
                    "type": "goto",
                    "goto": "verify",
                    "text": "Reminder plus backup note are saved.",
                    "requiresItems": [
                        {
                            "id": "07d9b966-da28-465e-81b6-d6bd774326aa",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "recover-missed-alert",
                    "text": "I forgot to set a backup note and already missed one check.",
                    "requiresItems": [
                        {
                            "id": "07d9b966-da28-465e-81b6-d6bd774326aa",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "verify",
            "text": "Before we lock this in, do a dry run: confirm next trigger time is visible and notifications are allowed. If timing is wrong, edit now.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Next trigger is visible and notifications are enabled.",
                    "requiresItems": [
                        {
                            "id": "07d9b966-da28-465e-81b6-d6bd774326aa",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "recover-missed-alert",
                    "text": "Trigger time looks wrong or notifications are blocked."
                }
            ]
        },
        {
            "id": "recover-missed-alert",
            "text": "Good catch. Reopen the reminder, set a second alert window, and pin a weekly checklist note so silence or timezone drift cannot hide new quests.",
            "options": [
                {
                    "type": "process",
                    "process": "schedule-quest-reminder",
                    "text": "Reconfigure reminder with backup coverage"
                },
                {
                    "type": "goto",
                    "goto": "verify",
                    "text": "Backup reminders are rebuilt. Re-run the verification.",
                    "requiresItems": [
                        {
                            "id": "07d9b966-da28-465e-81b6-d6bd774326aa",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "finish",
            "text": "Great! Your reminder system can survive missed pings, so new quests won't slip by unnoticed.",
            "options": [
                {
                    "type": "finish",
                    "text": "Schedule locked in."
                }
            ]
        }
    ],
    "rewards": [
        {
            "id": "b281360b-2ecc-4fea-a248-36a61c5f7399",
            "count": 1
        }
    ],
    "requiresQuests": ["completionist/polish"],
    "hardening": {
        "passes": 0,
        "score": 90,
        "emoji": "🛠️",
        "history": []
    }
}
