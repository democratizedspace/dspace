{
    "id": "completionist/reminder",
    "title": "Check for New Quests",
    "description": "Set and verify a weekly reminder so new quests never sneak past you.",
    "image": "/assets/quests/completionist_new_quests_reminder.jpg",
    "npc": "/assets/npc/dChat.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "More quests are added all the time. Keep an eye on the board so you can maintain that shiny Completionist trophy!",
            "options": [
                {
                    "type": "goto",
                    "goto": "set-window",
                    "text": "I'll lock in a weekly quest check",
                    "requiresItems": [
                        {
                            "id": "c01676ec-27e5-4a53-9a47-24bf6c5a56a9",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "set-window",
            "text": "Pick a repeatable day/time and set quiet-hours-safe notifications so the reminder is useful instead of disruptive.",
            "options": [
                {
                    "type": "process",
                    "process": "schedule-quest-reminder",
                    "text": "Schedule the weekly reminder"
                },
                {
                    "type": "goto",
                    "goto": "verify-alert",
                    "text": "Reminder exists with day/time and alert enabled",
                    "requiresItems": [
                        {
                            "id": "07d9b966-da28-465e-81b6-d6bd774326aa",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "verify-alert",
            "text": "Run a quick test alert now. If it fails, classify the failure before closing: muted app, wrong day, or no repeat rule.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Test alert fired and repeat cadence looks correct",
                    "requiresItems": [
                        {
                            "id": "07d9b966-da28-465e-81b6-d6bd774326aa",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "recover-alert",
                    "text": "Alert failed or cadence is wrong, fix and retry"
                }
            ]
        },
        {
            "id": "recover-alert",
            "text": "Fix one issue at a time: unmute notifications, restore weekly repeat, then rerun the test alert before leaving this quest.",
            "options": [
                {
                    "type": "process",
                    "process": "schedule-quest-reminder",
                    "text": "Reconfigure the reminder safely"
                },
                {
                    "type": "goto",
                    "goto": "verify-alert",
                    "text": "Settings corrected, run verification again",
                    "requiresItems": [
                        {
                            "id": "07d9b966-da28-465e-81b6-d6bd774326aa",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "finish",
            "text": "Great! Your reminder is configured and verified, so future quests should never silently pile up.",
            "options": [
                {
                    "type": "finish",
                    "text": "Reminder verified"
                }
            ]
        }
    ],
    "rewards": [
        {
            "id": "b281360b-2ecc-4fea-a248-36a61c5f7399",
            "count": 1
        }
    ],
    "requiresQuests": ["completionist/polish"],
    "hardening": {
        "passes": 0,
        "score": 90,
        "emoji": "🛠️",
        "history": []
    }
}
