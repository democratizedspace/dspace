{
    "id": "completionist/reminder",
    "title": "Check for New Quests",
    "description": "Set a weekly reminder so new quests never sneak past you.",
    "image": "/assets/quests/completionist_new_quests_reminder.jpg",
    "npc": "/assets/npc/dChat.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "More quests are added all the time. Keep an eye on the board so you can maintain that shiny Completionist trophy!",
            "options": [
                {
                    "type": "goto",
                    "goto": "plan",
                    "text": "I'll set up a reliable reminder loop.",
                    "requiresItems": [
                        {
                            "id": "c01676ec-27e5-4a53-9a47-24bf6c5a56a9",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "plan",
            "text": "Pick your strategy: calendar app with repeating alerts, or an analog checklist in your quest notebook. Either route needs proof before we close.",
            "options": [
                {
                    "type": "goto",
                    "goto": "digital",
                    "text": "Use a digital reminder"
                },
                {
                    "type": "goto",
                    "goto": "manual",
                    "text": "Use a manual checklist routine"
                }
            ]
        },
        {
            "id": "digital",
            "text": "Open your calendar and set a weekly recurring reminder for quests. Include day, time, and notification lead time so you actually act on it.",
            "options": [
                {
                    "type": "process",
                    "process": "schedule-quest-reminder",
                    "text": "Create the weekly quest reminder"
                },
                {
                    "type": "goto",
                    "goto": "verify",
                    "text": "Reminder created; move to verification.",
                    "requiresItems": [
                        {
                            "id": "07d9b966-da28-465e-81b6-d6bd774326aa",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "manual",
            "text": "Manual path works too: write your recurring quest check-in cadence and keep it somewhere visible. If you miss a week, switch to alarms immediately.",
            "options": [
                {
                    "type": "goto",
                    "goto": "verify",
                    "text": "Checklist routine is in place and visible.",
                    "requiresItems": [
                        {
                            "id": "07d9b966-da28-465e-81b6-d6bd774326aa",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "troubleshoot",
                    "text": "I keep forgetting and need a recovery plan."
                }
            ]
        },
        {
            "id": "verify",
            "text": "Verification gate: show an active weekly reminder artifact, then commit to your first check-in window.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Reminder verified and first check-in scheduled.",
                    "requiresItems": [
                        {
                            "id": "07d9b966-da28-465e-81b6-d6bd774326aa",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "troubleshoot",
                    "text": "Reminder failed or cadence is unclear."
                }
            ]
        },
        {
            "id": "troubleshoot",
            "text": "Recovery branch: simplify to one weekly reminder, test notification volume now, and set a backup reminder 24 hours later before retrying verification.",
            "options": [
                {
                    "type": "goto",
                    "goto": "digital",
                    "text": "Recovery complete; rebuild and verify the reminder."
                }
            ]
        },
        {
            "id": "finish",
            "text": "Great! Your dedication keeps the future Metaguild growing.",
            "options": [
                {
                    "type": "finish",
                    "text": "Happy to help."
                }
            ]
        }
    ],
    "rewards": [
        {
            "id": "b281360b-2ecc-4fea-a248-36a61c5f7399",
            "count": 1
        }
    ],
