{
    "id": "completionist/reminder",
    "title": "Check for New Quests",
    "description": "Set a weekly reminder so new quests never sneak past you.",
    "image": "/assets/quests/completionist_new_quests_reminder.jpg",
    "npc": "/assets/npc/dChat.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "More quests are added all the time. Keep an eye on the board so you can maintain that shiny Completionist trophy!",
            "options": [
                {
                    "type": "goto",
                    "goto": "plan-window",
                    "text": "I'll set up a real weekly reminder",
                    "requiresItems": [
                        {
                            "id": "c01676ec-27e5-4a53-9a47-24bf6c5a56a9",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "plan-window",
            "text": "Pick one weekday and one backup slot so missed pings don't turn into missed quest drops.",
            "options": [
                {
                    "type": "process",
                    "process": "schedule-quest-reminder",
                    "text": "Create the primary weekly quest reminder"
                },
                {
                    "type": "goto",
                    "goto": "verify-reminder",
                    "text": "Reminder exists and is repeating",
                    "requiresItems": [
                        {
                            "id": "07d9b966-da28-465e-81b6-d6bd774326aa",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "verify-reminder",
            "text": "Sanity check before we lock it in: title includes 'new quests', repeat is weekly, and notifications are enabled.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Everything looks correct and active",
                    "requiresItems": [
                        {
                            "id": "07d9b966-da28-465e-81b6-d6bd774326aa",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "recover-reminder",
                    "text": "The reminder is muted, duplicated, or missing details"
                }
            ]
        },
        {
            "id": "recover-reminder",
            "text": "Good catch. Edit it now: disable duplicate reminders, re-enable notifications, and keep one canonical entry so you trust the signal.",
            "options": [
                {
                    "type": "process",
                    "process": "schedule-quest-reminder",
                    "text": "Rebuild a clean weekly reminder"
                },
                {
                    "type": "goto",
                    "goto": "verify-reminder",
                    "text": "Cleanup done, re-run verification",
                    "requiresItems": [
                        {
                            "id": "07d9b966-da28-465e-81b6-d6bd774326aa",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "finish",
            "text": "Great! Your dedication keeps the future Metaguild growing.",
            "options": [
                {
                    "type": "finish",
                    "text": "Happy to help."
                }
            ]
        }
    ],
    "rewards": [
        {
            "id": "b281360b-2ecc-4fea-a248-36a61c5f7399",
            "count": 1
        }
    ],
    "requiresQuests": ["completionist/polish"],
    "hardening": {
        "passes": 0,
        "score": 90,
        "emoji": "🛠️",
        "history": []
    }
}
