{
    "id": "composting/check-temperature",
    "title": "Check Compost Temperature",
    "description": "Measure the heat of your compost to ensure active decomposition.",
    "image": "/assets/quests/compost_check_temperature.jpg",
    "npc": "/assets/npc/nova.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Let's see if your bucket is moving from hot phase to curing.",
            "options": [
                {
                    "type": "goto",
                    "goto": "readings",
                    "requiresItems": [
                        {
                            "id": "ff89afa1-2f88-44f2-a414-7fb1eda08735",
                            "count": 1
                        }
                    ],
                    "text": "Ready to take readings."
                }
            ]
        },
        {
            "id": "readings",
            "text": "Run both probes again: insert the compost thermometer to the core, then check moisture and note whether it feels wetter or drier than last time.",
            "options": [
                {
                    "type": "process",
                    "process": "measure-compost-temperature",
                    "goto": "readings",
                    "text": "Log the temperature"
                },
                {
                    "type": "process",
                    "process": "measure-compost-moisture",
                    "goto": "readings",
                    "text": "Record the moisture"
                },
                {
                    "type": "goto",
                    "goto": "recheck",
                    "requiresItems": [
                        {
                            "id": "e034d081-a29e-4040-830f-a192304db50d",
                            "count": 2
                        },
                        {
                            "id": "723f5795-735c-46ee-8a33-30a3a403cdfd",
                            "count": 2
                        }
                    ],
                    "text": "Both recheck readings are logged"
                }
            ]
        },
        {
            "id": "recheck",
            "text": "Take one more temperature reading after moisture balancing so you can confirm the bucket is cooling.",
            "options": [
                {
                    "type": "process",
                    "process": "recheck-compost-temperature",
                    "goto": "cooldown",
                    "text": "Confirm cooldown trend"
                },
                {
                    "type": "goto",
                    "goto": "cooldown",
                    "requiresItems": [
                        {
                            "id": "e034d081-a29e-4040-830f-a192304db50d",
                            "count": 2
                        },
                        {
                            "id": "723f5795-735c-46ee-8a33-30a3a403cdfd",
                            "count": 2
                        }
                    ],
                    "text": "Two temps and two moisture logs are ready"
                }
            ]
        },
        {
            "id": "cooldown",
            "text": "If temps hold steady or dip below 50 °C and moisture is balanced, let the bucket rest and cure.",
            "options": [
                {
                    "type": "process",
                    "process": "cure-compost-bucket",
                    "goto": "finish",
                    "text": "Start the cure rest"
                },
                {
                    "type": "goto",
                    "goto": "finish",
                    "requiresItems": [
                        {
                            "id": "b281360b-2ecc-4fea-a248-36a61c5f7399",
                            "count": 1
                        },
                        {
                            "id": "e034d081-a29e-4040-830f-a192304db50d",
                            "count": 2
                        },
                        {
                            "id": "723f5795-735c-46ee-8a33-30a3a403cdfd",
                            "count": 2
                        }
                    ],
                    "text": "Bucket has cooled and smells earthy"
                }
            ]
        },
        {
            "id": "finish",
            "text": "Great monitoring. A cured bucket is ready for screening or a quick refresh turn if it stalls.",
            "options": [
                {
                    "type": "finish",
                    "requiresItems": [
                        {
                            "id": "b281360b-2ecc-4fea-a248-36a61c5f7399",
                            "count": 1
                        },
                        {
                            "id": "e034d081-a29e-4040-830f-a192304db50d",
                            "count": 2
                        },
                        {
                            "id": "723f5795-735c-46ee-8a33-30a3a403cdfd",
                            "count": 2
                        }
                    ],
                    "text": "On to sifting!"
                }
            ]
        }
    ],
    "rewards": [
        {
            "id": "5e165cbc-f4f2-4e9d-ac92-9588ff1ac9c1",
            "count": 1
        }
    ],
    "requiresQuests": ["composting/turn-pile"],
