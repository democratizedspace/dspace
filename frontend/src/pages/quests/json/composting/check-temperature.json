{
    "id": "composting/check-temperature",
    "title": "Check Compost Temperature",
    "description": "Measure the heat of your compost to ensure active decomposition.",
    "image": "/assets/bucket.jpg",
    "npc": "/assets/npc/nova.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Wondering if your compost is cooking? Let's find out.",
            "options": [{ "type": "goto", "goto": "probe", "text": "How do I check?" }]
        },
        {
            "id": "probe",
            "text": "Insert a compost thermometer deep into the bucket to read the core heat.",
            "options": [
                {
                    "type": "goto",
                    "goto": "reading",
                    "process": "measure-compost-temperature",
                    "requiresItems": [{ "id": "4d21c498-9225-4d0b-9a1a-ed65e349f0a8", "count": 1 }],
                    "text": "Take the temperature"
                }
            ]
        },
        {
            "id": "reading",
            "text": "The dial climbs to a toasty 60 °C—microbes are feasting happily!",
            "options": [{ "type": "goto", "goto": "finish", "text": "Nice, it's hot!" }]
        },
        {
            "id": "finish",
            "text": "Keep monitoring and turning to maintain that microbial frenzy.",
            "options": [{ "type": "finish", "text": "Will do!" }]
        }
    ],
    "rewards": [],
    "requiresQuests": ["composting/cover-bucket"]
}
