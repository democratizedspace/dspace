{
    "id": "composting/start",
    "title": "Start a Compost Bucket",
    "description": "Begin recycling kitchen scraps into soil.",
    "image": "/assets/quests/compost_start_bucket.jpg",
    "npc": "/assets/npc/nova.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Waste not, friend! Let's turn scraps into nutrient-rich compost with a bucket starter.",
            "options": [
                {
                    "type": "goto",
                    "goto": "bucket",
                    "text": "What do I need?"
                }
            ]
        },
        {
            "id": "bucket",
            "text": "Grab a 5 gal bucket, drill a few vent holes near the top, and set out gloves plus a scoop of dry browns.",
            "options": [
                {
                    "type": "goto",
                    "goto": "layer",
                    "requiresItems": [
                        {
                            "id": "0564d441-7367-412e-b709-dad770814a39",
                            "count": 1
                        },
                        {
                            "id": "997eaba9-25ee-43d5-bbdc-5d6adf03adfa",
                            "count": 1
                        }
                    ],
                    "text": "Bucket drilled and gloves on."
                },
                {
                    "type": "goto",
                    "goto": "prep",
                    "text": "Remind me about greens vs browns."
                }
            ]
        },
        {
            "id": "prep",
            "text": "Greens = fresh scraps and coffee grounds; browns = shredded paper, dried leaves, or cardboard. Keep handfuls of each nearby.",
            "options": [
                {
                    "type": "goto",
                    "goto": "layer",
                    "requiresItems": [
                        {
                            "id": "0564d441-7367-412e-b709-dad770814a39",
                            "count": 1
                        },
                        {
                            "id": "997eaba9-25ee-43d5-bbdc-5d6adf03adfa",
                            "count": 1
                        }
                    ],
                    "text": "Supplies staged."
                },
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "I'll come back once I find a bucket."
                }
            ]
        },
        {
            "id": "layer",
            "text": "Add a brown base, mix in kitchen scraps, then cap with dry browns. Keep it damp like a wrung sponge and close the lid.",
            "options": [
                {
                    "type": "process",
                    "process": "start-compost-bin",
                    "goto": "layer",
                    "text": "Layer and vent the bucket"
                },
                {
                    "type": "goto",
                    "goto": "finish",
                    "requiresItems": [
                        {
                            "id": "025862b3-8377-4396-ab32-aa572bdc3260",
                            "count": 1
                        }
                    ],
                    "text": "Bucket is layered and capped"
                }
            ]
        },
        {
            "id": "finish",
            "text": "Nice build! Keep adding scraps under that brown cap and you have your first active bucket.",
            "options": [
                {
                    "type": "finish",
                    "requiresItems": [
                        {
                            "id": "025862b3-8377-4396-ab32-aa572bdc3260",
                            "count": 1
                        }
                    ],
                    "text": "Ready to start collecting scraps"
                }
            ]
        }
    ],
