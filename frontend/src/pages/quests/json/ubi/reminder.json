{
    "id": "ubi/reminder",
    "title": "Set a UBI Reminder",
    "description": "Set an IRL phone reminder so you remember your daily dUSD claim.",
    "image": "/assets/quests/ubi_daily_reminder.jpg",
    "npc": "/assets/npc/dChat.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Nice work claiming your first payout. Want a simple way to remember tomorrow's claim?",
            "options": [
                {
                    "type": "goto",
                    "goto": "platform",
                    "text": "Yes, show me how to set one on my phone."
                }
            ]
        },
        {
            "id": "platform",
            "text": "Use your real phone's Clock or Reminders app—there isn't an in-game reminder yet. Set a repeating alert for your usual claim time.",
            "options": [
                {
                    "type": "goto",
                    "goto": "confirm",
                    "text": "I'll set a recurring reminder now."
                },
                {
                    "type": "goto",
                    "goto": "tips",
                    "text": "Any tips so I don't miss it?"
                }
            ]
        },
        {
            "id": "tips",
            "text": "Good defaults: label it 'Claim dUSD', make it daily, and add one backup reminder 15 minutes later.",
            "options": [
                {
                    "type": "goto",
                    "goto": "confirm",
                    "text": "Perfect. I'll use that setup."
                }
            ]
        },
        {
            "id": "confirm",
            "text": "Once your reminder is saved, come back tomorrow and run the basic-income claim again.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Done. Reminder is scheduled.",
                    "requiresItems": [
                        {
                            "id": "016d4758-d114-4e04-9e6a-853db93a2eee",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "finish",
            "text": "Great habit. Your phone handles the reminder, and you handle the daily claim.",
            "options": [
                {
                    "type": "finish",
                    "text": "Thanks, I'll keep the streak going."
                }
            ]
        }
    ],
    "rewards": [
        {
            "id": "b281360b-2ecc-4fea-a248-36a61c5f7399",
            "count": 1
        }
    ],
    "requiresQuests": ["ubi/first-payment"],
