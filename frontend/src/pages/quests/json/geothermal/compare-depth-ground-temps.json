                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "deploy",
                    "text": "Walk me through depth setup"
                }
            ]
        },
        {
            "id": "deploy",
            "text": "Run a synchronized logging window with one shallow and one deep thermistor.",
            "options": [
