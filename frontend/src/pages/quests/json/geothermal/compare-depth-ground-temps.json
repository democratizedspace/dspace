                    ]
                }
            ]
        },
        {
            "id": "plot",
            "text": "Plot both depth traces and annotate weather/watering events that could skew the surface probe.",
            "options": [
                {
                    "type": "process",
                    "process": "plot-temperature-data",
                    "text": "Plot depth traces",
                    "requiresItems": [
                        {
                            "id": "d06c9f8d-6553-4f3c-9e10-05e1cf33a6b8",
