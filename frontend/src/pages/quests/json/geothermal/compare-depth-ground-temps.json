{
    "id": "geothermal/compare-depth-ground-temps",
    "title": "Compare Depth Ground Temps",
    "description": "Bury two thermistors at different depths, log both, and verify the depth gradient is stable.",
    "image": "/assets/quests/geothermal_compare_depth_ground_temps.jpg",
    "npc": "/assets/npc/orion.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Curious how ground temperature changes with depth? We'll capture shallow and deep traces, then confirm the gradient is believable before we call it done.",
            "options": [
                {
                    "type": "goto",
                    "goto": "deploy",
                    "text": "Let's map the depth gradient."
                }
            ]
        },
        {
            "id": "deploy",
            "text": "Wire two sensors with arduino-thermistor-read. Place one shallow and one deep, keep spacing fixed, and start a synchronized run.",
            "options": [
                {
                    "type": "process",
                    "process": "arduino-thermistor-read",
                    "text": "Capture paired depth readings",
                    "requiresItems": [
                        {
                            "id": "72b4448e-27d9-4746-bd3a-967ff13f501b",
                            "count": 2
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "interpret",
                    "text": "Paired logs are captured",
                    "requiresItems": [
                        {
                            "id": "72b4448e-27d9-4746-bd3a-967ff13f501b",
                            "count": 2
                        }
                    ]
                }
            ]
        },
        {
            "id": "interpret",
            "text": "Interpret with thresholds: deep probe should be at least 1°C steadier than shallow, and absolute spread should stay below 6°C unless weather notes justify it.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Gradient is plausible and within threshold",
                    "requiresItems": [
                        {
                            "id": "72b4448e-27d9-4746-bd3a-967ff13f501b",
                            "count": 2
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "troubleshoot",
                    "text": "Gradient is noisy or out-of-range"
                }
            ]
        },
        {
            "id": "troubleshoot",
            "text": "Troubleshoot before retry: confirm depth markers, reseat loose probe contacts, and wait for thermal settle time so transient spikes do not fake the result.",
            "options": [
                {
                    "type": "goto",
                    "goto": "deploy",
                    "text": "Corrections applied; rerun paired capture",
                    "requiresItems": [
                        {
                            "id": "72b4448e-27d9-4746-bd3a-967ff13f501b",
                            "count": 2
                        }
                    ]
                }
            ]
        },
        {
            "id": "finish",
            "text": "Awesome. You now have a verified depth profile to guide loop depth decisions.",
            "options": [
                {
                    "type": "finish",
                    "text": "Analyze depth profile"
                }
            ]
        }
    ],
