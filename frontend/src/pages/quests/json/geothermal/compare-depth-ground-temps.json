                    ]
                }
            ]
        },
        {
            "id": "evaluate",
            "text": "Expected deep-minus-shallow delta is 1-5°C with no inversion longer than two samples. Does the chart satisfy this?",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Yes, depth delta is stable",
                    "requiresItems": [
                        {
                            "id": "e7d1cd7d-e014-43a1-b1c8-9b7fb39deeed",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "corrective",
                    "text": "No, depth delta looks suspicious"
                }
            ]
        },
        {
            "id": "corrective",
            "text": "Re-seat the shallow probe to original depth, repack soil to remove air gaps, and rerun the synchronized log window.",
            "options": [
                {
                    "type": "goto",
                    "goto": "deploy",
                    "text": "Probe placement corrected; rerun depth logging",
