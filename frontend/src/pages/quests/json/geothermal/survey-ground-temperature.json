{
    "id": "geothermal/survey-ground-temperature",
    "title": "Survey for Geothermal Heat",
    "description": "Capture and interpret a baseline ground-temperature log before approving a site for geothermal work.",
    "image": "/assets/quests/geothermal_ground_temperature_probe.jpg",
    "npc": "/assets/npc/orion.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Orion here—before any digging, call utility locates, glove up, and pick a test spot clear of irrigation lines. Ready to run a defensible site survey?",
            "options": [
                {
                    "type": "goto",
                    "goto": "materials",
                    "text": "Safety and locate checks are complete"
                },
                {
                    "type": "goto",
                    "goto": "materials",
                    "text": "Walk me through safe survey prep"
                }
            ]
        },
        {
            "id": "materials",
            "text": "We'll use a thermistor logger at 1 m depth and capture hourly readings for a full day so short weather swings do not trick us.",
            "options": [
                {
                    "type": "grantsItems",
                    "grantsItems": [
                        {
                            "id": "8e81b5e5-4aee-402c-bd04-fed9188f8c07",
                            "count": 1
                        },
                        {
                            "id": "e62dca47-fba6-4ad5-abd4-95dd41f5f4c2",
                            "count": 1
                        }
                    ],
                    "text": "Issue thermometer and logging rig"
                },
                {
                    "type": "goto",
                    "goto": "measure",
                    "text": "Survey kit is staged",
                    "requiresItems": [
                        {
                            "id": "8e81b5e5-4aee-402c-bd04-fed9188f8c07",
                            "count": 1
                        },
                        {
                            "id": "e62dca47-fba6-4ad5-abd4-95dd41f5f4c2",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "measure",
            "text": "Install the probe in undisturbed soil, backfill firmly, then capture a 24 h baseline. Target range is 10–14°C with <=1.5°C daily swing at this depth.",
            "options": [
                {
                    "type": "process",
                    "process": "capture-hourly-temperature-log",
                    "text": "Capture the 24 h baseline log",
                    "requiresItems": [
                        {
                            "id": "e62dca47-fba6-4ad5-abd4-95dd41f5f4c2",
                            "count": 1
                        },
                        {
                            "id": "b6fc1ed6-f399-4fdb-9f9d-3913f893f43d",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "interpret",
                    "text": "Baseline log exported",
                    "requiresItems": [
                        {
                            "id": "d06c9f8d-6553-4f3c-9e10-05e1cf33a6b8",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "interpret",
            "text": "Interpretation gate: if median sits in 10–14°C and swing stays <=1.5°C, the site passes. Outside those bounds means placement or moisture bias and needs correction.",
            "options": [
                {
                    "type": "process",
                    "process": "plot-temperature-data",
                    "text": "Plot and review the survey log",
                    "requiresItems": [
                        {
                            "id": "d06c9f8d-6553-4f3c-9e10-05e1cf33a6b8",
                            "count": 1
                        },
                        {
                            "id": "b6fc1ed6-f399-4fdb-9f9d-3913f893f43d",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Readings meet geothermal baseline bounds",
                    "requiresItems": [
                        {
                            "id": "e7d1cd7d-e014-43a1-b1c8-9b7fb39deeed",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "corrective",
                    "text": "Baseline is out of range or unstable"
                }
            ]
        },
        {
            "id": "corrective",
            "text": "Troubleshooting path: reseat probe to full depth, re-pack soil to remove air pockets, and avoid direct sun irrigation zones. Re-run the 24 h log before deciding.",
            "options": [
                {
                    "type": "goto",
                    "goto": "measure",
                    "text": "Corrections applied, collect a new baseline"
                },
                {
                    "type": "goto",
                    "goto": "start",
                    "text": "Pause and redo safety/locate checks"
                }
            ]
        },
        {
            "id": "finish",
            "text": "Nice work. Archive the plotted baseline with depth and soil notes so later loop sizing compares against the same survey method.",
            "options": [
                {
                    "type": "finish",
                    "text": "Survey baseline approved",
                    "requiresItems": [
                        {
                            "id": "e7d1cd7d-e014-43a1-b1c8-9b7fb39deeed",
                            "count": 1
                        }
                    ]
                }
            ]
        }
    ],
