{
    "id": "geothermal/survey-ground-temperature",
    "title": "Survey for Geothermal Heat",
    "description": "Collect a baseline ground-temperature survey, classify viability against thresholds, and retest if readings are unstable.",
    "image": "/assets/quests/geothermal_ground_temperature_probe.jpg",
    "npc": "/assets/npc/orion.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Before we dream about heat pumps, we prove the site. Mark a one-meter test point, isolate from direct sun, and keep electrical tools dry.",
            "options": [
                {
                    "type": "goto",
                    "goto": "materials",
                    "text": "Survey point is marked"
                }
            ]
        },
        {
            "id": "materials",
            "text": "Use a stable thermometer and a simple logger so your reading is reproducible.",
            "options": [
                {
                    "type": "grantsItems",
                    "grantsItems": [
                        {
                            "id": "8e81b5e5-4aee-402c-bd04-fed9188f8c07",
                            "count": 1
                        }
                    ],
                    "text": "Issue survey thermometer"
                },
                {
                    "type": "goto",
                    "requiresItems": [
                        {
                            "id": "8e81b5e5-4aee-402c-bd04-fed9188f8c07",
                            "count": 1
                        }
                    ],
                    "goto": "measure",
                    "text": "Tooling is ready"
                }
            ]
        },
        {
            "id": "measure",
            "text": "Capture a baseline run at one meter depth and export the log before interpreting geothermal potential.",
            "options": [
                {
                    "type": "process",
                    "process": "capture-hourly-temperature-log",
                    "text": "Capture baseline survey log",
                    "requiresItems": [
                        {
                            "id": "e62dca47-fba6-4ad5-abd4-95dd41f5f4c2",
                            "count": 1
                        },
                        {
                            "id": "b6fc1ed6-f399-4fdb-9f9d-3913f893f43d",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "plot",
                    "text": "Baseline log exported",
                    "requiresItems": [
                        {
                            "id": "d06c9f8d-6553-4f3c-9e10-05e1cf33a6b8",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "plot",
            "text": "Plot the survey and annotate weather or irrigation events so short-term spikes are explainable.",
            "options": [
                {
                    "type": "process",
                    "process": "plot-temperature-data",
                    "text": "Plot survey curve",
                    "requiresItems": [
                        {
                            "id": "d06c9f8d-6553-4f3c-9e10-05e1cf33a6b8",
                            "count": 1
                        },
                        {
                            "id": "b6fc1ed6-f399-4fdb-9f9d-3913f893f43d",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "evaluate",
                    "text": "Survey chart reviewed",
                    "requiresItems": [
                        {
                            "id": "e7d1cd7d-e014-43a1-b1c8-9b7fb39deeed",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "evaluate",
            "text": "Viability band is 8-18°C with drift within ±2°C during the run. Do the results clear that threshold?",
            "options": [
                {
                    "type": "goto",
                    "goto": "fin",
                    "text": "Yes, site is viable",
                    "requiresItems": [
                        {
                            "id": "e7d1cd7d-e014-43a1-b1c8-9b7fb39deeed",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "corrective",
                    "text": "No, readings are unstable or out of range"
                }
            ]
        },
        {
            "id": "corrective",
            "text": "Repack the borehole wall, shade the probe from sun gain, wait one hour, and rerun the baseline capture before deciding.",
            "options": [
                {
                    "type": "goto",
                    "goto": "measure",
                    "text": "Site corrected; rerun baseline",
                    "requiresItems": [
                        {
                            "id": "8e81b5e5-4aee-402c-bd04-fed9188f8c07",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "fin",
            "text": "Great survey. You now have thresholded evidence the site can support a loop design.",
            "options": [
                {
                    "type": "finish",
                    "text": "Survey validated",
                    "requiresItems": [
