{
    "id": "geothermal/survey-ground-temperature",
    "title": "Survey for Geothermal Heat",
    "description": "Measure the ground temperature to see if a heat pump will work.",
    "image": "/assets/quests/geothermal_ground_temperature_probe.jpg",
    "npc": "/assets/npc/orion.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Before we dig, call utility locate and mark safe probe spots. Once the site is clear, we can record a defensible baseline.",
            "options": [
                {
                    "type": "goto",
                    "goto": "materials",
                    "text": "Utility locate is confirmed and PPE is ready."
                }
            ]
        },
        {
            "id": "materials",
            "text": "We'll take repeated readings at a meter depth. Grab a reliable thermometer and a notebook so this survey becomes evidence, not guesswork.",
            "options": [
                {
                    "type": "grantsItems",
                    "grantsItems": [
                        {
                            "id": "8e81b5e5-4aee-402c-bd04-fed9188f8c07",
                            "count": 1
                        }
                    ],
                    "text": "Issue survey thermometer"
                },
                {
                    "type": "goto",
                    "requiresItems": [
                        {
                            "id": "8e81b5e5-4aee-402c-bd04-fed9188f8c07",
                            "count": 1
                        }
                    ],
                    "goto": "measure",
                    "text": "Thermometer staged; begin the survey log."
                }
            ]
        },
        {
            "id": "measure",
            "text": "Capture two readings 30 minutes apart from the same depth and note soil moisture. A stable baseline should land around 8-14\u00b0C with less than 1\u00b0C drift.",
            "options": [
                {
                    "type": "goto",
                    "goto": "verify",
                    "text": "Measurements logged",
                    "requiresItems": [
                        {
                            "id": "8e81b5e5-4aee-402c-bd04-fed9188f8c07",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "verify",
            "text": "Interpret the log before committing to loop design.",
            "options": [
                {
                    "type": "goto",
                    "goto": "fin",
                    "text": "Baseline is in range and stable",
                    "requiresItems": [
                        {
                            "id": "8e81b5e5-4aee-402c-bd04-fed9188f8c07",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "retest",
                    "text": "Readings drifted or landed out of range",
                    "requiresItems": [
                        {
                            "id": "8e81b5e5-4aee-402c-bd04-fed9188f8c07",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "retest",
            "text": "Pause and troubleshoot: verify probe depth, improve soil contact, and avoid waterlogged pockets. If you hit unexpected piping or wiring, stop excavation and relocate before retesting.",
            "options": [
                {
                    "type": "goto",
                    "goto": "measure",
                    "text": "Apply corrections and re-measure",
                    "requiresItems": [
                        {
                            "id": "8e81b5e5-4aee-402c-bd04-fed9188f8c07",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "fin",
            "text": "Great survey discipline. With a stable ground baseline recorded, we can calibrate sensors and size the loop with confidence.",
            "options": [
                {
                    "type": "finish",
                    "text": "Baseline accepted",
                    "requiresItems": [
                        {
                            "id": "8e81b5e5-4aee-402c-bd04-fed9188f8c07",
                            "count": 1
                        }
                    ]
                }
            ]
        }
    ],
    "rewards": [
