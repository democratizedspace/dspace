{
    "id": "geothermal/survey-ground-temperature",
    "title": "Survey for Geothermal Heat",
    "description": "Measure ground temperature with repeatable evidence and resolve out-of-range site readings.",
    "image": "/assets/quests/geothermal_ground_temperature_probe.jpg",
    "npc": "/assets/npc/orion.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Before we trust the earth as a battery, we collect evidence. Mark utility lines, wear gloves, and keep the probe cable dry before taking readings.",
            "options": [
                {
                    "type": "goto",
                    "goto": "materials",
                    "text": "Safety prep is complete"
                },
                {
                    "type": "goto",
                    "goto": "materials",
                    "text": "Show me the safe survey setup"
                }
            ]
        },
        {
            "id": "materials",
            "text": "You need a thermometer and a logging notebook so today's measurement can be compared later.",
            "options": [
                {
                    "type": "grantsItems",
                    "grantsItems": [
                        {
                            "id": "8e81b5e5-4aee-402c-bd04-fed9188f8c07",
                            "count": 1
                        }
                    ],
                    "text": "Issue me the survey thermometer"
                },
                {
                    "type": "goto",
                    "goto": "measure",
                    "text": "Tools are ready",
                    "requiresItems": [
                        {
                            "id": "8e81b5e5-4aee-402c-bd04-fed9188f8c07",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "measure",
            "text": "Take two readings at ~1 m depth, five minutes apart, and record weather notes. A stable 8–15°C range is the pass window for this starter site.",
            "options": [
                {
                    "type": "goto",
                    "goto": "interpret",
                    "text": "Readings recorded in the target range"
                },
                {
                    "type": "goto",
                    "goto": "corrective",
                    "text": "Readings are outside range or unstable"
                }
            ]
        },
        {
            "id": "corrective",
            "text": "Recovery branch: relocate away from sun-baked spots, improve probe contact, and wait for temperature stabilization before repeating both readings.",
            "options": [
                {
                    "type": "goto",
                    "goto": "measure",
                    "text": "Retry survey after corrections"
                },
                {
                    "type": "goto",
                    "goto": "start",
                    "text": "Stop and re-check dig safety before retrying"
                }
            ]
        },
        {
            "id": "interpret",
            "text": "Interpretation check: if both readings are within 8–15°C and within 1°C of each other, the site baseline is credible for loop planning.",
            "options": [
                {
                    "type": "goto",
                    "goto": "fin",
                    "text": "Baseline passes and notes are complete",
                    "requiresItems": [
                        {
                            "id": "8e81b5e5-4aee-402c-bd04-fed9188f8c07",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "fin",
            "text": "Great. You now have a documented baseline with thresholds and retry logic, so later loop diagnostics have trustworthy context.",
            "options": [
                {
                    "type": "finish",
                    "text": "Survey baseline archived",
                    "requiresItems": [
                        {
                            "id": "8e81b5e5-4aee-402c-bd04-fed9188f8c07",
                            "count": 1
                        }
                    ]
                }
            ]
        }
    ],
