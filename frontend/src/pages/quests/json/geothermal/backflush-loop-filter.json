{
    "id": "geothermal/backflush-loop-filter",
    "title": "Backflush Loop Filter",
    "description": "Use a submersible pump to rinse debris from the geothermal loop filter.",
    "image": "/assets/quests/geothermal_backflush_loop_filter.jpg",
    "npc": "/assets/npc/orion.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Flow dropped? Lock out the pump breaker, verify pressure is bled down, and stage towels before touching fittings.",
            "options": [
                {
                    "type": "goto",
                    "goto": "materials",
                    "text": "Safety lockout complete."
                },
                {
                    "type": "goto",
                    "goto": "materials",
                    "text": "What gear do I need?"
                }
            ]
        },
        {
            "id": "materials",
            "text": "Use a submersible pump, clean bucket, and clear hose so debris does not re-enter the loop.",
            "options": [
                {
                    "type": "grantsItems",
                    "grantsItems": [
                        {
                            "id": "584ca717-4ce1-4ca1-bcd3-38272a52768a",
                            "count": 1
                        }
                    ],
                    "text": "Issue a submersible pump."
                },
                {
                    "type": "goto",
                    "goto": "baseline",
                    "requiresItems": [
                        {
                            "id": "584ca717-4ce1-4ca1-bcd3-38272a52768a",
                            "count": 1
                        },
                        {
                            "id": "72b4448e-27d9-4746-bd3a-967ff13f501b",
                            "count": 1
                        }
                    ],
                    "text": "Pump and logger are staged."
                }
            ]
        },
        {
            "id": "baseline",
            "text": "Before flushing, grab a 2-minute pressure baseline so we can prove improvement after cleanup.",
            "options": [
                {
                    "type": "goto",
                    "goto": "flush",
                    "text": "Baseline noted: unstable flow and visible debris.",
                    "requiresItems": [
                        {
                            "id": "72b4448e-27d9-4746-bd3a-967ff13f501b",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "flush",
            "text": "Backflush in 30-second bursts. If water stays cloudy after three bursts, stop and inspect the housing seal before continuing.",
            "options": [
                {
                    "type": "goto",
                    "goto": "verify",
                    "text": "Water is clear and pressure normalized."
                },
                {
                    "type": "goto",
                    "goto": "troubleshoot",
                    "text": "Still cloudy or pressure is erratic."
                }
            ]
        },
        {
            "id": "troubleshoot",
            "text": "Good catch. Check for collapsed hose, clogged impeller, or mis-seated gasket. Re-seat parts and run one short flush before re-verifying.",
            "options": [
                {
                    "type": "goto",
                    "goto": "flush",
                    "text": "Corrected and ready to retry flush."
                },
                {
                    "type": "goto",
                    "goto": "baseline",
                    "text": "Need a new baseline before retry."
                }
            ]
        },
        {
            "id": "verify",
            "text": "Record post-flush pressure and confirm the manifold stays dry for five minutes with the pump running.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Post-flush check passed; no leaks observed.",
                    "requiresItems": [
                        {
                            "id": "72b4448e-27d9-4746-bd3a-967ff13f501b",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "troubleshoot",
                    "text": "Pressure still drifts or moisture appears."
                }
            ]
        },
        {
            "id": "finish",
            "text": "Filter backflush is complete with before/after evidence. Tag the service log with flow result and date.",
            "options": [
                {
                    "type": "finish",
                    "text": "Return loop to normal operation."
                }
            ]
        }
    ],
    "rewards": [
        {
            "id": "b281360b-2ecc-4fea-a248-36a61c5f7399",
            "count": 1
        }
    ],
    "requiresQuests": ["geothermal/purge-loop-air"],
