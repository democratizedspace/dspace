{
    "id": "geothermal/backflush-loop-filter",
    "title": "Backflush Loop Filter",
    "description": "Use a submersible pump to rinse debris from the geothermal loop filter.",
    "image": "/assets/quests/basic_circuit.svg",
    "npc": "/assets/npc/orion.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Flow dropped? Let's rinse that filter clean.",
            "options": [
                {
                    "type": "goto",
                    "goto": "materials",
                    "text": "What do I need?"
                }
            ]
        },
        {
            "id": "materials",
            "text": "A small pump pushes water backward through the filter.",
            "options": [
                {
                    "type": "grantsItems",
                    "grantsItems": [
                        {
                            "id": "584ca717-4ce1-4ca1-bcd3-38272a52768a",
                            "count": 1
                        }
                    ],
                    "text": "Take this pump."
                },
                {
                    "type": "goto",
                    "goto": "flush",
                    "requiresItems": [
                        {
                            "id": "584ca717-4ce1-4ca1-bcd3-38272a52768a",
                            "count": 1
                        }
                    ],
                    "text": "I have a pump ready."
                }
            ]
        },
        {
            "id": "flush",
            "text": "Disconnect the filter and run water backward until clear.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Filter runs clear."
                }
            ]
        },
        {
            "id": "finish",
            "text": "Debris flushed. Flow should improve now.",
            "options": [
                {
                    "type": "finish",
                    "text": "Back to the manifold."
                }
            ]
        }
    ],
    "rewards": [],
    "requiresQuests": []
}
