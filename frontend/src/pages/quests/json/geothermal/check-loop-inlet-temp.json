{
    "id": "geothermal/check-loop-inlet-temp",
    "title": "Check Loop Inlet Temperature",
    "description": "Use an Arduino to log the water temperature entering the heat pump.",
    "image": "/assets/quests/geothermal_check_loop_inlet_temp_arduino.jpg",
    "npc": "/assets/npc/orion.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Lock out the pump, wipe the manifold dry, and keep hands clear of live mains. Ready to stage an inlet probe?",
            "options": [
                {
                    "type": "goto",
                    "goto": "build",
                    "text": "Rig is on the bench.",
                    "requiresItems": [
                        {
                            "id": "72b4448e-27d9-4746-bd3a-967ff13f501b",
                            "count": 1
                        },
                        {
                            "id": "d1105b87-8185-4a30-ba55-406384be169f",
                            "count": 1
                        },
                        {
                            "id": "3cd82744-d2aa-414e-9f03-80024b624066",
                            "count": 4
                        },
                        {
                            "id": "5a6bb713-ed34-4463-94ee-cfe7b8faa45c",
                            "count": 1
                        },
                        {
                            "id": "ffe0b74a-f111-4d66-b4c3-d82965a976ac",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "build",
                    "text": "Walk me through the setup."
                }
            ]
        },
        {
            "id": "build",
            "text": "Seat the thermistor on the inlet barb with strain relief so vibration cannot pull it loose.",
            "options": [
                {
                    "type": "goto",
                    "goto": "log",
                    "text": "Logger wired and secured",
                    "process": "assemble-thermistor-logger"
                },
                {
                    "type": "goto",
                    "goto": "log",
                    "text": "Rig is already built",
                    "requiresItems": [
                        {
                            "id": "e62dca47-fba6-4ad5-abd4-95dd41f5f4c2",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "log",
            "text": "Run ten minutes at normal flow and capture the inlet trace. Record target range 5-18\u00b0C with <2\u00b0C swing.",
            "options": [
                {
                    "type": "process",
                    "process": "capture-hourly-temperature-log",
                    "text": "Capture the inlet trace",
                    "requiresItems": [
                        {
                            "id": "e62dca47-fba6-4ad5-abd4-95dd41f5f4c2",
                            "count": 1
                        },
                        {
                            "id": "b6fc1ed6-f399-4fdb-9f9d-3913f893f43d",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "interpret",
                    "text": "Trace saved",
                    "requiresItems": [
                        {
                            "id": "d06c9f8d-6553-4f3c-9e10-05e1cf33a6b8",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "interpret",
            "text": "Interpret the trace: pass if median inlet temp is 5-18\u00b0C and oscillation stays below 2\u00b0C. Otherwise choose corrective action.",
            "options": [
                {
                    "type": "goto",
                    "goto": "plot",
                    "text": "Within bounds: proceed to chart.",
                    "requiresItems": [
                        {
                            "id": "d06c9f8d-6553-4f3c-9e10-05e1cf33a6b8",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "corrective",
                    "text": "Out of bounds or noisy trace."
                }
            ]
        },
        {
            "id": "corrective",
            "text": "Corrective branch: bleed trapped air, re-seat probe insulation, and confirm pump speed. Then retest before closing.",
            "options": [
                {
                    "type": "goto",
                    "goto": "log",
                    "text": "Corrective action complete; run mandatory retest.",
                    "requiresItems": [
                        {
                            "id": "e62dca47-fba6-4ad5-abd4-95dd41f5f4c2",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "plot",
            "text": "Generate a labeled chart and attach pass/fail notes so future outlet comparisons are auditable.",
            "options": [
                {
                    "type": "process",
                    "process": "plot-temperature-data",
                    "text": "Plot the inlet run",
                    "requiresItems": [
