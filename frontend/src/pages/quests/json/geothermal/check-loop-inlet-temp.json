{
    "id": "geothermal/check-loop-inlet-temp",
    "title": "Check Loop Inlet Temperature",
    "description": "Log inlet temperature, classify stability against explicit thresholds, and resolve anomalies before sign-off.",
    "image": "/assets/quests/geothermal_check_loop_inlet_temp_arduino.jpg",
    "npc": "/assets/npc/orion.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Lock out the pump, wipe the manifold dry, and keep your hands clear of live mains. Ready to clip a probe to the inlet?",
            "options": [
                {
                    "type": "goto",
                    "goto": "build",
                    "text": "Rig is on the bench.",
                    "requiresItems": [
                        {
                            "id": "72b4448e-27d9-4746-bd3a-967ff13f501b",
                            "count": 1
                        },
                        {
                            "id": "d1105b87-8185-4a30-ba55-406384be169f",
                            "count": 1
                        },
                        {
                            "id": "3cd82744-d2aa-414e-9f03-80024b624066",
                            "count": 4
                        },
                        {
                            "id": "5a6bb713-ed34-4463-94ee-cfe7b8faa45c",
                            "count": 1
                        },
                        {
                            "id": "ffe0b74a-f111-4d66-b4c3-d82965a976ac",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "build",
                    "text": "Walk me through the steps."
                }
            ]
        },
        {
            "id": "build",
            "text": "Seat the thermistor securely on the inlet barb and add strain relief to the leads. Build the logger so the probe can't slip when the pump starts.",
            "options": [
                {
                    "type": "goto",
                    "goto": "log",
                    "text": "Logger wired and secured",
                    "process": "assemble-thermistor-logger"
                },
                {
                    "type": "goto",
                    "goto": "log",
                    "text": "Rig is already built",
                    "requiresItems": [
                        {
                            "id": "e62dca47-fba6-4ad5-abd4-95dd41f5f4c2",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "log",
            "text": "Run a 10-minute inlet capture. Pass band is 6–18°C with sample jitter no greater than 1.5°C between adjacent readings.",
            "options": [
                {
                    "type": "process",
                    "process": "capture-hourly-temperature-log",
                    "text": "Capture the inlet trace",
                    "requiresItems": [
                        {
                            "id": "e62dca47-fba6-4ad5-abd4-95dd41f5f4c2",
                            "count": 1
                        },
                        {
                            "id": "b6fc1ed6-f399-4fdb-9f9d-3913f893f43d",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "plot",
                    "text": "Trace saved",
                    "requiresItems": [
                        {
                            "id": "d06c9f8d-6553-4f3c-9e10-05e1cf33a6b8",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "plot",
            "text": "Plot and annotate the capture so you can distinguish startup transients from sustained drift.",
            "options": [
                {
                    "type": "process",
                    "process": "plot-temperature-data",
                    "text": "Plot the inlet run",
                    "requiresItems": [
                        {
                            "id": "d06c9f8d-6553-4f3c-9e10-05e1cf33a6b8",
                            "count": 1
                        },
                        {
                            "id": "b6fc1ed6-f399-4fdb-9f9d-3913f893f43d",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "process",
                    "process": "refine-temperature-graph",
                    "text": "Annotate startup and steady-state windows",
                    "requiresItems": [
                        {
                            "id": "e7d1cd7d-e014-43a1-b1c8-9b7fb39deeed",
                            "count": 1
                        },
                        {
                            "id": "b6fc1ed6-f399-4fdb-9f9d-3913f893f43d",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "interpret",
                    "text": "Annotated chart reviewed",
                    "requiresItems": [
                        {
                            "id": "50360fd0-e296-4ef8-a3a9-00e049318166",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "interpret",
            "text": "Classify the run: in-band and steady passes; below 6°C hints freeze risk, above 18°C hints poor exchange, and >1.5°C jitter suggests air or sensor coupling issues.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Inlet run is in-band and stable",
                    "requiresItems": [
                        {
                            "id": "50360fd0-e296-4ef8-a3a9-00e049318166",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "corrective",
                    "text": "Out-of-band or unstable trace"
                }
            ]
        },
        {
            "id": "corrective",
            "text": "Corrective branch: bleed trapped air, re-seat probe insulation, and verify pump speed. Re-run the capture after each fix before closure.",
            "options": [
                {
                    "type": "goto",
                    "goto": "log",
                    "text": "Applied corrective action, retest now",
                    "requiresItems": [
                        {
                            "id": "e62dca47-fba6-4ad5-abd4-95dd41f5f4c2",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "start",
                    "text": "Stop and re-run lockout/safety checks"
                }
            ]
        },
        {
            "id": "finish",
            "text": "Save the annotated inlet chart with weather and pump-state notes. That evidence becomes your baseline for outlet and delta diagnostics.",
            "options": [
                {
                    "type": "finish",
                    "text": "Inlet trend logged",
                    "requiresItems": [
                        {
                            "id": "50360fd0-e296-4ef8-a3a9-00e049318166",
                            "count": 1
                        }
                    ]
                }
            ]
        }
