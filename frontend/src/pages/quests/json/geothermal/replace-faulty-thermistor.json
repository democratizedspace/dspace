{
    "id": "geothermal/replace-faulty-thermistor",
    "title": "Replace Faulty Thermistor",
    "description": "Swap the failed probe, verify parity against baseline readings, and recover cleanly if drift remains.",
    "image": "/assets/quests/geothermal_replace_faulty_thermistor.jpg",
    "npc": "/assets/npc/orion.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Power down the controller, tag the failed lead, and dry all terminals before opening the junction. Ready for a controlled replacement?",
            "options": [
                {
                    "type": "goto",
                    "goto": "stage",
                    "text": "Safety lockout complete"
                },
                {
                    "type": "goto",
                    "goto": "stage",
                    "text": "Remind me what to stage first"
                }
            ]
        },
        {
            "id": "stage",
            "text": "Stage one Arduino logger and a replacement thermistor. We'll only close this after a post-swap stability check.",
            "options": [
                {
                    "type": "goto",
                    "goto": "replace",
                    "text": "Spare probe and logger are ready",
                    "requiresItems": [
                        {
                            "id": "72b4448e-27d9-4746-bd3a-967ff13f501b",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "replace",
            "text": "Install the replacement probe with strain relief and record a baseline capture on the restored channel.",
            "options": [
                {
                    "type": "process",
                    "process": "arduino-thermistor-read",
                    "text": "Capture post-replacement baseline"
                },
                {
                    "type": "goto",
                    "goto": "verify",
                    "text": "Baseline capture saved",
                    "requiresItems": [
                        {
                            "id": "72b4448e-27d9-4746-bd3a-967ff13f501b",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "verify",
            "text": "Verification gate: readings must stay within 1.5°C of the backup probe for a 10-minute run with no dropouts.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Parity holds across the verification window",
                    "requiresItems": [
                        {
                            "id": "72b4448e-27d9-4746-bd3a-967ff13f501b",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "troubleshoot",
                    "text": "Drift or dropouts detected"
                }
            ]
        },
        {
            "id": "troubleshoot",
            "text": "Troubleshoot by reseating connectors, checking moisture ingress, and restoring the last-known-good wiring path before another capture.",
            "options": [
                {
                    "type": "goto",
                    "goto": "replace",
                    "text": "Corrective action done, re-run baseline",
                    "requiresItems": [
                        {
                            "id": "72b4448e-27d9-4746-bd3a-967ff13f501b",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "start",
                    "text": "Stop and repeat lockout before retry"
                }
            ]
        },
        {
            "id": "finish",
            "text": "Excellent. Log channel mapping and timestamp so seasonal diagnostics can trust this sensor path.",
            "options": [
                {
                    "type": "finish",
                    "text": "Replacement thermistor verified",
                    "requiresItems": [
                        {
                            "id": "72b4448e-27d9-4746-bd3a-967ff13f501b",
                            "count": 1
                        }
                    ]
                }
            ]
