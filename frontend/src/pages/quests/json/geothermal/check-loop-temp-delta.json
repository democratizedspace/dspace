{
    "id": "geothermal/check-loop-temp-delta",
    "title": "Check Loop Temperature Delta",
    "description": "Use two thermistors with an Arduino to compare loop inlet and outlet temps.",
    "image": "/assets/quests/geothermal_check_loop_temp_delta_dual_thermistors.jpg",
    "npc": "/assets/npc/orion.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Time to see how much heat the loop really moves. We'll combine inlet plots with a live outlet feed to watch the delta in real time.",
            "options": [
                {
                    "type": "goto",
                    "goto": "align",
                    "text": "Both probes are mounted",
                    "requiresItems": [
                        {
                            "id": "e62dca47-fba6-4ad5-abd4-95dd41f5f4c2",
                            "count": 1
                        },
                        {
                            "id": "f763cb7d-4e1a-4146-b304-4d8bfde4df86",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "align",
                    "text": "Need a quick walkthrough"
                }
            ]
        },
        {
            "id": "align",
            "text": "Secure both probes, purge bubbles, and balance the leads so readings don't drift. Capture a fresh paired trace before we compare it to the live outlet stream.",
            "options": [
                {
                    "type": "process",
                    "process": "capture-hourly-temperature-log",
                    "text": "Capture the paired trace",
                    "requiresItems": [
                        {
                            "id": "e62dca47-fba6-4ad5-abd4-95dd41f5f4c2",
                            "count": 1
                        },
                        {
                            "id": "b6fc1ed6-f399-4fdb-9f9d-3913f893f43d",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "plot",
                    "text": "Trace is saved",
                    "requiresItems": [
                        {
                            "id": "d06c9f8d-6553-4f3c-9e10-05e1cf33a6b8",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "plot",
            "text": "Plot inlet versus outlet for this run so you can catch lag or odd spikes. We'll annotate before pushing it to the live dashboard.",
            "options": [
                {
                    "type": "process",
                    "process": "plot-temperature-data",
                    "text": "Plot both runs",
                    "requiresItems": [
                        {
                            "id": "d06c9f8d-6553-4f3c-9e10-05e1cf33a6b8",
                            "count": 1
                        },
                        {
                            "id": "b6fc1ed6-f399-4fdb-9f9d-3913f893f43d",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "annotate",
                    "text": "Plot looks clean",
                    "requiresItems": [
                        {
                            "id": "e7d1cd7d-e014-43a1-b1c8-9b7fb39deeed",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "annotate",
            "text": "Mark pump start, circulator speed changes, and outdoor temp in the notes. That context makes the delta meaningful when you automate alerts.",
            "options": [
                {
                    "type": "process",
                    "process": "refine-temperature-graph",
                    "text": "Add notes to the overlay",
                    "requiresItems": [
                        {
                            "id": "e7d1cd7d-e014-43a1-b1c8-9b7fb39deeed",
                            "count": 1
                        },
                        {
                            "id": "b6fc1ed6-f399-4fdb-9f9d-3913f893f43d",
                            "count": 1
                        },
                        {
                            "id": "f763cb7d-4e1a-4146-b304-4d8bfde4df86",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "publish",
                    "text": "Notes are logged",
                    "requiresItems": [
                        {
                            "id": "50360fd0-e296-4ef8-a3a9-00e049318166",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "publish",
            "text": "Now pair your annotated inlet plot with the live outlet endpoint so you can watch the delta-T as the heat pump cycles.",
            "options": [
                {
                    "type": "process",
                    "process": "publish-live-temperature-graph",
                    "text": "Push a live delta dashboard",
                    "requiresItems": [
                        {
                            "id": "f763cb7d-4e1a-4146-b304-4d8bfde4df86",
                            "count": 1
                        },
                        {
                            "id": "50360fd0-e296-4ef8-a3a9-00e049318166",
                            "count": 1
                        },
                        {
                            "id": "b6fc1ed6-f399-4fdb-9f9d-3913f893f43d",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "interpret",
                    "text": "Dashboard is live, interpret delta stability",
                    "requiresItems": [
                        {
                            "id": "c377a2ff-1391-4ad8-a150-1e4531067406",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "interpret",
            "text": "Interpret before closing: pass only if delta-T stays in the 3-8\u00b0C band during a steady cycle and drift remains within \u00b11.5\u00b0C. Outside that range usually means trapped air, flow imbalance, or a slipping probe.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Delta stayed stable and in range",
                    "requiresItems": [
                        {
                            "id": "c377a2ff-1391-4ad8-a150-1e4531067406",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "corrective",
                    "text": "Delta is unstable or out of bounds"
                }
            ]
        },
        {
            "id": "corrective",
            "text": "Recovery loop: isolate the pump, bleed trapped air, and reseat both probes against cleaned contact points. Rebuild the paired trace before interpretation so we do not approve stale evidence.",
            "options": [
                {
                    "type": "goto",
                    "goto": "retest",
                    "text": "Corrective maintenance complete"
                }
            ]
        },
        {
            "id": "retest",
            "text": "Run a fresh paired capture after corrective work. This retest trace is mandatory before you can re-interpret the delta.",
            "options": [
                {
                    "type": "process",
                    "process": "capture-hourly-temperature-log",
                    "text": "Capture post-correction paired trace",
                    "requiresItems": [
                        {
                            "id": "e62dca47-fba6-4ad5-abd4-95dd41f5f4c2",
                            "count": 1
                        },
                        {
                            "id": "b6fc1ed6-f399-4fdb-9f9d-3913f893f43d",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "interpret-retest",
                    "text": "Corrective trace logged, move to re-interpretation",
                    "requiresItems": [
                        {
                            "id": "d06c9f8d-6553-4f3c-9e10-05e1cf33a6b8",
                            "count": 2
                        }
                    ]
                }
            ]
        },
        {
            "id": "interpret-retest",
            "text": "Re-check pass bounds with the corrective trace: only approve if delta-T is 3-8\u00b0C with drift within \u00b11.5\u00b0C over a full steady cycle.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Corrective trace passed",
                    "requiresItems": [
                        {
                            "id": "d06c9f8d-6553-4f3c-9e10-05e1cf33a6b8",
                            "count": 3
                        },
                        {
                            "id": "c377a2ff-1391-4ad8-a150-1e4531067406",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "corrective",
                    "text": "Still out of range, repeat corrective loop"
                }
            ]
        },
        {
            "id": "finish",
            "text": "Pin that delta-T dashboard to your maintenance list. Trends will call out air in the loop or fouled exchangers long before you feel it indoors.",
            "options": [
                {
                    "type": "finish",
                    "text": "Delta is monitored",
                    "requiresItems": [
                        {
                            "id": "c377a2ff-1391-4ad8-a150-1e4531067406",
                            "count": 1
                        }
                    ]
                }
            ]
        }
    ],
