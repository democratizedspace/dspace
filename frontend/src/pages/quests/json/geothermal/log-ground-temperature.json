{
    "id": "geothermal/log-ground-temperature",
    "title": "Log Ground Temperature",
    "description": "Capture a 24-hour buried baseline, classify anomalies, and verify corrections before closing.",
    "image": "/assets/quests/geothermal_log_ground_temperature_arduino.jpg",
    "npc": "/assets/npc/orion.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Tie back hair, don gloves, and mark where utilities run before you dig. Want to log a clean ground temperature baseline?",
            "options": [
                {
                    "type": "goto",
                    "goto": "prep",
                    "text": "Site is marked and safe."
                }
            ]
        },
        {
            "id": "prep",
            "text": "Dust and moisture kill logs. Weatherproof the thermistor leads, leave a drip loop, and tape the USB connector so soil can't wick water inside.",
            "options": [
                {
                    "type": "goto",
                    "goto": "bury",
                    "text": "Logger is built and sealed",
                    "process": "assemble-thermistor-logger"
                },
                {
                    "type": "goto",
                    "goto": "bury",
                    "text": "Rig is already sealed",
                    "requiresItems": [
                        {
                            "id": "e62dca47-fba6-4ad5-abd4-95dd41f5f4c2",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "bury",
            "text": "Dig to 1 m, tamp the probe against undisturbed soil, and backfill tight so air pockets don't skew readings. Let's capture a full-day baseline.",
            "options": [
                {
                    "type": "process",
                    "process": "capture-hourly-temperature-log",
                    "text": "Start a buried 24 h log",
                    "requiresItems": [
                        {
                            "id": "e62dca47-fba6-4ad5-abd4-95dd41f5f4c2",
                            "count": 1
                        },
                        {
                            "id": "b6fc1ed6-f399-4fdb-9f9d-3913f893f43d",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "chart",
                    "text": "Baseline log exported",
                    "requiresItems": [
                        {
                            "id": "d06c9f8d-6553-4f3c-9e10-05e1cf33a6b8",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "chart",
            "text": "Plot the buried probe data and mark sunrise, irrigation, or rain so you know which blips are weather and which are loop effects.",
            "options": [
                {
                    "type": "process",
                    "process": "plot-temperature-data",
                    "text": "Plot the baseline curve",
                    "requiresItems": [
                        {
                            "id": "d06c9f8d-6553-4f3c-9e10-05e1cf33a6b8",
                            "count": 1
                        },
                        {
                            "id": "b6fc1ed6-f399-4fdb-9f9d-3913f893f43d",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "process",
                    "process": "refine-temperature-graph",
                    "text": "Annotate weather notes",
                    "requiresItems": [
                        {
                            "id": "e7d1cd7d-e014-43a1-b1c8-9b7fb39deeed",
                            "count": 1
                        },
                        {
                            "id": "b6fc1ed6-f399-4fdb-9f9d-3913f893f43d",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "evaluate",
                    "text": "Baseline chart saved",
                    "requiresItems": [
                        {
                            "id": "50360fd0-e296-4ef8-a3a9-00e049318166",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "evaluate",
            "text": "Pass criteria: overnight drift stays within ±1.5°C and anomaly notes explain every spike. Does your chart satisfy that baseline standard?",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Yes, baseline is stable and explained",
                    "requiresItems": [
                        {
                            "id": "50360fd0-e296-4ef8-a3a9-00e049318166",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "recheck",
                    "text": "No, drift or unexplained spikes remain"
                }
            ]
        },
        {
            "id": "recheck",
            "text": "Anomaly branch: re-seat probe depth, pack soil to remove air gaps, and verify weather notes before rerunning the 24-hour capture.",
            "options": [
                {
                    "type": "goto",
                    "goto": "bury",
                    "text": "Corrections applied, rerun baseline capture"
                },
                {
                    "type": "goto",
                    "goto": "start",
                    "text": "Restart from utility marking and safety prep"
                }
            ]
        },
        {
            "id": "finish",
            "text": "Store that baseline plot with soil type, depth, and pass/fail notes. It'll anchor every seasonal check and heat-pump sizing run that follows.",
            "options": [
                {
                    "type": "finish",
                    "text": "Ground curve logged",
