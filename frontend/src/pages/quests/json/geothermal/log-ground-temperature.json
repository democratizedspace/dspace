{
    "id": "geothermal/log-ground-temperature",
    "title": "Log Ground Temperature",
    "description": "Use a buried thermistor with Arduino to monitor ground temperature over time.",
    "image": "/assets/quests/geothermal_log_ground_temperature_arduino.jpg",
    "npc": "/assets/npc/orion.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Tie back hair, don gloves, and mark utility lines before digging. Ready to capture a defensible baseline log?",
            "options": [
                {
                    "type": "goto",
                    "goto": "prep",
                    "text": "Site is marked and safe."
                }
            ]
        },
        {
            "id": "prep",
            "text": "Weatherproof thermistor leads, add a drip loop, and seal connectors so moisture cannot corrupt the run.",
            "options": [
                {
                    "type": "goto",
                    "goto": "bury",
                    "text": "Logger is built and sealed",
                    "process": "assemble-thermistor-logger"
                },
                {
                    "type": "goto",
                    "goto": "bury",
                    "text": "Rig is already sealed",
                    "requiresItems": [
                        {
                            "id": "e62dca47-fba6-4ad5-abd4-95dd41f5f4c2",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "bury",
            "text": "Bury probe at 1 m, tamp soil tight, and start a 24 h log at hourly cadence. Target drift is \u22642\u00b0C across adjacent readings.",
            "options": [
