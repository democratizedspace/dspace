{
    "id": "geothermal/log-ground-temperature",
    "title": "Log Ground Temperature",
    "description": "Produce an annotated baseline log with explicit cadence and anomaly-handling before closing the task.",
    "image": "/assets/quests/geothermal_log_ground_temperature_arduino.jpg",
    "npc": "/assets/npc/orion.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Tie back hair, glove up, and confirm utility marks before digging. Ready to capture a baseline we can compare month to month?",
            "options": [
                {
                    "type": "goto",
                    "goto": "prep",
                    "text": "Site is marked and safe"
                },
                {
                    "type": "goto",
                    "goto": "prep",
                    "text": "Review the safety prep checklist"
                }
            ]
        },
        {
            "id": "prep",
            "text": "Weatherproof the thermistor leads, leave a drip loop, and seal the USB end. A leaky harness invalidates long-run data.",
            "options": [
                {
                    "type": "process",
                    "process": "assemble-thermistor-logger",
                    "text": "Assemble and seal logging rig"
                },
                {
                    "type": "goto",
                    "goto": "bury",
                    "text": "Rig is already sealed",
                    "requiresItems": [
                        {
                            "id": "e62dca47-fba6-4ad5-abd4-95dd41f5f4c2",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "bury",
            "text": "Bury at 1 m in undisturbed soil and log hourly for 24 h. Required fields: timestamp, temp, weather note, soil moisture note, and probe depth.",
            "options": [
                {
                    "type": "process",
                    "process": "capture-hourly-temperature-log",
                    "text": "Capture buried 24 h log",
                    "requiresItems": [
                        {
                            "id": "e62dca47-fba6-4ad5-abd4-95dd41f5f4c2",
                            "count": 1
                        },
                        {
                            "id": "b6fc1ed6-f399-4fdb-9f9d-3913f893f43d",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "analyze",
                    "text": "Baseline log exported",
                    "requiresItems": [
                        {
                            "id": "d06c9f8d-6553-4f3c-9e10-05e1cf33a6b8",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "analyze",
            "text": "Pass window for this baseline: daily swing <=2°C and no unexplained spikes >1°C in consecutive samples. Annotate every suspect segment before classifying.",
            "options": [
                {
                    "type": "process",
                    "process": "plot-temperature-data",
                    "text": "Plot baseline curve",
                    "requiresItems": [
                        {
                            "id": "d06c9f8d-6553-4f3c-9e10-05e1cf33a6b8",
                            "count": 1
                        },
                        {
                            "id": "b6fc1ed6-f399-4fdb-9f9d-3913f893f43d",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "process",
                    "process": "refine-temperature-graph",
                    "text": "Annotate weather and irrigation events",
                    "requiresItems": [
                        {
                            "id": "e7d1cd7d-e014-43a1-b1c8-9b7fb39deeed",
                            "count": 1
                        },
                        {
                            "id": "b6fc1ed6-f399-4fdb-9f9d-3913f893f43d",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Annotated log meets baseline thresholds",
                    "requiresItems": [
                        {
                            "id": "50360fd0-e296-4ef8-a3a9-00e049318166",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "anomaly",
                    "text": "Spikes or drift need investigation"
                }
            ]
        },
        {
            "id": "anomaly",
            "text": "Classify anomaly source (probe depth shift, moisture ingress, or weather burst), apply one correction, then run a fresh 24 h window before closure.",
            "options": [
                {
                    "type": "goto",
                    "goto": "bury",
                    "text": "Correction applied, capture a follow-up log"
                },
                {
                    "type": "goto",
                    "goto": "start",
                    "text": "Pause and repeat safety setup"
                }
            ]
        },
        {
            "id": "finish",
            "text": "Archive the annotated baseline with depth, soil type, and weather context. That gives operations a repeatable monitor for seasonal drift.",
            "options": [
                {
                    "type": "finish",
                    "text": "Ground baseline logged",
                    "requiresItems": [
                        {
                            "id": "50360fd0-e296-4ef8-a3a9-00e049318166",
                            "count": 1
                        }
                    ]
                }
            ]
        }
