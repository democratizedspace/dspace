{
    "id": "geothermal/check-loop-outlet-temp",
    "title": "Check Loop Outlet Temperature",
    "description": "Log the water temperature leaving the heat pump, apply pass/fail bounds, and recover from unstable traces.",
    "image": "/assets/quests/geothermal_check_loop_outlet_temp_arduino.jpg",
    "npc": "/assets/npc/orion.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Outlet lines run warmer and wetter than inlet. Kill power before touching fittings, glove up, and stage towels so we can log safely.",
            "options": [
                {
                    "type": "goto",
                    "goto": "reposition",
                    "text": "Safety checks complete, begin outlet setup."
                },
                {
                    "type": "goto",
                    "goto": "reposition",
                    "text": "Rig is already staged on the outlet",
                    "requiresItems": [
                        {
                            "id": "e62dca47-fba6-4ad5-abd4-95dd41f5f4c2",
                            "count": 1
                        },
                        {
                            "id": "d06c9f8d-6553-4f3c-9e10-05e1cf33a6b8",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "reposition",
            "text": "Strap the thermistor at the outlet barb, insulate leads from condensation, and purge one minute to clear bubbles before logging.",
            "options": [
                {
                    "type": "process",
                    "process": "capture-hourly-temperature-log",
                    "text": "Log the outlet run",
                    "requiresItems": [
                        {
                            "id": "e62dca47-fba6-4ad5-abd4-95dd41f5f4c2",
                            "count": 1
                        },
                        {
                            "id": "b6fc1ed6-f399-4fdb-9f9d-3913f893f43d",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "interpret",
                    "text": "Outlet trace captured",
                    "requiresItems": [
                        {
                            "id": "d06c9f8d-6553-4f3c-9e10-05e1cf33a6b8",
                            "count": 2
                        }
                    ]
                }
            ]
        },
        {
            "id": "interpret",
            "text": "Interpret before publish: pass when outlet remains 28-45°C and drift is under ±2°C during a steady pump cycle. Any sharp sawtooth usually means bad contact or trapped air.",
            "options": [
                {
                    "type": "goto",
                    "goto": "stream",
                    "text": "Trace is in range and stable",
                    "requiresItems": [
                        {
                            "id": "d06c9f8d-6553-4f3c-9e10-05e1cf33a6b8",
                            "count": 2
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "corrective",
                    "text": "Out-of-range or unstable, run corrective loop"
                }
            ]
        },
        {
            "id": "corrective",
            "text": "Recovery path: reseat the probe, dry connectors, and bleed trapped air from the outlet section. Then repeat a full outlet logging pass before re-evaluating.",
            "options": [
                {
                    "type": "goto",
                    "goto": "reposition-retest",
                    "text": "Corrective steps done, re-log outlet trace."
                }
            ]
        },
        {
            "id": "reposition-retest",
            "text": "Run a fresh outlet capture after corrective work so the interpretation step uses post-fix evidence, not the earlier trace.",
            "options": [
                {
                    "type": "process",
                    "process": "capture-hourly-temperature-log",
                    "text": "Log corrective outlet run",
                    "requiresItems": [
                        {
                            "id": "e62dca47-fba6-4ad5-abd4-95dd41f5f4c2",
                            "count": 1
                        },
                        {
                            "id": "b6fc1ed6-f399-4fdb-9f9d-3913f893f43d",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "interpret-retest",
                    "text": "Corrective trace captured",
                    "requiresItems": [
                        {
                            "id": "d06c9f8d-6553-4f3c-9e10-05e1cf33a6b8",
                            "count": 3
                        }
                    ]
                }
            ]
        },
        {
            "id": "interpret-retest",
            "text": "Re-interpret using the fresh corrective capture: pass only if outlet stays 28-45°C with drift under ±2°C during a steady cycle.",
            "options": [
                {
                    "type": "goto",
                    "goto": "stream",
                    "text": "Corrective trace is now stable and in range",
                    "requiresItems": [
                        {
                            "id": "d06c9f8d-6553-4f3c-9e10-05e1cf33a6b8",
                            "count": 3
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "corrective",
                    "text": "Still unstable, run another corrective loop"
                }
            ]
        },
        {
            "id": "stream",
            "text": "Now deploy the outlet stream. Export JSON and compare against inlet history so maintenance alerts can catch fouling early.",
            "options": [
                {
                    "type": "process",
                    "process": "deploy-temperature-json-endpoint",
                    "text": "Publish the outlet endpoint",
                    "requiresItems": [
                        {
                            "id": "e62dca47-fba6-4ad5-abd4-95dd41f5f4c2",
                            "count": 1
                        },
                        {
                            "id": "d06c9f8d-6553-4f3c-9e10-05e1cf33a6b8",
                            "count": 1
                        },
                        {
                            "id": "ce140453-c7ef-42c9-b9f9-38acfb4219cf",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Endpoint is live",
                    "requiresItems": [
                        {
                            "id": "f763cb7d-4e1a-4146-b304-4d8bfde4df86",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "finish",
            "text": "Great! With a validated outlet trace plus live endpoint, you can spot drift early and plan maintenance before efficiency tanks.",
            "options": [
                {
                    "type": "finish",
                    "text": "Outlet stream validated",
                    "requiresItems": [
                        {
                            "id": "f763cb7d-4e1a-4146-b304-4d8bfde4df86",
                            "count": 1
                        }
                    ]
                }
            ]
        }
    ],
    "rewards": [
