{
    "id": "geothermal/check-loop-outlet-temp",
    "title": "Check Loop Outlet Temperature",
    "description": "Log the water temperature leaving the heat pump with an Arduino thermistor.",
    "image": "/assets/quests/geothermal_check_loop_outlet_temp_arduino.jpg",
    "npc": "/assets/npc/orion.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Outlet lines run warmer and wetter. Kill power, put on gloves, and have towels ready. Ready to move the probe to the outlet side?",
            "options": [
                {
                    "type": "goto",
                    "goto": "reposition",
                    "text": "Pump is safe to touch."
                },
                {
                    "type": "goto",
                    "goto": "reposition",
                    "text": "Rig is already staged on the outlet",
                    "requiresItems": [
                        {
                            "id": "e62dca47-fba6-4ad5-abd4-95dd41f5f4c2",
                            "count": 1
                        },
                        {
                            "id": "d06c9f8d-6553-4f3c-9e10-05e1cf33a6b8",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "reposition",
            "text": "Strap the thermistor at the outlet barb, insulate the leads from condensation, and purge a minute to clear bubbles before logging.",
            "options": [
                {
                    "type": "process",
                    "process": "capture-hourly-temperature-log",
                    "text": "Log the outlet run",
                    "requiresItems": [
                        {
                            "id": "e62dca47-fba6-4ad5-abd4-95dd41f5f4c2",
                            "count": 1
                        },
                        {
                            "id": "b6fc1ed6-f399-4fdb-9f9d-3913f893f43d",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "evaluate",
                    "text": "Outlet trace captured",
                    "requiresItems": [
                        {
                            "id": "d06c9f8d-6553-4f3c-9e10-05e1cf33a6b8",
                            "count": 2
                        }
                    ]
                }
            ]
        },
        {
            "id": "evaluate",
            "text": "Read the captured trace before publishing anything: target a steady 8-15\u00b0C outlet window with less than \u00b11\u00b0C swing over the sample. If it misses, hold deployment and diagnose first.",
            "options": [
                {
                    "type": "goto",
                    "goto": "stream",
                    "text": "Trace is in range and stable",
                    "requiresItems": [
                        {
                            "id": "d06c9f8d-6553-4f3c-9e10-05e1cf33a6b8",
                            "count": 2
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "corrective",
                    "text": "Trace is drifting or out of range",
                    "requiresItems": [
                        {
                            "id": "d06c9f8d-6553-4f3c-9e10-05e1cf33a6b8",
                            "count": 2
                        }
                    ]
                }
            ]
        },
        {
            "id": "corrective",
            "text": "Pause the stream rollout. Check insulation, reseat the probe, and bleed trapped air before another run. If lines are too hot to handle safely, power down and wait before retrying.",
            "options": [
                {
                    "type": "process",
                    "process": "capture-hourly-temperature-log",
                    "text": "Run a corrective re-log",
                    "requiresItems": [
                        {
                            "id": "e62dca47-fba6-4ad5-abd4-95dd41f5f4c2",
                            "count": 1
                        },
                        {
                            "id": "b6fc1ed6-f399-4fdb-9f9d-3913f893f43d",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "evaluate",
                    "text": "Corrective trace captured; re-evaluate",
                    "requiresItems": [
                        {
                            "id": "d06c9f8d-6553-4f3c-9e10-05e1cf33a6b8",
                            "count": 3
                        }
                    ]
                }
            ]
        },
        {
            "id": "stream",
            "text": "Let's keep that outlet temp live. Drop the logger on a Pi, export JSON, and sanity check against the inlet graph before you leave.",
            "options": [
                {
                    "type": "process",
                    "process": "deploy-temperature-json-endpoint",
                    "text": "Publish the outlet endpoint",
                    "requiresItems": [
                        {
                            "id": "e62dca47-fba6-4ad5-abd4-95dd41f5f4c2",
                            "count": 1
                        },
                        {
                            "id": "d06c9f8d-6553-4f3c-9e10-05e1cf33a6b8",
                            "count": 1
                        },
                        {
                            "id": "ce140453-c7ef-42c9-b9f9-38acfb4219cf",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Endpoint is live",
                    "requiresItems": [
                        {
                            "id": "f763cb7d-4e1a-4146-b304-4d8bfde4df86",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "finish",
            "text": "Great! With a live outlet feed you can watch flow, compare to inlet plots, and spot fouling before it tanks efficiency.",
            "options": [
                {
                    "type": "finish",
                    "text": "Outlet stream pinned",
                    "requiresItems": [
                        {
                            "id": "f763cb7d-4e1a-4146-b304-4d8bfde4df86",
                            "count": 1
                        }
                    ]
                }
            ]
        }
    ],
