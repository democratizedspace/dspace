{
    "id": "geothermal/check-loop-outlet-temp",
    "title": "Check Loop Outlet Temperature",
    "description": "Log outlet temperature, validate it against operating bounds, and recover safely when readings drift.",
    "image": "/assets/quests/geothermal_check_loop_outlet_temp_arduino.jpg",
    "npc": "/assets/npc/orion.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Outlet lines run warmer and wetter. Kill power, put on gloves, and keep towels staged before touching fittings. Ready to baseline outlet temperature?",
            "options": [
                {
                    "type": "goto",
                    "goto": "reposition",
                    "text": "Safety lockout is complete"
                },
                {
                    "type": "goto",
                    "goto": "reposition",
                    "text": "Walk me through the outlet-side safety check"
                }
            ]
        },
        {
            "id": "reposition",
            "text": "Strap the thermistor at the outlet barb, insulate the leads from condensation, and purge briefly to clear bubbles before you log.",
            "options": [
                {
                    "type": "process",
                    "process": "capture-hourly-temperature-log",
                    "text": "Capture an outlet temperature run",
                    "requiresItems": [
                        {
                            "id": "e62dca47-fba6-4ad5-abd4-95dd41f5f4c2",
                            "count": 1
                        },
                        {
                            "id": "b6fc1ed6-f399-4fdb-9f9d-3913f893f43d",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "interpret",
                    "text": "Outlet log captured",
                    "requiresItems": [
                        {
                            "id": "d06c9f8d-6553-4f3c-9e10-05e1cf33a6b8",
                            "count": 2
                        }
                    ]
                }
            ]
        },
        {
            "id": "interpret",
            "text": "Interpret the run: stable outlet temperatures in the expected band pass. Spikes, drops, or drift suggest trapped air, poor insulation, or flow instability.",
            "options": [
                {
                    "type": "goto",
                    "goto": "publish",
                    "text": "Readings are in range and stable"
                },
                {
                    "type": "goto",
                    "goto": "corrective",
                    "text": "Readings are unstable or out of range"
                }
            ]
        },
        {
            "id": "corrective",
            "text": "Recovery path: reseat the probe, dry/rewrap insulation, and re-check purge flow. If moisture is uncontrolled or fittings seep, stop and re-lockout before retrying.",
            "options": [
                {
                    "type": "goto",
                    "goto": "reposition",
                    "text": "Apply corrections and capture another run"
                },
                {
                    "type": "goto",
                    "goto": "start",
                    "text": "Pause and redo lockout before another attempt"
                }
            ]
        },
        {
            "id": "publish",
            "text": "Publish the verified outlet feed and keep the JSON endpoint available so inlet/outlet comparisons stay reproducible.",
            "options": [
                {
                    "type": "process",
                    "process": "deploy-temperature-json-endpoint",
                    "text": "Publish the outlet endpoint",
                    "requiresItems": [
                        {
                            "id": "e62dca47-fba6-4ad5-abd4-95dd41f5f4c2",
                            "count": 1
                        },
                        {
                            "id": "d06c9f8d-6553-4f3c-9e10-05e1cf33a6b8",
                            "count": 2
                        },
                        {
                            "id": "ce140453-c7ef-42c9-b9f9-38acfb4219cf",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Endpoint is live",
                    "requiresItems": [
                        {
                            "id": "f763cb7d-4e1a-4146-b304-4d8bfde4df86",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "finish",
            "text": "Great work. Record the timestamp, outdoor conditions, and outlet average so drift investigations start from a trusted baseline.",
            "options": [
                {
                    "type": "finish",
                    "text": "Outlet temperature verified",
