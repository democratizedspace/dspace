{
    "id": "geothermal/check-loop-outlet-temp",
    "title": "Check Loop Outlet Temperature",
    "description": "Log outlet temperature, evaluate against explicit limits, and close only after any corrective retest passes.",
    "image": "/assets/quests/geothermal_check_loop_outlet_temp_arduino.jpg",
    "npc": "/assets/npc/orion.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Outlet lines run warmer and wetter. Lock out mains power, towel up condensation points, and wear insulated gloves before touching fittings.",
            "options": [
                {
                    "type": "goto",
                    "goto": "reposition",
                    "text": "Safety checks are complete"
                },
                {
                    "type": "goto",
                    "goto": "reposition",
                    "text": "Rig is already staged on the outlet",
                    "requiresItems": [
                        {
                            "id": "e62dca47-fba6-4ad5-abd4-95dd41f5f4c2",
                            "count": 1
                        },
                        {
                            "id": "d06c9f8d-6553-4f3c-9e10-05e1cf33a6b8",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "reposition",
            "text": "Strap the thermistor to the outlet barb, insulate the leads from drips, purge one minute, then capture a stable run.",
            "options": [
                {
                    "type": "process",
                    "process": "capture-hourly-temperature-log",
                    "text": "Capture the outlet trace",
                    "requiresItems": [
                        {
                            "id": "e62dca47-fba6-4ad5-abd4-95dd41f5f4c2",
                            "count": 1
                        },
                        {
                            "id": "b6fc1ed6-f399-4fdb-9f9d-3913f893f43d",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "plot",
                    "text": "Outlet trace captured",
                    "requiresItems": [
                        {
                            "id": "d06c9f8d-6553-4f3c-9e10-05e1cf33a6b8",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "plot",
            "text": "Plot the outlet run and annotate any spikes at compressor start. We need an interpretable chart before evaluating limits.",
            "options": [
                {
                    "type": "process",
                    "process": "plot-temperature-data",
                    "text": "Plot the outlet trace",
                    "requiresItems": [
                        {
                            "id": "d06c9f8d-6553-4f3c-9e10-05e1cf33a6b8",
                            "count": 1
                        },
                        {
                            "id": "b6fc1ed6-f399-4fdb-9f9d-3913f893f43d",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "evaluate",
                    "text": "Chart reviewed",
                    "requiresItems": [
                        {
                            "id": "e7d1cd7d-e014-43a1-b1c8-9b7fb39deeed",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "evaluate",
            "text": "Acceptance band is 25-45°C with oscillation no greater than ±2°C once flow stabilizes. Does your chart meet those bounds?",
            "options": [
                {
                    "type": "goto",
                    "goto": "stream",
                    "text": "Yes, outlet trend is in range",
                    "requiresItems": [
                        {
                            "id": "e7d1cd7d-e014-43a1-b1c8-9b7fb39deeed",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "corrective",
                    "text": "No, outlet trend is out of range"
                }
            ]
        },
        {
            "id": "corrective",
            "text": "Pause and troubleshoot: reseat probe insulation, bleed microbubbles, and verify pump speed setpoint before retesting.",
            "options": [
                {
                    "type": "goto",
                    "goto": "reposition",
                    "text": "Corrective actions complete; retake the outlet trace",
                    "requiresItems": [
                        {
                            "id": "e62dca47-fba6-4ad5-abd4-95dd41f5f4c2",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "stream",
            "text": "Publish the validated outlet feed on the Pi so later quests can compare inlet/outlet behavior continuously.",
            "options": [
                {
                    "type": "process",
                    "process": "deploy-temperature-json-endpoint",
                    "text": "Publish the outlet endpoint",
                    "requiresItems": [
