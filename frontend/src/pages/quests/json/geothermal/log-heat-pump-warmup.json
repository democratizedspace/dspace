                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "stage",
                    "text": "Give me the staging checklist"
                }
            ]
        },
        {
            "id": "stage",
            "text": "Run from cold start and capture 15 minutes of outlet rise. Required log fields: timestamp, outlet temp, ambient temp, pump mode, and compressor state.",
            "options": [
                {
                    "type": "process",
                    "process": "capture-hourly-temperature-log",
                    "text": "Capture warmup trace",
                    "requiresItems": [
                        {
                            "id": "e62dca47-fba6-4ad5-abd4-95dd41f5f4c2",
                            "count": 1
                        },
                        {
                            "id": "b6fc1ed6-f399-4fdb-9f9d-3913f893f43d",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "analyze",
                    "text": "Warmup log exported",
                    "requiresItems": [
                        {
                            "id": "d06c9f8d-6553-4f3c-9e10-05e1cf33a6b8",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "analyze",
            "text": "Pass criteria: outlet rise reaches at least 4°C in the first 15 minutes and settles without more than 1°C oscillation over the final 5 minutes.",
            "options": [
                {
                    "type": "process",
                    "process": "plot-temperature-data",
                    "text": "Plot and inspect warmup curve",
                    "requiresItems": [
                        {
                            "id": "d06c9f8d-6553-4f3c-9e10-05e1cf33a6b8",
