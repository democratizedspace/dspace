                            "count": 1
                        }
                    ]
                },
                {
                    "type": "process",
                    "process": "refine-temperature-graph",
                    "text": "Annotate compressor ramp and settle window",
                    "requiresItems": [
                        {
                            "id": "e7d1cd7d-e014-43a1-b1c8-9b7fb39deeed",
                            "count": 1
                        },
                        {
                            "id": "b6fc1ed6-f399-4fdb-9f9d-3913f893f43d",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Curve meets threshold and annotations are saved",
                    "requiresItems": [
