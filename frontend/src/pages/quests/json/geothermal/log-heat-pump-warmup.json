            "id": "anomaly",
            "text": "Classify anomaly: slow rise suggests low flow/air, high oscillation suggests control tuning, and flat lines suggest sensor faults. Apply one corrective action, then re-log.",
            "options": [
                {
                    "type": "goto",
                    "goto": "stage",
                    "text": "Corrective action applied, collect a new trace",
                    "requiresItems": [
