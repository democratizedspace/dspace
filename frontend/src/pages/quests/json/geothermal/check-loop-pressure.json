            "options": [
                {
                    "type": "process",
                    "process": "attach-loop-pressure-gauge",
                    "text": "Attach the gauge and purge the port"
                },
                {
                    "type": "goto",
                    "goto": "hold",
                    "text": "Gauge is on and lines are tight.",
