            ]
        },
        {
            "id": "finish",
            "text": "Routine pressure logs catch slow leaks long before heat output tanks.",
            "options": [
                {
                    "type": "finish",
                    "text": "I'll keep monitoring."
                }
            ]
        }
    ],
