            ]
        },
        {
            "id": "hold",
            "text": "Hold the loop fifteen minutes, watch for drift, then log the number.",
            "options": [
                {
                    "type": "process",
                    "process": "log-loop-pressure",
                    "text": "Record the loop pressure hold"
                },
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Log entry saved with timestamp.",
