{
    "id": "rocketry/parachute",
    "title": "Add a parachute",
    "description": "Install and validate a parachute recovery system with safety checks, verification evidence, and retry paths.",
    "image": "/assets/quests/model_rocket_parachute_installation.jpg",
    "npc": "/assets/npc/nova.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Your first launch proved the design. Now let's make it reusable by installing a parachute system and proving it works under controlled checks.",
            "options": [
                {
                    "type": "goto",
                    "goto": "inventory-check",
                    "text": "Let's run the install checklist."
                }
            ]
        },
        {
            "id": "inventory-check",
            "text": "Gather the launch-capable rocket, parachute, Kevlar shock cord, harness kit, and flame-resistant wadding. Motor stays out during install.",
            "options": [
                {
                    "type": "goto",
                    "goto": "install",
                    "text": "All parts staged and motor removed.",
                    "requiresItems": [
                        {
                            "id": "aaa5fbca-54a1-40a5-8461-24dc2ef81d4d",
                            "count": 1
                        },
                        {
                            "id": "80a83ecc-bcd2-400e-a469-8488a6453bb8",
                            "count": 1
                        },
                        {
                            "id": "0484a3ab-92e7-42fa-a5e6-25a4afe841d6",
                            "count": 1
                        },
                        {
                            "id": "9477a618-591b-45e0-9d81-18d60b848490",
                            "count": 1
                        },
                        {
                            "id": "84324403-0bd8-411a-b575-a3c966c8a73e",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "troubleshoot-install",
                    "text": "Missing parts or unclear fit. Troubleshoot before installation."
                }
            ]
        },
        {
            "id": "install",
            "text": "Run the install process and seat the harness so the chute can deploy without snagging.",
            "options": [
                {
                    "type": "process",
                    "process": "assemble-rocket-parachute",
                    "text": "Assemble parachute recovery stack."
                },
                {
                    "type": "goto",
                    "goto": "verify-install",
                    "text": "Install complete. Verify continuity and packing.",
                    "requiresItems": [
                        {
                            "id": "e9123658-fb2b-4fb2-bfc4-9eaeebddf3ec",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "verify-install",
            "text": "Verification gate: check knot security, chute fold, and body-tube clearance. If any bind appears, do not arm for launch.",
            "options": [
                {
                    "type": "goto",
                    "goto": "safety-brief",
                    "text": "Verification passed. Proceed to launch safety brief."
                },
                {
                    "type": "goto",
                    "goto": "troubleshoot-install",
                    "text": "Snag or loose knot found. Rework the install."
                }
            ]
        },
        {
            "id": "safety-brief",
            "text": "Safety branch: keep bystanders 5 m away, verify launch controller continuity, and confirm an abort caller before ignition.",
            "options": [
                {
                    "type": "goto",
                    "goto": "launch",
                    "text": "Safety brief complete and range is clear."
                },
                {
                    "type": "goto",
                    "goto": "hold",
                    "text": "Range not ready. Hold and reset the launch lane."
                }
            ]
        },
        {
            "id": "launch",
            "text": "Run a controlled launch to validate deployment. Track canopy opening and touchdown behavior.",
            "options": [
                {
                    "type": "process",
                    "process": "launch-rocket-parachute",
                    "text": "Execute parachute validation launch."
                },
                {
                    "type": "goto",
                    "goto": "assess",
                    "text": "Flight complete. Assess recovery outcome.",
                    "requiresItems": [
                        {
                            "id": "eb9c2a75-a87a-4171-8bc3-088e75936bcf",
                            "count": 2
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "troubleshoot-install",
                    "text": "Deployment looked unstable. Return to troubleshooting."
                }
            ]
        },
        {
            "id": "assess",
            "text": "Outcome gate: pass only when descent was controlled and no recovery hardware damage appears. Otherwise repair and re-test.",
            "options": [
                {
                    "type": "goto",
                    "goto": "success",
                    "text": "Descent and hardware condition both passed."
                },
                {
                    "type": "goto",
                    "goto": "troubleshoot-install",
                    "text": "Recovery failed checks. Repack and run another validation launch."
                }
            ]
        },
        {
            "id": "troubleshoot-install",
            "text": "Troubleshooting/recovery loop: replace scorched wadding, loosen chute folds, and re-seat the harness anchor before rerunning verification.",
            "options": [
                {
                    "type": "goto",
                    "goto": "inventory-check",
                    "text": "Corrections done. Restart checklist from inventory gate."
                }
            ]
        },
        {
            "id": "hold",
            "text": "Hold acknowledged. Keep igniter disconnected and maintain cold motor handling until range control confirms safe conditions.",
            "options": [
                {
                    "type": "goto",
                    "goto": "safety-brief",
                    "text": "Conditions corrected. Resume safety brief."
                }
            ]
        },
        {
            "id": "success",
            "text": "Excellent work. You installed, verified, and flight-tested the parachute system with a real corrective path.",
            "options": [
                {
                    "type": "finish",
                    "text": "Parachute recovery system validated."
                }
            ]
        }
    ],
