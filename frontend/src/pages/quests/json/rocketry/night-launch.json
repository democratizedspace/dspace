{
    "id": "rocketry/night-launch",
    "title": "Night Launch",
    "description": "Take your rocket experience to the stars with a night launch. Gather your gear and light up the sky.",
    "image": "/assets/quests/model_rocket_night_launch.jpg",
    "npc": "/assets/npc/nova.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Night ops can be gorgeous, but they punish sloppy prep. We'll run this launch like a checklist discipline drill.",
            "options": [
                {
                    "type": "goto",
                    "goto": "range-brief",
                    "text": "I'm in. Walk me through the plan."
                }
            ]
        },
        {
            "id": "range-brief",
            "text": "First gate: range lighting, perimeter markers, and a clear recovery lane. If visibility is weak, we hold.",
            "options": [
                {
                    "type": "goto",
                    "goto": "prep",
                    "text": "Range lights and markers are set."
                },
                {
                    "type": "goto",
                    "goto": "hold",
                    "text": "Visibility is sketchy. Initiate hold."
                }
            ]
        },
        {
            "id": "hold",
            "text": "Good call. Night launch abort criteria matter: no countdown until observers can track ascent and descent end-to-end.",
            "options": [
                {
                    "type": "goto",
                    "goto": "range-brief",
                    "text": "Visibility restored. Resume briefing."
                }
            ]
        },
        {
            "id": "prep",
            "text": "Stage launchpad, controller, igniter, parachute-equipped rocket, plus fresh wadding to protect recovery at night.",
            "options": [
                {
                    "type": "goto",
                    "goto": "checklist",
                    "requiresItems": [
                        {
                            "id": "11d73d3c-aa22-450f-aef2-d6163e34e90d",
                            "count": 1
                        },
                        {
                            "id": "ae343640-c7c0-4f7e-907b-17bd87574d9b",
                            "count": 1
                        },
                        {
                            "id": "d2f3e684-84e2-41f9-b39d-51ee224608ac",
                            "count": 1
                        },
                        {
                            "id": "e9123658-fb2b-4fb2-bfc4-9eaeebddf3ec",
                            "count": 1
                        },
                        {
                            "id": "246a8dca-ed43-490d-8b28-5ab4ab47a792",
                            "count": 1
                        }
                    ],
                    "text": "Night gear staged with recovery consumables."
                }
            ]
        },
        {
            "id": "checklist",
            "text": "Run a dry countdown and continuity check. If the igniter or line-of-sight check fails, branch to troubleshooting before we arm.",
            "options": [
                {
                    "type": "goto",
                    "goto": "launch",
                    "text": "Checklist passed. We are green."
                },
                {
                    "type": "goto",
                    "goto": "troubleshoot",
                    "text": "Continuity or visibility check failed."
                }
            ]
        },
        {
            "id": "troubleshoot",
            "text": "Swap igniter, re-aim launch rod, and relocate the observation spot if glare blocks tracking. Then rerun checklist from the top.",
            "options": [
                {
                    "type": "goto",
                    "goto": "checklist",
                    "text": "Corrections applied. Re-run checklist."
                }
            ]
        },
        {
            "id": "launch",
            "text": "Launch window is open. Keep callouts loud and track the descent arc all the way to touchdown.",
            "options": [
                {
                    "type": "process",
                    "process": "launch-rocket-parachute",
                    "text": "Ignite into the night!"
                },
                {
                    "type": "goto",
                    "goto": "debrief",
                    "requiresItems": [
                        {
                            "id": "e9123658-fb2b-4fb2-bfc4-9eaeebddf3ec",
                            "count": 1
                        },
                        {
                            "id": "eb9c2a75-a87a-4171-8bc3-088e75936bcf",
                            "count": 2
                        }
                    ],
                    "text": "Rocket recovered with confirmed night-flight log."
                }
            ]
        },
        {
            "id": "debrief",
            "text": "Excellent discipline. You launched safely, recovered cleanly, and captured enough data to repeat this under tighter windows.",
            "options": [
                {
                    "type": "finish",
                    "text": "Night launch complete with safety margins intact."
                }
            ]
        }
    ],
    "rewards": [
        {
            "id": "d660dc50-7afb-4a2f-9508-a42490aae5e4",
            "count": 1
        }
    ],
