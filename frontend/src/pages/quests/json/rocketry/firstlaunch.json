{
    "id": "rocketry/firstlaunch",
    "title": "First rocket launch!",
    "description": "Print and launch your own model rocket. Follow the steps to print, assemble, and launch the rocket. Get ready for liftoff!",
    "image": "/assets/quests/firstlaunch.jpg",
    "npc": "/assets/npc/nova.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Nova here. First launch is my favorite. We'll print, assemble, verify, and only then fly.",
            "options": [
                {
                    "type": "goto",
                    "goto": "height",
                    "text": "Let's do it. How high should this training launch go?"
                }
            ]
        },
        {
            "id": "height",
            "text": "About 35 meters in calm air with this config. Wind and prep quality decide whether that flight is clean or chaotic.",
            "options": [
                {
                    "type": "goto",
                    "goto": "paperwork",
                    "text": "Any legal guardrails before we start?"
                }
            ]
        },
        {
            "id": "paperwork",
            "text": "FAA hobby limits apply: under 1500 g total and under 125 g propellant. We stay far below that and use an open launch site.",
            "options": [
                {
                    "type": "goto",
                    "goto": "print",
                    "text": "Great. I'll begin the build."
                }
            ]
        },
        {
            "id": "print",
            "text": "Print four modular parts so failures are cheap: nosecone, body tube, fincan, and coupler.",
            "options": [
                {
                    "type": "goto",
                    "goto": "components",
                    "text": "Queueing the print jobs now."
                }
            ]
        },
        {
            "id": "components",
            "text": "Run each print and confirm no delamination before assembly.",
            "options": [
                {
                    "type": "process",
                    "process": "3dprint-rocket-nosecone",
                    "text": "Print nosecone"
                },
                {
                    "type": "process",
                    "process": "3dprint-rocket-body-tube",
                    "text": "Print body tube"
                },
                {
                    "type": "process",
                    "process": "3dprint-rocket-fincan",
                    "text": "Print fincan"
                },
                {
                    "type": "process",
                    "process": "3dprint-rocket-nosecone-coupler",
                    "text": "Print nosecone coupler"
                },
                {
                    "type": "goto",
                    "goto": "assemble",
                    "requiresItems": [
                        {
                            "id": "7ca9cad5-4bc2-420b-9733-24d1e38c2324",
                            "count": 1
                        },
                        {
                            "id": "1eac8955-bb70-474b-b6b0-4002ff3aa09a",
                            "count": 1
                        },
                        {
                            "id": "563956c2-17d1-4b82-8fce-48b07dc8a71b",
                            "count": 1
                        },
                        {
                            "id": "05c339ee-f50b-419a-804a-341f850b85e9",
                            "count": 1
                        }
                    ],
                    "text": "All four parts printed and inspected."
                }
            ]
        },
        {
            "id": "assemble",
            "text": "Assemble with motor, shock cord, and superglue. Then we'll run a pre-pad verification before any ignition hardware appears.",
            "options": [
                {
                    "type": "process",
                    "process": "assemble-rocket",
                    "text": "Assemble the rocket"
                },
                {
                    "type": "goto",
                    "requiresItems": [
                        {
                            "id": "aaa5fbca-54a1-40a5-8461-24dc2ef81d4d",
                            "count": 1
                        }
                    ],
                    "goto": "verification",
                    "text": "Assembly complete. Start pre-pad verification."
                }
            ]
        },
        {
            "id": "verification",
            "text": "Check fin alignment and shock-cord anchor tension. If either fails, rework now; no launch exceptions.",
            "options": [
                {
                    "type": "goto",
                    "goto": "launch-kit",
                    "text": "Verification passed."
                },
                {
                    "type": "goto",
                    "goto": "repair-loop",
                    "text": "I found glue creep or loose anchor points."
                }
            ]
        },
        {
            "id": "repair-loop",
            "text": "Good catch. Re-seat the coupler, re-glue any weak joints, and re-run assembly checks before proceeding.",
            "options": [
                {
                    "type": "goto",
                    "goto": "assemble",
                    "text": "Repairs done. Return to assembly verification."
                }
            ]
        },
        {
            "id": "launch-kit",
            "text": "Now stage launch gear. You'll need a launch pad, igniter, controller, and printed launch checklist.",
            "options": [
                {
                    "type": "grantsItems",
                    "grantsItems": [
                        {
                            "id": "ae343640-c7c0-4f7e-907b-17bd87574d9b",
                            "count": 1
                        },
                        {
                            "id": "d2f3e684-84e2-41f9-b39d-51ee224608ac",
                            "count": 1
                        },
                        {
                            "id": "11d73d3c-aa22-450f-aef2-d6163e34e90d",
                            "count": 1
                        }
                    ],
                    "text": "I'll issue you fresh launch hardware."
                },
                {
                    "type": "goto",
                    "requiresItems": [
                        {
                            "id": "ae343640-c7c0-4f7e-907b-17bd87574d9b",
                            "count": 1
                        },
                        {
                            "id": "d2f3e684-84e2-41f9-b39d-51ee224608ac",
                            "count": 1
                        },
                        {
                            "id": "11d73d3c-aa22-450f-aef2-d6163e34e90d",
                            "count": 1
                        },
                        {
                            "id": "99c0472d-0d95-4030-a529-df3e8e8349f4",
                            "count": 1
                        }
                    ],
                    "goto": "range-check",
                    "text": "Launch kit and checklist are staged."
                }
            ]
        },
        {
            "id": "range-check",
            "text": "Final safety gate: verify clear perimeter and low wind. If either fails, we hold and reset.",
            "options": [
                {
                    "type": "goto",
                    "goto": "go",
                    "text": "Range is clear and wind is acceptable."
                },
                {
                    "type": "goto",
                    "goto": "weather-hold",
                    "text": "Unsafe conditions detected. Hold launch."
                }
            ]
        },
        {
            "id": "weather-hold",
            "text": "Standing down is a win. Secure the igniter, wait for safer conditions, then restart range checks.",
            "options": [
                {
                    "type": "goto",
                    "goto": "range-check",
                    "text": "Conditions improved. Re-run the range check."
                }
            ]
        },
        {
            "id": "go",
            "text": "Place rocket on pad, install igniter, connect controller, and launch on clear callouts.",
            "options": [
                {
                    "type": "process",
                    "process": "launch-rocket",
                    "text": "3...2...1... liftoff!"
                },
                {
                    "type": "goto",
                    "goto": "done",
                    "requiresItems": [
                        {
                            "id": "63362e5c-9897-4710-8ef6-26540fabd0ca",
                            "count": 1
                        }
                    ],
                    "text": "Flight logged and rocket recovered in training condition."
                }
            ]
        },
        {
            "id": "done",
            "text": "You launched with real preflight discipline: build proof, safety gates, and recovery mindset. That's the foundation for advanced flights.",
            "options": [
                {
                    "type": "finish",
                    "text": "First launch complete."
                }
            ]
        }
    ],
    "rewards": [
