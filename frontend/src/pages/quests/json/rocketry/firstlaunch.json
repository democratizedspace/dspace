{
    "id": "rocketry/firstlaunch",
    "title": "First rocket launch!",
    "description": "Print, assemble, and launch a model rocket with explicit range safety and recovery troubleshooting.",
    "image": "/assets/quests/firstlaunch.jpg",
    "npc": "/assets/npc/nova.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Nova here. First launch day! We'll print, assemble, and fly with range discipline. Ready to begin?",
            "options": [
                {
                    "type": "goto",
                    "goto": "height",
                    "text": "Yep. What altitude are we expecting?"
                }
            ]
        },
        {
            "id": "height",
            "text": "This airframe usually reaches ~35 m in calm conditions. Wind and prep quality decide the rest.",
            "options": [
                {
                    "type": "goto",
                    "goto": "paperwork",
                    "text": "Do I need any legal or range checks first?"
                }
            ]
        },
        {
            "id": "paperwork",
            "text": "Hobby limits are friendly: under 1500 g total and under 125 g propellant. We still need a clear field and a controlled launch line.",
            "options": [
                {
                    "type": "goto",
                    "goto": "print-plan",
                    "text": "Let's print first, then run a full safety check."
                },
                {
                    "type": "goto",
                    "goto": "safety-brief",
                    "text": "I already have parts. Can we run safety and assembly first?"
                }
            ]
        },
        {
            "id": "print-plan",
            "text": "Print four modular parts: nosecone, body tube, fincan, and nosecone coupler. Modularity keeps failures small.",
            "options": [
                {
                    "type": "process",
                    "process": "3dprint-rocket-nosecone",
                    "text": "Print nosecone."
                },
                {
                    "type": "process",
                    "process": "3dprint-rocket-body-tube",
                    "text": "Print body tube."
                },
                {
                    "type": "process",
                    "process": "3dprint-rocket-fincan",
                    "text": "Print fincan."
                },
                {
                    "type": "process",
                    "process": "3dprint-rocket-nosecone-coupler",
                    "text": "Print nosecone coupler."
                },
                {
                    "type": "goto",
                    "goto": "safety-brief",
                    "requiresItems": [
                        {
                            "id": "7ca9cad5-4bc2-420b-9733-24d1e38c2324",
                            "count": 1
                        },
                        {
                            "id": "1eac8955-bb70-474b-b6b0-4002ff3aa09a",
                            "count": 1
                        },
                        {
                            "id": "563956c2-17d1-4b82-8fce-48b07dc8a71b",
                            "count": 1
                        },
                        {
                            "id": "05c339ee-f50b-419a-804a-341f850b85e9",
                            "count": 1
                        }
                    ],
                    "text": "All four printed parts are complete."
                }
            ]
        },
        {
            "id": "safety-brief",
            "text": "Safety branch: if range is crowded, wind shifts hard, or continuity fails twice, we hold launch and troubleshoot before ignition.",
            "options": [
                {
                    "type": "goto",
                    "goto": "assemble",
                    "text": "Range is clear and safety line is set. Assemble rocket."
                },
                {
                    "type": "goto",
                    "goto": "troubleshoot",
                    "text": "Something looks wrong. Start troubleshooting."
                }
            ]
        },
        {
            "id": "assemble",
            "text": "Assembly time: motor, superglue, and Kevlar shock cord. Build the airframe before launch staging.",
            "options": [
                {
                    "type": "process",
                    "process": "assemble-rocket",
                    "text": "Assemble launch-capable rocket."
                },
                {
                    "type": "goto",
                    "goto": "launch-gear",
                    "requiresItems": [
                        {
                            "id": "aaa5fbca-54a1-40a5-8461-24dc2ef81d4d",
                            "count": 1
                        }
                    ],
                    "text": "Rocket assembled and inspected."
                }
            ]
        },
        {
            "id": "launch-gear",
            "text": "You'll need launch pad, igniter, and controller. I packed spares so you can run a controlled first flight.",
            "options": [
                {
                    "type": "grantsItems",
                    "grantsItems": [
                        {
                            "id": "ae343640-c7c0-4f7e-907b-17bd87574d9b",
                            "count": 1
                        },
                        {
                            "id": "d2f3e684-84e2-41f9-b39d-51ee224608ac",
                            "count": 3
                        },
                        {
                            "id": "11d73d3c-aa22-450f-aef2-d6163e34e90d",
                            "count": 1
                        }
                    ],
                    "text": "Thanks for the launch kit spares."
                },
                {
                    "type": "goto",
                    "goto": "arm",
                    "requiresItems": [
                        {
                            "id": "ae343640-c7c0-4f7e-907b-17bd87574d9b",
                            "count": 1
                        },
                        {
                            "id": "d2f3e684-84e2-41f9-b39d-51ee224608ac",
                            "count": 1
                        },
                        {
                            "id": "11d73d3c-aa22-450f-aef2-d6163e34e90d",
                            "count": 1
                        }
                    ],
                    "text": "Pad, igniter, and controller are staged."
                }
            ]
        },
        {
            "id": "troubleshoot",
            "text": "Troubleshooting branch: fix pad angle, re-seat igniter leads, and clear the field boundary. Then run pre-arm checks again.",
            "options": [
                {
                    "type": "goto",
                    "goto": "safety-brief",
                    "text": "Issues corrected. Re-run safety checks."
                }
            ]
        },
        {
            "id": "arm",
            "text": "Final checks complete. Arm the controller and launch only if everyone stays behind the safety line.",
            "options": [
                {
                    "type": "process",
                    "process": "launch-rocket",
                    "text": "Initiate launch sequence."
                },
                {
                    "type": "goto",
                    "goto": "recovery",
                    "requiresItems": [
                        {
                            "id": "63362e5c-9897-4710-8ef6-26540fabd0ca",
                            "count": 1
                        }
                    ],
                    "text": "Launch complete. Move to recovery review."
                }
            ]
        },
        {
            "id": "recovery",
            "text": "Post-flight check: if body damage is minor, salvage and log lessons. If severe, pause and rebuild before next attempt.",
            "options": [
                {
                    "type": "goto",
                    "goto": "done",
                    "text": "Recovery logged and lessons noted."
                },
                {
                    "type": "goto",
                    "goto": "troubleshoot",
                    "text": "Damage too high. Loop through troubleshooting before another launch."
                }
            ]
        },
        {
            "id": "done",
            "text": "You earned this one: printed parts, assembled safely, launched with evidence, and handled recovery decisions like a range lead.",
            "options": [
                {
                    "type": "finish",
                    "text": "First launch complete."
                }
            ]
        }
    ],
    "rewards": [
        {
            "id": "c754c1e7-244c-41ec-96d4-ad468b6b3e52",
            "count": 1
        }
    ],
    "requiresQuests": ["3dprinter/start"],
