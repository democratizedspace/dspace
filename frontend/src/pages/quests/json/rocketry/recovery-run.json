                    "text": "Range corrected. Continue."
                }
            ]
        },
        {
            "id": "done",
            "text": "Excellent recovery discipline. You validated reuse with launch evidence and a full troubleshooting loop.",
            "options": [
                {
                    "type": "finish",
                    "text": "Recovery run verified."
                }
