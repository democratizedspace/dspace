                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "troubleshoot",
                    "text": "Chute fold looked wrong or cord snagged."
                }
            ]
        },
        {
            "id": "range-check",
            "text": "Operational safety gate: clear a 5 m perimeter, verify launch rod tilt, and assign one person to call abort.",
            "options": [
                {
                    "type": "goto",
                    "goto": "launch",
                    "text": "Pad is clear and abort caller is assigned."
                },
                {
                    "type": "goto",
                    "goto": "hold",
                    "text": "Range setup is not safe yet. Hold."
                }
            ]
        },
        {
            "id": "launch",
            "text": "Run the parachute launch and watch for full canopy deployment and drift direction.",
            "options": [
                {
                    "type": "process",
                    "process": "launch-rocket-parachute",
                    "text": "Launch and track descent."
                },
                {
                    "type": "goto",
                    "goto": "inspect",
                    "text": "Rocket recovered. Begin post-flight inspection.",
                    "requiresItems": [
                        {
                            "id": "e9123658-fb2b-4fb2-bfc4-9eaeebddf3ec",
                            "count": 1
                        },
                        {
                            "id": "eb9c2a75-a87a-4171-8bc3-088e75936bcf",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "troubleshoot",
                    "text": "Recovery looked unstable. Enter troubleshooting branch."
                }
            ]
        },
        {
            "id": "inspect",
            "text": "Evidence gate: inspect chute canopy, shock cord, and body tube. Only pass if no tears, burns, or loose knots are found.",
            "options": [
                {
                    "type": "goto",
                    "goto": "done",
                    "text": "Inspection passed. Rocket is reusable for next iteration.",
                    "requiresItems": [
                        {
                            "id": "e9123658-fb2b-4fb2-bfc4-9eaeebddf3ec",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "troubleshoot",
                    "text": "Damage found. Fix and re-run recovery workflow."
                }
            ]
        },
        {
            "id": "troubleshoot",
            "text": "Troubleshooting flow: repack chute with looser folds, re-seat knots, and replace scorched wadding before attempting another launch.",
            "options": [
                {
                    "type": "goto",
                    "goto": "prep",
                    "text": "Fixes complete. Restart prep and verify again."
                }
            ]
        },
        {
            "id": "hold",
            "text": "Hold accepted. Keep igniter disconnected, clear non-essential crew, and resume only when the pad passes range safety checks.",
            "options": [
                {
                    "type": "goto",
