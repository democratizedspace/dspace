    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Great flights are repeatable flights. We'll prep recovery gear, run launch-and-retrieve, and verify condition before declaring the rocket reusable.",
            "options": [
                {
                    "type": "goto",
                    "goto": "prep",
                    "text": "Ready to run the recovery drill."
                }
            ]
        },
        {
            "id": "prep",
            "text": "Pack flame-resistant wadding, fold the chute, and verify shock cord routing with motor removed.",
            "options": [
                {
                    "type": "goto",
                    "goto": "range-check",
                    "text": "Recovery stack prepped and motor is still out.",
                    "requiresItems": [
                        {
                            "id": "e9123658-fb2b-4fb2-bfc4-9eaeebddf3ec",
                            "count": 1
                        },
                        {
