                            "id": "eb9c2a75-a87a-4171-8bc3-088e75936bcf",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "finish",
            "text": "Excellent! Smooth recoveries mean we can iterate faster on designs.",
            "options": [
                {
                    "type": "finish",
                    "text": "Can't wait for the next launch!"
                }
            ]
