{
    "id": "rocketry/wind-check",
    "title": "Check the Launch Winds",
    "description": "Measure wind speed to ensure safe rocket launches.",
    "image": "/assets/quests/model_rocket_wind_check.jpg",
    "npc": "/assets/npc/nova.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Nimbus here. Wind is data, not vibes. Let's make sure it's safe to fly.",
            "options": [
                {
                    "type": "goto",
                    "goto": "measure",
                    "text": "Got it, let's check the wind."
                }
            ]
        },
        {
            "id": "measure",
            "text": "Hold an anemometer at launch height and take a reading. Then take a second one.",
            "options": [
                {
                    "type": "process",
                    "process": "measure-wind-speed",
                    "goto": "ready",
                    "text": "Take an anemometer reading."
                },
                {
                    "type": "goto",
                    "goto": "ready",
                    "text": "Reading taken\u2014winds are calm."
                }
            ]
        },
        {
            "id": "ready",
            "text": "Looks good. Winds are within limits, launch window is open.",
            "options": [
                {
                    "type": "goto",
                    "goto": "done",
                    "text": "Sweet, let's get this bird in the air!"
                }
            ]
        },
        {
            "id": "done",
            "text": "Good work. Always respect the wind; rockets prefer calm applause.",
            "options": [
                {
                    "type": "finish",
                    "text": "Launch conditions verified."
                }
            ]
        }
    ],
    "rewards": [
        {
            "id": "15e3dd7e-374b-4233-b8c9-117e3057f009",
            "count": 1
        }
    ],
    "requiresQuests": ["rocketry/preflight-check"],
