{
    "id": "rocketry/static-test",
    "title": "Perform a Static Engine Test",
    "description": "Run a secured static burn with safety checks, interpret thrust behavior against pass bounds, and loop through corrective retests when needed.",
    "image": "/assets/quests/model_rocket_static_engine_test.jpg",
    "npc": "/assets/npc/nova.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Before launch day, we run a static burn exactly like a range team: secure mount, clear line, and evidence first.",
            "options": [
                {
                    "type": "goto",
                    "goto": "setup",
                    "text": "Start static-test setup."
                }
            ]
        },
        {
            "id": "setup",
            "text": "Safety gate: lock the airframe to the stand, place the launchpad on stable ground, and brief everyone on the remote-fire line.",
            "options": [
                {
                    "type": "goto",
                    "goto": "baseline",
                    "requiresItems": [
                        {
                            "id": "11d73d3c-aa22-450f-aef2-d6163e34e90d",
                            "count": 1
                        },
                        {
                            "id": "4d817f1c-d78d-4fac-a514-402bce330693",
                            "count": 1
                        },
                        {
                            "id": "d2f3e684-84e2-41f9-b39d-51ee224608ac",
                            "count": 1
                        }
                    ],
                    "text": "Pad stable, motor secured, igniter routed."
                }
            ]
        },
        {
            "id": "baseline",
            "text": "Capture baseline notes (mount tension, igniter continuity, and expected thrust class) before ignition.",
            "grantsItems": [
                {
                    "id": "70bb8d86-2c4e-4330-9705-371891934686",
                    "count": 1
                }
            ],
            "options": [
                {
                    "type": "goto",
                    "goto": "burn",
                    "requiresItems": [
                        {
                            "id": "70bb8d86-2c4e-4330-9705-371891934686",
                            "count": 1
                        }
                    ],
                    "text": "Baseline captured; proceed to remote ignition."
                }
            ]
        },
        {
            "id": "burn",
            "text": "Ignite remotely and observe thrust stability. Record whether burn profile is smooth, delayed, or oscillatory.",
            "options": [
                {
                    "type": "grantsItems",
                    "grantsItems": [
                        {
                            "id": "280ed361-ac70-4ab9-bcd9-aee481790faf",
                            "count": 1
                        }
                    ],
                    "goto": "interpret",
                    "requiresItems": [
                        {
                            "id": "70bb8d86-2c4e-4330-9705-371891934686",
                            "count": 1
                        }
                    ],
                    "text": "Burn observation logged."
                }
            ]
        },
        {
            "id": "interpret",
            "text": "Interpretation gate: pass only if ignition delay stays controlled and thrust stays stable through the burn. Otherwise branch to corrective work and re-test.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "requiresItems": [
                        {
                            "id": "280ed361-ac70-4ab9-bcd9-aee481790faf",
                            "count": 1
                        },
                        {
                            "id": "80a83ecc-bcd2-400e-a469-8488a6453bb8",
                            "count": 1
                        }
                    ],
                    "text": "Profile is in bounds; close test with notes."
                },
                {
                    "type": "goto",
                    "goto": "corrective",
                    "requiresItems": [
                        {
                            "id": "280ed361-ac70-4ab9-bcd9-aee481790faf",
                            "count": 1
                        }
                    ],
                    "text": "Profile out of bounds; run corrective branch."
                }
            ]
        },
        {
            "id": "corrective",
            "text": "Corrective branch: replace suspect igniter routing, re-check mount rigidity, and only then loop back through baseline and ignition.",
            "options": [
                {
                    "type": "goto",
                    "goto": "baseline",
                    "requiresItems": [
                        {
                            "id": "d2f3e684-84e2-41f9-b39d-51ee224608ac",
                            "count": 1
                        }
                    ],
                    "text": "Corrective action complete; run mandatory re-test."
                }
            ]
        },
        {
            "id": "finish",
            "text": "Excellent. Static evidence is logged, interpretation is explicit, and the motor setup is now safer for launch day.",
            "options": [
                {
                    "type": "finish",
                    "text": "Static test complete."
                }
            ]
        }
    ],
