{
    "id": "rocketry/preflight-check",
    "title": "Preflight Checklist",
    "description": "Run a full launch readiness check with a weather hold branch, safety verification, and documented go/no-go evidence before liftoff.",
    "image": "/assets/quests/model_rocket_preflight_checklist.jpg",
    "npc": "/assets/npc/nova.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Hey friend! Nova here. We are not doing send-it rocketry today; we are doing disciplined preflight. Ready to run the board?",
            "options": [
                {
                    "type": "goto",
                    "goto": "supplies",
                    "text": "Yes, run the standard preflight lane."
                },
                {
                    "type": "goto",
                    "goto": "weather-hold",
                    "text": "Let's branch to weather and pad conditions first."
                }
            ]
        },
        {
            "id": "supplies",
            "text": "Stage the critical launch kit: pad, igniter, and controller. No staged kit means no armed countdown.",
            "options": [
                {
                    "type": "goto",
                    "goto": "safety-brief",
                    "requiresItems": [
                        {
                            "id": "ae343640-c7c0-4f7e-907b-17bd87574d9b",
                            "count": 1
                        },
                        {
                            "id": "d2f3e684-84e2-41f9-b39d-51ee224608ac",
                            "count": 1
                        },
                        {
                            "id": "11d73d3c-aa22-450f-aef2-d6163e34e90d",
                            "count": 1
                        }
                    ],
                    "text": "Kit staged and physically checked."
                }
            ]
        },
        {
            "id": "weather-hold",
            "text": "If gusts or pad tilt exceed comfort, hold launch. Confirm pad stability and route back into the checklist before arming.",
            "options": [
                {
                    "type": "goto",
                    "goto": "supplies",
                    "requiresItems": [
                        {
                            "id": "11d73d3c-aa22-450f-aef2-d6163e34e90d",
                            "count": 1
                        }
                    ],
                    "text": "Pad is stable now, resume full checklist."
                }
            ]
        },
        {
            "id": "safety-brief",
            "text": "Safety gate: range clear, eye protection on, and launch checklist in hand before we arm the circuit.",
            "options": [
                {
                    "type": "goto",
                    "goto": "arm",
                    "requiresItems": [
                        {
                            "id": "99c0472d-0d95-4030-a529-df3e8e8349f4",
                            "count": 1
                        },
                        {
                            "id": "ae343640-c7c0-4f7e-907b-17bd87574d9b",
                            "count": 1
                        },
                        {
                            "id": "11d73d3c-aa22-450f-aef2-d6163e34e90d",
                            "count": 1
                        }
                    ],
                    "text": "Checklist complete, safety call made."
                }
            ]
        },
        {
            "id": "arm",
            "text": "Armed state. Execute launch only if countdown discipline holds; otherwise route to troubleshooting and re-verify.",
            "options": [
                {
                    "type": "process",
                    "process": "launch-rocket",
                    "text": "Initiate launch sequence.",
                    "goto": "verify"
                },
                {
                    "type": "goto",
                    "goto": "troubleshoot",
                    "text": "Hold: continuity callout or pad setup looks wrong."
                }
            ]
        },
        {
            "id": "troubleshoot",
            "text": "Troubleshooting branch: disarm, inspect igniter seating and clip polarity, then re-run safety checks before another arm attempt.",
            "options": [
                {
                    "type": "goto",
                    "goto": "safety-brief",
                    "requiresItems": [
                        {
                            "id": "d2f3e684-84e2-41f9-b39d-51ee224608ac",
                            "count": 1
                        },
                        {
                            "id": "99c0472d-0d95-4030-a529-df3e8e8349f4",
                            "count": 1
                        }
                    ],
                    "text": "Issue corrected, re-verify and re-arm."
                }
            ]
        },
        {
            "id": "verify",
            "text": "Evidence gate: confirm post-launch artifacts and declare whether this was a clean go or a conditional recovery event.",
            "options": [
                {
                    "type": "goto",
                    "goto": "done",
                    "requiresItems": [
                        {
                            "id": "63362e5c-9897-4710-8ef6-26540fabd0ca",
                            "count": 1
                        },
                        {
                            "id": "eb9c2a75-a87a-4171-8bc3-088e75936bcf",
                            "count": 1
                        }
                    ],
                    "text": "Artifacts captured and checklist signed off."
                },
                {
                    "type": "goto",
                    "goto": "troubleshoot",
                    "requiresItems": [
                        {
                            "id": "63362e5c-9897-4710-8ef6-26540fabd0ca",
                            "count": 1
                        }
                    ],
                    "text": "Recovery needed before next launch window."
                }
            ]
        },
        {
            "id": "done",
            "text": "Nice work. That was a real preflight: staged equipment, safety callouts, launch evidence, and documented decision-making.",
            "options": [
                {
                    "type": "finish",
                    "text": "Preflight discipline locked in."
                }
            ]
        }
    ],
