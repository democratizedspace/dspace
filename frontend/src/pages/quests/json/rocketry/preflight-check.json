{
    "id": "rocketry/preflight-check",
    "title": "Preflight Checklist",
    "description": "Confirm gear and run a quick launch sequence.",
    "image": "/assets/quests/model_rocket_preflight_checklist.jpg",
    "npc": "/assets/npc/nova.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Hey friend! Nova here. Before we launch, we need a preflight check with pass/fail limits, not vibes. Ready to run through it?",
            "options": [
                {
                    "type": "goto",
                    "goto": "supplies",
                    "text": "Let's check the gear."
                }
            ]
        },
        {
            "id": "supplies",
            "text": "You'll need a launch pad, an igniter, and a controller. Then we log a checklist pass before we can arm.",
            "options": [
                {
                    "type": "goto",
                    "goto": "measure",
                    "requiresItems": [
                        {
                            "id": "ae343640-c7c0-4f7e-907b-17bd87574d9b",
                            "count": 1
                        },
                        {
                            "id": "d2f3e684-84e2-41f9-b39d-51ee224608ac",
                            "count": 1
                        },
                        {
                            "id": "11d73d3c-aa22-450f-aef2-d6163e34e90d",
                            "count": 1
                        }
                    ],
                    "text": "All set, gear in hand."
                },
                {
                    "type": "goto",
                    "goto": "recovery",
                    "text": "I'm missing hardware\u2014what should I fix first?"
                }
            ]
        },
        {
            "id": "measure",
            "text": "Run the preflight checklist and verify three bounds: pad angle in range, igniter continuity good, and range clear. Any red flag means no launch.",
            "options": [
                {
                    "type": "goto",
                    "goto": "interpret",
                    "requiresItems": [
                        {
                            "id": "246a8dca-ed43-490d-8b28-5ab4ab47a792",
                            "count": 1
                        }
                    ],
                    "text": "Checklist log captured."
                },
                {
                    "type": "goto",
                    "goto": "recovery",
                    "text": "A bound failed or conditions changed."
                }
            ]
        },
        {
            "id": "interpret",
            "text": "Interpretation gate: launch only if all checks are green and the hazard arc stays clear. If not, scrub and fix the issue.",
            "options": [
                {
                    "type": "goto",
                    "goto": "arm",
                    "text": "All checks green. Proceed to launch sequence."
                },
                {
                    "type": "goto",
                    "goto": "recovery",
                    "text": "Not green yet. Troubleshoot and re-test."
                }
            ]
        },
        {
            "id": "recovery",
            "text": "Troubleshoot path: replace suspect igniter clips, reset pad angle, and clear spectators to the safe perimeter. Re-run the checklist before arming.",
            "options": [
                {
                    "type": "goto",
                    "goto": "measure",
                    "requiresItems": [
                        {
                            "id": "246a8dca-ed43-490d-8b28-5ab4ab47a792",
                            "count": 1
                        }
                    ],
                    "text": "Corrections complete; verify bounds again."
                }
            ]
        },
        {
            "id": "arm",
            "text": "Everything looks good and documented. Ready to fire?",
            "options": [
                {
                    "type": "process",
                    "process": "launch-rocket",
                    "text": "Initiate launch!"
                },
                {
                    "type": "goto",
                    "goto": "done",
                    "requiresItems": [
                        {
                            "id": "63362e5c-9897-4710-8ef6-26540fabd0ca",
                            "count": 1
                        }
                    ],
                    "text": "Launch successful!"
                }
            ]
        },
        {
            "id": "done",
            "text": "Nice work! Preflight complete and rocket soaring.",
            "options": [
                {
                    "type": "finish",
                    "text": "Mission accomplished."
                }
            ]
        }
    ],
    "rewards": [
        {
            "id": "c754c1e7-244c-41ec-96d4-ad468b6b3e52",
            "count": 1
        }
    ],
    "requiresQuests": [
        "rocketry/parachute"
    ],
    "hardening": {
        "passes": 0,
        "score": 95,
        "emoji": "\ud83d\udee0\ufe0f",
        "history": []
    }
}
