{
    "id": "rocketry/preflight-check",
    "title": "Preflight Checklist",
    "description": "Confirm launch gear, capture a wind-readiness artifact, and enforce go/no-go safety gates.",
    "image": "/assets/quests/model_rocket_preflight_checklist.jpg",
    "npc": "/assets/npc/nova.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Nova here. Preflight is where we earn safe launches. Ready for a real go/no-go review?",
            "options": [
                {
                    "type": "goto",
                    "goto": "supplies",
                    "text": "Let's run the checklist."
                }
            ]
        },
        {
            "id": "supplies",
            "text": "Stage launch pad, igniter, and controller. We don't continue without all three.",
            "options": [
                {
                    "type": "goto",
                    "goto": "measure",
                    "requiresItems": [
                        {
                            "id": "ae343640-c7c0-4f7e-907b-17bd87574d9b",
                            "count": 1
                        },
                        {
                            "id": "d2f3e684-84e2-41f9-b39d-51ee224608ac",
                            "count": 1
                        },
                        {
                            "id": "11d73d3c-aa22-450f-aef2-d6163e34e90d",
                            "count": 1
                        }
                    ],
                    "text": "Gear staged. Proceed to measurement evidence."
                }
            ]
        },
        {
            "id": "measure",
            "text": "Capture an on-pad wind reading for this launch window. This reading is your preflight evidence artifact.",
            "options": [
                {
                    "type": "goto",
                    "goto": "interpret",
                    "requiresItems": [
                        {
                            "id": "15e3dd7e-374b-4233-b8c9-117e3057f009",
                            "count": 1
                        }
                    ],
                    "text": "Measurement card captured. Interpret go/no-go."
                }
            ]
        },
        {
            "id": "interpret",
            "text": "Go/no-go bounds: sustained wind <= 8 m/s and gust spread <= 3 m/s. Any exceedance is an automatic NO-GO safety stop.",
            "options": [
                {
                    "type": "goto",
                    "goto": "arm",
                    "requiresItems": [
                        {
                            "id": "15e3dd7e-374b-4233-b8c9-117e3057f009",
                            "count": 1
                        }
                    ],
                    "text": "GO: values are inside limits. Arm for launch."
                },
                {
                    "type": "goto",
                    "goto": "corrective",
                    "text": "NO-GO: out-of-range reading. Begin corrective loop."
                }
            ]
        },
        {
            "id": "corrective",
            "text": "Corrective branch: hold launch, reposition pad, and wait for calmer conditions. Then run another measurement before re-evaluating.",
            "options": [
                {
                    "type": "goto",
                    "goto": "retest",
                    "text": "Corrections complete. Mandatory re-test next."
                }
            ]
        },
        {
            "id": "retest",
            "text": "Repeat the wind measurement. Preflight cannot finish until a fresh reading passes bounds.",
            "options": [
                {
                    "type": "goto",
                    "goto": "interpret",
                    "requiresItems": [
                        {
                            "id": "15e3dd7e-374b-4233-b8c9-117e3057f009",
                            "count": 1
                        }
                    ],
                    "text": "Re-test captured. Re-check go/no-go bounds."
                }
            ]
        },
        {
            "id": "arm",
            "text": "Final safety check: range clear, everyone behind the line, controller continuity confirmed.",
            "options": [
                {
                    "type": "process",
                    "process": "launch-rocket",
                    "text": "Initiate controlled launch sequence."
                },
                {
                    "type": "goto",
                    "goto": "done",
                    "requiresItems": [
                        {
                            "id": "63362e5c-9897-4710-8ef6-26540fabd0ca",
                            "count": 1
                        }
                    ],
                    "text": "Launch complete with evidence captured."
                }
            ]
        },
        {
            "id": "done",
            "text": "Excellent preflight discipline. You verified bounds, handled safety stops, and launched responsibly.",
            "options": [
                {
                    "type": "finish",
                    "text": "Mission accomplished."
                }
            ]
        }
    ],
    "rewards": [
        {
            "id": "c754c1e7-244c-41ec-96d4-ad468b6b3e52",
            "count": 1
        }
    ],
    "requiresQuests": ["rocketry/parachute"],
    "hardening": {
        "passes": 0,
        "score": 95,
        "emoji": "🛠️",
        "history": []
    }
}
