        },
        {
            "id": "layout",
            "text": "Mark a floor, front, two sides, back, and a two-piece roof. Keep the entry hole about 32 mm and add roof overhang for rain.",
            "options": [
                {
                    "type": "goto",
                    "goto": "cut",
                    "text": "Measurements marked"
                },
                {
                    "type": "goto",
                    "goto": "template-jig",
                    "text": "Use a cardboard template to double-check symmetry"
                },
                {
                    "type": "goto",
                    "goto": "gather",
                    "text": "Need to grab materials"
                }
            ]
        },
        {
            "id": "template-jig",
            "text": "Trace each panel on cardboard before cutting. If the mock-up rocks or the entry hole sits too low, correct marks now to avoid wasted lumber.",
            "options": [
                {
                    "type": "goto",
                    "goto": "cut",
                    "text": "Template fit passes; cut the real panels"
                },
                {
                    "type": "goto",
                    "goto": "layout",
                    "text": "Template shows mismatch; re-mark measurements"
                }
            ]
        },
        {
            "id": "cut",
            "text": "Crosscut the pine into labeled panels and drill the entrance hole. Square edges make clean glue joints.",
            "options": [
                {
                    "type": "process",
                    "process": "cut-birdhouse-panels",
                    "text": "Cut and drill the pine panels"
                },
                {
                    "type": "goto",
                    "goto": "layout",
                    "text": "Recheck measurements"
                },
                {
                    "type": "goto",
                    "goto": "assemble",
                    "requiresItems": [
                        {
                            "id": "0e6f2e1c-1e8a-4c05-b1db-38f1eec6f64a",
                            "count": 1
                        }
                    ],
                    "text": "Panels are cut"
                }
            ]
        },
        {
            "id": "assemble",
            "text": "Dry-fit first, then glue and nail the walls and roof. Recess the floor so water drains out.",
            "options": [
                {
                    "type": "process",
                    "process": "glue-birdhouse-shell",
                    "text": "Glue and nail the shell"
                },
                {
                    "type": "goto",
                    "goto": "cut",
                    "text": "Trim a panel again"
                },
                {
                    "type": "goto",
                    "goto": "troubleshoot-joints",
                    "text": "Gap, split, or wobble spotted in the dry-fit"
                },
                {
                    "type": "goto",
                    "goto": "finish",
                    "requiresItems": [
                        {
                            "id": "c97f9b74-4d4f-4e83-993c-5df76e9d026e",
                            "count": 1
                        }
                    ],
                    "text": "Shell is glued up"
                }
            ]
        },
        {
            "id": "troubleshoot-joints",
            "text": "Troubleshooting branch: clamp the split, pre-drill nail paths, and confirm goggles stay on before retrying any cut or glue step.",
            "options": [
                {
                    "type": "goto",
                    "goto": "cut",
                    "text": "Panel damage needs a recut"
                },
                {
                    "type": "goto",
                    "goto": "assemble",
                    "text": "Dry-fit is corrected; retry glue-up"
                }
            ]
        },
        {
            "id": "finish",
            "text": "Ease every edge with sandpaper, add a small perch if you like, and pre-drill for a hook or screw.",
            "options": [
                {
                    "type": "process",
                    "process": "build-birdhouse",
                    "text": "Sand, roof, and pre-drill for hanging"
                },
                {
                    "type": "goto",
                    "goto": "assemble",
                    "text": "Tighten up the glue-up"
                },
                {
                    "type": "goto",
                    "goto": "complete",
