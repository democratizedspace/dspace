{
    "id": "woodworking/birdhouse",
    "title": "Build a birdhouse",
    "description": "Start woodworking with a straightforward birdhouse that teaches measuring, safe cuts, and clean glue joints.",
    "image": "/assets/quests/woodworking_birdhouse_build.jpg",
    "npc": "/assets/npc/atlas.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Let's kick off your woodworking journey with a small project. A birdhouse is perfect for practicing basic cuts and assembly.",
            "options": [
                {
                    "type": "goto",
                    "goto": "gather",
                    "text": "Sounds fun!"
                }
            ]
        },
        {
            "id": "gather",
            "text": "You'll need a pine board, wood glue, sandpaper, your handsaw, tape measure, hammer, and safety goggles. I'll supply missing gear.",
            "options": [
                {
                    "type": "grantsItems",
                    "grantsItems": [
                        { "id": "6c075116-ebd1-4147-8666-ec6338ca251e", "count": 1 },
                        { "id": "30a7cd72-cf99-4ed7-9a4c-f30a68a4a399", "count": 1 },
                        { "id": "ac6d5ef4-a7ec-4651-8f0c-db4c0ede865e", "count": 1 },
                        { "id": "2dfe683c-56f6-4026-b9e9-2d01a03b1878", "count": 1 },
                        { "id": "2770ee5d-f9a0-4dc8-9c79-4f031fefd093", "count": 1 },
                        { "id": "5fbabfcf-27d0-48f5-a89e-7aba8ca4b913", "count": 1 },
                        { "id": "c9b51052-4594-42d7-a723-82b815ab8cc2", "count": 1 }
                    ],
                    "text": "Gather materials"
                },
                {
                    "type": "goto",
                    "goto": "layout",
                    "requiresItems": [
                        { "id": "6c075116-ebd1-4147-8666-ec6338ca251e", "count": 1 },
                        { "id": "30a7cd72-cf99-4ed7-9a4c-f30a68a4a399", "count": 1 },
                        { "id": "ac6d5ef4-a7ec-4651-8f0c-db4c0ede865e", "count": 1 },
                        { "id": "2dfe683c-56f6-4026-b9e9-2d01a03b1878", "count": 1 },
                        { "id": "2770ee5d-f9a0-4dc8-9c79-4f031fefd093", "count": 1 },
                        { "id": "5fbabfcf-27d0-48f5-a89e-7aba8ca4b913", "count": 1 },
                        { "id": "c9b51052-4594-42d7-a723-82b815ab8cc2", "count": 1 }
                    ],
                    "text": "Materials ready"
                }
            ]
        },
        {
            "id": "layout",
            "text": "Mark the board into a floor, a front, two side walls, a back, and a two-piece roof. Keep the entry hole about 32 mm and leave overhang to shed rain.",
            "options": [
                {
                    "type": "goto",
                    "goto": "cut",
                    "text": "Measurements marked"
                },
                {
                    "type": "goto",
                    "goto": "gather",
                    "text": "Need to grab materials"
                }
            ]
        },
        {
            "id": "cut",
            "text": "Crosscut the pine board into labeled panels and drill the entrance hole. Check for square edges so glue joints align later.",
            "options": [
                {
                    "type": "process",
                    "process": "cut-birdhouse-panels",
                    "text": "Cut and drill the pine panels"
                },
                {
                    "type": "goto",
                    "goto": "layout",
                    "text": "Recheck measurements"
                },
                {
                    "type": "goto",
                    "goto": "assemble",
                    "requiresItems": [{ "id": "0e6f2e1c-1e8a-4c05-b1db-38f1eec6f64a", "count": 1 }],
                    "text": "Panels are cut"
                }
            ]
        },
        {
            "id": "assemble",
            "text": "Dry-fit the panels, then glue and nail the walls and roof. Keep the floor slightly recessed so rainwater drains away.",
            "options": [
                {
                    "type": "process",
                    "process": "glue-birdhouse-shell",
                    "text": "Glue and nail the shell"
                },
                {
                    "type": "goto",
                    "goto": "cut",
                    "text": "Trim a panel again"
                },
                {
                    "type": "goto",
                    "goto": "finish",
                    "requiresItems": [{ "id": "c97f9b74-4d4f-4e83-993c-5df76e9d026e", "count": 1 }],
                    "text": "Shell is glued up"
                }
            ]
        },
        {
            "id": "finish",
            "text": "Ease every edge with sandpaper, add a small perch if you like, and pre-drill for a hook or screw so mounting is easy.",
            "options": [
                {
                    "type": "process",
                    "process": "build-birdhouse",
                    "text": "Sand, roof, and pre-drill for hanging"
                },
                {
                    "type": "goto",
                    "goto": "assemble",
                    "text": "Tighten up the glue-up"
                },
                {
                    "type": "goto",
                    "goto": "complete",
                    "requiresItems": [{ "id": "092fdddc-431a-40bd-a66c-f7ef878ae1f8", "count": 1 }],
                    "text": "Ready to mount"
                }
            ]
        },
        {
            "id": "complete",
            "text": "Excellent craftsmanship! Mount your birdhouse outdoors and watch for new feathered tenants.",
            "options": [
                {
                    "type": "finish",
                    "text": "Thanks for the lesson!"
                }
            ]
        }
    ],
