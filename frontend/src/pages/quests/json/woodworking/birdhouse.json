                    ],
                    "text": "Ready to mount"
                }
            ]
        },
        {
            "id": "complete",
            "text": "Nice craftsmanship. Mount it outdoors and keep an eye out for new tenants.",
            "options": [
                {
                    "type": "finish",
                    "text": "Thanks for the lesson!"
                }
