{
    "id": "woodworking/picture-frame",
    "title": "Craft a Picture Frame",
    "description": "Make a simple frame to showcase your favorite photo.",
    "image": "/assets/quests/woodworking_picture_frame_craft.jpg",
    "npc": "/assets/npc/atlas.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Frames make memories pop. We'll pick a style, prove square assembly, and verify hanging safety before sign-off.",
            "options": [
                {
                    "type": "goto",
                    "goto": "style",
                    "text": "Help me plan the look"
                },
                {
                    "type": "goto",
                    "goto": "assemble",
                    "text": "I already planned dimensions"
                }
            ]
        },
        {
            "id": "style",
            "text": "Use a 20\u00d725 cm opening with 3 cm rails. Choose a natural finish or painted accent before cutting.",
            "options": [
                {
                    "type": "goto",
                    "goto": "assemble",
                    "text": "Natural grain route"
                },
                {
                    "type": "goto",
                    "goto": "assemble",
                    "text": "Painted accent route"
                }
            ]
        },
        {
            "id": "assemble",
            "text": "Cut four rails, miter the ends, then glue and clamp. Confirm equal diagonals so the frame stays square.",
            "options": [
                {
                    "type": "goto",
                    "goto": "verify-square",
                    "text": "Miters are clamped",
                    "requiresItems": [
                        {
                            "id": "6c075116-ebd1-4147-8666-ec6338ca251e",
                            "count": 1
                        },
                        {
                            "id": "30a7cd72-cf99-4ed7-9a4c-f30a68a4a399",
                            "count": 1
                        },
                        {
                            "id": "ac6d5ef4-a7ec-4651-8f0c-db4c0ede865e",
                            "count": 1
                        },
                        {
                            "id": "2770ee5d-f9a0-4dc8-9c79-4f031fefd093",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "miter-repair",
                    "text": "My corners show visible gaps"
                }
            ]
        },
        {
            "id": "miter-repair",
            "text": "Troubleshoot by recutting one rail at a time and dry-fitting before glue. Small errors compound fast on frames.",
            "options": [
                {
                    "type": "goto",
                    "goto": "assemble",
                    "text": "Recut complete, reassemble"
                },
                {
                    "type": "goto",
                    "goto": "verify-square",
                    "text": "Gaps corrected, verify square",
                    "requiresItems": [
                        {
                            "id": "6c075116-ebd1-4147-8666-ec6338ca251e",
                            "count": 1
                        },
                        {
                            "id": "30a7cd72-cf99-4ed7-9a4c-f30a68a4a399",
                            "count": 1
                        },
                        {
                            "id": "ac6d5ef4-a7ec-4651-8f0c-db4c0ede865e",
                            "count": 1
                        },
                        {
                            "id": "2770ee5d-f9a0-4dc8-9c79-4f031fefd093",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "verify-square",
            "text": "Evidence gate: both diagonal measurements must match before moving to backing and hardware.",
            "options": [
                {
                    "type": "goto",
                    "goto": "backer",
                    "text": "Diagonals match and glue is set",
                    "requiresItems": [
                        {
                            "id": "6c075116-ebd1-4147-8666-ec6338ca251e",
                            "count": 1
                        },
                        {
                            "id": "ac6d5ef4-a7ec-4651-8f0c-db4c0ede865e",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "miter-repair",
                    "text": "Diagonals are still off"
                }
            ]
        },
        {
            "id": "backer",
            "text": "Cut a thin backer and add sawtooth hangers 5 cm from the top. Pre-drill to prevent splitting.",
            "options": [
                {
                    "type": "goto",
                    "goto": "surface-prep",
                    "text": "Backer and hangers installed"
                },
                {
                    "type": "goto",
                    "goto": "hardware-fix",
                    "text": "Hardware feels loose"
                }
            ]
        },
        {
            "id": "hardware-fix",
            "text": "Remove loose fasteners, pre-drill slightly smaller pilot holes, and re-seat hardware flush to the rail.",
            "options": [
                {
                    "type": "goto",
                    "goto": "backer",
                    "text": "Retry hardware install"
                },
                {
                    "type": "goto",
                    "goto": "surface-prep",
                    "text": "Hardware is secure now"
                }
            ]
        },
        {
            "id": "surface-prep",
            "text": "Feather corners with 180 grit then 220 grit so seams disappear before finish or paint.",
            "options": [
                {
                    "type": "goto",
                    "goto": "hang-check",
                    "text": "Surface is smooth",
                    "requiresItems": [
                        {
                            "id": "2770ee5d-f9a0-4dc8-9c79-4f031fefd093",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "miter-repair",
                    "text": "Seams are still visible"
                }
            ]
        },
        {
            "id": "hang-check",
            "text": "Safety check: confirm hanger screws are seated and test-hang over a soft surface before wall mounting.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Load test passed"
                },
                {
                    "type": "goto",
                    "goto": "hardware-fix",
                    "text": "Load test failed"
                }
            ]
        },
        {
            "id": "finish",
            "text": "Great job. Your frame is square, sanded, and safe to hang with your print installed.",
            "options": [
                {
                    "type": "process",
                    "process": "craft-picture-frame",
                    "text": "Glue, clamp, and finish the frame for hanging."
                },
                {
                    "type": "goto",
                    "goto": "complete",
                    "text": "Take the picture frame.",
                    "requiresItems": [
                        {
                            "id": "7b2c58bc-e484-4110-996c-220cfb7a4ba7",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "complete",
            "text": "Frame finished and hang-ready. Pick the photo, set the backing, and put it where you'll see it daily.",
            "options": [
                {
                    "type": "finish",
                    "text": "Hang it up!"
                }
            ]
        }
    ],
    "rewards": [
