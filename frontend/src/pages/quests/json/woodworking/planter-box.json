{
    "id": "woodworking/planter-box",
    "title": "Build a Planter Box",
    "description": "Cut and nail a pine planter box that introduces square joints and waterproof glue-ups.",
    "image": "/assets/quests/woodworking_planter_box_build.jpg",
    "npc": "/assets/npc/atlas.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Ready for another project? We'll build a planter box that can survive wet soil without twisting out of square.",
            "options": [
                {
                    "type": "goto",
                    "goto": "layout",
                    "text": "Walk me through the build"
                },
                {
                    "type": "goto",
                    "goto": "safety",
                    "text": "Start with safety checks"
                }
            ]
        },
        {
            "id": "safety",
            "text": "Wear eye protection before cutting, keep the board clamped while sawing, and stop if cuts wander near your support hand.",
            "options": [
                {
                    "type": "goto",
                    "goto": "layout",
                    "text": "Safety checks done"
                },
                {
                    "type": "goto",
                    "goto": "start",
                    "text": "Reset my work area first"
                }
            ]
        },
        {
            "id": "layout",
            "text": "Cut four pine boards for a 60×25×20 cm box. Mark a reference edge so each corner can be checked against the same face.",
            "options": [
                {
                    "type": "goto",
                    "goto": "gather",
                    "text": "Let's gather supplies"
                },
                {
                    "type": "goto",
                    "goto": "drainage",
                    "text": "Any drainage tips?"
                }
            ]
        },
        {
            "id": "gather",
            "text": "Grab four pine boards, waterproof glue, your handsaw, and a fresh sandpaper pack. I'll loan the 16 oz claw hammer.",
            "options": [
                {
                    "type": "grantsItems",
                    "grantsItems": [
                        {
                            "id": "5fbabfcf-27d0-48f5-a89e-7aba8ca4b913",
                            "count": 1
                        }
                    ],
                    "text": "Issue the hammer"
                },
                {
                    "type": "goto",
                    "goto": "fit-choice",
                    "text": "Materials ready",
                    "requiresItems": [
                        {
                            "id": "6c075116-ebd1-4147-8666-ec6338ca251e",
                            "count": 4
                        },
                        {
                            "id": "30a7cd72-cf99-4ed7-9a4c-f30a68a4a399",
                            "count": 1
                        },
                        {
                            "id": "5fbabfcf-27d0-48f5-a89e-7aba8ca4b913",
                            "count": 1
                        },
                        {
                            "id": "ac6d5ef4-a7ec-4651-8f0c-db4c0ede865e",
                            "count": 1
                        },
                        {
                            "id": "2770ee5d-f9a0-4dc8-9c79-4f031fefd093",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "drainage",
            "text": "Drill 8 mm holes every 10 cm and leave 2 mm gaps between slats. Keep the bottom flat so water exits instead of pooling.",
            "options": [
                {
                    "type": "goto",
                    "goto": "gather",
                    "text": "Drainage pattern ready, gather the full kit"
                },
                {
                    "type": "goto",
                    "goto": "layout",
                    "text": "Re-check my cut marks"
                }
            ]
        },
        {
            "id": "fit-choice",
            "text": "Choose your assembly order: dry-fit first for squareness, or pre-drill first for cleaner nail lines in hard grain.",
            "options": [
                {
                    "type": "goto",
                    "goto": "dryfit",
                    "text": "Dry-fit corners first"
                },
                {
                    "type": "goto",
                    "goto": "predrill",
                    "text": "Pre-drill and mark fasteners"
                }
            ]
        },
        {
            "id": "dryfit",
            "text": "Dry-fit the pieces like a frame and keep diagonal difference under 3 mm before adding glue.",
            "options": [
                {
                    "type": "goto",
                    "goto": "build",
                    "text": "Square confirmed, start glue-up"
                },
                {
                    "type": "goto",
                    "goto": "troubleshoot",
                    "text": "Corners keep drifting"
                }
            ]
        },
        {
            "id": "predrill",
            "text": "Mark two nails per corner and pre-drill pilot holes to prevent splits. Keep nails offset so the tips do not collide.",
            "options": [
                {
                    "type": "goto",
                    "goto": "build",
                    "text": "Pilot holes complete"
                },
                {
                    "type": "goto",
                    "goto": "troubleshoot",
                    "text": "Board edge started cracking"
                }
            ]
        },
        {
            "id": "troubleshoot",
            "text": "Recovery: back out the fastener, trim the split edge, and clamp the corner before retrying. Re-check diagonal spread before continuing.",
            "options": [
                {
                    "type": "goto",
                    "goto": "fit-choice",
                    "text": "Retry assembly with corrections"
                },
                {
                    "type": "goto",
                    "goto": "safety",
                    "text": "Pause for a safety reset"
                }
            ]
        },
        {
            "id": "build",
            "text": "Glue edges, clamp lightly, and drive two 40 mm nails per corner from the kit. Wipe squeeze-out and keep the base flat while curing.",
            "options": [
                {
                    "type": "process",
                    "process": "assemble-planter-box",
                    "text": "Run assembly process"
                },
                {
                    "type": "goto",
                    "goto": "seal",
                    "text": "Assembly done, move to liner check",
                    "requiresItems": [
                        {
                            "id": "ea830e47-5996-4886-b5ee-74bb2b932988",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "seal",
            "text": "Optional liner path: add fabric without blocking drainage holes, then confirm the box sits level and does not rack when lifted.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Drainage and stability verified",
                    "requiresItems": [
                        {
                            "id": "ea830e47-5996-4886-b5ee-74bb2b932988",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "troubleshoot",
                    "text": "It twists or leaks at one corner"
                }
            ]
        },
        {
            "id": "finish",
            "text": "Great build. Let the glue cure eight hours before loading soil or hydroponic gear so the joints stay tight.",
            "options": [
                {
                    "type": "finish",
                    "text": "Planter complete"
                }
            ]
        }
    ],
    "rewards": [
        {
            "id": "ea830e47-5996-4886-b5ee-74bb2b932988",
            "count": 1
        },
