{
    "id": "woodworking/planter-box",
    "title": "Build a Planter Box",
    "description": "Cut and nail a pine planter box that introduces square joints and waterproof glue-ups.",
    "image": "/assets/quests/woodworking_planter_box_build.jpg",
    "npc": "/assets/npc/atlas.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Ready for another project? Let's make a pine planter box for your balcony or hydroponics rig.",
            "options": [
                {
                    "type": "goto",
                    "goto": "layout",
                    "text": "Walk me through the build"
                },
                {
                    "type": "goto",
                    "goto": "gather",
                    "text": "Just tell me what to grab"
                }
            ]
        },
        {
            "id": "layout",
            "text": "Cut four pine boards for a 60×25×20 cm box. Bevel the base to shed water and keep corners square.",
            "options": [
                {
                    "type": "goto",
                    "goto": "gather",
                    "text": "Let's gather supplies"
                },
                {
                    "type": "goto",
                    "goto": "drainage",
                    "text": "Any drainage tips?"
                }
            ]
        },
        {
            "id": "gather",
            "text": "Grab four pine boards, waterproof glue, your handsaw, and a fresh sandpaper pack for smoothing the edges. I'll loan the 16 oz claw hammer.",
            "options": [
                {
                    "type": "grantsItems",
                    "grantsItems": [
                        {
                            "id": "5fbabfcf-27d0-48f5-a89e-7aba8ca4b913",
                            "count": 1
                        }
                    ],
                    "text": "Gather materials"
                },
                {
                    "type": "goto",
                    "goto": "build",
                    "text": "Materials ready",
                    "requiresItems": [
                        {
                            "id": "6c075116-ebd1-4147-8666-ec6338ca251e",
                            "count": 4
                        },
                        {
                            "id": "30a7cd72-cf99-4ed7-9a4c-f30a68a4a399",
                            "count": 1
                        },
                        {
                            "id": "5fbabfcf-27d0-48f5-a89e-7aba8ca4b913",
                            "count": 1
                        },
                        {
                            "id": "ac6d5ef4-a7ec-4651-8f0c-db4c0ede865e",
                            "count": 1
                        },
                        {
                            "id": "2770ee5d-f9a0-4dc8-9c79-4f031fefd093",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "drainage",
            "text": "Drill 8 mm holes every 10 cm and leave 2 mm gaps between slats. Fabric or a liner helps soil stay put while it drains.",
            "options": [
                {
                    "type": "goto",
                    "goto": "gather",
                    "text": "Okay, let's get the wood"
                },
                {
                    "type": "goto",
                    "goto": "dryfit",
                    "text": "I've already drilled drainage"
                }
            ]
        },
        {
            "id": "dryfit",
            "text": "Dry-fit the pieces like a picture frame so corners align. Keep diagonals within 3 mm before gluing.",
            "options": [
                {
                    "type": "goto",
                    "goto": "build",
                    "text": "Alignment looks good"
                },
                {
                    "type": "goto",
                    "goto": "layout",
                    "text": "Revisit layout"
                }
            ]
        },
        {
            "id": "build",
            "text": "Glue edges, clamp lightly if you have them, and drive two 40 mm nails per corner from the kit. Wipe squeeze-out and keep it flat.",
            "options": [
                {
                    "type": "process",
                    "process": "assemble-planter-box",
                    "text": "Cut, glue, and nail the planter box"
                },
                {
                    "type": "goto",
                    "goto": "seal",
                    "text": "Can I add a liner?"
                }
            ]
        },
        {
            "id": "seal",
            "text": "Optionally add a liner or staple fabric so the wood can breathe. Keep bottom gaps open so water escapes.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Liner added, ready to fill"
                },
                {
                    "type": "goto",
                    "goto": "build",
                    "text": "Skipping liner, back to assembly"
                }
            ]
        },
        {
            "id": "finish",
            "text": "Great job! This planter can hold soil or a small hydroponic tub. Let the glue cure 8 hours first.",
            "options": [
                {
                    "type": "finish",
                    "text": "Looks sturdy!"
                }
            ]
        }
    ],
