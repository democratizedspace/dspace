{
    "id": "woodworking/tool-rack",
    "title": "Build a Tool Rack",
    "description": "Organize your workspace with a simple rack for hand tools.",
    "image": "/assets/quests/wooden_wall_tool_rack.jpg",
    "npc": "/assets/npc/atlas.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Your bench is buried under clamps and screwdrivers. Let's build a wall rack so every tool has a hook.",
            "options": [
                {
                    "type": "goto",
                    "goto": "design",
                    "text": "Show me a layout"
                },
                {
                    "type": "goto",
                    "goto": "gather",
                    "text": "I just need a cut list"
                }
            ]
        },
        {
            "id": "design",
            "text": "Measure wall space, mark studs 40 cm apart, and leave 2 cm between slots so chisels slide in.",
            "options": [
                {
                    "type": "goto",
                    "goto": "gather",
                    "text": "Got my measurements"
                },
                {
                    "type": "goto",
                    "goto": "mounting",
                    "text": "How do I hang this on masonry?"
                }
            ]
        },
        {
            "id": "gather",
            "text": "Grab a pine board, handsaw, glue, chisel, and sandpaper. Predrill for screws or anchors before hanging.",
            "options": [
                {
                    "type": "goto",
                    "goto": "cut",
                    "text": "Materials ready",
                    "requiresItems": [
                        {
                            "id": "6c075116-ebd1-4147-8666-ec6338ca251e",
                            "count": 1
                        },
                        {
                            "id": "ac6d5ef4-a7ec-4651-8f0c-db4c0ede865e",
                            "count": 1
                        },
                        {
                            "id": "30a7cd72-cf99-4ed7-9a4c-f30a68a4a399",
                            "count": 1
                        },
                        {
                            "id": "7f78fea7-e017-411d-bb4b-82c8b0940d34",
                            "count": 1
                        },
                        {
                            "id": "2770ee5d-f9a0-4dc8-9c79-4f031fefd093",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "mounting",
                    "text": "Walk me through anchors"
                }
            ]
        },
        {
            "id": "cut",
            "text": "Cut to 60 cm, plane rough edges, and chisel shallow slots. Dry-fit tools to confirm spacing.",
            "options": [
                {
                    "type": "goto",
                    "goto": "mount",
                    "text": "Slots look good",
                    "requiresItems": [
                        {
                            "id": "6c075116-ebd1-4147-8666-ec6338ca251e",
                            "count": 1
                        },
                        {
                            "id": "ac6d5ef4-a7ec-4651-8f0c-db4c0ede865e",
                            "count": 1
                        },
                        {
                            "id": "7f78fea7-e017-411d-bb4b-82c8b0940d34",
                            "count": 1
                        },
                        {
                            "id": "2770ee5d-f9a0-4dc8-9c79-4f031fefd093",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "design",
                    "text": "I want to adjust spacing"
                }
            ]
        },
        {
            "id": "mounting",
            "text": "Use 6 mm anchors in masonry or 70 mm screws into studs. Keep a level so the rack sits straight.",
            "options": [
                {
                    "type": "goto",
                    "goto": "cut",
                    "text": "Back to carving slots"
                },
                {
                    "type": "goto",
                    "goto": "mount",
                    "text": "Ready to mount"
                }
            ]
        },
        {
            "id": "mount",
            "text": "Clamp, mark holes, then predrill and fasten. Add a thin glue bead before driving screws.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Rack is secured"
                },
                {
                    "type": "goto",
                    "goto": "mounting",
                    "text": "Check anchor choice"
                }
            ]
        },
        {
            "id": "finish",
            "text": "Nice work! Space your tools by category and leave a blank slot for the one that always goes missing.",
            "options": [
                {
                    "type": "finish",
                    "text": "Everything in its place!"
                }
            ]
        }
    ],
