{
    "id": "woodworking/apply-finish",
    "title": "Apply a Wood Finish",
    "description": "Brush on a thin protective finish that resists moisture and highlights the grain you just sanded smooth.",
    "image": "/assets/quests/woodworking_apply_finish.jpg",
    "npc": "/assets/npc/atlas.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Time to give your build a durable sheen. Do you want a wipe-on route or a brush-on route?",
            "options": [
                {
                    "type": "goto",
                    "goto": "prep-area",
                    "text": "Walk me through prep and safety"
                },
                {
                    "type": "goto",
                    "goto": "prep-area",
                    "text": "I know my finish, let's choose it"
                }
            ]
        },
        {
            "id": "prep-area",
            "text": "Set cross-ventilation, remove ignition sources, and lay oily rags flat so they cannot self-heat in a pile.",
            "options": [
                {
                    "type": "goto",
                    "goto": "choose-finish",
                    "text": "Bench is ventilated and clear"
                },
                {
                    "type": "goto",
                    "goto": "safety-reset",
                    "text": "I smell solvent buildup already"
                }
            ]
        },
        {
            "id": "safety-reset",
            "text": "Pause. Open airflow, move rags to a nonflammable surface, and wait until the air clears before resuming.",
            "options": [
                {
                    "type": "goto",
                    "goto": "prep-area",
                    "text": "Air is clear now, retry setup"
                },
                {
                    "type": "goto",
                    "goto": "choose-finish",
                    "text": "Safety checks complete"
                }
            ]
        },
        {
            "id": "choose-finish",
            "text": "Wipe-on poly builds fast with thin coats. Hardwax oil looks natural but needs slower cure windows.",
            "options": [
                {
                    "type": "goto",
                    "goto": "gather",
                    "text": "Wipe-on poly path"
                },
                {
                    "type": "goto",
                    "goto": "gather",
                    "text": "Hardwax oil path"
                }
            ]
        },
        {
            "id": "gather",
            "text": "You need a paintbrush and sandpaper for between-coat scuffing. I can loan the brush if needed.",
            "options": [
                {
                    "type": "grantsItems",
                    "grantsItems": [
                        {
                            "id": "05dd84f7-b9bc-4eac-93c5-5838cab84b32",
                            "count": 1
                        }
                    ],
                    "text": "Take the brush"
                },
                {
                    "type": "goto",
                    "goto": "first-coat",
                    "text": "Start first coat",
                    "requiresItems": [
                        {
                            "id": "05dd84f7-b9bc-4eac-93c5-5838cab84b32",
                            "count": 1
                        },
                        {
                            "id": "2770ee5d-f9a0-4dc8-9c79-4f031fefd093",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "first-coat",
            "text": "Apply a thin coat with the grain and tip off edges before drips set. Keep the coat thin to reduce runs.",
            "options": [
                {
                    "type": "goto",
                    "goto": "inspect-coat",
                    "text": "Coat is down, inspect it"
                },
                {
                    "type": "goto",
                    "goto": "fix-runs",
                    "text": "I can see runs or sags"
                }
            ]
        },
        {
            "id": "fix-runs",
            "text": "Let it tack, flatten the run lightly with 320 grit, then recoat only the affected area.",
            "options": [
                {
                    "type": "goto",
                    "goto": "first-coat",
                    "text": "Retry with lighter passes"
                },
                {
                    "type": "goto",
                    "goto": "inspect-coat",
                    "text": "Runs corrected, verify surface"
                }
            ]
        },
        {
            "id": "inspect-coat",
            "text": "Checkpoint: no sticky puddles, even sheen, and no solvent smell trapped in the room.",
            "options": [
                {
                    "type": "goto",
                    "goto": "second-coat",
                    "text": "Surface passed inspection",
                    "requiresItems": [
                        {
                            "id": "05dd84f7-b9bc-4eac-93c5-5838cab84b32",
                            "count": 1
                        },
                        {
                            "id": "2770ee5d-f9a0-4dc8-9c79-4f031fefd093",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "safety-reset",
                    "text": "Room still smells unsafe"
                }
            ]
        },
        {
            "id": "second-coat",
            "text": "Scuff lightly, wipe dust, and apply a second thin coat for durability. Allow full cure per can instructions.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Second coat cured and dry to touch",
                    "requiresItems": [
                        {
                            "id": "05dd84f7-b9bc-4eac-93c5-5838cab84b32",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "fix-runs",
                    "text": "Second coat showed defects"
                }
            ]
        },
        {
            "id": "finish",
            "text": "Your project is protected and cleanly finished. Store finish sealed and keep oily rags spread flat until fully cured.",
            "options": [
                {
                    "type": "finish",
                    "text": "Finish quality verified"
                }
            ]
        }
    ],
    "rewards": [
        {
            "id": "30a7cd72-cf99-4ed7-9a4c-f30a68a4a399",
            "count": 1
        },
        {
            "id": "2770ee5d-f9a0-4dc8-9c79-4f031fefd093",
            "count": 1
        }
    ],
    "requiresQuests": [
        "woodworking/finish-sanding"
    ],
