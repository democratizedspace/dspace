{
    "id": "woodworking/apply-finish",
    "title": "Apply a Wood Finish",
    "description": "Brush on a thin protective finish that resists moisture and highlights the grain you just sanded smooth.",
    "image": "/assets/quests/woodworking_apply_finish.jpg",
    "npc": "/assets/npc/atlas.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Time to give your work a durable sheen. Want to choose a finish type or gather tools first?",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish-choice",
                    "text": "Help me pick a finish"
                },
                {
                    "type": "goto",
                    "goto": "gather",
                    "text": "What do I need?"
                }
            ]
        },
        {
            "id": "finish-choice",
            "text": "Wipe-on poly dries in 4–6 hours. Hardwax oil feels natural but needs longer between coats.",
            "options": [
                {
                    "type": "goto",
                    "goto": "gather",
                    "text": "Poly sounds good"
                },
                {
                    "type": "goto",
                    "goto": "apply",
                    "text": "I'm using hardwax oil"
                }
            ]
        },
        {
            "id": "gather",
            "text": "You'll need a paintbrush and a can of finish. I'll loan you the brush.",
            "options": [
                {
                    "type": "grantsItems",
                    "grantsItems": [
                        {
                            "id": "05dd84f7-b9bc-4eac-93c5-5838cab84b32",
                            "count": 1
                        }
                    ],
                    "text": "Take the brush"
                },
                {
                    "type": "goto",
                    "goto": "apply",
                    "text": "Ready to apply",
                    "requiresItems": [
                        {
                            "id": "05dd84f7-b9bc-4eac-93c5-5838cab84b32",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "apply",
            "text": "Brush on a thin coat with the grain, ventilate, and keep sparks away. Tip off strokes and chase edge drips.",
            "options": [
                {
                    "type": "goto",
                    "goto": "dry",
                    "text": "Coat applied"
                },
                {
                    "type": "goto",
                    "goto": "finish-choice",
                    "text": "Need a different finish"
                }
            ]
        },
        {
            "id": "dry",
            "text": "If you're using wipe-on poly, let it dry about 6 hours before handling. Hardwax oil often needs longer—follow the can's instructions. For durability, scuff with 320 grit and add a second coat.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Ready after one coat"
                },
                {
                    "type": "goto",
                    "goto": "apply",
                    "text": "Applying a second coat"
                }
            ]
        },
        {
            "id": "finish",
            "text": "Your project is protected and gleaming. Dispose of oily rags safely by laying them flat to dry.",
            "options": [
                {
                    "type": "finish",
                    "text": "Looks great!"
                }
            ]
        }
    ],
    "rewards": [
