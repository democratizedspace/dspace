            "options": [
                {
                    "type": "grantsItems",
                    "grantsItems": [
                        { "id": "112", "count": 4 },
                        { "id": "110", "count": 1 },
                        { "id": "109", "count": 1 }
                    ],
                    "text": "Buy lumber"
                },
                {
                    "type": "goto",
                    "goto": "assemble",
                    "requiresItems": [
                        { "id": "112", "count": 4 },
                        { "id": "110", "count": 1 },
                        { "id": "109", "count": 1 }
                    ],
                    "text": "All materials ready"
                }
            ]
        },
        {
            "id": "assemble",
            "text": "Cut the side panels and shelves, glue and clamp everything square, then let it dry. Finish by sanding the surfaces smooth.",
