{
    "id": "programming/temp-alert",
    "title": "Set Temperature Alert",
    "description": "Write a script that warns you when the sensor crosses a threshold.",
    "image": "/assets/quests/programming_temperature_threshold_alert.jpg",
    "npc": "/assets/npc/orion.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Your graph looks great—now let's make the stack scream when the room heats up.",
            "options": [
                {
                    "type": "goto",
                    "goto": "thresholds",
                    "text": "Set the guardrails",
                    "requiresItems": [
                        { "id": "c377a2ff-1391-4ad8-a150-1e4531067406", "count": 1 },
                        { "id": "99692727-4949-4950-8123-30a57abfa065", "count": 1 },
