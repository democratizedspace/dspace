                        { "id": "9607e03a-606a-4226-baf3-fa662d9ced01", "count": 1 }
                    ]
                }
            ]
        },
        {
            "id": "thresholds",
            "text": "Pick thresholds, hysteresis, and cooldown timers from your smoothed and deviation stats so alerts don't flap.",
            "options": [
                {
                    "type": "process",
                    "process": "draft-temperature-alert-thresholds",
                    "text": "Document thresholds and debounce"
                },
                {
                    "type": "goto",
                    "goto": "deploy",
                    "text": "Thresholds locked in",
                    "requiresItems": [{ "id": "b27f7cd8-c90f-4e4d-9ecd-fa8f3a716e7d", "count": 1 }]
                }
            ]
        },
        {
            "id": "deploy",
            "text": "Run a watchdog service on the Pi that polls the live endpoint, caches state, and posts a status page for quick checks.",
            "options": [
                {
                    "type": "process",
                    "process": "deploy-temperature-alert-service",
                    "text": "Deploy the alert service"
                },
                {
                    "type": "goto",
                    "goto": "test",
                    "text": "Service is running",
                    "requiresItems": [{ "id": "d9d6a921-2d4b-4ea3-be5b-e101ac0ede9d", "count": 1 }]
                }
            ]
        },
        {
            "id": "test",
            "text": "Simulate slow climbs and sudden spikes to make sure the alert fires once, logs its work, and then quiets down.",
            "options": [
                {
                    "type": "process",
                    "process": "simulate-temperature-alert",
                    "text": "Run alert simulations"
                },
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Alert works and is logged",
                    "requiresItems": [{ "id": "9d23795e-f2bd-4b82-9067-fa37eadbb84d", "count": 1 }]
                }
            ]
        },
        {
            "id": "finish",
            "text": "Great job! Your system now shouts when it should and stays quiet when it must.",
            "options": [
                {
                    "type": "finish",
                    "text": "Handy!"
                }
            ]
        }
    ],
