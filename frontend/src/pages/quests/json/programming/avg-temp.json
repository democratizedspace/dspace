{
    "id": "programming/avg-temp",
    "title": "Compute Average Temperature",
    "description": "Write a small script that reads your log file and prints the daily average temperature.",
    "image": "/assets/quests/programming_compute_avg_temperature.jpg",
    "npc": "/assets/npc/orion.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "You've been logging data. Let's compute a trustworthy average without hiding noise.",
            "options": [
                {
                    "type": "goto",
                    "goto": "collect",
                    "text": "Point me at the right log."
                }
            ]
        },
        {
            "id": "collect",
            "text": "Pull a clean CSV so the mean isn't distorted by serial glitches. Refresh the dataset if your last run was short.",
            "options": [
                {
                    "type": "process",
                    "process": "capture-hourly-temperature-log",
                    "text": "Record a fresh day of readings."
                },
                {
                    "type": "goto",
                    "goto": "chart",
                    "text": "CSV is ready for analysis.",
                    "requiresItems": [
                        {
                            "id": "d06c9f8d-6553-4f3c-9e10-05e1cf33a6b8",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "chart",
            "text": "Plot the CSV, spot outliers, and mark the central tendency you actually want to report.",
            "options": [
                {
                    "type": "process",
                    "process": "plot-temperature-data",
                    "text": "Generate a line chart and flag spikes."
                },
                {
                    "type": "goto",
                    "goto": "smooth",
                    "text": "Baseline chart is ready to annotate.",
                    "requiresItems": [
                        {
                            "id": "e7d1cd7d-e014-43a1-b1c8-9b7fb39deeed",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "smooth",
            "text": "Trim noisy edges, mark the mean, and annotate any dips that skew the average.",
            "options": [
                {
                    "type": "process",
                    "process": "refine-temperature-graph",
                    "text": "Annotate the mean and trim spikes."
                },
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Smoothed chart with average overlay is ready.",
                    "requiresItems": [
                        {
                            "id": "50360fd0-e296-4ef8-a3a9-00e049318166",
                            "count": 1
