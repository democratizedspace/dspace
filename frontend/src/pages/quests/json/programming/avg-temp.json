{
    "id": "programming/avg-temp",
    "title": "Compute Average Temperature",
    "description": "Write a small script that reads your log file and prints the daily average temperature.",
    "image": "/assets/quests/programming_compute_avg_temperature.jpg",
    "npc": "/assets/npc/orion.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "You've been logging data. Let's crunch the numbers for an average you can trust.",
            "options": [
                {
                    "type": "goto",
                    "goto": "prep",
                    "text": "Load the CSV",
                    "requiresItems": [
                        {
                            "id": "d06c9f8d-6553-4f3c-9e10-05e1cf33a6b8",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "prep",
            "text": "Parse the CSV, drop any obvious outliers, and keep timestamps intact so you can slice by day or hour.",
            "options": [
                {
                    "type": "process",
                    "process": "plot-temperature-data",
                    "text": "Plot a baseline chart"
                },
                {
                    "type": "goto",
                    "goto": "compute",
                    "text": "Data looks clean",
                    "requiresItems": [
                        {
                            "id": "e7d1cd7d-e014-43a1-b1c8-9b7fb39deeed",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "compute",
            "text": "Calculate mean, median, and count. Add them to your graph so anyone can see how steady the room stayed.",
            "options": [
                {
                    "type": "process",
                    "process": "refine-temperature-graph",
                    "text": "Annotate the averages"
                },
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Averages plotted and saved",
                    "requiresItems": [
                        {
                            "id": "50360fd0-e296-4ef8-a3a9-00e049318166",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "finish",
            "text": "Nice work! Those stats will help spot trends and power the rest of your automations.",
            "options": [
                {
                    "type": "finish",
                    "text": "Sweet!"
                }
            ]
        }
    ],
