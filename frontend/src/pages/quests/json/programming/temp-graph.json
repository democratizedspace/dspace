{
    "id": "programming/temp-graph",
    "title": "Serve a live temperature graph",
    "description": "Host a simple web page that fetches your live temperature JSON endpoint and renders an auto-refreshing temperature chart.",
    "image": "/assets/quests/temperature_log_line_chart.jpg",
    "npc": "/assets/npc/orion.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "You've been logging temperatures and plotting them locally. Now let's publish a live graph that anyone on the network can open.",
            "options": [
                {
                    "type": "goto",
                    "goto": "code",
                    "text": "Show me how.",
                    "requiresItems": [
                        {
                            "id": "f763cb7d-4e1a-4146-b304-4d8bfde4df86",
                            "count": 1
                        },
                        {
