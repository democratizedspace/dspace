                            "count": 1
                        },
                        {
                            "id": "b6fc1ed6-f399-4fdb-9f9d-3913f893f43d",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "code",
            "text": "Add a lightweight web page that calls your live temperature JSON endpoint and renders an updating line chart.",
            "options": [
                {
                    "type": "process",
                    "process": "publish-live-temperature-graph",
                    "text": "Publish the live dashboard"
                },
                {
                    "type": "goto",
                    "goto": "review",
                    "text": "Dashboard is up. Let's verify the graph behavior.",
                    "requiresItems": [
                        {
                            "id": "c377a2ff-1391-4ad8-a150-1e4531067406",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "review",
            "text": "Check the last five points. Accept only if updates arrive every minute and values stay in the expected 18-30C window.",
            "options": [
                {
                    "type": "goto",
                    "goto": "stable",
                    "text": "Cadence and values look good."
                },
                {
                    "type": "goto",
                    "goto": "drift",
                    "text": "The graph is stale or values drift outside the safe window."
                }
            ]
        },
        {
            "id": "drift",
            "text": "Do not trust a drifting dashboard. Verify API timestamps, browser cache headers, and sensor units before declaring success.",
            "options": [
                {
                    "type": "process",
                    "process": "publish-live-temperature-graph",
                    "text": "Republish after fixes."
                },
                {
                    "type": "goto",
                    "goto": "review",
                    "text": "Re-check five fresh points."
                }
            ]
        },
        {
            "id": "stable",
            "text": "Great. Capture a screenshot/log note for your ops journal so others can audit this dashboard baseline later.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Evidence captured.",
