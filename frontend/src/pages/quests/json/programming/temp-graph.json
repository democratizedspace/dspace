                    ]
                }
            ]
        },
        {
            "id": "finish",
            "text": "Nice work! Visualizing data makes patterns much easier to spot, and now you have pass/fail checks for reliability.",
            "options": [
                {
                    "type": "finish",
                    "text": "Looks great!"
                }
            ]
        }
