                }
            ]
        },
        {
            "id": "wire",
            "text": "Mount the logger to your Pi, enable pyserial, and watch a few readings stream in. Keep the USB cable strain-relieved so it doesn't brown out mid-request.",
            "options": [
                {
                    "type": "process",
                    "process": "pyserial-install",
                    "text": "Install pyserial on the Pi"
                },
                {
                    "type": "process",
                    "process": "raspberry-pi-serial-log",
                    "text": "Confirm the Pi can read the sensor"
                },
                {
                    "type": "goto",
                    "goto": "publish",
                    "text": "Serial feed is stable",
                    "requiresItems": [
                        {
                            "id": "e62dca47-fba6-4ad5-abd4-95dd41f5f4c2",
                            "count": 1
                        },
                        {
                            "id": "ce140453-c7ef-42c9-b9f9-38acfb4219cf",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "publish",
            "text": "Add a `/api/temp` route that returns the latest reading, units, and timestamp. Set the content-type header, clamp out-of-range values, and return a helpful 503 if the sensor drops.",
            "options": [
                {
                    "type": "process",
                    "process": "deploy-temperature-json-endpoint",
                    "text": "Expose the JSON route"
                },
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Endpoint returns 200 with JSON body",
                    "requiresItems": [
                        {
