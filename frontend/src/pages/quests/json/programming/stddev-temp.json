{
    "id": "programming/stddev-temp",
    "title": "Compute Temperature Standard Deviation",
    "description": "Extend your script to report the standard deviation of daily temperature readings.",
    "image": "/assets/quests/programming_temperature_stddev.jpg",
    "npc": "/assets/npc/orion.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "You've nailed median and mean. Now let's quantify variability with standard deviation.",
            "options": [
                {
                    "type": "goto",
                    "goto": "prep",
                    "text": "Load the latest dataset",
                    "requiresItems": [
                        {
                            "id": "d06c9f8d-6553-4f3c-9e10-05e1cf33a6b8",
                            "count": 5.0
                        }
                    ]
                }
            ]
        },
        {
            "id": "prep",
            "text": "Filter malformed rows, then compute mean + variance before taking the square root for standard deviation.",
            "options": [
                {
                    "type": "process",
                    "process": "plot-temperature-data",
                    "text": "Generate a baseline plot for context"
                },
                {
                    "type": "goto",
                    "goto": "interpret",
                    "text": "Deviation report generated",
                    "requiresItems": [
                        {
                            "id": "e7d1cd7d-e014-43a1-b1c8-9b7fb39deeed",
                            "count": 3.0
                        }
                    ]
                }
            ]
        },
        {
            "id": "interpret",
            "text": "Interpret the deviation: healthy indoor telemetry should stay low and consistent. Large spikes mean either environment shifts or sensor noise.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Deviation is in expected band and documented",
                    "requiresItems": [
                        {
                            "id": "e7d1cd7d-e014-43a1-b1c8-9b7fb39deeed",
                            "count": 3.0
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "retest",
                    "text": "Deviation is too high or inconsistent"
                }
            ]
        },
        {
            "id": "retest",
            "text": "Troubleshoot before retrying: reseat thermistor wiring, capture a fresh log window, then recompute standard deviation and compare.",
            "options": [
                {
                    "type": "process",
                    "process": "capture-hourly-temperature-log",
                    "text": "Capture replacement log"
                },
                {
                    "type": "process",
                    "process": "plot-temperature-data",
                    "text": "Recompute baseline + deviation context"
                },
                {
                    "type": "goto",
                    "goto": "interpret",
                    "text": "Re-test with the new log",
                    "requiresItems": [
                        {
                            "id": "d06c9f8d-6553-4f3c-9e10-05e1cf33a6b8",
                            "count": 5.0
                        },
                        {
                            "id": "e7d1cd7d-e014-43a1-b1c8-9b7fb39deeed",
                            "count": 3.0
                        }
                    ]
                }
            ]
        },
        {
            "id": "finish",
            "text": "Great! Deviation gives you a reliable noise budget for future alerts.",
            "options": [
                {
                    "type": "finish",
                    "text": "Done!"
                }
            ]
        }
    ],
