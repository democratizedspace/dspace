{
    "id": "programming/temp-logger",
    "title": "Log Temperature Data",
    "description": "Write a simple script that records hourly temperature readings.",
    "image": "/assets/quests/programming_temperature_logger_script.jpg",
    "npc": "/assets/npc/orion.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "You've taken single readings. Now let's wire a logger that quietly records the room every hour so we can graph it later.",
            "options": [
                {
                    "type": "goto",
                    "goto": "wire",
                    "text": "I've got my Arduino kit ready."
                }
            ]
        },
        {
            "id": "wire",
            "text": "Build the divider on a breadboard and flash a sketch that streams readings over USB. A tidy rig now makes the log trustworthy later.",
            "options": [
                {
                    "type": "process",
                    "process": "assemble-thermistor-logger",
                    "text": "Wire the Uno and thermistor"
                },
                {
                    "type": "goto",
                    "goto": "log",
                    "text": "Rig is wired and sketch uploaded",
                    "requiresItems": [
                        {
                            "id": "e62dca47-fba6-4ad5-abd4-95dd41f5f4c2",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "log",
            "text": "Let it run for a day, then roll the readings into a CSV so we can reuse them in the plotting quests.",
            "options": [
                {
                    "type": "process",
                    "process": "capture-hourly-temperature-log",
                    "text": "Collect and export the log"
                },
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "CSV saved",
                    "requiresItems": [
                        {
                            "id": "d06c9f8d-6553-4f3c-9e10-05e1cf33a6b8",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "finish",
            "text": "Excellent! With regular logs you'll spot interesting patterns in your environment.",
            "options": [
                {
                    "type": "finish",
                    "text": "Cool!"
                }
            ]
        }
    ],
