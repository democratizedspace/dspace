                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "visualize",
            "text": "Overlay the moving average on your existing chart and mark any periods where the window went blind.",
            "options": [
                {
                    "type": "process",
                    "process": "render-moving-average-chart",
                    "text": "Plot the smoothed trend"
                },
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Smoothed chart ready",
                    "requiresItems": [
                        {
                            "id": "7c9b814d-93fb-4b7f-8a4f-89f1de6f1fcf",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "finish",
            "text": "Nice! The moving average reveals trends in real time without letting brief spikes boss you around.",
            "options": [
                {
                    "type": "finish",
                    "text": "Data looks smoother."
                }
            ]
        }
