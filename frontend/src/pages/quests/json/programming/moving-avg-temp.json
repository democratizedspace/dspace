{
    "id": "programming/moving-avg-temp",
    "title": "Compute Moving Average Temperature",
    "description": "Add a moving average to your temperature analysis script.",
    "image": "/assets/quests/programming_moving_average_temperature.jpg",
    "npc": "/assets/npc/orion.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Your average gives the big picture; now prove your moving average is stable enough for alerting decisions.",
            "options": [
                {
                    "type": "goto",
                    "goto": "prep",
                    "text": "Use the latest logger export.",
                    "requiresItems": [
