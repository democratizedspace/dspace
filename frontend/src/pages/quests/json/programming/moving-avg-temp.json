                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "code",
            "text": "Calculate a moving average over the last N readings in your log, flagging any gaps so alerts won't miss a stalled sensor.",
            "options": [
                {
                    "type": "process",
                    "process": "compute-moving-average-series",
                    "text": "Generate the rolling series"
                },
                {
                    "type": "goto",
