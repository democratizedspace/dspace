{
    "id": "programming/temp-json-api",
    "title": "Serve Temperature as JSON",
    "description": "Expose the latest sensor reading at a live temperature JSON endpoint.",
    "image": "/assets/quests/programming_temperature_json_api.jpg",
    "npc": "/assets/npc/orion.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Your API returns static data. Let's feed it live temperature readings.",
            "options": [
                {
                    "type": "goto",
                    "goto": "deploy",
                    "text": "Sounds great.",
                    "requiresItems": [
                        {
                            "id": "d06c9f8d-6553-4f3c-9e10-05e1cf33a6b8",
                            "count": 1
                        },
                        {
                            "id": "e62dca47-fba6-4ad5-abd4-95dd41f5f4c2",
                            "count": 1
                        },
                        {
                            "id": "ce140453-c7ef-42c9-b9f9-38acfb4219cf",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "deploy",
            "text": "Deploy `/temp` so it reads from the sensor, then collect three timestamped samples over at least ten minutes to prove it is live.",
            "options": [
                {
                    "type": "process",
                    "process": "deploy-temperature-json-endpoint",
                    "text": "Publish the JSON route"
                },
                {
                    "type": "goto",
                    "goto": "interpret",
                    "text": "I logged three samples in the 15-35°C expected range.",
                    "requiresItems": [
                        {
                            "id": "f763cb7d-4e1a-4146-b304-4d8bfde4df86",
                            "count": 1
                        },
                        {
                            "id": "d06c9f8d-6553-4f3c-9e10-05e1cf33a6b8",
                            "count": 2
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "out-of-range",
                    "text": "One or more samples were outside 15-35°C or missing.",
                    "requiresItems": [
                        {
                            "id": "d06c9f8d-6553-4f3c-9e10-05e1cf33a6b8",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "out-of-range",
            "text": "Good catch. Verify sensor wiring and API parse logic, then take a fresh sample set before trusting this endpoint.",
            "options": [
                {
                    "type": "goto",
                    "goto": "retest",
                    "text": "I patched wiring/parsing and will re-test.",
                    "requiresItems": [
                        {
                            "id": "ce140453-c7ef-42c9-b9f9-38acfb4219cf",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "retest",
            "text": "Run another ten-minute capture window and compare it against room conditions before re-evaluating pass/fail.",
            "options": [
                {
                    "type": "process",
                    "process": "capture-hourly-temperature-log",
                    "text": "Capture another temperature log"
                },
                {
                    "type": "goto",
                    "goto": "deploy",
                    "text": "Retest data collected; evaluate bounds again.",
                    "requiresItems": [
                        {
                            "id": "d06c9f8d-6553-4f3c-9e10-05e1cf33a6b8",
                            "count": 2
                        }
                    ]
                }
            ]
        },
        {
            "id": "interpret",
            "text": "Interpret the sample trend: if values track ambient expectations and update cadence, your live temperature JSON endpoint is trustworthy.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Interpretation documented and endpoint validated.",
                    "requiresItems": [
                        {
                            "id": "f763cb7d-4e1a-4146-b304-4d8bfde4df86",
                            "count": 1
                        },
                        {
                            "id": "d06c9f8d-6553-4f3c-9e10-05e1cf33a6b8",
                            "count": 2
                        }
                    ]
                }
            ]
        },
        {
            "id": "finish",
            "text": "Nice! Clients can now fetch the current temperature from your server with confidence in the data quality.",
            "options": [
                {
                    "type": "finish",
                    "text": "API live."
                }
            ]
        }
    ],
