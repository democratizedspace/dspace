{
    "id": "programming/hello-sensor",
    "title": "Log Temperature Data",
    "description": "dChat shows you how a short script can capture sensor information for later analysis.",
    "image": "/assets/quests/programming_hello_sensor_logging.jpg",
    "npc": "/assets/npc/dChat.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Greetings! I'm dChat. Let's turn a loose thermistor into a tidy logging rig you can build on.",
            "options": [
                {
                    "type": "goto",
                    "goto": "wire",
                    "text": "Walk me through the wiring."
                }
            ]
        },
        {
            "id": "wire",
            "text": "Seat the thermistor in a voltage divider, flash the sketch, and confirm readings in serial before you leave the bench.",
            "options": [
                {
                    "type": "process",
                    "process": "assemble-thermistor-logger",
                    "text": "Build the logging rig."
                },
                {
                    "type": "goto",
                    "goto": "log",
                    "text": "Serial stream looks steady.",
                    "requiresItems": [
                        {
                            "id": "e62dca47-fba6-4ad5-abd4-95dd41f5f4c2",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "log",
            "text": "Let the rig run long enough to capture real swings, then export the readings to CSV so you can analyze them offline.",
            "options": [
                {
                    "type": "process",
                    "process": "capture-hourly-temperature-log",
                    "text": "Log a fresh dataset."
                },
                {
                    "type": "goto",
                    "goto": "plot",
                    "text": "CSV exported with timestamps.",
                    "requiresItems": [
                        {
                            "id": "d06c9f8d-6553-4f3c-9e10-05e1cf33a6b8",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "plot",
            "text": "Plot the CSV with Python so you can eyeball noise, offsets, and any spikes before trusting the stream.",
            "options": [
                {
                    "type": "process",
                    "process": "plot-temperature-data",
                    "text": "Generate the first chart."
                },
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Chart renders without gaps.",
                    "requiresItems": [
                        {
                            "id": "e7d1cd7d-e014-43a1-b1c8-9b7fb39deeed",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "finish",
            "text": "Excellent! You have a verified hardware loop plus a chart you can extend into alerts or APIs.",
            "options": [
                {
                    "type": "finish",
                    "text": "On to deeper analytics.",
                    "requiresItems": [
                        {
                            "id": "e7d1cd7d-e014-43a1-b1c8-9b7fb39deeed",
                            "count": 1
                        }
                    ]
                }
            ]
        }
    ],
