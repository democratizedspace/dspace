{
    "id": "programming/hello-sensor",
    "title": "Log Temperature Data",
    "description": "dChat shows how a short script can capture sensor readings for later analysis.",
    "image": "/assets/quests/programming_hello_sensor_logging.jpg",
    "npc": "/assets/npc/dChat.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "dChat here! Let's go from bare breadboard to a logger that saves real temps.",
            "options": [
                {
                    "type": "goto",
                    "goto": "build",
                    "text": "Wire up the rig."
                }
            ]
        },
        {
            "id": "build",
            "text": "Wire a thermistor divider, flash the sketch, and confirm serial output.",
            "options": [
                {
                    "type": "process",
                    "process": "assemble-thermistor-logger",
                    "text": "Flash and assemble the logger"
                },
                {
                    "type": "goto",
                    "goto": "log",
                    "text": "Logger is wired and streaming numbers.",
                    "requiresItems": [
                        {
                            "id": "e62dca47-fba6-4ad5-abd4-95dd41f5f4c2",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "log",
            "text": "Let it run for a clean dataset and export a CSV while it keeps sampling.",
            "options": [
                {
                    "type": "process",
                    "process": "capture-hourly-temperature-log",
                    "text": "Capture an hourly CSV export"
                },
                {
                    "type": "goto",
                    "goto": "plot",
                    "text": "CSV saved—ready to plot.",
                    "requiresItems": [
                        {
                            "id": "d06c9f8d-6553-4f3c-9e10-05e1cf33a6b8",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "plot",
            "text": "Turn the CSV into a quick line chart to spot drift or spikes at a glance.",
            "options": [
                {
                    "type": "process",
                    "process": "plot-temperature-data",
                    "text": "Render the temperature chart"
                },
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Chart exported with a clean timeline.",
                    "requiresItems": [
                        {
                            "id": "e7d1cd7d-e014-43a1-b1c8-9b7fb39deeed",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "finish",
            "text": "Your loop now logs data and a quick chart you can reuse for bigger builds.",
            "options": [
                {
                    "type": "finish",
                    "text": "Data looks solid."
                }
            ]
        }
