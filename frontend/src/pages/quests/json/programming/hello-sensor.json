{
    "id": "programming/hello-sensor",
    "title": "Log Temperature Data",
    "description": "dChat shows you how a short script can capture sensor information for later analysis.",
    "image": "/assets/quests/programming_hello_sensor_logging.jpg",
    "npc": "/assets/npc/dChat.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Greetings! I'm dChat. Let's wire a thermistor rig, log data, and turn it into a graph you can reuse.",
            "options": [
                {
                    "type": "goto",
                    "goto": "assemble",
                    "text": "Sounds good"
                }
            ]
        },
        {
            "id": "assemble",
            "text": "Grab your Arduino, thermistor, and a laptop with the IDE. We'll build a quick voltage divider and load a serial logging sketch.",
            "options": [
                {
                    "type": "process",
                    "process": "assemble-thermistor-logger",
                    "text": "Wire the rig and upload the sketch.",
                    "goto": "sample"
                }
            ]
        },
        {
            "id": "sample",
            "text": "Open the serial monitor and make sure the readings move when you pinch the thermistor.",
            "options": [
                {
                    "type": "process",
                    "process": "arduino-thermistor-read",
                    "text": "Verify live readings look reasonable.",
                    "goto": "log",
                    "requiresItems": [
                        {
                            "id": "e62dca47-fba6-4ad5-abd4-95dd41f5f4c2",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "log",
            "text": "Let the logger run for an hour, then export the CSV while the rig keeps rolling.",
            "options": [
                {
                    "type": "process",
                    "process": "capture-hourly-temperature-log",
                    "text": "Capture the CSV while keeping the rig powered.",
                    "goto": "visualize",
                    "requiresItems": [
                        {
                            "id": "e62dca47-fba6-4ad5-abd4-95dd41f5f4c2",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "visualize",
            "text": "Load the CSV into Python and give yourself a quick temperature plot to sanity-check the data.",
            "options": [
                {
                    "type": "process",
                    "process": "plot-temperature-data",
                    "text": "Plot the readings.",
                    "goto": "polish",
                    "requiresItems": [
                        {
                            "id": "d06c9f8d-6553-4f3c-9e10-05e1cf33a6b8",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "polish",
            "text": "Smooth the line, annotate highs and lows, and get it ready to share with the crew.",
            "options": [
                {
                    "type": "process",
                    "process": "refine-temperature-graph",
                    "text": "Clean up the chart for sharing.",
                    "goto": "finish",
                    "requiresItems": [
                        {
                            "id": "e7d1cd7d-e014-43a1-b1c8-9b7fb39deeed",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "finish",
            "text": "Excellent! Save that annotated graph template—next you'll automate a live JSON endpoint and dashboard from the same rig.",
            "options": [
                {
                    "type": "finish",
                    "text": "Cool!",
                    "requiresItems": [
                        {
                            "id": "50360fd0-e296-4ef8-a3a9-00e049318166",
                            "count": 1
                        }
                    ]
                }
            ]
        }
    ],
