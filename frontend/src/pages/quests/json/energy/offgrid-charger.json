                    "grantsItems": [
                        { "id": "5", "count": 1 },
                        { "id": "6", "count": 1 }
                    ],
                    "text": "Take the solar kit"
                },
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Phone is charging!",
                    "requiresItems": [
                        { "id": "5", "count": 1 },
                        { "id": "6", "count": 1 }
                    ]
                }
            ]
        },
        {
            "id": "finish",
            "text": "Nice work! With this setup you can stay powered even off-grid.",
            "options": [{ "type": "finish", "text": "Handy!" }]
        }
    ],
    "rewards": [],
    "requiresQuests": ["energy/solar"]
}
