                            "count": 1
                        },
                        {
                            "id": "fb60696a-6c94-4e5e-9277-b62377ee6d73",
                            "count": 1
                        }
                    ],
                    "text": "Take the solar kit"
                },
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Phone is charging!",
