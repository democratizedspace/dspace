{
    "id": "energy/offgrid-charger",
    "title": "Charge a Device Off-Grid",
    "description": "Charge a phone off-grid with a 200 W panel, charge controller, 200 Wh LiFePO4 battery and USB cable.",
    "image": "/assets/quests/offgrid_phone_charging_200Wh.jpg",
    "npc": "/assets/npc/orion.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Phone low? Set up a 200 W panel, charge controller, 200 Wh LiFePO4 battery, fused lead kit, USB cable, and your smartphone on dry ground. Handle connectors by insulation and stop if weather turns.",
            "options": [
                {
                    "type": "goto",
                    "goto": "kit",
                    "text": "Stage the off-grid charging kit"
                }
            ]
        },
        {
            "id": "kit",
            "text": "Take the full kit and perform a safety pre-check: dry surface, no frayed wires, and no hot connectors from prior runs.",
            "options": [
                {
                    "type": "grantsItems",
                    "grantsItems": [
                        {
                            "id": "02b32152-a7b2-458e-9643-7b754c722165",
                            "count": 1
                        },
                        {
                            "id": "cfe87611-623a-45b0-9243-422cd8a73a16",
                            "count": 1
                        },
                        {
                            "id": "67a682f8-a8a4-4a14-8806-5ccd3620fd3b",
                            "count": 1
                        },
                        {
                            "id": "fb60696a-6c94-4e5e-9277-b62377ee6d73",
                            "count": 1
                        },
                        {
                            "id": "0ccc4a37-b719-4f7c-ba73-9e4becdcd778",
                            "count": 1
                        }
                    ],
                    "text": "Take the solar kit"
                },
                {
                    "type": "goto",
                    "goto": "wire",
                    "text": "Everything is staged and dry.",
                    "requiresItems": [
                        {
                            "id": "02b32152-a7b2-458e-9643-7b754c722165",
                            "count": 1
                        },
                        {
                            "id": "cfe87611-623a-45b0-9243-422cd8a73a16",
                            "count": 1
                        },
                        {
                            "id": "67a682f8-a8a4-4a14-8806-5ccd3620fd3b",
                            "count": 1
                        },
                        {
                            "id": "fb60696a-6c94-4e5e-9277-b62377ee6d73",
                            "count": 1
                        },
                        {
                            "id": "0ccc4a37-b719-4f7c-ba73-9e4becdcd778",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "wire",
            "text": "Battery first, then panel: red to positive, black to negative, fuse in-line, controller elevated. If anything sparks or heats, pull the fuse immediately.",
            "options": [
                {
                    "type": "process",
                    "process": "wire-portable-solar-kit",
                    "text": "Wire and fuse the system"
                },
                {
                    "type": "goto",
                    "goto": "profile",
                    "text": "Everything is tight, fused, and quiet.",
                    "requiresItems": [
                        {
                            "id": "8e540f94-91e0-47a1-b6ca-78e8b48aefac",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "safety-stop",
                    "text": "I saw heat, sparks, or loose terminals"
                }
            ]
        },
        {
            "id": "profile",
            "text": "Set LiFePO4 profile: absorb 14.4 V, float 13.6 V, temp sensor attached. Save the profile so this setup is reproducible.",
            "options": [
                {
                    "type": "process",
                    "process": "configure-charge-controller-profile",
                    "text": "Save the profile"
                },
                {
                    "type": "goto",
                    "goto": "charge-strategy",
                    "text": "Profile saved; cables remain cool.",
                    "requiresItems": [
                        {
                            "id": "22a50cfd-4433-4ce7-bbed-e4038338191b",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "safety-stop",
                    "text": "Controller warnings appeared"
                }
            ]
        },
        {
            "id": "charge-strategy",
            "text": "Pick a charging strategy. Direct sun is fastest; low-light mode requires repositioning and staged checks.",
            "options": [
                {
                    "type": "goto",
                    "goto": "charge",
                    "text": "Run direct-sun charging"
                },
                {
                    "type": "goto",
                    "goto": "low-light-recovery",
                    "text": "Use low-light recovery strategy"
                }
            ]
        },
        {
            "id": "charge",
            "text": "Face the panel toward the sun, shade the battery, and charge until you collect 200 Wh. Stop immediately if fuse warms or voltage sags sharply.",
            "options": [
                {
                    "type": "process",
                    "process": "harvest-200Wh-portable",
                    "text": "Harvest some energy"
                },
                {
                    "type": "goto",
                    "goto": "phone",
                    "text": "200 Wh harvested and stable.",
                    "requiresItems": [
                        {
                            "id": "b02ecff5-1f7d-4247-a09d-7d6cd6bb218a",
                            "count": 200
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "safety-stop",
                    "text": "Unsafe heat or weather during harvest"
                }
            ]
        },
        {
            "id": "low-light-recovery",
            "text": "Low-light branch: re-angle the panel every 20 minutes, reduce USB draw, and verify controller remains in a safe charging band.",
            "options": [
                {
                    "type": "process",
                    "process": "harvest-200Wh-portable",
                    "text": "Run staged low-light charging checks"
                },
                {
                    "type": "goto",
                    "goto": "charge",
                    "text": "Output stabilized; return to main charge path"
                },
                {
                    "type": "goto",
                    "goto": "safety-stop",
                    "text": "Output unstable or connectors heating"
                }
            ]
        },
        {
            "id": "phone",
            "text": "Plug USB cable into the controller and phone. Keep cable off wet ground and verify cable temperature stays safe during the session.",
            "options": [
                {
                    "type": "process",
                    "process": "charge-smartphone-offgrid",
                    "text": "Charge the phone"
                },
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Phone charged and cable stayed cool.",
                    "requiresItems": [
                        {
                            "id": "2a9083b7-8578-45e3-8d76-7a298462f847",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "safety-stop",
                    "text": "Cable warmed or phone failed to negotiate charge"
                }
            ]
        },
        {
            "id": "safety-stop",
            "text": "Safety stop engaged. Disconnect panel first, then battery, inspect fuse and terminals, and do not resume until heat/spark causes are corrected.",
            "options": [
                {
                    "type": "process",
                    "process": "wire-portable-solar-kit",
                    "text": "Perform safe disconnect and rewire"
                },
                {
                    "type": "goto",
                    "goto": "wire",
                    "text": "Retry wiring and verification"
                }
            ]
        },
        {
            "id": "finish",
            "text": "Nice work! Disconnect in reverse order, coil the USB cable, and store the panel and battery out of direct sun.",
            "options": [
                {
                    "type": "finish",
                    "text": "Handy!"
                }
            ]
        }
    ],
    "rewards": [
