{
    "id": "energy/offgrid-charger",
    "title": "Charge a Device Off-Grid",
    "description": "Charge a phone off-grid with a 200 W panel, charge controller, 200 Wh LiFePO4 battery and USB cable.",
    "image": "/assets/quests/offgrid_phone_charging_200Wh.jpg",
    "npc": "/assets/npc/orion.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Phone low? Set up a 200 W panel, charge controller, 200 Wh LiFePO4 battery and USB cable on dry ground. Handle connectors by their insulation and stop if cables warm or weather turns.",
            "options": [
                {
                    "type": "process",
                    "process": "stage-offgrid-charger",
                    "text": "Lay out the panel, controller, and pack"
                },
                {
                    "type": "goto",
                    "goto": "wire",
                    "text": "Gear staged and inspected",
                    "requiresItems": [
                        { "id": "2a7a18f8-6f16-4a3f-ae99-239ace9132dd", "count": 1 }
                    ]
                }
            ]
        },
        {
            "id": "wire",
            "text": "Unfold the panel toward the sun, snap MC4 leads into the controller, then clip controller output to the LiFePO4 pack. Shade the battery on a nonflammable surface and check polarity before you touch USB ports.",
            "options": [
                {
                    "type": "process",
                    "process": "wire-and-safety-check-offgrid-charger",
                    "text": "Strain-relief the connectors",
                    "requiresItems": [
                        { "id": "2a7a18f8-6f16-4a3f-ae99-239ace9132dd", "count": 1 }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "charge",
                    "text": "Controller is live and stable",
                    "requiresItems": [
                        { "id": "c198de14-611f-4427-9d70-b42f5f5173f0", "count": 1 }
                    ]
                }
            ]
        },
        {
            "id": "charge",
            "text": "Plug the USB cable into the controller and your phone. Verify the pack stays cool and the charge current is steady before you pocket the device.",
            "options": [
                {
                    "type": "process",
                    "process": "charge-phone-offgrid",
                    "text": "Top off the phone off-grid",
                    "requiresItems": [
                        { "id": "c198de14-611f-4427-9d70-b42f5f5173f0", "count": 1 }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Phone is charging!",
                    "requiresItems": [
                        { "id": "3f09a2ad-5599-4613-8c03-c9b993c337e1", "count": 1 }
                    ]
                }
            ]
        },
        {
            "id": "finish",
            "text": "Nice work! Disconnect in reverse order, coil the USB cable, and store the panel and battery out of direct sun.",
            "options": [
                {
                    "type": "finish",
                    "text": "Handy!",
                    "requiresItems": [
                        { "id": "3f09a2ad-5599-4613-8c03-c9b993c337e1", "count": 1 }
                    ]
                }
            ]
        }
    ],
    "rewards": [],
