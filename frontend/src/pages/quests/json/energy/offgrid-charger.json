{
    "id": "energy/offgrid-charger",
    "title": "Charge a Device Off-Grid",
    "description": "Top off your phone using only sunlight and a battery pack.",
    "image": "/assets/quests/solar_200Wh.jpg",
    "npc": "/assets/npc/orion.jpg",
    "start": "start",
    "dialogue": [
        {
