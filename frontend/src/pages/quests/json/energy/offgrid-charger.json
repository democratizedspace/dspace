{
    "id": "energy/offgrid-charger",
    "title": "Charge a Device Off-Grid",
    "description": "Charge a phone off-grid with a 200 W panel, charge controller, 200 Wh LiFePO4 battery and USB cable.",
    "image": "/assets/quests/offgrid_phone_charging_200Wh.jpg",
    "npc": "/assets/npc/orion.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Phone low? Set up a 200 W panel, charge controller, 200 Wh LiFePO4 battery, fused lead kit, USB cable, and your smartphone on dry ground. Handle connectors by their insulation and stop if cables warm or weather turns.",
            "options": [
                {
                    "type": "goto",
                    "goto": "kit",
                    "text": "Let's give it a try.",
                    "requiresItems": [
                        {
                            "id": "82577af7-6724-4cb2-8922-f7140e550145",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "weather-hold",
                    "text": "Cloudburst rolling in—pause setup until conditions are safe."
                }
            ]
        },
        {
            "id": "weather-hold",
            "text": "Good call. Park the kit under cover, cap exposed connectors, and wait for dry footing before touching terminals again.",
            "options": [
                {
                    "type": "goto",
                    "goto": "kit",
                    "text": "Weather cleared and workspace is dry. Resume setup."
                }
            ]
        },
        {
            "id": "kit",
            "text": "Unfold the panel, set the controller, battery, and fused leads on a dry board, and keep metal away from the terminals.",
            "options": [
                {
                    "type": "grantsItems",
                    "grantsItems": [
                        {
                            "id": "02b32152-a7b2-458e-9643-7b754c722165",
                            "count": 1
                        },
                        {
                            "id": "cfe87611-623a-45b0-9243-422cd8a73a16",
                            "count": 1
                        },
                        {
                            "id": "67a682f8-a8a4-4a14-8806-5ccd3620fd3b",
                            "count": 1
                        },
                        {
                            "id": "fb60696a-6c94-4e5e-9277-b62377ee6d73",
                            "count": 1
                        },
                        {
                            "id": "0ccc4a37-b719-4f7c-ba73-9e4becdcd778",
                            "count": 1
                        }
                    ],
                    "text": "Take the solar kit"
                },
                {
                    "type": "goto",
                    "goto": "precheck",
                    "text": "Everything is staged and dry.",
                    "requiresItems": [
                        {
                            "id": "02b32152-a7b2-458e-9643-7b754c722165",
                            "count": 1
                        },
                        {
                            "id": "cfe87611-623a-45b0-9243-422cd8a73a16",
                            "count": 1
                        },
                        {
                            "id": "67a682f8-a8a4-4a14-8806-5ccd3620fd3b",
                            "count": 1
                        },
                        {
                            "id": "fb60696a-6c94-4e5e-9277-b62377ee6d73",
                            "count": 1
                        },
                        {
                            "id": "0ccc4a37-b719-4f7c-ba73-9e4becdcd778",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "precheck",
            "text": "Before live wiring, choose your plan: direct sun for speed or partial shade to keep thermal headroom. Either path must keep connectors cool and fuse accessible.",
            "options": [
                {
                    "type": "goto",
                    "goto": "wire",
                    "text": "Run a direct-sun setup and monitor cable temperature every 5 minutes.",
                    "requiresItems": [
                        {
                            "id": "0ccc4a37-b719-4f7c-ba73-9e4becdcd778",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "wire",
                    "text": "Start in partial shade for a conservative ramp-up, then re-aim after a stability check.",
                    "requiresItems": [
                        {
                            "id": "0ccc4a37-b719-4f7c-ba73-9e4becdcd778",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "weather-hold",
                    "text": "Surface got damp or windy; pause and reset safety conditions."
                }
            ]
        },
        {
            "id": "wire",
            "text": "Battery first, then panel—keep red to positive, black to negative, fuse in line, and controller off the ground. If anything sparks or heats up, pull the fuse.",
            "options": [
                {
                    "type": "process",
                    "process": "wire-portable-solar-kit",
                    "text": "Wire and fuse the system"
                },
                {
                    "type": "goto",
                    "goto": "profile",
                    "text": "Everything is tight, fused, and quiet.",
                    "requiresItems": [
                        {
                            "id": "8e540f94-91e0-47a1-b6ca-78e8b48aefac",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "rewire",
                    "text": "I spotted polarity uncertainty or a warm connector—run troubleshooting first."
                }
            ]
        },
        {
            "id": "rewire",
            "text": "Troubleshooting path: isolate the battery, inspect every crimp and polarity mark, then reseat the fuse only after terminals cool and strain relief is restored.",
            "options": [
                {
                    "type": "goto",
                    "goto": "wire",
                    "text": "Checks complete. Retry controlled wiring."
                }
            ]
        },
        {
            "id": "profile",
            "text": "Set LiFePO4 profile: absorb 14.4 V, float 13.6 V, temp sensor attached. Note the settings so you can rebuild this later.",
            "options": [
                {
                    "type": "process",
                    "process": "configure-charge-controller-profile",
                    "text": "Save the profile"
                },
                {
                    "type": "goto",
                    "goto": "profile-audit",
                    "text": "Profile saved; run an audit before charging.",
                    "requiresItems": [
                        {
                            "id": "22a50cfd-4433-4ce7-bbed-e4038338191b",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "rewire",
                    "text": "Controller warnings persisted; re-check wiring before profile retries."
                }
            ]
        },
        {
            "id": "profile-audit",
            "text": "Evidence gate: confirm the controller still shows LiFePO4 values and no thermal alarms after a 2-minute idle soak.",
            "options": [
                {
                    "type": "goto",
                    "goto": "charge",
                    "text": "Audit passed. Begin energy harvest.",
                    "requiresItems": [
                        {
                            "id": "22a50cfd-4433-4ce7-bbed-e4038338191b",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "rewire",
                    "text": "Audit failed. Return to troubleshooting and rewire."
                }
            ]
        },
        {
            "id": "charge",
            "text": "Face the panel toward the sun, shade the battery, and charge until you collect 200 Wh. Stop if the fuse warms or voltage sags sharply.",
            "options": [
                {
                    "type": "process",
                    "process": "harvest-200Wh-portable",
                    "text": "Harvest some energy"
                },
                {
                    "type": "goto",
                    "goto": "phone",
                    "text": "200 Wh harvested and stable.",
                    "requiresItems": [
                        {
                            "id": "b02ecff5-1f7d-4247-a09d-7d6cd6bb218a",
                            "count": 200
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "shade-recovery",
                    "text": "Output dipped or connectors heated—run recovery and retry harvest."
                }
            ]
        },
        {
            "id": "shade-recovery",
            "text": "Recovery branch: reduce panel angle, move battery into shade, and wait until connectors are cool-to-touch before resuming harvest.",
            "options": [
                {
                    "type": "goto",
                    "goto": "charge",
                    "text": "Thermals stabilized. Retry charging."
                }
            ]
        },
        {
            "id": "phone",
            "text": "Plug the USB cable into the controller and your phone. Coil slack, keep connectors off wet ground, and stop if the cable warms.",
            "options": [
                {
                    "type": "process",
                    "process": "charge-smartphone-offgrid",
                    "text": "Charge the phone"
                },
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Phone charged and the cable stayed cool.",
                    "requiresItems": [
                        {
                            "id": "2a9083b7-8578-45e3-8d76-7a298462f847",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "port-cleanup",
                    "text": "Charging port got dusty or warm; pause for cleanup before retrying."
                }
            ]
        },
        {
            "id": "port-cleanup",
            "text": "Unplug, dry and inspect the USB ends, then reconnect only once contacts are clean and strain-relieved.",
            "options": [
                {
                    "type": "goto",
                    "goto": "phone",
                    "text": "Ports cleaned. Retry final charging pass."
                }
            ]
        },
        {
            "id": "finish",
            "text": "Nice work! Disconnect in reverse order, coil the USB cable, and store the panel and battery out of direct sun.",
            "options": [
                {
                    "type": "finish",
                    "text": "Handy!"
                }
            ]
        }
    ],
    "rewards": [
        {
            "id": "02b32152-a7b2-458e-9643-7b754c722165",
            "count": 1
        }
    ],
