{
    "id": "energy/solar-tracker",
    "title": "Build a Solar Tracker",
    "description": "Rotate your 200 Wh kit to follow the sun.",
    "image": "/assets/quests/solar_tracker_200Wh_kit.jpg",
    "npc": "/assets/npc/orion.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Fixed panels miss watts. Let's mount your 200 Wh kit on a swivel stand to chase the sun without stressing cables.",
            "options": [
                {
                    "type": "goto",
                    "goto": "prep",
                    "text": "Let's set up the tracker."
                }
            ]
        },
        {
            "id": "prep",
            "text": "Gather the tracker parts: aluminum extrusion frame, stepper pair, driver board, and microcontroller before mounting the 200 Wh panel.",
            "options": [
                {
                    "type": "grantsItems",
                    "grantsItems": [
                        {
                            "id": "e0590418-22c7-4885-9c9e-1d1cdafb78d6",
                            "count": 1
                        }
                    ],
                    "text": "Take the 200 Wh kit."
                },
                {
                    "type": "grantsItems",
                    "grantsItems": [
                        {
                            "id": "72b4448e-27d9-4746-bd3a-967ff13f501b",
                            "count": 1
                        }
                    ],
                    "text": "Grab an Arduino Uno controller."
                },
                {
                    "type": "grantsItems",
                    "grantsItems": [
                        {
                            "id": "ed6e7882-15a0-4026-9851-4acd86b249e3",
                            "count": 1
                        }
                    ],
                    "text": "Grab the NEMA 17 stepper motor pair."
                },
                {
                    "type": "grantsItems",
                    "grantsItems": [
                        {
                            "id": "2b9d0d39-301e-4926-bba7-e73fff73d759",
                            "count": 1
                        }
                    ],
                    "text": "Grab the dual stepper motor driver."
                },
                {
                    "type": "grantsItems",
                    "grantsItems": [
                        {
                            "id": "9fdc9d2a-10fc-407d-9a42-aa76b3f569e1",
                            "count": 1
                        }
                    ],
                    "text": "Grab the aluminum extrusion frame kit."
                },
                {
                    "type": "process",
                    "process": "assemble-solar-tracking-unit",
                    "text": "Assemble and calibrate the tracking unit."
                },
                {
                    "type": "goto",
                    "goto": "track",
                    "text": "Tracker assembled and limits calibrated.",
                    "requiresItems": [
                        {
                            "id": "94349146-9330-4762-ac7d-a73a467ebef3",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "recover",
                    "text": "Base shifts or cable strain appears during setup."
                }
            ]
        },
        {
            "id": "track",
            "text": "Use the tracking unit to follow sun position hourly while the controller nudges azimuth and tilt without cable snags.",
            "options": [
                {
                    "type": "process",
                    "process": "solar-200Wh",
                    "text": "Track and generate.",
                    "requiresItems": [
                        {
                            "id": "94349146-9330-4762-ac7d-a73a467ebef3",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "verify",
                    "text": "Run complete; verify output and mechanical stability.",
                    "requiresItems": [
                        {
                            "id": "94349146-9330-4762-ac7d-a73a467ebef3",
                            "count": 1
                        },
                        {
                            "id": "b02ecff5-1f7d-4247-a09d-7d6cd6bb218a",
                            "count": 200
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "recover",
                    "text": "Output drops unexpectedly or alignment drifts."
                }
            ]
        },
        {
            "id": "recover",
            "text": "Recovery branch: flatten the tracker, retension the frame, re-home both steppers, and recheck controller wiring before retrying.",
            "options": [
                {
                    "type": "goto",
                    "goto": "prep",
                    "text": "Hardware secured; re-stage the tracker."
                },
                {
                    "type": "goto",
                    "goto": "track",
                    "text": "Minor issue fixed; retry the tracking run.",
                    "requiresItems": [
                        {
                            "id": "94349146-9330-4762-ac7d-a73a467ebef3",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "verify",
            "text": "Evidence gate: confirm at least 200 dSolar harvested with stable motion logs and no overheating in motors or driver board.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Verified: tracker is productive and safe.",
                    "requiresItems": [
                        {
                            "id": "94349146-9330-4762-ac7d-a73a467ebef3",
                            "count": 1
                        },
                        {
                            "id": "b02ecff5-1f7d-4247-a09d-7d6cd6bb218a",
                            "count": 200
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "recover",
                    "text": "Verification failed; adjust tracker and retry."
                }
            ]
        },
        {
            "id": "finish",
            "text": "Great work! Following the sun stretched your daily harvest.",
            "options": [
                {
                    "type": "finish",
                    "text": "Sun chasing!"
                }
            ]
        }
    ],
