{
    "id": "energy/solar-tracker",
    "title": "Build a Solar Tracker",
    "description": "Rotate your 200 Wh kit to follow the sun.",
    "image": "/assets/quests/solar_tracker_200Wh_kit.jpg",
    "npc": "/assets/npc/orion.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Fixed panels miss watts. Let's mount your 200 Wh kit on a swivel stand to chase the sun without stressing cables.",
            "options": [
                {
                    "type": "goto",
                    "goto": "prep",
                    "text": "Let's set up the tracker."
                }
            ]
        },
        {
            "id": "prep",
            "text": "Stage the tracker base, brace the frame, and prep control wiring before first movement checks.",
            "options": [
                {
                    "type": "grantsItems",
                    "grantsItems": [
                        {
                            "id": "e0590418-22c7-4885-9c9e-1d1cdafb78d6",
                            "count": 1
                        }
                    ],
                    "text": "Take the 200 Wh kit."
                },
                {
                    "type": "goto",
                    "goto": "build",
                    "text": "Base is staged; build the tracker drive and controls.",
                    "requiresItems": [
                        {
                            "id": "e0590418-22c7-4885-9c9e-1d1cdafb78d6",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "recover",
                    "text": "Base shifts or cable strain appears during setup."
                }
            ]
        },
        {
            "id": "build",
            "text": "Install the Arduino controller, mount paired stepper motors, and bolt the panel rail onto aluminum extrusions before live tracking.",
            "options": [
                {
                    "type": "process",
                    "process": "assemble-solar-tracking-unit",
                    "text": "Assemble the solar tracking unit."
                },
                {
                    "type": "goto",
                    "goto": "track",
                    "text": "Assembly complete; start tracking cycles.",
                    "requiresItems": [
                        {
                            "id": "aab2d917-b5a6-440a-9281-5251606e7828",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "recover",
                    "text": "Build issue detected: binding, missed steps, or loose frame hardware."
                }
            ]
        },
        {
            "id": "track",
            "text": "Rotate the panel hourly toward peak sun and log generation windows. Pause if wind rises enough to shake the mast.",
            "options": [
                {
                    "type": "process",
                    "process": "solar-200Wh",
                    "text": "Track and generate."
                },
                {
                    "type": "goto",
                    "goto": "verify",
                    "text": "Run complete; verify output and mechanical stability.",
                    "requiresItems": [
                        {
                            "id": "aab2d917-b5a6-440a-9281-5251606e7828",
                            "count": 1
                        },
                        {
                            "id": "b02ecff5-1f7d-4247-a09d-7d6cd6bb218a",
                            "count": 1001.0
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "recover",
                    "text": "Output drops unexpectedly or alignment drifts."
                }
            ]
        },
        {
            "id": "recover",
            "text": "Recovery branch: lock the tracker flat, retighten pivot hardware, and reset cable routing before another generation cycle.",
            "options": [
                {
                    "type": "goto",
                    "goto": "prep",
                    "text": "Hardware secured; re-stage the tracker."
                },
                {
                    "type": "goto",
                    "goto": "build",
                    "text": "Mechanical issue fixed; rerun assembly checks.",
                    "requiresItems": [
                        {
                            "id": "e0590418-22c7-4885-9c9e-1d1cdafb78d6",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "track",
                    "text": "Minor issue fixed; retry the tracking run.",
                    "requiresItems": [
                        {
                            "id": "e0590418-22c7-4885-9c9e-1d1cdafb78d6",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "verify",
            "text": "Evidence gate: confirm at least 200 dSolar harvested while the tracker held alignment and motor temperatures stayed in spec.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Verified: tracker is productive and safe.",
                    "requiresItems": [
                        {
                            "id": "aab2d917-b5a6-440a-9281-5251606e7828",
                            "count": 1
                        },
                        {
                            "id": "b02ecff5-1f7d-4247-a09d-7d6cd6bb218a",
                            "count": 1001.0
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "recover",
                    "text": "Verification failed; adjust tracker and retry."
                }
            ]
        },
        {
            "id": "finish",
            "text": "Great work! Following the sun stretched your daily harvest.",
            "options": [
                {
                    "type": "finish",
                    "text": "Sun chasing!"
                }
            ]
        }
    ],
