{
    "id": "energy/biogas-digester",
    "title": "Build a Biogas Digester",
    "description": "Ferment kitchen scraps into methane for cooking.",
    "image": "/assets/quests/biogas_digester_small_scale.jpg",
    "npc": "/assets/npc/orion.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Turn leftovers into fuel by building a biogas digester. We treat methane like a serious fuel: gloves on, no flames, and active venting.",
            "options": [
                {
                    "type": "goto",
                    "goto": "assemble",
                    "text": "I'm ready to build it safely."
                }
            ]
        },
        {
            "id": "assemble",
            "text": "Use a sealed 20 L drum, fit gas lines, and power the mixer with a 200 Wh pack while keeping ignition sources clear.",
            "options": [
                {
                    "type": "grantsItems",
                    "grantsItems": [
                        {
                            "id": "cfe87611-623a-45b0-9243-422cd8a73a16",
                            "count": 1
                        }
                    ],
                    "text": "I'll grab the battery pack."
                },
                {
                    "type": "goto",
                    "goto": "feed",
                    "text": "Frame assembled, vent line routed, and leak check complete.",
                    "requiresItems": [
                        {
                            "id": "cfe87611-623a-45b0-9243-422cd8a73a16",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "safety-stop",
                    "text": "I smell gas or cannot maintain a seal."
                }
            ]
        },
        {
            "id": "feed",
            "text": "Add scraps and water, seal the drum, and start fermentation. Log output milestones so you can confirm healthy digestion.",
            "options": [
                {
                    "type": "goto",
                    "goto": "verify",
                    "text": "Fermentation run complete; verify output and safety checks.",
                    "requiresItems": [
                        {
                            "id": "09f93589-9613-4f6d-a607-7dd144646f18",
                            "count": 50
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "safety-stop",
                    "text": "Pressure spikes or vent condensate blocks the line."
                }
            ]
        },
        {
            "id": "safety-stop",
            "text": "Stop and vent to a safe outdoor area. Purge lines, inspect seals, and restart only when the leak source is corrected and gauges are steady.",
            "options": [
                {
                    "type": "goto",
                    "goto": "assemble",
                    "text": "Leak fixed and vent path clear; reassemble safely."
                },
                {
                    "type": "goto",
                    "goto": "feed",
                    "text": "Seal is stable again; resume fermentation.",
                    "requiresItems": [
                        {
                            "id": "cfe87611-623a-45b0-9243-422cd8a73a16",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "verify",
            "text": "Evidence gate: confirm at least 50 dWatt generated and record that the digester remained leak-free through the run before cooking use.",
            "options": [
                {
                    "type": "goto",
                    "goto": "fin",
                    "text": "Verified: output + safety log both pass.",
                    "requiresItems": [
                        {
                            "id": "09f93589-9613-4f6d-a607-7dd144646f18",
                            "count": 50
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "safety-stop",
                    "text": "Verification failed; classify anomaly and re-run."
                }
            ]
        },
        {
            "id": "fin",
            "text": "Nice work! Vent the gas safely and use it for a low flame on a rocket stove.",
            "options": [
                {
                    "type": "finish",
                    "text": "Can't wait to cook with it!"
                }
            ]
        }
    ],
