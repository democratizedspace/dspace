                    ]
                }
            ]
        },
        {
            "id": "setup",
            "text": "Square the mast, torque the hardware, and route the DC leads down the tower. Wire the brake switch into the charge controller and confirm polarity with your meter before closing anything up.",
            "options": [
                {
                    "type": "process",
                    "process": "mount-wire-wind-turbine-500w",
                    "text": "Mount, wire, and brake-test the turbine"
                },
                {
                    "type": "goto",
                    "goto": "harvest",
                    "text": "Tower is anchored and the brake test passed.",
                    "requiresItems": [
                        {
                            "id": "34540aad-4c25-4268-a158-a291283bc7a0",
                            "count": 1
                        },
                        {
                            "id": "cfe87611-623a-45b0-9243-422cd8a73a16",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "harvest",
            "text": "Face the nacelle into the breeze, ease off the brake, and watch voltage under light load before sending power into the 200 Wh pack. Stop if the tower flexes or the cables heat up.",
            "options": [
                {
                    "type": "process",
                    "process": "charge-battery-pack-wind",
                    "text": "Harvest wind and top the pack"
                },
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Logged 200 dWatt and cables stayed cool.",
                    "requiresItems": [
                        {
                            "id": "061fd221-404a-4bd1-9432-3e25b0f17a2c",
                            "count": 200
                        }
                    ]
                }
            ]
        },
        {
            "id": "finish",
            "text": "Excellent! Lock the brake when you leave, coil slack, and check mast hardware after the first gusty night.",
            "options": [
                {
                    "type": "finish",
                    "text": "Can't wait for the next storm!"
                }
            ]
        }
