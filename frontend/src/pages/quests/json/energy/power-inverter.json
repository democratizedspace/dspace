{
    "id": "energy/power-inverter",
    "title": "Install a Power Inverter",
    "description": "Convert your battery's DC output into AC for household gear.",
    "image": "/assets/quests/power_inverter_installation.jpg",
    "npc": "/assets/npc/orion.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Your battery bank works great. Let's add a 300 W pure sine inverter so you can run AC gadgets without cooking the wiring.",
            "options": [
                {
                    "type": "goto",
                    "goto": "gather",
                    "text": "I'm ready."
                }
            ]
        },
        {
            "id": "gather",
            "text": "Grab the inverter, fused 8 AWG leads, your 200 Wh pack, and a multimeter. Mount the inverter within 30 cm of the pack to keep voltage drop tiny.",
            "options": [
                {
                    "type": "goto",
                    "goto": "mount",
                    "text": "Parts staged and vent fans are clear.",
                    "requiresItems": [
                        {
                            "id": "082481a4-5e40-43e6-8542-0e64a3bd92d7",
                            "count": 1
                        },
                        {
                            "id": "0ccc4a37-b719-4f7c-ba73-9e4becdcd778",
                            "count": 1
                        },
                        {
                            "id": "cfe87611-623a-45b0-9243-422cd8a73a16",
                            "count": 1
                        },
                        {
                            "id": "5127e156-3009-4db4-85ac-e3ea070b68f2",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "mount",
            "text": "Crimp the ring lugs, fuse the positive lead, torque the battery terminals, and mount the inverter to a board or bulkhead with airflow. No loose copper, no sparks.",
            "options": [
                {
                    "type": "process",
                    "process": "mount-inverter-300w",
                    "text": "Mount and fuse it"
                },
                {
                    "type": "goto",
                    "goto": "test",
                    "text": "Inverter mounted, fuse in, cables secure.",
                    "requiresItems": [
                        {
                            "id": "466cb507-6beb-4c20-967b-4f1fda1d6463",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "test",
            "text": "Plug in a 150 W load and check voltage with your multimeter. If voltage sags below 11.5 V or the fuse warms, stop and shorten the leads.",
            "options": [
                {
                    "type": "process",
                    "process": "load-test-inverter-300w",
                    "text": "Load test at 150 W"
                },
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "AC holds steady and nothing smells toasty.",
                    "requiresItems": [
                        {
                            "id": "2e6f7453-6b8a-4e04-8ea6-1ddba490019f",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "finish",
            "text": "Nice! Coil any slack, label the fuse rating, and keep ventilation clear. Your inverter is ready for laptops and lights\u2014no toasters yet.",
            "options": [
                {
                    "type": "finish",
                    "text": "Time to plug in."
                }
            ]
        }
    ],
    "rewards": [
        {
            "id": "b281360b-2ecc-4fea-a248-36a61c5f7399",
            "count": 1
        }
    ],
    "requiresQuests": [
        "energy/battery-upgrade"
    ],
