{
    "id": "energy/portable-solar-panel",
    "title": "Test a Portable Solar Panel",
    "description": "Harvest sunshine anywhere with a foldable panel.",
    "image": "/assets/quests/portable_foldable_solar_panel_test.jpg",
    "npc": "/assets/npc/orion.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Want off-grid power on the go? I have a 200 W portable panel, charge controller, and 200 Wh pack\u2014if you wire them right.",
            "options": [
                {
                    "type": "goto",
                    "goto": "kit",
                    "text": "I'd love to test it!"
                },
                {
                    "type": "goto",
                    "goto": "site-check",
                    "text": "Let's run a safety site check first."
                }
            ]
        },
        {
            "id": "site-check",
            "text": "Scout the setup zone: dry footing, no overhead hazards, and enough airflow around the battery. Abort if rain starts or connectors are contaminated.",
            "options": [
                {
                    "type": "goto",
                    "goto": "kit",
                    "text": "Site is dry, stable, and clear."
                }
            ]
        },
        {
            "id": "kit",
            "text": "I'll loan you the panel, controller, pack, and a fused lead kit. Lay them out on a dry surface, keep ring terminals off the ground, and disconnect if anything gets hot.",
            "options": [
                {
                    "type": "grantsItems",
                    "grantsItems": [
                        {
                            "id": "02b32152-a7b2-458e-9643-7b754c722165",
                            "count": 1
                        },
                        {
                            "id": "67a682f8-a8a4-4a14-8806-5ccd3620fd3b",
                            "count": 1
                        },
                        {
                            "id": "cfe87611-623a-45b0-9243-422cd8a73a16",
                            "count": 1
                        },
                        {
                            "id": "0ccc4a37-b719-4f7c-ba73-9e4becdcd778",
                            "count": 1
                        }
                    ],
                    "text": "Take the loaner kit"
                },
                {
                    "type": "goto",
                    "goto": "wire",
                    "text": "Parts staged and safe.",
                    "requiresItems": [
                        {
                            "id": "02b32152-a7b2-458e-9643-7b754c722165",
                            "count": 1
                        },
                        {
                            "id": "67a682f8-a8a4-4a14-8806-5ccd3620fd3b",
                            "count": 1
                        },
                        {
                            "id": "cfe87611-623a-45b0-9243-422cd8a73a16",
                            "count": 1
                        },
                        {
                            "id": "0ccc4a37-b719-4f7c-ba73-9e4becdcd778",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "wire",
            "text": "Crimped lugs go battery-side, MC4s point to the panel. Fuse on the positive lead\u2014red to positive, black to negative\u2014torque to spec, and zip-tie strain relief so nothing yanks free.",
            "options": [
                {
                    "type": "process",
                    "process": "wire-portable-solar-kit",
                    "text": "Wire it carefully"
                },
                {
                    "type": "goto",
                    "goto": "harvest",
                    "text": "Cable ends are tight and fused.",
                    "requiresItems": [
                        {
                            "id": "8e540f94-91e0-47a1-b6ca-78e8b48aefac",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "rewire",
                    "text": "Polarity check failed; I need to rewire safely."
                }
            ]
        },
        {
            "id": "harvest",
            "text": "Face the panel toward the sun, shade the battery, and start charging. Stop if connectors warm up or voltage dips below the controller\u2019s low-cutoff.",
            "options": [
                {
                    "type": "process",
                    "process": "harvest-200Wh-portable",
                    "text": "Let the photons flow"
                },
                {
                    "type": "goto",
                    "goto": "panel-log",
                    "text": "Harvested 200 Wh without any hot cables.",
                    "requiresItems": [
                        {
                            "id": "b02ecff5-1f7d-4247-a09d-7d6cd6bb218a",
                            "count": 200
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "shade-recovery",
                    "text": "Output dipped; I need to troubleshoot shading and angle."
                }
            ]
        },
        {
            "id": "rewire",
            "text": "De-energize before touching conductors: remove fuse, inspect MC4 seating, and confirm red/black orientation with the controller labels before retrying.",
            "options": [
                {
                    "type": "goto",
                    "goto": "wire",
                    "text": "Fuse out and polarity verified; retry wiring.",
                    "requiresItems": [
                        {
                            "id": "0ccc4a37-b719-4f7c-ba73-9e4becdcd778",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "shade-recovery",
            "text": "Track the sun and remove shadow sources. If panel temperature spikes or wind gusts become unsafe, pause and re-stage the array before continuing.",
            "options": [
                {
                    "type": "goto",
                    "goto": "harvest",
                    "text": "Panel repositioned and output recovered; retry harvest.",
                    "requiresItems": [
                        {
                            "id": "8e540f94-91e0-47a1-b6ca-78e8b48aefac",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "panel-log",
            "text": "Before wrap-up, log panel angle, weather conditions, and stable output notes so future deployments can reproduce this performance window.",
            "options": [
                {
                    "type": "goto",
                    "goto": "fin",
                    "text": "Logged orientation and stable-output evidence.",
                    "requiresItems": [
                        {
                            "id": "8e540f94-91e0-47a1-b6ca-78e8b48aefac",
                            "count": 1
                        },
                        {
                            "id": "b02ecff5-1f7d-4247-a09d-7d6cd6bb218a",
                            "count": 200
                        }
                    ]
                }
            ]
        },
        {
            "id": "fin",
            "text": "Nice work! Coil the MC4 leads, keep the fuse installed, and stash the kit dry for your next off-grid errand.",
            "options": [
                {
                    "type": "finish",
                    "text": "Sun power for the win!"
                }
            ]
        }
    ],
    "rewards": [
        {
            "id": "b281360b-2ecc-4fea-a248-36a61c5f7399",
            "count": 1
        }
    ],
    "requiresQuests": ["energy/offgrid-charger"],
