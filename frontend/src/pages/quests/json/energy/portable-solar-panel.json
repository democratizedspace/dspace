{
    "id": "energy/portable-solar-panel",
    "title": "Test a Portable Solar Panel",
    "description": "Harvest sunshine anywhere with a foldable panel.",
    "image": "/assets/quests/portable_foldable_solar_panel_test.jpg",
    "npc": "/assets/npc/orion.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Want off-grid power on the go? I have a 200 W portable panel, charge controller, and 200 Wh pack if you wire and monitor them correctly.",
            "options": [
                {
                    "type": "goto",
                    "goto": "kit",
                    "text": "I'd love to test it!"
                }
            ]
        },
        {
            "id": "kit",
            "text": "I'll loan you the panel, controller, pack, and fused lead kit. Stage on dry ground, keep terminals clean, and stop if any connector gets hot.",
            "options": [
                {
                    "type": "grantsItems",
                    "grantsItems": [
                        {
                            "id": "02b32152-a7b2-458e-9643-7b754c722165",
                            "count": 1
                        },
                        {
                            "id": "67a682f8-a8a4-4a14-8806-5ccd3620fd3b",
                            "count": 1
                        },
                        {
                            "id": "cfe87611-623a-45b0-9243-422cd8a73a16",
                            "count": 1
                        },
                        {
                            "id": "0ccc4a37-b719-4f7c-ba73-9e4becdcd778",
                            "count": 1
                        }
                    ],
                    "text": "Take the loaner kit"
                },
                {
                    "type": "goto",
                    "goto": "approach",
                    "text": "Parts staged and safe.",
                    "requiresItems": [
                        {
                            "id": "02b32152-a7b2-458e-9643-7b754c722165",
                            "count": 1
                        },
                        {
                            "id": "67a682f8-a8a4-4a14-8806-5ccd3620fd3b",
                            "count": 1
                        },
                        {
                            "id": "cfe87611-623a-45b0-9243-422cd8a73a16",
                            "count": 1
                        },
                        {
                            "id": "0ccc4a37-b719-4f7c-ba73-9e4becdcd778",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "approach",
            "text": "Choose your test approach: rapid deploy for quick field checks, or stability-first with extra cable management for windy conditions.",
            "options": [
                {
                    "type": "goto",
                    "goto": "wire",
                    "text": "Rapid deploy path"
                },
                {
                    "type": "goto",
                    "goto": "stability-prep",
                    "text": "Stability-first path"
                }
            ]
        },
        {
            "id": "stability-prep",
            "text": "Secure panel legs, route strain relief loops, and verify fused positive lead cannot snag during repositioning.",
            "options": [
                {
                    "type": "process",
                    "process": "wire-portable-solar-kit",
                    "text": "Secure and pre-route cable strain relief"
                },
                {
                    "type": "goto",
                    "goto": "wire",
                    "text": "Stability prep complete"
                }
            ]
        },
        {
            "id": "wire",
            "text": "Crimped lugs go battery-side, MC4s point to panel. Fuse on positive lead, red to positive, black to negative, then torque to spec.",
            "options": [
                {
                    "type": "process",
                    "process": "wire-portable-solar-kit",
                    "text": "Wire it carefully"
                },
                {
                    "type": "goto",
                    "goto": "harvest",
                    "text": "Cable ends are tight and fused.",
                    "requiresItems": [
                        {
                            "id": "8e540f94-91e0-47a1-b6ca-78e8b48aefac",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "safety-recovery",
                    "text": "Terminal heat or polarity concern detected"
                }
            ]
        },
        {
            "id": "harvest",
            "text": "Face panel toward sun, shade battery, and start charging. Stop if connectors warm up, voltage dips below cutoff, or fast cloud cycles destabilize current.",
            "options": [
                {
                    "type": "process",
                    "process": "harvest-200Wh-portable",
                    "text": "Let the photons flow"
                },
                {
                    "type": "goto",
                    "goto": "verify-output",
                    "text": "Harvest run completed",
                    "requiresItems": [
                        {
                            "id": "b02ecff5-1f7d-4247-a09d-7d6cd6bb218a",
                            "count": 200
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "safety-recovery",
                    "text": "Heat spike or voltage instability occurred"
                }
            ]
        },
        {
            "id": "verify-output",
            "text": "Verification gate: confirm you hit 200 Wh and held safe connector temperature through the end of the run.",
            "options": [
                {
                    "type": "goto",
                    "goto": "fin",
                    "text": "Output and thermal checks both passed",
                    "requiresItems": [
                        {
                            "id": "b02ecff5-1f7d-4247-a09d-7d6cd6bb218a",
                            "count": 200
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "safety-recovery",
                    "text": "I need to troubleshoot before signing off"
                }
            ]
        },
        {
            "id": "safety-recovery",
            "text": "Recovery path: disconnect panel first, inspect fuse and connector faces, re-seat polarity, then restart only after cables remain cool for a full check interval.",
            "options": [
                {
                    "type": "process",
                    "process": "wire-portable-solar-kit",
                    "text": "Perform safe disconnect + rewire"
                },
                {
                    "type": "goto",
                    "goto": "wire",
                    "text": "Retry wiring and harvest"
                }
            ]
        },
        {
            "id": "fin",
            "text": "Nice work! Coil MC4 leads, keep fuse installed, and stash kit dry for your next off-grid errand.",
            "options": [
                {
                    "type": "finish",
                    "text": "Sun power for the win!"
                }
            ]
        }
    ],
