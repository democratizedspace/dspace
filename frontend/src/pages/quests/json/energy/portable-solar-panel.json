{
    "id": "energy/portable-solar-panel",
    "title": "Test a Portable Solar Panel",
    "description": "Harvest sunshine anywhere with a foldable panel.",
    "image": "/assets/quests/portable_foldable_solar_panel_test.jpg",
    "npc": "/assets/npc/orion.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Want off-grid power on the go? I have a 200 W portable panel, charge controller, and 200 Wh pack—if you wire them right and respect weather risk.",
            "options": [
                {
                    "type": "goto",
                    "goto": "kit",
                    "text": "I'd love to test it!"
                }
            ]
        },
        {
            "id": "kit",
            "text": "I'll loan you the panel, controller, pack, and fused lead kit. Lay them out on a dry surface, keep ring terminals off the ground, and abort if clouds turn stormy.",
            "options": [
                {
                    "type": "grantsItems",
                    "grantsItems": [
                        {
                            "id": "02b32152-a7b2-458e-9643-7b754c722165",
                            "count": 1
                        },
                        {
                            "id": "67a682f8-a8a4-4a14-8806-5ccd3620fd3b",
                            "count": 1
                        },
                        {
                            "id": "cfe87611-623a-45b0-9243-422cd8a73a16",
                            "count": 1
                        },
                        {
                            "id": "0ccc4a37-b719-4f7c-ba73-9e4becdcd778",
                            "count": 1
                        }
                    ],
                    "text": "Take the loaner kit"
                },
                {
                    "type": "goto",
                    "goto": "wire",
                    "text": "Parts staged, dry, and storm watch is clear.",
                    "requiresItems": [
                        {
                            "id": "02b32152-a7b2-458e-9643-7b754c722165",
                            "count": 1
                        },
                        {
                            "id": "67a682f8-a8a4-4a14-8806-5ccd3620fd3b",
                            "count": 1
                        },
                        {
                            "id": "cfe87611-623a-45b0-9243-422cd8a73a16",
                            "count": 1
                        },
                        {
                            "id": "0ccc4a37-b719-4f7c-ba73-9e4becdcd778",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "wire",
            "text": "Crimped lugs go battery-side, MC4s point to the panel. Fuse on the positive lead—red to positive, black to negative—torque to spec, then zip-tie strain relief.",
            "options": [
                {
                    "type": "process",
                    "process": "wire-portable-solar-kit",
                    "text": "Wire it carefully"
                },
                {
                    "type": "goto",
                    "goto": "harvest",
                    "text": "Cable ends are tight and fused.",
                    "requiresItems": [
                        {
                            "id": "8e540f94-91e0-47a1-b6ca-78e8b48aefac",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "rewire-recovery",
                    "text": "I saw a hot connector or loose strain relief."
                }
            ]
        },
        {
            "id": "harvest",
            "text": "Face the panel toward the sun, shade the battery, and start charging. Capture the total harvested energy and stop if connectors warm or voltage dips below cutoff.",
            "options": [
                {
                    "type": "process",
                    "process": "harvest-200Wh-portable",
                    "text": "Let the photons flow"
                },
                {
                    "type": "goto",
                    "goto": "verify-yield",
                    "text": "Harvest run complete; check output logs.",
                    "requiresItems": [
                        {
                            "id": "b02ecff5-1f7d-4247-a09d-7d6cd6bb218a",
                            "count": 200
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "low-yield-recovery",
                    "text": "Yield stalled or weather shifted during harvest."
                }
            ]
        },
        {
            "id": "verify-yield",
            "text": "Verification gate: confirm at least 200 Wh landed without hot cables, then document shutdown order (panel → controller → battery).",
            "options": [
                {
                    "type": "goto",
                    "goto": "fin",
                    "text": "Verified 200 Wh and safe shutdown notes captured.",
                    "requiresItems": [
                        {
                            "id": "b02ecff5-1f7d-4247-a09d-7d6cd6bb218a",
                            "count": 200
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "low-yield-recovery",
                    "text": "Output or safety notes were incomplete; recover and retry."
                }
            ]
        },
        {
            "id": "rewire-recovery",
            "text": "Recovery path: de-energize, replace the suspect connector, and rebuild strain relief before reconnecting. Never tighten live conductors.",
            "options": [
                {
                    "type": "process",
                    "process": "wire-portable-solar-kit",
                    "text": "Rewire after corrective actions"
                },
                {
                    "type": "goto",
                    "goto": "harvest",
                    "text": "Rewire complete; begin harvest again.",
                    "requiresItems": [
                        {
                            "id": "8e540f94-91e0-47a1-b6ca-78e8b48aefac",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "low-yield-recovery",
            "text": "Troubleshooting branch: re-aim panel tilt, clear shade, and wait for stable sun before retrying. If storm risk rises, pack down and restart later.",
            "options": [
                {
                    "type": "goto",
                    "goto": "harvest",
                    "text": "Conditions stabilized; retry the harvest pass.",
                    "requiresItems": [
                        {
                            "id": "8e540f94-91e0-47a1-b6ca-78e8b48aefac",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "fin",
            "text": "Nice work! Coil the MC4 leads, keep the fuse installed, and stash the kit dry for your next off-grid errand.",
            "options": [
                {
                    "type": "finish",
                    "text": "Sun power for the win!"
                }
            ]
        }
    ],
    "rewards": [
