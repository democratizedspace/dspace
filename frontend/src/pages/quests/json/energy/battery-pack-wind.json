                    "text": "Spin up the turbine"
                },
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Battery full",
                    "requiresItems": [
                        {
                            "id": "cfe87611-623a-45b0-9243-422cd8a73a16",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "finish",
            "text": "Nice! Wind energy now tops up your battery pack.",
            "options": [
                {
                    "type": "finish",
                    "text": "Renewable power!"
                }
            ]
        }
    ],
