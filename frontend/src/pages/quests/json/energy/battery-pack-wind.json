                },
                {
                    "type": "goto",
                    "goto": "charge",
                    "text": "Pack connected",
                    "requiresItems": [
                        {
                            "id": "cfe87611-623a-45b0-9243-422cd8a73a16",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "charge",
            "text": "Let the blades spin until the pack is full.",
            "options": [
                {
                    "type": "process",
