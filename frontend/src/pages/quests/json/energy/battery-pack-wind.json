                {
                    "type": "goto",
                    "goto": "prep",
                    "text": "Let's charge a battery!"
                }
            ]
        },
        {
            "id": "prep",
            "text": "Connect this 200 Wh battery pack to your turbine's charge controller.",
            "options": [
                {
                    "type": "grantsItems",
                    "grantsItems": [
                        {
                            "id": "cfe87611-623a-45b0-9243-422cd8a73a16",
                            "count": 1
                        }
                    ],
