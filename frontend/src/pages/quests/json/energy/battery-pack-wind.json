{
    "id": "energy/battery-pack-wind",
    "title": "Charge a Battery Pack with Wind",
    "description": "Use your 500 W turbine to fill a 200 Wh battery pack.",
    "image": "/assets/quests/solar_200Wh.jpg",
    "npc": "/assets/npc/orion.jpg",
    "start": "start",
    "dialogue": [
        {
