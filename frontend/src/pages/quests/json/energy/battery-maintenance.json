{
    "id": "energy/battery-maintenance",
    "title": "Maintain Your Battery Pack",
    "description": "Cycle your 200 Wh battery pack with solar to keep it healthy.",
    "image": "/assets/quests/solar_battery_pack_200Wh_maintenance.jpg",
    "npc": "/assets/npc/orion.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "A battery lasts longer when you cycle it with intent. We'll log one maintenance window and only close once the numbers look safe.",
            "options": [
                {
                    "type": "goto",
                    "goto": "prep",
                    "text": "Open a maintenance log."
                }
            ]
        },
        {
            "id": "prep",
            "text": "Set the pack on a dry surface, check cables for nicks, and confirm the charge controller is in LiFePO4 mode before charging.",
            "options": [
                {
                    "type": "goto",
                    "goto": "cycle",
                    "text": "Safety check complete.",
                    "requiresItems": [
                        {
                            "id": "cfe87611-623a-45b0-9243-422cd8a73a16",
                            "count": 1
                        },
                        {
                            "id": "67a682f8-a8a4-4a14-8806-5ccd3620fd3b",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "cycle",
            "text": "Run one solar charging cycle, then record harvested energy and cable temperature notes.",
            "options": [
                {
                    "type": "process",
                    "process": "charge-battery-pack-solar",
                    "text": "Run the maintenance cycle"
                },
                {
                    "type": "goto",
                    "goto": "interpret",
                    "text": "Log shows at least 200 Wh harvested.",
                    "requiresItems": [
                        {
                            "id": "b02ecff5-1f7d-4247-a09d-7d6cd6bb218a",
                            "count": 200
                        }
                    ]
                }
            ]
        },
        {
            "id": "interpret",
            "text": "Interpret the log: stable voltage and cool cables means pass. Any heat spike, voltage sag, or connector smell means stop and troubleshoot.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Readings are stable and safe.",
                    "requiresItems": [
                        {
                            "id": "cfe87611-623a-45b0-9243-422cd8a73a16",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "anomaly",
                    "text": "I detected a heat or voltage anomaly."
                }
            ]
        },
        {
            "id": "anomaly",
            "text": "Good catch. Pause charging, reseat terminals, and move the pack to shade before attempting another cycle.",
            "options": [
                {
                    "type": "goto",
                    "goto": "cycle",
                    "text": "Corrective actions done; run a re-test cycle.",
                    "requiresItems": [
                        {
                            "id": "67a682f8-a8a4-4a14-8806-5ccd3620fd3b",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "finish",
            "text": "Nice work! You didn't just cycle the pack—you validated that it can run safely.",
            "options": [
                {
                    "type": "finish",
                    "text": "Maintenance logged."
                }
            ]
        }
    ],
    "rewards": [
        {
            "id": "b281360b-2ecc-4fea-a248-36a61c5f7399",
            "count": 1
        }
    ],
    "requiresQuests": ["energy/solar"],
    "hardening": {
        "passes": 0,
        "score": 90,
        "emoji": "🛠️",
        "history": []
    }
}
