{
    "id": "energy/battery-maintenance",
    "title": "Maintain Your Battery Pack",
    "description": "Cycle your 200 Wh battery pack with solar to keep it healthy.",
    "image": "/assets/quests/solar_battery_pack_200Wh_maintenance.jpg",
    "npc": "/assets/npc/orion.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "A battery lasts longer when you cycle it occasionally. Ready for a quick health check?",
            "options": [
                {
                    "type": "goto",
                    "goto": "prep-log",
                    "text": "Let's give it some exercise."
                }
            ]
        },
        {
            "id": "prep-log",
            "text": "Before you cycle, capture a baseline: pack voltage, cable temperature, and connector condition. That log gives us something to compare after charging.",
            "options": [
                {
                    "type": "process",
                    "process": "measure-battery-voltage",
                    "text": "Record baseline pack voltage"
                },
                {
                    "type": "goto",
                    "goto": "cycle",
                    "text": "Baseline recorded, proceed to charge cycle.",
                    "requiresItems": [
                        {
                            "id": "cfe87611-623a-45b0-9243-422cd8a73a16",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "cycle",
            "text": "Discharge your pack a bit, then hook it to the solar kit and top it off.",
            "options": [
                {
                    "type": "process",
                    "process": "charge-battery-pack-solar",
                    "text": "Charge with solar"
                },
                {
                    "type": "goto",
                    "goto": "verify-log",
                    "text": "Cycle complete; compare post-cycle reading to baseline.",
                    "requiresItems": [
                        {
                            "id": "b02ecff5-1f7d-4247-a09d-7d6cd6bb218a",
                            "count": 200
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "anomaly-response",
                    "text": "Charge stalled or cable temperature keeps climbing."
                }
            ]
        },
        {
            "id": "anomaly-response",
            "text": "Good catch. Stop charging, inspect connectors for corrosion, re-seat the fuse, and verify ventilation. Resume only if the next reading is stable and hardware stays cool.",
            "options": [
                {
                    "type": "goto",
                    "goto": "cycle",
                    "text": "Corrective action complete; retry controlled cycle.",
                    "requiresItems": [
                        {
                            "id": "cfe87611-623a-45b0-9243-422cd8a73a16",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "verify-log",
            "text": "Interpret your maintenance log: if voltage recovered and connector temps remained in-range, the pack passes this cycle. If not, loop back through troubleshooting.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Log review passed: healthy charge profile confirmed.",
                    "requiresItems": [
                        {
                            "id": "b02ecff5-1f7d-4247-a09d-7d6cd6bb218a",
                            "count": 200
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "anomaly-response",
                    "text": "Log flags an anomaly; run corrective loop first."
                }
            ]
        },
        {
            "id": "finish",
            "text": "Nice work! Your pack is ready for more adventures.",
            "options": [
                {
                    "type": "finish",
                    "text": "Power up!"
                }
            ]
        }
    ],
    "rewards": [
        {
            "id": "b281360b-2ecc-4fea-a248-36a61c5f7399",
            "count": 1
        }
    ],
    "requiresQuests": ["energy/solar"],
    "hardening": {
        "passes": 0,
        "score": 90,
        "emoji": "\ud83d\udee0\ufe0f",
        "history": []
    }
}
