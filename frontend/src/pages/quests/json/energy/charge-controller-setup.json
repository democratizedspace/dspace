{
    "id": "energy/charge-controller-setup",
    "title": "Configure a Solar Charge Controller",
    "description": "Wire and configure a charge controller to safely charge your 200 Wh battery.",
    "image": "/assets/quests/solar_charge_controller_setup.jpg",
    "npc": "/assets/npc/orion.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "A charge controller keeps your battery safe. We will stage, wire, verify, and keep a rollback path if anything behaves oddly.",
            "options": [
                {
                    "type": "goto",
                    "goto": "layout",
                    "text": "Start staged install."
                }
            ]
        },
        {
            "id": "layout",
            "text": "Lay out panel, controller, 200 Wh pack, and fused leads on a dry surface. Keep the fuse pulled until polarity is confirmed.",
            "options": [
                {
                    "type": "grantsItems",
                    "grantsItems": [
                        {
                            "id": "67a682f8-a8a4-4a14-8806-5ccd3620fd3b",
                            "count": 1
                        },
                        {
                            "id": "02b32152-a7b2-458e-9643-7b754c722165",
                            "count": 1
                        },
                        {
                            "id": "cfe87611-623a-45b0-9243-422cd8a73a16",
                            "count": 1
                        },
                        {
                            "id": "0ccc4a37-b719-4f7c-ba73-9e4becdcd778",
                            "count": 1
                        }
                    ],
                    "text": "Borrow my kit"
                },
                {
                    "type": "goto",
                    "goto": "wire",
                    "text": "Polarity checked; fuse still out.",
                    "requiresItems": [
                        {
                            "id": "67a682f8-a8a4-4a14-8806-5ccd3620fd3b",
                            "count": 1
                        },
                        {
                            "id": "02b32152-a7b2-458e-9643-7b754c722165",
                            "count": 1
                        },
                        {
                            "id": "cfe87611-623a-45b0-9243-422cd8a73a16",
                            "count": 1
                        },
                        {
                            "id": "0ccc4a37-b719-4f7c-ba73-9e4becdcd778",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "wire",
            "text": "Connect battery first, then panel MC4s. Torque ring terminals, insert fuse, and keep one hand clear so you can disconnect fast if needed.",
            "options": [
                {
                    "type": "process",
                    "process": "wire-portable-solar-kit",
                    "text": "Wire and fuse everything"
                },
                {
                    "type": "goto",
                    "goto": "configure",
                    "text": "Controller powers up without sparks.",
                    "requiresItems": [
                        {
                            "id": "8e540f94-91e0-47a1-b6ca-78e8b48aefac",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "rollback",
                    "text": "I saw sparks or unstable boot behavior."
                }
            ]
        },
        {
            "id": "rollback",
            "text": "Rollback: pull fuse, disconnect panel, then battery. Inspect polarity and damaged insulation before trying again.",
            "options": [
                {
                    "type": "goto",
                    "goto": "wire",
                    "text": "Fault corrected; re-run wire verification.",
                    "requiresItems": [
                        {
                            "id": "0ccc4a37-b719-4f7c-ba73-9e4becdcd778",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "configure",
            "text": "Select LiFePO4 mode, set absorb 14.4 V and float 13.6 V, and save the profile so you can audit settings later.",
            "options": [
                {
                    "type": "process",
                    "process": "configure-charge-controller-profile",
                    "text": "Store the profile"
                },
                {
                    "type": "goto",
                    "goto": "charge",
                    "text": "Settings saved and fuse seated.",
                    "requiresItems": [
                        {
                            "id": "22a50cfd-4433-4ce7-bbed-e4038338191b",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "charge",
            "text": "Run a 200 Wh charge window. Keep cables cool and confirm the controller display stays steady for at least one check interval.",
            "options": [
                {
                    "type": "process",
                    "process": "harvest-200Wh-portable",
                    "text": "Start charging"
                },
                {
                    "type": "goto",
                    "goto": "verify",
                    "text": "Controller reached target energy.",
                    "requiresItems": [
                        {
                            "id": "b02ecff5-1f7d-4247-a09d-7d6cd6bb218a",
                            "count": 200
                        }
                    ]
                }
            ]
        },
        {
            "id": "verify",
            "text": "Final verification: profile present, kit still wired cleanly, no connector heat, and 200 Wh harvested.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Verification passed.",
                    "requiresItems": [
                        {
                            "id": "22a50cfd-4433-4ce7-bbed-e4038338191b",
                            "count": 1
                        },
                        {
                            "id": "8e540f94-91e0-47a1-b6ca-78e8b48aefac",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "rollback",
                    "text": "Verification failed; perform rollback and re-verify."
                }
            ]
        },
        {
            "id": "finish",
            "text": "Nice work! You completed an install with an explicit rollback and verification trail.",
            "options": [
                {
                    "type": "finish",
                    "text": "Sun power secured!"
                }
            ]
        }
    ],
    "rewards": [
