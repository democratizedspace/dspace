{
    "id": "energy/charge-controller-setup",
    "title": "Configure a Solar Charge Controller",
    "description": "Wire and configure a charge controller to safely charge your 200 Wh battery.",
    "image": "/assets/quests/solar_charge_controller_setup.jpg",
    "npc": "/assets/npc/orion.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "A charge controller keeps your battery safe. Ready to wire and program one for LiFePO4?",
            "options": [
                {
                    "type": "goto",
                    "goto": "layout",
                    "text": "Let's do it!"
                }
            ]
        },
        {
            "id": "layout",
            "text": "Lay out the panel, controller, 200 Wh pack, and fused leads on a dry surface. Keep the fuse pulled until you double-check polarity.",
            "options": [
                {
                    "type": "grantsItems",
                    "grantsItems": [
                        {
                            "id": "67a682f8-a8a4-4a14-8806-5ccd3620fd3b",
                            "count": 1
                        },
                        {
                            "id": "02b32152-a7b2-458e-9643-7b754c722165",
                            "count": 1
                        },
                        {
                            "id": "cfe87611-623a-45b0-9243-422cd8a73a16",
                            "count": 1
                        },
                        {
                            "id": "0ccc4a37-b719-4f7c-ba73-9e4becdcd778",
                            "count": 1
                        }
                    ],
                    "text": "Borrow my kit"
                },
                {
                    "type": "goto",
                    "goto": "wire",
                    "text": "Polarity checked; fuse still out.",
                    "requiresItems": [
                        {
                            "id": "67a682f8-a8a4-4a14-8806-5ccd3620fd3b",
                            "count": 1
                        },
                        {
                            "id": "02b32152-a7b2-458e-9643-7b754c722165",
                            "count": 1
                        },
                        {
                            "id": "cfe87611-623a-45b0-9243-422cd8a73a16",
                            "count": 1
                        },
                        {
                            "id": "0ccc4a37-b719-4f7c-ba73-9e4becdcd778",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "bench-test",
                    "text": "Bench-test the controller display before connecting the panel."
                }
            ]
        },
        {
            "id": "bench-test",
            "text": "Quick bench test: power the controller from the battery only, confirm display boot and fault log are clear, then disconnect before panel hookup.",
            "options": [
                {
                    "type": "goto",
                    "goto": "wire",
                    "text": "Bench test passed; proceed to full wiring.",
                    "requiresItems": [
                        {
                            "id": "67a682f8-a8a4-4a14-8806-5ccd3620fd3b",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "rollback-safe",
                    "text": "Bench test raised warnings; enter rollback-safe diagnostics."
                }
            ]
        },
        {
            "id": "wire",
            "text": "Connect battery first, then panel MC4s, keeping red to positive (+) and black to negative (\u2212). Torque ring terminals, seat the fuse, and tuck the controller off the ground.",
            "options": [
                {
                    "type": "process",
                    "process": "wire-portable-solar-kit",
                    "text": "Wire and fuse everything"
                },
                {
                    "type": "goto",
                    "goto": "configure",
                    "text": "Controller powers up without sparks.",
                    "requiresItems": [
                        {
                            "id": "8e540f94-91e0-47a1-b6ca-78e8b48aefac",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "rollback-safe",
                    "text": "Controller boot is unstable or fuse trips immediately."
                }
            ]
        },
        {
            "id": "rollback-safe",
            "text": "Hold up\u2014go to safe mode: disconnect panel input, pull the fuse, and re-check polarity before touching terminals. We only resume once no connector heating or fault code remains.",
            "options": [
                {
                    "type": "goto",
                    "goto": "wire",
                    "text": "Rollback complete, wiring rechecked. Retry controlled power-up.",
                    "requiresItems": [
                        {
                            "id": "8e540f94-91e0-47a1-b6ca-78e8b48aefac",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "configure",
            "text": "Select LiFePO4 mode, set absorb to 14.4 V and float to 13.6 V, then record the settings so you can rebuild this later.",
            "options": [
                {
                    "type": "process",
                    "process": "configure-charge-controller-profile",
                    "text": "Store the profile"
                },
                {
                    "type": "goto",
                    "goto": "charge",
                    "text": "Settings saved and fuse seated.",
                    "requiresItems": [
                        {
                            "id": "22a50cfd-4433-4ce7-bbed-e4038338191b",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "rollback-safe",
                    "text": "Profile mismatch or repeated warnings; return to safe rollback."
                },
                {
                    "type": "goto",
                    "goto": "profile-review",
                    "text": "Run a profile review checklist before charging.",
                    "requiresItems": [
                        {
                            "id": "22a50cfd-4433-4ce7-bbed-e4038338191b",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "charge",
            "text": "Point the panel at the sun and let it soak up 200 Wh. Check the controller display after 10 minutes\u2014cool cables and steady voltage mean you're good.",
            "options": [
                {
                    "type": "process",
                    "process": "harvest-200Wh-portable",
                    "text": "Start charging"
                },
                {
                    "type": "goto",
                    "goto": "verify",
                    "text": "Controller reports stable charging. Verify before finish.",
                    "requiresItems": [
                        {
                            "id": "b02ecff5-1f7d-4247-a09d-7d6cd6bb218a",
                            "count": 200
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "rollback-safe",
                    "text": "Voltage swings or heating detected during charge."
                }
            ]
        },
        {
            "id": "profile-review",
            "text": "Alternate verification branch: read back absorb/float settings and confirm they match the recorded LiFePO4 target values before charging starts.",
            "options": [
                {
                    "type": "goto",
                    "goto": "charge",
                    "text": "Profile values match. Continue to controlled charging.",
                    "requiresItems": [
                        {
                            "id": "22a50cfd-4433-4ce7-bbed-e4038338191b",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "rollback-safe",
                    "text": "Values drifted. Roll back and reconfigure."
                }
            ]
        },
        {
            "id": "verify",
            "text": "Verification gate: confirm the stored profile still matches LiFePO4 targets and the final charge run completed without alarms. If anything drifted, roll back and re-verify.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Verified: profile + charge output are both in spec.",
                    "requiresItems": [
                        {
                            "id": "22a50cfd-4433-4ce7-bbed-e4038338191b",
                            "count": 1
                        },
                        {
                            "id": "b02ecff5-1f7d-4247-a09d-7d6cd6bb218a",
                            "count": 200
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "rollback-safe",
                    "text": "Verification failed; execute rollback and retry sequence."
                },
                {
                    "type": "goto",
                    "goto": "monitor-recovery",
                    "text": "Minor drift detected; run monitoring recovery then re-verify."
                }
            ]
        },
        {
            "id": "monitor-recovery",
            "text": "Monitoring recovery: cool the controller, tighten terminal screws, and wait one check interval for stable voltage before returning to final verification.",
            "options": [
                {
                    "type": "goto",
                    "goto": "verify",
                    "text": "Recovery complete. Re-run verification gate.",
                    "requiresItems": [
                        {
                            "id": "22a50cfd-4433-4ce7-bbed-e4038338191b",
                            "count": 1
                        },
                        {
                            "id": "b02ecff5-1f7d-4247-a09d-7d6cd6bb218a",
                            "count": 200
                        }
                    ]
                }
            ]
        },
        {
            "id": "finish",
            "text": "Nice work! The controller will guard your battery while sun fills it up.",
            "options": [
                {
                    "type": "finish",
                    "text": "Sun power secured!"
                }
            ]
        }
    ],
