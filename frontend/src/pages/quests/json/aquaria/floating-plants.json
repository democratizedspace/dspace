{
    "id": "aquaria/floating-plants",
    "title": "Add Floating Plants",
    "description": "Introduce guppy grass to help balance nutrients in your tank.",
    "image": "/assets/quests/floating_plants.jpg",
    "npc": "/assets/npc/vega.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Algae is creeping in. Add floaters to soak up nutrients?",
            "options": [
                {
                    "type": "goto",
                    "goto": "prep",
                    "text": "Yes, help me stage them."
                },
                {
                    "type": "goto",
                    "goto": "light",
                    "text": "Let me check the light first."
                }
            ]
        },
        {
            "id": "light",
            "text": "Keep floaters off the spray bar, leave open water, and run 6–8 hours light.",
            "options": [
                {
                    "type": "goto",
                    "goto": "prep",
                    "text": "Light timing looks good."
                }
            ]
        },
        {
            "id": "prep",
            "text": "Rinse plants in tank water, check hitchhikers, and set a ring to corral them.",
            "options": [
                {
                    "type": "grantsItems",
                    "grantsItems": [
                        {
                            "id": "0704e829-ce72-4c7d-91b0-8a774b11575d",
                            "count": 1
                        },
                        {
                            "id": "c5a7574e-515f-4e9a-83fc-350703131f25",
                            "count": 1
                        }
                    ],
                    "text": "Share a starter mix."
                },
                {
                    "type": "goto",
                    "goto": "place",
                    "text": "Plants rinsed and corral ready.",
                    "requiresItems": [
                        {
                            "id": "0704e829-ce72-4c7d-91b0-8a774b11575d",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "place",
            "text": "Lay guppy grass near the outflow for gentle flow and leave room to vent gas.",
            "options": [
                {
                    "type": "goto",
                    "goto": "thin",
                    "text": "Plants placed and floating."
                },
                {
                    "type": "goto",
                    "goto": "light",
                    "text": "Need to move them away from the spray bar."
                }
            ]
        },
        {
            "id": "thin",
            "text": "If floaters cover half the surface, scoop a handful weekly to share or toss.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Noted—I'll keep them trimmed."
                }
            ]
        },
        {
            "id": "finish",
            "text": "Great! Floaters will gobble up nitrates and give fry a safe canopy.",
            "options": [
                {
                    "type": "finish",
                    "text": "Surface looks balanced."
                }
            ]
        }
    ],
    "rewards": [
        {
            "id": "c5a7574e-515f-4e9a-83fc-350703131f25",
            "count": 1
        },
        {
            "id": "092dae11-237a-43cc-b342-246aabbba258",
            "count": 1
        }
    ],
    "requiresQuests": ["aquaria/shrimp"]
}
