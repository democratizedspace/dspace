        },
        {
            "id": "verify",
            "text": "Outcome check: fry cover should be dense but breathable. If leaves melt, trap food film, or drift into the filter throat, run recovery before closing.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Cover is stable and livestock movement stays calm.",
