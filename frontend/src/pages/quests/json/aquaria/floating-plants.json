                        },
                        {
                            "id": "ee7d437d-7426-47cd-b691-386dd20f4e47",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "quarantine-hold",
            "text": "Quarantine path: hold clippings in dechlorinated water, remove melt-prone stems, and only place vigorous growth after a final rinse.",
            "options": [
                {
                    "type": "process",
                    "process": "rinse-floating-plants",
                    "text": "Run quarantine rinse and trim weak stems.",
                    "goto": "place",
                    "requiresItems": [
                        {
                            "id": "0704e829-ce72-4c7d-91b0-8a774b11575d",
                            "count": 1
                        },
                        {
                            "id": "71efa72a-8c87-4dc2-8e2c-9119bb28fe50",
                            "count": 1
                        },
                        {
                            "id": "ee7d437d-7426-47cd-b691-386dd20f4e47",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "place",
                    "text": "Quarantine check passed; healthy bundle ready for placement.",
                    "requiresItems": [
                        {
                            "id": "c1f5f126-ad6b-4ba8-86ad-5598fb5038e9",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "place",
            "text": "Float the rinsed stems under the light, keep them clear of the intake, and leave a breathing lane so shrimp can reach the surface.",
            "options": [
                {
                    "type": "process",
                    "process": "place-floating-plants",
                    "text": "Float and spread the guppy grass mat.",
                    "goto": "verify",
                    "requiresItems": [
                        {
                            "id": "c1f5f126-ad6b-4ba8-86ad-5598fb5038e9",
                            "count": 1
