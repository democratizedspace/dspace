{
    "id": "aquaria/floating-plants",
    "title": "Add Floating Plants",
    "description": "Rinse guppy grass in dechlorinated water, then float it so it soaks up excess nutrients and shelters fry.",
    "image": "/assets/quests/floating_plants.jpg",
    "npc": "/assets/npc/vega.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Your shrimp are thriving, but nutrient levels creep up fast. We'll run a clean install path and a slower quarantine path so pests never hitchhike into the tank.",
            "options": [
                {
                    "type": "process",
                    "process": "bucket-water-dechlorinated",
                    "text": "Prep fresh dechlorinated rinse water.",
                    "goto": "strategy"
                },
                {
                    "type": "goto",
                    "goto": "strategy",
                    "text": "I'll use the bucket that's already dechlorinated.",
                    "requiresItems": [
                        {
                            "id": "71efa72a-8c87-4dc2-8e2c-9119bb28fe50",
                            "count": 1
                        },
                        {
                            "id": "0704e829-ce72-4c7d-91b0-8a774b11575d",
                            "count": 1
                        },
                        {
                            "id": "ee7d437d-7426-47cd-b691-386dd20f4e47",
                            "count": 1
                        },
                        {
                            "id": "997eaba9-25ee-43d5-bbdc-5d6adf03adfa",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "strategy",
            "text": "Choose your path: quick rinse for healthy clippings, or quarantine rinse when you suspect snail eggs or damaged stems.",
            "options": [
                {
                    "type": "goto",
                    "goto": "rinse",
                    "text": "Use the standard rinse path.",
                    "requiresItems": [
                        {
                            "id": "71efa72a-8c87-4dc2-8e2c-9119bb28fe50",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "troubleshoot",
                    "text": "I found hitchhikers or mushy stems; do a recovery rinse.",
                    "requiresItems": [
                        {
                            "id": "71efa72a-8c87-4dc2-8e2c-9119bb28fe50",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "quarantine-hold",
                    "text": "Run the cautious quarantine hold before placing plants.",
                    "requiresItems": [
                        {
                            "id": "71efa72a-8c87-4dc2-8e2c-9119bb28fe50",
                            "count": 1
                        },
                        {
                            "id": "0704e829-ce72-4c7d-91b0-8a774b11575d",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "rinse",
            "text": "Swirl guppy grass in dechlorinated water, strip brown stems, and keep only bright green growth for surface cover.",
            "options": [
                {
                    "type": "process",
                    "process": "rinse-floating-plants",
                    "text": "Rinse and inspect the plants.",
                    "goto": "place",
                    "requiresItems": [
                        {
                            "id": "0704e829-ce72-4c7d-91b0-8a774b11575d",
                            "count": 1
