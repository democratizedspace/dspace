{
    "id": "aquaria/floating-plants",
    "title": "Add Floating Plants",
    "description": "Add floating plants with staged setup and outcome evidence, plus a recovery path for rot or intake block issues.",
    "image": "/assets/quests/floating_plants.jpg",
    "npc": "/assets/npc/vega.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Floating plants help export nutrients, but only if we start clean. Stage your dechlorinated rinse bucket, net, and trim tools first.",
            "options": [
                {
                    "type": "process",
                    "process": "bucket-water-dechlorinated",
                    "text": "Prep a bucket of dechlorinated water.",
                    "goto": "setup-proof"
                },
                {
                    "type": "goto",
                    "goto": "setup-proof",
                    "text": "Gear is staged and rinse water is ready.",
                    "requiresItems": [
                        {
                            "id": "0704e829-ce72-4c7d-91b0-8a774b11575d",
                            "count": 1
                        },
                        {
                            "id": "71efa72a-8c87-4dc2-8e2c-9119bb28fe50",
                            "count": 1
                        },
                        {
                            "id": "ee7d437d-7426-47cd-b691-386dd20f4e47",
                            "count": 1
                        },
                        {
                            "id": "997eaba9-25ee-43d5-bbdc-5d6adf03adfa",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "setup-proof",
            "text": "First evidence gate: rinse and inspect every stem. Remove hitchhikers and dead tissue so we do not seed pests.",
            "options": [
                {
                    "type": "process",
                    "process": "rinse-floating-plants",
                    "text": "Rinse and inspect floating plants.",
                    "goto": "place"
                },
                {
                    "type": "goto",
                    "goto": "place",
                    "text": "Clean rinsed bundle is ready for placement.",
                    "requiresItems": [
                        {
                            "id": "c1f5f126-ad6b-4ba8-86ad-5598fb5038e9",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "place",
            "text": "Second evidence gate: float plants under light while keeping a clear intake lane and open surface gap for gas exchange.",
            "options": [
                {
                    "type": "process",
                    "process": "place-floating-plants",
                    "text": "Place and spread floating plants.",
                    "goto": "monitor",
                    "requiresItems": [
                        {
                            "id": "c1f5f126-ad6b-4ba8-86ad-5598fb5038e9",
                            "count": 1
                        },
                        {
                            "id": "62757412-be94-48c0-a1c0-8fad9bdb8c4a",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "monitor",
                    "text": "Placement complete and intake lane is clear.",
                    "requiresItems": [
                        {
                            "id": "1bdcb22a-17e2-42f8-b990-b842f9684169",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "monitor",
            "text": "Check after a full light cycle: plants should stay buoyant and green without choking the filter intake.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Plants are healthy and flow remains unobstructed.",
                    "requiresItems": [
                        {
                            "id": "1bdcb22a-17e2-42f8-b990-b842f9684169",
                            "count": 1
                        },
                        {
                            "id": "62757412-be94-48c0-a1c0-8fad9bdb8c4a",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "recovery",
                    "text": "I see rot, pests, or intake blockage; run recovery.",
                    "requiresItems": [
                        {
                            "id": "1bdcb22a-17e2-42f8-b990-b842f9684169",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "recovery",
            "text": "Trim failing stems, clear the intake lane, and re-rinse survivors in dechlorinated water before re-placing. Pause if fish gasp at the surface and restore circulation first.",
            "options": [
                {
                    "type": "process",
                    "process": "rinse-floating-plants",
                    "text": "Run recovery rinse and trim cycle.",
                    "goto": "place",
                    "requiresItems": [
                        {
                            "id": "ee7d437d-7426-47cd-b691-386dd20f4e47",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "finish",
            "text": "Good discipline. You proved both setup quality and stable outcome before declaring success.",
            "options": [
                {
                    "type": "finish",
                    "text": "Floating plant habitat stabilized."
                }
            ]
        }
    ],
