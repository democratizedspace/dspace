                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "verify",
                    "text": "Mat is floating and the intake lane stays open.",
                    "requiresItems": [
                        {
                            "id": "1bdcb22a-17e2-42f8-b990-b842f9684169",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "verify",
            "text": "Now verify operations: if the mat covers more than half the surface, blocks flow, or shades out oxygen exchange, thin it before calling this stable.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Coverage and flow are balanced; fry still have open surface access.",
                    "requiresItems": [
                        {
                            "id": "1bdcb22a-17e2-42f8-b990-b842f9684169",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "troubleshoot",
                    "text": "Flow is blocked or plants are melting; troubleshoot and re-rinse before retrying.",
                    "requiresItems": [
                        {
                            "id": "1bdcb22a-17e2-42f8-b990-b842f9684169",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "safety-trim",
                    "text": "Surface gas exchange looks sluggish; run safety trim and reopen lanes.",
                    "requiresItems": [
                        {
                            "id": "1bdcb22a-17e2-42f8-b990-b842f9684169",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "safety-trim",
            "text": "Safety trim branch: remove excess surface cover, clear the filter intake lane, and confirm shrimp can still reach open air pockets before final verification.",
            "options": [
                {
                    "type": "goto",
                    "goto": "verify",
                    "text": "Trim complete; re-check flow and surface access.",
                    "requiresItems": [
                        {
                            "id": "1bdcb22a-17e2-42f8-b990-b842f9684169",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "finish",
            "text": "Perfect. The floating mat now acts as a nutrient sponge and nursery cover without choking gas exchange.",
            "options": [
                {
                    "type": "finish",
                    "text": "I'll keep the mat trimmed and the surface lane clear."
                }
            ]
        }
