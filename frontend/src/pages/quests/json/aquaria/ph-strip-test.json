{
    "id": "aquaria/ph-strip-test",
    "title": "Check aquarium pH",
    "description": "Capture a pH strip reading, interpret against safe bounds, and re-test if the tank is out of range.",
    "image": "/assets/quests/aquarium_ph_strip_test.jpg",
    "npc": "/assets/npc/vega.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Let's verify pH with clean technique. Gloves on, fresh strip in hand, and chart within arm's reach before you dip.",
            "options": [
                {
                    "type": "grantsItems",
                    "grantsItems": [
                        {
                            "id": "13167d6a-5617-4931-8a6e-6f463c6b8835",
                            "count": 1
                        }
                    ],
                    "text": "I need a strip."
                },
                {
                    "type": "goto",
                    "goto": "dip",
                    "requiresItems": [
                        {
                            "id": "13167d6a-5617-4931-8a6e-6f463c6b8835",
                            "count": 1
                        },
                        {
                            "id": "997eaba9-25ee-43d5-bbdc-5d6adf03adfa",
                            "count": 1
                        }
                    ],
                    "text": "Strip and gloves ready."
                }
            ]
        },
        {
            "id": "dip",
            "text": "Dip for 2 seconds mid-column, flick drips, and read within 30 seconds with the chart beside the tank.",
            "options": [
                {
                    "type": "process",
                    "process": "measure-aquarium-ph",
                    "text": "Dip and read the strip.",
