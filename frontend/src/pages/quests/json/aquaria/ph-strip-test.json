        },
        {
            "id": "corrective",
            "text": "Corrective branch: pause livestock changes, adjust buffer in a small dose, wait for circulation, then re-test before logging closure.",
            "grantsItems": [
                {
                    "id": "13167d6a-5617-4931-8a6e-6f463c6b8835",
                    "count": 1
                }
            ],
            "options": [
                {
                    "type": "goto",
                    "goto": "dip",
                    "text": "Correction staged; run a mandatory re-test",
                    "requiresItems": [
                        {
                            "id": "13167d6a-5617-4931-8a6e-6f463c6b8835",
                            "count": 1
                        },
                        {
                            "id": "997eaba9-25ee-43d5-bbdc-5d6adf03adfa",
                            "count": 1
