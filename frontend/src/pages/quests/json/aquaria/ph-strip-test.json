{
    "id": "aquaria/ph-strip-test",
    "title": "Check aquarium pH",
    "description": "Capture a pH strip reading, interpret against safe bounds, and re-test if the tank is out of range.",
    "image": "/assets/quests/aquarium_ph_strip_test.jpg",
    "npc": "/assets/npc/vega.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Let's verify pH with clean technique. Gloves on, fresh strip in hand, and chart within arm's reach before you dip.",
            "options": [
                {
                    "type": "grantsItems",
                    "grantsItems": [
                        {
                            "id": "13167d6a-5617-4931-8a6e-6f463c6b8835",
                            "count": 1
                        }
                    ],
                    "text": "I need a strip."
                },
                {
                    "type": "goto",
                    "goto": "dip",
                    "requiresItems": [
                        {
                            "id": "13167d6a-5617-4931-8a6e-6f463c6b8835",
                            "count": 1
                        },
                        {
                            "id": "997eaba9-25ee-43d5-bbdc-5d6adf03adfa",
                            "count": 1
                        }
                    ],
                    "text": "Strip and gloves ready."
                }
            ]
        },
        {
            "id": "dip",
            "text": "Dip for 2 seconds mid-column, flick drips, and read within 30 seconds with the chart beside the tank.",
            "options": [
                {
                    "type": "process",
                    "process": "measure-aquarium-ph",
                    "text": "Dip and read the strip.",
                    "goto": "interpret",
                    "requiresItems": [
                        {
                            "id": "13167d6a-5617-4931-8a6e-6f463c6b8835",
                            "count": 1
                        },
                        {
                            "id": "997eaba9-25ee-43d5-bbdc-5d6adf03adfa",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "interpret",
                    "text": "Reading recorded from the strip.",
                    "requiresItems": [
                        {
                            "id": "2d1b7889-b28c-4970-8be9-5de092cfd4d9",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "interpret",
            "text": "Interpret against the safe band: 6.8-7.6 is stable for this setup. Outside that band means corrective action and mandatory re-test.",
            "options": [
                {
                    "type": "goto",
                    "goto": "log",
                    "text": "Reading is within 6.8-7.6",
                    "requiresItems": [
                        {
                            "id": "2d1b7889-b28c-4970-8be9-5de092cfd4d9",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "corrective",
                    "text": "Reading is out of range",
                    "requiresItems": [
                        {
                            "id": "2d1b7889-b28c-4970-8be9-5de092cfd4d9",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "emergency-response",
                    "text": "Reading is below 6.4 or above 8.0 (livestock stress risk)",
                    "requiresItems": [
                        {
                            "id": "2d1b7889-b28c-4970-8be9-5de092cfd4d9",
                            "count": 1
                        },
                        {
                            "id": "8c0f72a2-db79-4238-b80f-97721def169f",
