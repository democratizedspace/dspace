{
    "id": "aquaria/ph-strip-test",
    "title": "Check aquarium pH",
    "description": "Measure aquarium pH with strips, log the reading, and run corrective retest loops when outside safe bounds.",
    "image": "/assets/quests/aquarium_ph_strip_test.jpg",
    "npc": "/assets/npc/vega.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Let's make sure your aquarium pH is in range. Put on nitrile gloves, prep your strip, and keep the color chart next to the tank.",
            "options": [
                {
                    "type": "grantsItems",
                    "grantsItems": [
                        {
                            "id": "13167d6a-5617-4931-8a6e-6f463c6b8835",
                            "count": 1
                        }
                    ],
                    "text": "I need a strip"
                },
                {
                    "type": "goto",
                    "goto": "dip",
                    "requiresItems": [
                        {
                            "id": "13167d6a-5617-4931-8a6e-6f463c6b8835",
                            "count": 1
                        },
                        {
                            "id": "997eaba9-25ee-43d5-bbdc-5d6adf03adfa",
                            "count": 1
                        }
                    ],
                    "text": "Strip and gloves ready"
                }
            ]
        },
        {
            "id": "dip",
            "text": "Dip for 2 seconds at mid-water, flick drips, and read within 30 seconds. Do not touch the reactive pad or your reading can drift.",
            "options": [
                {
                    "type": "process",
                    "process": "measure-aquarium-ph",
                    "text": "Dip and read the strip",
                    "goto": "log",
                    "requiresItems": [
                        {
                            "id": "13167d6a-5617-4931-8a6e-6f463c6b8835",
                            "count": 1
                        },
                        {
                            "id": "997eaba9-25ee-43d5-bbdc-5d6adf03adfa",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "log",
                    "text": "Reading captured from the strip",
                    "requiresItems": [
                        {
                            "id": "2d1b7889-b28c-4970-8be9-5de092cfd4d9",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "log",
            "text": "Log pH with date/time and tank notes so trend shifts are visible. This log is your evidence before any buffer adjustment.",
            "options": [
                {
                    "type": "process",
                    "process": "log-aquarium-ph-reading",
                    "text": "Write reading in the logbook",
                    "goto": "interpret",
                    "requiresItems": [
                        {
                            "id": "2d1b7889-b28c-4970-8be9-5de092cfd4d9",
                            "count": 1
                        },
                        {
                            "id": "b8602362-2035-4f00-9376-f48d8668cf38",
                            "count": 1
                        },
                        {
                            "id": "997eaba9-25ee-43d5-bbdc-5d6adf03adfa",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "interpret",
                    "text": "Entry logged and dated",
                    "requiresItems": [
                        {
                            "id": "9c392043-4067-4f49-8038-38eef00e0b24",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "interpret",
            "text": "Interpretation gate: if pH is 6.8-7.6, close out. If outside range or livestock shows stress, run a controlled correction and retest loop.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Reading is stable in the 6.8-7.6 range",
                    "requiresItems": [
                        {
                            "id": "9c392043-4067-4f49-8038-38eef00e0b24",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "correct",
                    "text": "Reading is out of range; start corrective dosing",
                    "requiresItems": [
                        {
                            "id": "9c392043-4067-4f49-8038-38eef00e0b24",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "correct",
            "text": "Wear goggles and gloves, dose in small increments, circulate, and never stack doses without a fresh strip reading.",
            "options": [
                {
                    "type": "process",
                    "process": "adjust-ph",
                    "text": "Apply controlled pH correction",
                    "goto": "retest",
                    "requiresItems": [
                        {
                            "id": "997eaba9-25ee-43d5-bbdc-5d6adf03adfa",
                            "count": 1
                        },
                        {
                            "id": "d7d7f91c-7c51-4fd0-bdd1-f8d25d4f03e0",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "retest",
                    "text": "Correction complete; move to mandatory retest"
                }
            ]
        },
        {
            "id": "retest",
            "text": "Wait for circulation, then run a fresh strip and log again. Do not finish this quest until a new in-range reading is recorded.",
            "options": [
                {
                    "type": "goto",
                    "goto": "dip",
                    "text": "Run retest loop"
                }
            ]
        },
        {
            "id": "finish",
            "text": "Great stability work. Keep weekly checks, and trigger correction early if readings trend toward 6.5 or 8.0.",
            "options": [
                {
                    "type": "finish",
                    "text": "I'll keep the weekly habit"
                }
            ]
        }
    ],
    "rewards": [
        {
            "id": "b281360b-2ecc-4fea-a248-36a61c5f7399",
            "count": 1
        }
    ],
    "requiresQuests": ["aquaria/water-testing"],
