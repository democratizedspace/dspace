{
    "id": "aquaria/ph-strip-test",
    "title": "Check aquarium pH",
    "description": "Grab gloves, dip a strip, and log the pH reading before it drifts.",
    "image": "/assets/quests/aquarium_ph_strip_test.jpg",
    "npc": "/assets/npc/vega.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Let's make sure your aquarium's pH is in range. Put on nitrile gloves so you don't contaminate the sample, then grab a strip and keep the color chart nearby.",
            "options": [
                {
                    "type": "grantsItems",
                    "grantsItems": [
                        {
                            "id": "13167d6a-5617-4931-8a6e-6f463c6b8835",
                            "count": 1
                        }
                    ],
                    "text": "I need a strip."
                },
                {
                    "type": "goto",
                    "goto": "dip",
                    "requiresItems": [
                        {
                            "id": "13167d6a-5617-4931-8a6e-6f463c6b8835",
                            "count": 1
                        },
                        {
                            "id": "997eaba9-25ee-43d5-bbdc-5d6adf03adfa",
                            "count": 1
                        }
                    ],
                    "text": "Strip and gloves ready."
                }
            ]
        },
        {
            "id": "dip",
            "text": "Dip the strip for 2 seconds mid-water column, flick off drips, and read the color within 30 seconds while the chart is right beside you.",
            "options": [
                {
                    "type": "process",
                    "process": "measure-aquarium-ph",
                    "text": "Dip and read the strip.",
                    "goto": "log",
                    "requiresItems": [
                        {
                            "id": "13167d6a-5617-4931-8a6e-6f463c6b8835",
                            "count": 1
                        },
                        {
                            "id": "997eaba9-25ee-43d5-bbdc-5d6adf03adfa",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "log",
                    "text": "Reading recorded from the strip.",
                    "requiresItems": [
                        {
                            "id": "2d1b7889-b28c-4970-8be9-5de092cfd4d9",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "log",
            "text": "Note the pH, date, and time so you can spot trends instead of guessing. If it swings, we can course-correct before the fish notice.",
            "options": [
                {
                    "type": "process",
                    "process": "log-aquarium-ph-reading",
                    "text": "Write it in the logbook.",
                    "goto": "interpret",
                    "requiresItems": [
                        {
                            "id": "2d1b7889-b28c-4970-8be9-5de092cfd4d9",
                            "count": 1
                        },
                        {
                            "id": "b8602362-2035-4f00-9376-f48d8668cf38",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "interpret",
                    "text": "Entry logged and dated.",
                    "requiresItems": [
                        {
                            "id": "9c392043-4067-4f49-8038-38eef00e0b24",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "interpret",
            "text": "Interpret the logged value now: target 6.8\u20137.6 for this community setup. Treat <6.5 as acidic stress risk and >8.0 as alkaline stress risk.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Logged pH is in the 6.8\u20137.6 operating range.",
                    "requiresItems": [
                        {
                            "id": "9c392043-4067-4f49-8038-38eef00e0b24",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "corrective",
                    "text": "Reading is outside safe bounds and needs correction."
                }
            ]
        },
        {
            "id": "corrective",
            "text": "Corrective branch: pause feeding, check aeration, and perform a small conditioned-water adjustment instead of a big swing. Retest after 30 minutes before declaring success.",
            "options": [
                {
                    "type": "process",
                    "process": "measure-aquarium-ph",
                    "text": "Retest pH after corrective step.",
                    "goto": "log",
                    "requiresItems": [
                        {
                            "id": "13167d6a-5617-4931-8a6e-6f463c6b8835",
                            "count": 1
                        },
                        {
                            "id": "997eaba9-25ee-43d5-bbdc-5d6adf03adfa",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "start",
                    "text": "Reset PPE and sampling setup before retrying."
                }
            ]
        },
        {
            "id": "finish",
            "text": "Great! Check weekly to keep fish happy, and flag any drift toward 6.5 or 8.0 so we can act before it stresses them.",
            "options": [
                {
                    "type": "finish",
                    "text": "I'll keep the weekly habit."
                }
            ]
        }
    ],
    "rewards": [
        {
            "id": "b281360b-2ecc-4fea-a248-36a61c5f7399",
            "count": 1
        }
    ],
