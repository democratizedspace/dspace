{
    "id": "aquaria/water-change",
    "title": "Perform a partial water change",
    "description": "Run a controlled 25% water change with prep evidence, post-change verification, and a troubleshooting loop for stressed fish or unstable readings.",
    "image": "/assets/quests/goldfish_partial_water_change.jpg",
    "npc": "/assets/npc/vega.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Safety first: unplug heater/filter, keep hands dry, and stage PPE plus siphon gear before opening the tank.",
            "options": [
                {
                    "type": "goto",
                    "goto": "prep-water",
                    "text": "Tank is electrically safe and gear is staged.",
                    "requiresItems": [
                        {
                            "id": "8c0f72a2-db79-4238-b80f-97721def169f",
                            "count": 1
                        },
                        {
                            "id": "97317bc3-507a-4e2c-912b-507d586cee87",
                            "count": 1
                        },
                        {
                            "id": "0564d441-7367-412e-b709-dad770814a39",
                            "count": 1
                        },
                        {
                            "id": "16eb261b-9d93-4aff-ab31-40f6a78d04f1",
                            "count": 1
                        },
                        {
                            "id": "997eaba9-25ee-43d5-bbdc-5d6adf03adfa",
                            "count": 1
                        },
                        {
                            "id": "d7d7f91c-7c51-4fd0-bdd1-f8d25d4f03e0",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "prep-water",
            "text": "Condition replacement water and match temperature within 2 °C before siphoning. If mismatch persists, do not continue.",
            "options": [
                {
                    "type": "process",
                    "process": "condition-bucket-water",
                    "text": "Condition and temperature-match replacement water.",
                    "goto": "change"
                },
                {
                    "type": "goto",
                    "goto": "change",
                    "text": "Replacement water is matched and ready.",
                    "requiresItems": [
                        {
                            "id": "71efa72a-8c87-4dc2-8e2c-9119bb28fe50",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "recovery",
                    "text": "Temperature mismatch or equipment issue detected; pause for recovery.",
                    "requiresItems": [
                        {
                            "id": "71efa72a-8c87-4dc2-8e2c-9119bb28fe50",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "change",
            "text": "Siphon ~25% while vacuuming debris, then refill slowly with conditioned water and restart heater/filter only when the waterline is stable.",
            "options": [
                {
                    "type": "process",
                    "process": "partial-water-change",
                    "text": "Run the partial water change sequence.",
                    "goto": "verify"
                },
                {
                    "type": "goto",
                    "goto": "verify",
                    "text": "Water swap complete and equipment restarted.",
                    "requiresItems": [
                        {
                            "id": "bc8ff31b-7c20-4c05-9af0-e3530d90fe3f",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "verify",
            "text": "Verification gate: fish should breathe normally and flow should remain steady for a full observation window.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Post-change stability confirmed; no stress signs observed.",
                    "requiresItems": [
                        {
                            "id": "bc8ff31b-7c20-4c05-9af0-e3530d90fe3f",
                            "count": 1
                        },
                        {
                            "id": "97317bc3-507a-4e2c-912b-507d586cee87",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "recovery",
                    "text": "Fish are stressed or flow is unstable; run corrective branch.",
                    "requiresItems": [
                        {
                            "id": "bc8ff31b-7c20-4c05-9af0-e3530d90fe3f",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "recovery",
            "text": "Stop feeding, aerate, and re-check temperature before repeating any swap. Abort if fish show severe distress and restore baseline flow before retrying.",
            "options": [
                {
                    "type": "goto",
                    "goto": "prep-water",
                    "text": "Conditions stabilized; restart prep and re-verify.",
                    "requiresItems": [
                        {
                            "id": "97317bc3-507a-4e2c-912b-507d586cee87",
                            "count": 1
                        },
                        {
                            "id": "8c0f72a2-db79-4238-b80f-97721def169f",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "finish",
            "text": "Excellent control. You proved safe prep, validated outcome stability, and used a recovery protocol instead of forcing through risk.",
            "options": [
                {
                    "type": "finish",
                    "text": "Partial water change complete."
                }
            ]
        }
    ],
    "rewards": [
