{
    "id": "aquaria/water-change",
    "title": "Perform a partial water change",
    "description": "Run a safe partial swap, verify post-change stability, and execute a recovery loop if fish stress or equipment faults appear.",
    "image": "/assets/quests/goldfish_partial_water_change.jpg",
    "npc": "/assets/npc/vega.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "First rule: power safety and PPE. Unplug heater/filter, keep cords dry, and stage everything before siphoning.",
            "options": [
                {
                    "type": "goto",
                    "goto": "prep",
                    "text": "Gear gathered and tank is safe to work.",
                    "requiresItems": [
                        {
                            "id": "8c0f72a2-db79-4238-b80f-97721def169f",
                            "count": 1
                        },
                        {
                            "id": "97317bc3-507a-4e2c-912b-507d586cee87",
                            "count": 1
                        },
                        {
                            "id": "0564d441-7367-412e-b709-dad770814a39",
                            "count": 1
                        },
                        {
                            "id": "16eb261b-9d93-4aff-ab31-40f6a78d04f1",
                            "count": 1
                        },
                        {
                            "id": "997eaba9-25ee-43d5-bbdc-5d6adf03adfa",
                            "count": 1
                        },
                        {
                            "id": "d7d7f91c-7c51-4fd0-bdd1-f8d25d4f03e0",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "prep",
            "text": "Condition replacement water and match temperature within 2°C before the siphon starts.",
            "options": [
                {
                    "type": "process",
                    "process": "condition-bucket-water",
                    "text": "Condition replacement water."
                },
                {
                    "type": "goto",
                    "goto": "remove",
                    "text": "Replacement water is conditioned and matched.",
                    "requiresItems": [
                        {
                            "id": "71efa72a-8c87-4dc2-8e2c-9119bb28fe50",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "remove",
            "text": "Vacuum detritus and swap about 25% volume. Refill slowly to avoid shocking fish or stirring substrate clouds.",
            "options": [
                {
                    "type": "process",
                    "process": "partial-water-change",
                    "text": "Run partial water change cycle."
                },
                {
                    "type": "goto",
                    "goto": "verify",
                    "text": "Water swapped and equipment restarted.",
                    "requiresItems": [
                        {
                            "id": "bc8ff31b-7c20-4c05-9af0-e3530d90fe3f",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "verify",
            "text": "Verification window: observe fish behavior and confirm heater/filter stability after restart before you close the ticket.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Flow is stable, fish are calm, and post-change state is clean.",
                    "requiresItems": [
                        {
                            "id": "bc8ff31b-7c20-4c05-9af0-e3530d90fe3f",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "troubleshoot",
                    "text": "Clouding, gasping, or weak flow detected after refill.",
                    "requiresItems": [
                        {
                            "id": "bc8ff31b-7c20-4c05-9af0-e3530d90fe3f",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "troubleshoot",
            "text": "Recovery branch: pause feeding, reduce light for one cycle, confirm intake isn't blocked, and run a smaller corrective swap before re-verifying.",
            "options": [
                {
                    "type": "process",
                    "process": "partial-water-change",
                    "text": "Run a reduced corrective swap."
                },
                {
                    "type": "goto",
                    "goto": "verify",
                    "text": "Corrective swap complete; run verification again.",
                    "requiresItems": [
                        {
                            "id": "bc8ff31b-7c20-4c05-9af0-e3530d90fe3f",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "finish",
            "text": "Water change complete. You closed safety checks, captured a stable post-change state, and handled the fallback loop.",
            "options": [
                {
                    "type": "finish",
                    "text": "Maintenance cycle complete."
                }
            ]
        }
    ],
