                    ]
                }
            ]
        },
        {
            "id": "prep-mix",
            "text": "Confirm replacement water is dechlorinated and within 2 °C of tank temperature before siphoning.",
            "options": [
                {
                    "type": "goto",
                    "goto": "remove",
                    "text": "Replacement water is matched and staged.",
                    "requiresItems": [
                        {
                            "id": "71efa72a-8c87-4dc2-8e2c-9119bb28fe50",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "prep-live",
            "text": "Fill and condition a bucket now, then temperature-match before opening the siphon.",
            "options": [
                {
                    "type": "process",
                    "process": "condition-bucket-water",
                    "text": "Condition fresh replacement water.",
                    "goto": "remove"
                },
                {
                    "type": "goto",
                    "goto": "remove",
                    "text": "Conditioned water is ready for swap.",
                    "requiresItems": [
                        {
                            "id": "71efa72a-8c87-4dc2-8e2c-9119bb28fe50",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "remove",
            "text": "Vacuum to ~25% volume removed, then refill slowly to avoid substrate disturbance and heater shock.",
            "options": [
                {
                    "type": "process",
                    "process": "partial-water-change",
                    "text": "Run the controlled siphon and refill.",
                    "goto": "verify"
                },
                {
                    "type": "goto",
                    "goto": "verify",
                    "text": "Swap complete and hardware restarted.",
                    "requiresItems": [
                        {
                            "id": "bc8ff31b-7c20-4c05-9af0-e3530d90fe3f",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "verify",
            "text": "Verify post-change stability: no leaks, steady heater indicator, and calm fish behavior before closure.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Post-change checks pass.",
                    "requiresItems": [
                        {
                            "id": "bc8ff31b-7c20-4c05-9af0-e3530d90fe3f",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "recover",
                    "text": "Detected temperature swing or fish stress; run recovery.",
                    "requiresItems": [
                        {
                            "id": "bc8ff31b-7c20-4c05-9af0-e3530d90fe3f",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "recover",
            "text": "Pause feeding, stabilize temperature gradually, and perform a smaller corrective top-off before re-verifying.",
            "options": [
                {
                    "type": "process",
                    "process": "condition-bucket-water",
                    "text": "Prepare corrective top-off water.",
                    "goto": "verify"
                },
                {
                    "type": "goto",
                    "goto": "verify",
                    "text": "Recovery complete; run post-change verification again.",
                    "requiresItems": [
                        {
                            "id": "71efa72a-8c87-4dc2-8e2c-9119bb28fe50",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "finish",
            "text": "Excellent discipline. You completed the swap with safety controls and proved recovery readiness.",
            "options": [
                {
                    "type": "finish",
                    "text": "Water change complete."
                }
            ]
        }
