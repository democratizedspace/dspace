{
    "id": "aquaria/net-fish",
    "title": "Catch a fish with a net",
    "description": "Use an aquarium net to move a fish safely during cleaning.",
    "image": "/assets/quests/catch_fish_with_a_net.jpg",
    "npc": "/assets/npc/vega.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "The tank needs a quick tidy. Before we move any fish, prep a calm transfer bucket with tank water and keep the net wet so fins stay protected.",
            "options": [
                {
                    "type": "goto",
                    "goto": "catch",
                    "text": "Transfer bucket and wet net are ready.",
                    "requiresItems": [
                        {
                            "id": "0564d441-7367-412e-b709-dad770814a39",
                            "count": 1
                        },
                        {
                            "id": "ee7d437d-7426-47cd-b691-386dd20f4e47",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "recover",
                    "text": "Fish are darting too hard for a safe scoop."
                }
            ]
        },
        {
            "id": "catch",
            "text": "Guide the fish into the net without chasing. Move slowly and keep the fish submerged while transferring to the bucket.",
            "options": [
                {
                    "type": "goto",
                    "text": "Fish is secure in the bucket after a calm scoop.",
                    "goto": "release",
                    "requiresItems": [
                        {
                            "id": "ee7d437d-7426-47cd-b691-386dd20f4e47",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "recover",
                    "text": "The fish bolted and I lost control of the net."
                }
            ]
        },
        {
            "id": "release",
            "text": "After cleaning, acclimate for a minute and return the fish gently. Confirm normal swimming before you call it done.",
            "options": [
                {
                    "type": "goto",
                    "text": "Fish returned and swimming normally.",
                    "goto": "fin"
                },
                {
                    "type": "goto",
                    "goto": "recover",
                    "text": "Fish is gasping or listing after return."
                }
            ]
        },
        {
            "id": "recover",
            "text": "Pause cleanup. Dim lights, reduce movement, and keep hands out of the tank for 10 minutes. If breathing stays rapid, abort and retry only after the fish settles.",
            "options": [
                {
                    "type": "goto",
                    "goto": "catch",
                    "text": "Fish has calmed down. Retry the transfer safely.",
                    "requiresItems": [
                        {
                            "id": "0564d441-7367-412e-b709-dad770814a39",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "start",
                    "text": "Reset setup before trying again."
                }
            ]
        },
        {
            "id": "fin",
            "text": "Great job\u2014safe transfer, cleanup, and return all verified. That's how you avoid stress injuries during maintenance.",
            "options": [
                {
                    "type": "finish",
                    "text": "All done."
                }
            ]
        }
    ],
    "rewards": [
        {
            "id": "b281360b-2ecc-4fea-a248-36a61c5f7399",
            "count": 1
        }
    ],
    "requiresQuests": ["aquaria/water-change"],
    "hardening": {
        "passes": 0,
        "score": 75,
        "emoji": "\ud83d\udee0\ufe0f",
        "history": []
    }
}
