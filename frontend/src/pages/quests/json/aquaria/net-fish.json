{
    "id": "aquaria/net-fish",
    "title": "Catch a fish with a net",
    "description": "Use an aquarium net to move a fish safely during cleaning.",
    "image": "/assets/quests/catch_fish_with_a_net.jpg",
    "npc": "/assets/npc/vega.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "We need to move a fish before cleaning. Want a quick briefing or jump in?",
            "options": [
                {
                    "type": "goto",
                    "goto": "tips",
                    "text": "Give me netting tips."
                },
                {
                    "type": "goto",
                    "goto": "prep",
                    "text": "I'm ready to set up the bucket."
                }
            ]
        },
        {
            "id": "tips",
            "text": "Move the net slowly above soft substrate, herd gently, and avoid chasing.",
            "options": [
                {
                    "type": "goto",
                    "goto": "prep",
                    "text": "Got it—let's prep."
                }
            ]
        },
        {
            "id": "prep",
            "text": "Fill a bucket with tank water, shade it, and keep an airstone ready.",
            "options": [
                {
                    "type": "grantsItems",
                    "grantsItems": [
                        {
                            "id": "0564d441-7367-412e-b709-dad770814a39",
                            "count": 1
                        },
                        {
                            "id": "ee7d437d-7426-47cd-b691-386dd20f4e47",
                            "count": 1
                        }
                    ],
                    "text": "Loan me a bucket and net."
                },
                {
                    "type": "goto",
                    "goto": "catch",
                    "text": "Bucket ready with the net floating inside.",
                    "requiresItems": [
                        {
                            "id": "0564d441-7367-412e-b709-dad770814a39",
                            "count": 1
                        },
                        {
                            "id": "ee7d437d-7426-47cd-b691-386dd20f4e47",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "catch",
            "text": "Guide the fish near the surface, lift the bucket, and keep the net low.",
            "options": [
                {
                    "type": "goto",
                    "goto": "holding",
                    "text": "Fish is secure in the bucket.",
                    "process": "catch-fish",
                    "requiresItems": [
                        {
                            "id": "ee7d437d-7426-47cd-b691-386dd20f4e47",
                            "count": 1
                        },
                        {
                            "id": "0564d441-7367-412e-b709-dad770814a39",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "tips",
                    "text": "It keeps dodging—remind me of the angles."
                }
            ]
        },
        {
            "id": "holding",
            "text": "Shade the bucket, leave the lid loose for air, and watch gills as you clean.",
            "options": [
                {
                    "type": "goto",
                    "goto": "release",
                    "text": "Tank is clean—ready to return.",
                    "requiresItems": [
                        {
                            "id": "0564d441-7367-412e-b709-dad770814a39",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "release",
            "text": "Tilt the bucket so the fish swims out; avoid pouring to protect slime coat.",
            "options": [
                {
                    "type": "goto",
                    "goto": "fin",
                    "text": "Fish swims back home.",
                    "process": "return-fish"
                }
            ]
        },
        {
            "id": "fin",
            "text": "Great job keeping the fish calm and safe during cleanup!",
            "options": [
                {
                    "type": "finish",
                    "text": "All done."
                }
            ]
        }
    ],
    "rewards": [
        {
            "id": "8807f2f1-3ca2-48da-9b2b-1915604a63e2",
            "count": 5
        },
        {
            "id": "16eb261b-9d93-4aff-ab31-40f6a78d04f1",
            "count": 1
        }
    ],
    "requiresQuests": ["aquaria/water-change"]
}
