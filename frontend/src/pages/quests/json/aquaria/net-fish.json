{
    "id": "aquaria/net-fish",
    "title": "Catch a fish with a net",
    "description": "Use an aquarium net to move a fish safely during cleaning.",
    "image": "/assets/quests/catch_fish_with_a_net.jpg",
    "npc": "/assets/npc/vega.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "The tank needs a quick tidy. We'll prep a covered holding bucket first so the fish is never stranded mid-clean.",
            "options": [
                {
                    "type": "goto",
                    "goto": "approach",
                    "text": "Bucket staged, lid cracked for air, and net ready.",
                    "requiresItems": [
                        {
                            "id": "ee7d437d-7426-47cd-b691-386dd20f4e47",
                            "count": 1
                        },
                        {
                            "id": "0564d441-7367-412e-b709-dad770814a39",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "approach",
            "text": "Approach slowly with lights dimmed. Fast chasing stresses fish and can damage fins.",
            "options": [
                {
                    "type": "goto",
                    "goto": "catch",
                    "text": "Fish is calm near the front glass."
                },
                {
                    "type": "goto",
                    "goto": "calm-fish",
                    "text": "Fish is darting. Pause and calm the tank first."
                }
            ]
        },
        {
            "id": "calm-fish",
            "text": "Stop moving for a minute, reduce reflections, and guide the fish with two slow passes instead of chasing.",
            "options": [
                {
                    "type": "goto",
                    "goto": "catch",
                    "text": "Fish settled. Retry the net pass."
                }
            ]
        },
        {
            "id": "catch",
            "text": "Gently scoop and transfer the fish to the holding bucket, keeping the net submerged until the last moment.",
            "options": [
                {
                    "type": "goto",
                    "text": "Run controlled capture",
                    "requiresItems": [
                        {
                            "id": "ee7d437d-7426-47cd-b691-386dd20f4e47",
                            "count": 1
                        }
                    ],
                    "goto": "cleanup"
                },
                {
                    "type": "goto",
                    "goto": "cleanup",
                    "text": "Fish is secure in the holding bucket.",
                    "requiresItems": [
                        {
                            "id": "ee7d437d-7426-47cd-b691-386dd20f4e47",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "cleanup",
            "text": "Complete the quick cleanup and confirm temperature drift stayed small before reintroduction.",
            "options": [
                {
                    "type": "goto",
                    "goto": "return",
                    "text": "Cleanup complete and fish still calm.",
                    "requiresItems": [
                        {
                            "id": "bc8ff31b-7c20-4c05-9af0-e3530d90fe3f",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "calm-fish",
                    "text": "Fish shows stress signs; pause and recover before return."
                }
            ]
        },
        {
            "id": "return",
            "text": "Return the fish to the tank gently and observe for normal swimming before you close the lid.",
            "options": [
                {
                    "type": "goto",
                    "text": "Return fish to tank",
                    "goto": "verify"
                },
                {
                    "type": "goto",
                    "goto": "verify",
                    "text": "Fish is back in the tank and moving normally.",
                    "requiresItems": [
                        {
                            "id": "21247ab3-427f-4448-8b68-4d8ad742cb7a",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "verify",
            "text": "Nice work. Minimal chase time, clean transfer, and controlled return reduce injury risk.",
            "options": [
                {
                    "type": "finish",
                    "text": "All done."
                }
            ]
        }
    ],
    "rewards": [
        {
            "id": "b281360b-2ecc-4fea-a248-36a61c5f7399",
            "count": 1
        }
    ],
    "requiresQuests": ["aquaria/water-change"],
    "hardening": {
        "passes": 0,
        "score": 100,
        "emoji": "\ud83d\udee0\ufe0f",
        "history": []
    }
}
