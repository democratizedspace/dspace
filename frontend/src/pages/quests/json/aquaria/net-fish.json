{
    "id": "aquaria/net-fish",
    "title": "Catch a fish with a net",
    "description": "Use an aquarium net to move a fish safely during cleaning.",
    "image": "/assets/quests/catch_fish_with_a_net.jpg",
    "npc": "/assets/npc/vega.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "The tank needs a quick tidy. We'll do a calm transfer: prep bucket water, dim lights, and avoid chasing fish around decor.",
            "options": [
                {
                    "type": "goto",
                    "goto": "baseline",
                    "text": "I'll stage a calm transfer lane and prep checks.",
                    "requiresItems": [
                        {
                            "id": "ee7d437d-7426-47cd-b691-386dd20f4e47",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "alternate-approach",
                    "text": "Fish are skittish; let's run a slower alternate approach.",
                    "requiresItems": [
                        {
                            "id": "ee7d437d-7426-47cd-b691-386dd20f4e47",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "alternate-approach",
            "text": "Alternate strategy: pause aeration bubbles briefly, use room lighting only, and guide fish with your free hand outside the net path instead of direct pursuit.",
            "options": [
                {
                    "type": "goto",
                    "goto": "baseline",
                    "text": "Fish settled; continue with baseline verification."
                },
                {
                    "type": "goto",
                    "goto": "recovery",
                    "text": "Fish are still darting or breathing fast."
                }
            ]
        },
        {
            "id": "baseline",
            "text": "Before transfer, capture a baseline tank reading so you can verify recovery after reintroduction.",
            "options": [
                {
                    "type": "process",
                    "process": "log-freshly-changed-walstad-temperature",
                    "text": "Log pre-transfer baseline reading.",
                    "goto": "baseline"
                },
                {
                    "type": "goto",
                    "goto": "catch",
                    "text": "Baseline is logged and fish are calm enough to net.",
                    "requiresItems": [
                        {
                            "id": "7f9d9d21-a4f2-4c48-b0e5-9a7483ab05d2",
                            "count": 1
                        },
                        {
                            "id": "ee7d437d-7426-47cd-b691-386dd20f4e47",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "catch",
            "text": "Use one steady scoop, keep the net submerged, and settle the fish in a bucket with matching water. Stop immediately if the fish thrashes against the mesh.",
            "options": [
                {
                    "type": "goto",
                    "goto": "release",
                    "text": "Fish transferred cleanly with minimal stress.",
                    "requiresItems": [
                        {
                            "id": "ee7d437d-7426-47cd-b691-386dd20f4e47",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "recovery",
                    "text": "Fish showed stress signs during transfer."
                }
            ]
        },
        {
            "id": "recovery",
            "text": "Recovery branch: pause handling, restore gentle flow, wait five minutes, then capture a fresh reading before retrying. Abort transfer if stress persists.",
            "options": [
                {
                    "type": "process",
                    "process": "log-freshly-changed-walstad-temperature",
                    "text": "Log recovery reading before retrying.",
                    "goto": "recovery"
                },
                {
                    "type": "goto",
                    "goto": "catch",
                    "text": "Recovery reading is logged and fish behavior normalized.",
                    "requiresItems": [
                        {
                            "id": "7f9d9d21-a4f2-4c48-b0e5-9a7483ab05d2",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "release",
            "text": "With cleanup complete, return the fish gently and verify conditions stayed stable after reintroduction.",
            "options": [
                {
                    "type": "process",
                    "process": "log-freshly-changed-walstad-temperature",
                    "text": "Capture post-release verification reading.",
                    "goto": "release"
                },
                {
                    "type": "finish",
                    "text": "Transfer complete, fish recovered, and verification logged.",
                    "requiresItems": [
                        {
                            "id": "7f9d9d21-a4f2-4c48-b0e5-9a7483ab05d2",
                            "count": 1
                        },
                        {
                            "id": "ee7d437d-7426-47cd-b691-386dd20f4e47",
                            "count": 1
                        }
                    ]
                }
            ]
        }
    ],
    "rewards": [
