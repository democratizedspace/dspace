{
    "id": "aquaria/heater-install",
    "title": "Install an aquarium heater",
    "description": "Install a 150 W heater in a Walstad tank and verify 26\u00b0C with a stick-on thermometer.",
    "image": "/assets/quests/install_aquarium_heater.jpg",
    "npc": "/assets/npc/vega.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Tropical fish need 26\u00b0C. Make sure the Walstad tank already has the strip thermometer on and flow running before you mount the heater.",
            "options": [
                {
                    "type": "goto",
                    "goto": "mount",
                    "text": "Tank is ready for heat",
                    "requiresItems": [
                        {
                            "id": "4e8db808-927f-4ac7-9d1f-1c8400c7f5d7",
                            "count": 1
                        },
                        {
                            "id": "0b85f058-38f2-4e9a-93e9-d47441608619",
                            "count": 1
                        },
                        {
                            "id": "6f08e704-1086-4fef-ad0a-f48922a5cfd0",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "safety-reset",
                    "text": "Outlet area is wet or cords are tangled."
                }
            ]
        },
        {
            "id": "mount",
            "text": "Unplug other gear, submerge the heater near flow, and set it to 26\u00b0C. Leave it unplugged for 20 minutes so the glass temp matches the water.",
            "options": [
                {
                    "type": "process",
                    "process": "heat-walstad",
                    "text": "Install and set the heater"
                },
                {
                    "type": "goto",
                    "goto": "verify",
                    "text": "Heater installed and powered on",
                    "requiresItems": [
                        {
                            "id": "8c0f72a2-db79-4238-b80f-97721def169f",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "safety-reset",
                    "text": "I powered on before full submersion or forgot the drip loop."
                }
            ]
        },
        {
            "id": "verify",
            "text": "Watch the strip for the next few minutes and log the temperature once it stabilizes. Aim for 26\u00b0C \u00b11\u00b0C before you add fish.",
            "options": [
                {
                    "type": "process",
                    "process": "log-walstad-temperature",
                    "text": "Log the stabilized reading"
                },
                {
                    "type": "goto",
                    "goto": "interpret",
                    "text": "Reading recorded and steady",
                    "requiresItems": [
                        {
                            "id": "7f9d9d21-a4f2-4c48-b0e5-9a7483ab05d2",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "recover-temp",
                    "text": "Temperature is still outside the safe range."
                }
            ]
        },
        {
            "id": "interpret",
            "text": "Interpret the reading before closure: 25\u201327\u00b0C is acceptable for guppies, but anything outside that range needs correction before stocking.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "We're in the 25\u201327\u00b0C band with stable flow.",
                    "requiresItems": [
                        {
                            "id": "7f9d9d21-a4f2-4c48-b0e5-9a7483ab05d2",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "recover-temp",
                    "text": "Reading drifted after a few minutes."
                }
            ]
        },
        {
            "id": "recover-temp",
            "text": "Recovery path: unplug the heater, verify full submersion and flow, reset to 26\u00b0C, then wait 10 minutes before rechecking. Do not add livestock until readings stabilize.",
            "options": [
                {
                    "type": "goto",
                    "goto": "verify",
                    "text": "Corrections made. Re-log the temperature."
                },
                {
                    "type": "goto",
                    "goto": "safety-reset",
                    "text": "I still see unsafe wiring or exposed heater glass."
                }
            ]
        },
        {
            "id": "safety-reset",
            "text": "Safety first. Dry hands and floor, route a drip loop below the outlet, and keep heater power off until fully submerged. Resume only when the area is safe.",
            "options": [
                {
                    "type": "goto",
                    "goto": "mount",
                    "text": "Safety reset complete. Resume install."
                },
                {
                    "type": "goto",
                    "goto": "start",
                    "text": "Restart from readiness checks."
                }
            ]
        },
        {
            "id": "finish",
            "text": "Nice control. Keep the heater cord dripped below the outlet and recheck daily for a week to confirm the thermostat holds.",
            "options": [
                {
                    "type": "finish",
                    "text": "Temperature locked in"
                }
            ]
        }
    ],
    "rewards": [
        {
            "id": "b281360b-2ecc-4fea-a248-36a61c5f7399",
            "count": 1
        }
    ],
    "requiresQuests": ["aquaria/sponge-filter", "aquaria/thermometer", "aquaria/walstad"],
    "hardening": {
