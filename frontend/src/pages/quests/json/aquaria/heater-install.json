{
    "id": "aquaria/heater-install",
    "title": "Install an aquarium heater",
    "description": "Install a 150 W heater in a Walstad tank, verify a stable 26°C band, and recover safely if readings drift.",
    "image": "/assets/quests/install_aquarium_heater.jpg",
    "npc": "/assets/npc/vega.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Tropical fish need 26°C. Confirm the strip thermometer is attached, sponge flow is restored, and the outlet has a drip loop before you mount the heater.",
            "options": [
                {
                    "type": "goto",
                    "goto": "mount",
                    "text": "Tank, airflow, and drip loop are ready",
                    "requiresItems": [
                        {
                            "id": "4e8db808-927f-4ac7-9d1f-1c8400c7f5d7",
                            "count": 1
                        },
                        {
                            "id": "0b85f058-38f2-4e9a-93e9-d47441608619",
                            "count": 1
                        },
                        {
                            "id": "6f08e704-1086-4fef-ad0a-f48922a5cfd0",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "mount",
            "text": "Unplug nearby gear, mount the heater near flow, set 26°C, and wait 20 minutes before powering it so glass temperature equalizes.",
            "options": [
                {
                    "type": "process",
                    "process": "heat-walstad",
                    "text": "Install and power the heater"
                },
                {
                    "type": "goto",
                    "goto": "verify",
                    "text": "Heater is installed and running",
                    "requiresItems": [
                        {
                            "id": "8c0f72a2-db79-4238-b80f-97721def169f",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "verify",
            "text": "Take and log a stabilized strip reading after circulation. Pass target is 25-27°C with normal fish behavior and no heater cycling alarms.",
            "options": [
                {
                    "type": "process",
                    "process": "log-walstad-temperature",
                    "text": "Log a stabilized temperature reading"
                },
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Reading is stable in the 25-27°C band",
                    "requiresItems": [
                        {
                            "id": "7f9d9d21-a4f2-4c48-b0e5-9a7483ab05d2",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "recover",
                    "text": "Reading is drifting or fish look stressed",
                    "requiresItems": [
                        {
                            "id": "7f9d9d21-a4f2-4c48-b0e5-9a7483ab05d2",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "recover",
            "text": "Recovery mode: unplug heater, confirm sponge flow, and reset thermostat to 25°C before a controlled restart. If temperature keeps drifting, pause stocking and escalate.",
            "options": [
                {
                    "type": "goto",
                    "goto": "mount",
                    "text": "Rollback complete; retry install sequence",
                    "requiresItems": [
                        {
                            "id": "4e8db808-927f-4ac7-9d1f-1c8400c7f5d7",
                            "count": 1
                        },
                        {
                            "id": "0b85f058-38f2-4e9a-93e9-d47441608619",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "verify",
                    "text": "Flow and thermostat look normal; re-verify after 10 minutes",
                    "requiresItems": [
                        {
                            "id": "8c0f72a2-db79-4238-b80f-97721def169f",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "finish",
            "text": "Nice control. Keep the drip loop below the outlet and log one reading daily for a week to confirm thermostat stability before adding sensitive livestock.",
            "options": [
                {
                    "type": "finish",
                    "text": "Temperature control is stable"
                }
            ]
        }
    ],
    "rewards": [
        {
            "id": "b281360b-2ecc-4fea-a248-36a61c5f7399",
            "count": 1
        }
    ],
    "requiresQuests": ["aquaria/sponge-filter", "aquaria/thermometer", "aquaria/walstad"],
