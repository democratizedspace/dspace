                    ]
                }
            ]
        },
        {
            "id": "stage",
            "text": "Level the stand, place the tank, and stage soil, gravel, plants, light, and conditioner with a clean bucket. Keep cords dry.",
            "options": [
                {
                    "type": "process",
                    "process": "condition-bucket-water",
                    "text": "Prep dechlorinated fill water"
                },
                {
                    "type": "goto",
                    "goto": "build",
                    "text": "Bucket is dechlorinated and tools are staged",
                    "requiresItems": [
                        {
                            "id": "71efa72a-8c87-4dc2-8e2c-9119bb28fe50",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "build",
            "text": "Add soil, cap with rinsed gravel, tuck in guppy grass and duckweed, then fill gently with dechlorinated water. Set the light to an 8-hour timer.",
            "options": [
                {
                    "type": "process",
                    "process": "assemble-walstad-tank",
                    "text": "Layer and plant the Walstad tank"
                },
                {
                    "type": "goto",
                    "goto": "thermo",
                    "text": "Substrate settled and plants look secure",
                    "requiresItems": [
                        {
                            "id": "785fa6f3-bb66-4197-a43f-52fea9cebd48",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "thermo",
            "text": "Dry the glass and mark a spot for the strip thermometer so you can track swings without dunking probes.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Placement marked and glass is dry",
                    "requiresItems": [
                        {
                            "id": "785fa6f3-bb66-4197-a43f-52fea9cebd48",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "finish",
            "text": "Good start. Let it settle, test often, and add fish only after ammonia and nitrite hold at zero.",
            "options": [
                {
                    "type": "finish",
                    "text": "I'll let it cycle cleanly"
                }
            ]
        }
