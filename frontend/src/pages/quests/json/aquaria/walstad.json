                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "stage",
            "text": "Level the stand, keep cords above drip lines, and prep dechlorinated water before soil touches glass.",
            "options": [
                {
                    "type": "process",
                    "process": "condition-bucket-water",
                    "text": "Prep dechlorinated fill water.",
                    "goto": "build"
                },
                {
                    "type": "goto",
                    "goto": "build",
                    "text": "Bucket is conditioned and tools are staged.",
                    "requiresItems": [
                        {
                            "id": "71efa72a-8c87-4dc2-8e2c-9119bb28fe50",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "build",
            "text": "Add soil, cap with rinsed gravel, plant lightly, and fill gently to avoid substrate bloom.",
            "options": [
                {
                    "type": "process",
                    "process": "assemble-walstad-tank",
                    "text": "Assemble and plant the Walstad tank.",
                    "goto": "verify"
                },
                {
                    "type": "goto",
                    "goto": "verify",
                    "text": "Tank assembled; substrate settled.",
                    "requiresItems": [
                        {
                            "id": "785fa6f3-bb66-4197-a43f-52fea9cebd48",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "verify",
            "text": "First-day verification: water should clear, plants stay rooted, and cords remain dry. If not, branch to recovery before continuing.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Setup is stable and first-day checks pass.",
                    "requiresItems": [
                        {
                            "id": "785fa6f3-bb66-4197-a43f-52fea9cebd48",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "recover",
                    "text": "Cloudiness, uprooted stems, or splash risk detected; recover first.",
                    "requiresItems": [
                        {
                            "id": "785fa6f3-bb66-4197-a43f-52fea9cebd48",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "recover",
            "text": "Pause stocking. Re-seat floating stems, reduce turbulence, and run a fresh conditioned top-off before re-checking after a full light cycle.",
            "options": [
                {
                    "type": "process",
                    "process": "condition-bucket-water",
                    "text": "Prepare corrective top-off water.",
                    "goto": "verify"
                },
                {
                    "type": "goto",
                    "goto": "verify",
                    "text": "Recovery actions complete; repeat first-day verification.",
                    "requiresItems": [
                        {
                            "id": "71efa72a-8c87-4dc2-8e2c-9119bb28fe50",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "finish",
            "text": "Good start. You staged safely, built with evidence, and proved recovery before moving on to livestock prep.",
            "options": [
                {
                    "type": "finish",
                    "text": "Walstad baseline established."
                }
            ]
        }
