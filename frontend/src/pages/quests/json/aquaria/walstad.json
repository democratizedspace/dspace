{
    "id": "aquaria/walstad",
    "title": "Set up a Walstad tank",
    "description": "Build a low-tech Walstad system with staged setup and outcome proofs, including a contingency loop when cycle health is unstable.",
    "image": "/assets/quests/walstad_setup.jpg",
    "npc": "/assets/npc/vega.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Vega here. We build stability in stages: materials first, controlled build second, then proof that the system settles safely before livestock.",
            "options": [
                {
                    "type": "goto",
                    "goto": "stage",
                    "text": "Materials staged and safety gear ready.",
                    "requiresItems": [
