                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "stage",
            "text": "Setup evidence gate: dechlorinate fill water before substrate work so roots and bacteria avoid chlorine shock.",
            "options": [
                {
                    "type": "process",
                    "process": "condition-bucket-water",
                    "text": "Prepare dechlorinated fill water.",
                    "goto": "build"
                },
                {
                    "type": "goto",
                    "goto": "build",
                    "text": "Water is conditioned and build station is staged.",
                    "requiresItems": [
                        {
                            "id": "71efa72a-8c87-4dc2-8e2c-9119bb28fe50",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "build",
            "text": "Outcome gate one: layer soil and cap, plant densely, fill gently, then set the light schedule.",
            "options": [
                {
                    "type": "process",
                    "process": "assemble-walstad-tank",
                    "text": "Assemble and plant the Walstad build.",
                    "goto": "stability-check"
                },
                {
                    "type": "goto",
                    "goto": "stability-check",
                    "text": "Substrate settled and planted layout is stable.",
                    "requiresItems": [
                        {
                            "id": "785fa6f3-bb66-4197-a43f-52fea9cebd48",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "stability-check",
            "text": "Outcome gate two: verify a stable first-day state—clear water column, secure stems, and no exposed soil plumes. If cloudy or uprooted, branch to recovery before cycling onward.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "System is stable and ready for monitored cycling.",
                    "requiresItems": [
                        {
                            "id": "785fa6f3-bb66-4197-a43f-52fea9cebd48",
                            "count": 1
                        },
                        {
                            "id": "62757412-be94-48c0-a1c0-8fad9bdb8c4a",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "recovery",
                    "text": "Clouding or uprooted plants detected; run recovery pass.",
                    "requiresItems": [
                        {
                            "id": "785fa6f3-bb66-4197-a43f-52fea9cebd48",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "recovery",
            "text": "Pause stocking. Re-seat uprooted stems, top off slowly with conditioned water, and cut light intensity for a day if algae bloom starts. Resume only after clarity recovers.",
            "options": [
                {
                    "type": "process",
                    "process": "condition-bucket-water",
                    "text": "Condition recovery top-off water.",
                    "goto": "build",
                    "requiresItems": [
                        {
                            "id": "71efa72a-8c87-4dc2-8e2c-9119bb28fe50",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "finish",
            "text": "Strong start. You provided setup proof, verified outcome stability, and handled failure criteria before calling the tank cycle-ready.",
            "options": [
                {
                    "type": "finish",
                    "text": "Walstad setup stabilized."
                }
            ]
        }
