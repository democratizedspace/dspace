{
    "id": "aquaria/walstad",
    "title": "Set up a Walstad tank",
    "description": "Build a staged Walstad setup with evidence checkpoints and a recovery loop before introducing livestock.",
    "image": "/assets/quests/walstad_setup.jpg",
    "npc": "/assets/npc/vega.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Vega here. Walstad works when we prove each stage: prep, build, stabilization, then safety re-check before any fish move in.",
            "options": [
                {
                    "type": "goto",
                    "goto": "stage",
                    "text": "Yes—show me the staged plan.",
                    "requiresItems": [
                        {
                            "id": "83fe7eee-135e-4885-9ce0-9042b9fb860a",
                            "count": 1
                        },
                        {
                            "id": "98609b23-4811-4275-8d83-ad59a2797753",
                            "count": 1
                        },
                        {
                            "id": "75cec98f-fcf0-4d73-8d31-5a53571317b2",
                            "count": 3
                        },
                        {
                            "id": "62757412-be94-48c0-a1c0-8fad9bdb8c4a",
                            "count": 1
                        },
                        {
                            "id": "0704e829-ce72-4c7d-91b0-8a774b11575d",
                            "count": 1
                        },
                        {
                            "id": "c5a7574e-515f-4e9a-83fc-350703131f25",
                            "count": 1
                        },
                        {
                            "id": "0564d441-7367-412e-b709-dad770814a39",
                            "count": 1
                        },
                        {
                            "id": "16eb261b-9d93-4aff-ab31-40f6a78d04f1",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "stage",
            "text": "Level stand, stage dry electrical routing, and prep dechlorinated fill water before substrate work. Keep every power loop below the outlet.",
            "options": [
                {
                    "type": "process",
                    "process": "condition-bucket-water",
                    "text": "Prep dechlorinated fill water."
                },
                {
                    "type": "goto",
                    "goto": "build",
                    "text": "Prep stage complete; build can start.",
                    "requiresItems": [
                        {
                            "id": "71efa72a-8c87-4dc2-8e2c-9119bb28fe50",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "build",
            "text": "Add soil, cap with rinsed gravel, plant densely, and fill gently to avoid substrate cloud bursts.",
            "options": [
                {
                    "type": "process",
                    "process": "assemble-walstad-tank",
                    "text": "Assemble planted Walstad layers."
                },
                {
                    "type": "goto",
                    "goto": "stabilize",
                    "text": "Build artifact is present and the substrate is settled.",
                    "requiresItems": [
                        {
                            "id": "785fa6f3-bb66-4197-a43f-52fea9cebd48",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "stabilize",
            "text": "Set an 8-hour light schedule and wait through an observation window. If water clouds hard, stems uproot, or odor spikes, recover before finishing.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Water is clear, plants are rooted, and electrical routing remains dry.",
                    "requiresItems": [
                        {
                            "id": "785fa6f3-bb66-4197-a43f-52fea9cebd48",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "recover",
                    "text": "Clouding or instability detected; run a recovery pass.",
                    "requiresItems": [
                        {
                            "id": "785fa6f3-bb66-4197-a43f-52fea9cebd48",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "recover",
            "text": "Pause livestock plans, trim loose stems, re-seat floating plants, and run a partial settle cycle before reassessing stability.",
            "options": [
                {
                    "type": "goto",
                    "goto": "stabilize",
                    "text": "Recovery complete; re-check stabilization window.",
                    "requiresItems": [
                        {
                            "id": "785fa6f3-bb66-4197-a43f-52fea9cebd48",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "finish",
            "text": "Strong foundation. You validated setup and stabilization with a recovery loop, so the tank is ready for controlled cycling.",
            "options": [
                {
                    "type": "finish",
                    "text": "Walstad baseline established."
                }
            ]
        }
    ],
