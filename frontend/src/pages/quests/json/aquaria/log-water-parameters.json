{
    "id": "aquaria/log-water-parameters",
    "title": "Log Water Parameters",
    "description": "Run a full liquid test panel, classify anomalies by severity, and log complete records with a deterministic corrective/retest loop.",
    "image": "/assets/quests/paperwork.jpg",
    "npc": "/assets/npc/vega.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Logs are how we catch trouble before livestock pays the price. Gloves on, kit open, and let's collect ammonia, nitrite, nitrate, and pH as a full snapshot.",
            "options": [
                {
                    "type": "goto",
                    "goto": "measure",
                    "text": "Bench is clear and kit is open.",
                    "requiresItems": [
                        {
                            "id": "8d30133e-0fbb-4e0f-845b-44d721a1f6b2",
                            "count": 1
                        },
                        {
                            "id": "997eaba9-25ee-43d5-bbdc-5d6adf03adfa",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "measure",
            "text": "Rinse vials in tank water, fill to line, add correct drops, and wait full reaction time. Keep gloves on to avoid contaminating readings.",
            "options": [
                {
                    "type": "process",
                    "process": "measure-liquid-parameters",
                    "text": "Run the liquid tests.",
                    "goto": "log",
                    "requiresItems": [
                        {
                            "id": "8d30133e-0fbb-4e0f-845b-44d721a1f6b2",
                            "count": 1
                        },
                        {
                            "id": "997eaba9-25ee-43d5-bbdc-5d6adf03adfa",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "log",
                    "text": "Readings are ready to log.",
                    "requiresItems": [
                        {
                            "id": "9748fccc-ec16-4664-982e-c79b1c082e5e",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "log",
            "text": "Record date/time plus all four fields. Minimum cadence is every 48 hours for stocked tanks. Flag ammonia or nitrite above 0 ppm, nitrate above 40 ppm, or pH outside 6.8–7.6. Incomplete logs must be corrected before closure.",
            "options": [
                {
                    "type": "process",
                    "process": "log-aquarium-test-results",
                    "text": "Record the results in the logbook.",
                    "goto": "interpret",
                    "requiresItems": [
                        {
                            "id": "8d30133e-0fbb-4e0f-845b-44d721a1f6b2",
                            "count": 1
                        },
                        {
                            "id": "9748fccc-ec16-4664-982e-c79b1c082e5e",
                            "count": 1
                        },
                        {
                            "id": "b8602362-2035-4f00-9376-f48d8668cf38",
                            "count": 1
                        },
                        {
                            "id": "997eaba9-25ee-43d5-bbdc-5d6adf03adfa",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "interpret",
                    "text": "Entry logged with today's readings.",
                    "requiresItems": [
                        {
                            "id": "9c60b34c-f0f0-4ed4-b490-e1d781ecb83c",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "audit-gap",
                    "text": "Log entry is missing a field or timestamp",
                    "requiresItems": [
                        {
                            "id": "9748fccc-ec16-4664-982e-c79b1c082e5e",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "audit-gap",
            "text": "Audit branch: incomplete records are operationally unsafe. Re-run the panel if needed, then rewrite the full entry with timestamp and all four parameters.",
            "options": [
                {
                    "type": "goto",
                    "goto": "measure",
                    "text": "Re-run measurements to complete missing fields",
                    "requiresItems": [
                        {
                            "id": "8d30133e-0fbb-4e0f-845b-44d721a1f6b2",
                            "count": 1
                        },
                        {
                            "id": "997eaba9-25ee-43d5-bbdc-5d6adf03adfa",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "log",
                    "text": "All fields and timestamp are now complete"
                }
            ]
        },
        {
            "id": "interpret",
            "text": "Now classify today's panel. If all fields are in bounds, close the cycle. If any field is out of bounds, run a corrective action and then re-measure.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "All readings are within guardrails",
                    "requiresItems": [
                        {
                            "id": "9c60b34c-f0f0-4ed4-b490-e1d781ecb83c",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "corrective",
                    "text": "At least one value is out of range",
                    "requiresItems": [
                        {
                            "id": "9c60b34c-f0f0-4ed4-b490-e1d781ecb83c",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "critical-response",
                    "text": "Ammonia or nitrite is above 0 ppm (critical event)",
                    "requiresItems": [
                        {
                            "id": "9c60b34c-f0f0-4ed4-b490-e1d781ecb83c",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "corrective",
            "text": "Corrective branch: perform a partial water change, then run the test panel again before we sign off the day. Keep fish feeding reduced until values normalize.",
            "options": [
                {
                    "type": "process",
                    "process": "partial-water-change",
                    "text": "Run corrective partial water change"
                },
                {
                    "type": "goto",
                    "goto": "measure",
                    "text": "Correction complete, re-measure the panel",
                    "requiresItems": [
                        {
                            "id": "bc8ff31b-7c20-4c05-9af0-e3530d90fe3f",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "critical-response",
            "text": "Critical response: pause feeding, run an immediate partial water change, and retest before returning to the normal logging cadence.",
            "options": [
                {
                    "type": "process",
                    "process": "partial-water-change",
                    "text": "Run emergency corrective water change"
                },
                {
                    "type": "goto",
                    "goto": "measure",
                    "text": "Emergency change complete; rerun full measurement panel",
                    "requiresItems": [
                        {
                            "id": "bc8ff31b-7c20-4c05-9af0-e3530d90fe3f",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "finish",
            "text": "Great recordkeeping. This log gives you trend evidence for feeding, water-change cadence, and fish stress prevention.",
            "options": [
                {
                    "type": "finish",
                    "text": "I'll keep logging."
                }
            ]
        }
    ],
    "rewards": [
