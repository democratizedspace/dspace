                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "measure",
            "text": "Rinse vials in tank water, fill to the line, add reagents, and wait full reaction time. Keep gloves on so skin oils do not contaminate readings.",
            "options": [
                {
                    "type": "process",
                    "process": "measure-liquid-parameters",
                    "text": "Run the liquid tests",
                    "goto": "log",
                    "requiresItems": [
