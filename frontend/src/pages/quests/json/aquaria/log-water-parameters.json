            "text": "Record values with date/time. Flag ammonia or nitrite above 0 ppm, or nitrate above 40 ppm, as an anomaly that needs immediate response.",
            "options": [
                {
                    "type": "process",
                    "process": "log-aquarium-test-results",
                    "text": "Record the results in the logbook",
