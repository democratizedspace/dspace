{
    "id": "aquaria/log-water-parameters",
    "title": "Log Water Parameters",
    "description": "Run a full liquid test panel, classify anomalies, and log a complete record for trend tracking.",
    "image": "/assets/quests/paperwork.jpg",
    "npc": "/assets/npc/vega.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Logs are how we catch trouble before livestock pays the price. Gloves on, kit open, and let's collect ammonia, nitrite, nitrate, and pH as a full snapshot.",
            "options": [
                {
                    "type": "goto",
                    "goto": "measure",
                    "text": "Bench is clear and kit is open.",
                    "requiresItems": [
                        {
                            "id": "8d30133e-0fbb-4e0f-845b-44d721a1f6b2",
                            "count": 1
                        },
                        {
                            "id": "997eaba9-25ee-43d5-bbdc-5d6adf03adfa",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "measure",
            "text": "Rinse vials in tank water, fill to line, add correct drops, and wait full reaction time. Keep gloves on to avoid contaminating readings.",
            "options": [
                {
                    "type": "process",
                    "process": "measure-liquid-parameters",
                    "text": "Run the liquid tests.",
                    "goto": "log",
                    "requiresItems": [
                        {
                            "id": "8d30133e-0fbb-4e0f-845b-44d721a1f6b2",
                            "count": 1
                        },
                        {
                            "id": "997eaba9-25ee-43d5-bbdc-5d6adf03adfa",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "log",
                    "text": "Readings are ready to log.",
                    "requiresItems": [
                        {
                            "id": "9748fccc-ec16-4664-982e-c79b1c082e5e",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "log",
            "text": "Record date/time plus all four fields. Flag ammonia or nitrite above 0 ppm, nitrate above 40 ppm, or pH outside 6.8–7.6.",
            "options": [
                {
                    "type": "process",
                    "process": "log-aquarium-test-results",
                    "text": "Record the results in the logbook.",
                    "goto": "interpret",
                    "requiresItems": [
                        {
                            "id": "8d30133e-0fbb-4e0f-845b-44d721a1f6b2",
                            "count": 1
                        },
                        {
