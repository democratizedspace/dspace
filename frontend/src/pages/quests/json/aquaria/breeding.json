                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "stress",
                    "text": "Fry are gasping or losses are appearing.",
                    "requiresItems": [
                        {
                            "id": "bda9e450-499d-41d6-ab32-df73528dc68f",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "outcome",
                    "text": "Monitoring checklist complete; review outcomes."
                }
            ]
        },
        {
            "id": "stress",
            "text": "Pause feeding for a cycle, remove leftovers, and run a partial water change before resuming grow-out. Re-check parameters after intervention.",
            "options": [
                {
                    "type": "process",
                    "process": "partial-water-change",
