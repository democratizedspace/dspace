{
    "id": "aquaria/breeding",
    "title": "Breed your guppies",
    "description": "Stage fry cover and feeding, then prove brood health with water-parameter checks before graduating juveniles.",
    "image": "/assets/quests/aquaria_guppy_breeding_plants.jpg",
    "npc": "/assets/npc/vega.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Guppies multiply quickly, but fry survive only when shelter and water quality stay steady. We'll stage habitat first, then validate outcomes before rehoming juveniles.",
            "options": [
                {
                    "type": "goto",
                    "goto": "cover",
                    "text": "Floating mat and warm tank are ready.",
                    "requiresItems": [
                        {
                            "id": "21247ab3-427f-4448-8b68-4d8ad742cb7a",
                            "count": 1
                        },
                        {
                            "id": "1bdcb22a-17e2-42f8-b990-b842f9684169",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "cover",
                    "text": "Begin fry-cover setup walkthrough."
                }
            ]
        },
        {
            "id": "cover",
            "text": "Pack hornwort and guppy grass at the surface so newborns can dodge adults. Keep intake paths open so fry are not pinned against filter flow.",
            "options": [
                {
                    "type": "process",
                    "process": "prepare-guppy-fry-cover",
                    "text": "Thicken the floating cover.",
                    "goto": "feed"
                },
                {
                    "type": "goto",
                    "goto": "feed",
                    "text": "Cover is dense and sheltering fry lanes.",
                    "requiresItems": [
                        {
                            "id": "bda9e450-499d-41d6-ab32-df73528dc68f",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "feed",
                    "text": "Shelter lanes are confirmed; move to feed planning."
                }
            ]
        },
        {
            "id": "feed",
            "text": "Crush flakes into powder and feed tiny portions 2-3 times daily. Siphon leftovers so ammonia spikes don't wipe the brood.",
            "options": [
                {
                    "type": "process",
                    "process": "portion-fry-food",
                    "text": "Powder a week's fry-food reserve.",
                    "goto": "monitor"
                },
                {
                    "type": "goto",
                    "goto": "monitor",
                    "text": "Fry food is portioned and dosing plan is set.",
                    "requiresItems": [
                        {
                            "id": "eb0f7f00-98dc-44b0-bf7c-9c8d998cbbcb",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "monitor",
                    "text": "Feeding plan drafted; continue to monitoring."
                }
            ]
        },
        {
            "id": "monitor",
            "text": "Now prove the environment is stable while fry grow. Log parameters and branch immediately if ammonia/nitrite drift appears.",
            "options": [
                {
                    "type": "process",
                    "process": "log-aquarium-test-results",
                    "text": "Log water parameters before graduation.",
                    "goto": "outcome"
                },
                {
                    "type": "goto",
                    "goto": "stress",
                    "text": "Fry are gasping or losses are appearing.",
                    "requiresItems": [
                        {
                            "id": "bda9e450-499d-41d6-ab32-df73528dc68f",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "outcome",
                    "text": "Monitoring checklist complete; review outcomes."
                }
            ]
        },
        {
            "id": "stress",
            "text": "Pause feeding for a cycle, remove leftovers, and run a partial water change before resuming grow-out. Re-check parameters after intervention.",
            "options": [
                {
                    "type": "process",
                    "process": "partial-water-change",
                    "text": "Run emergency partial water change.",
                    "goto": "monitor"
                },
                {
                    "type": "goto",
                    "goto": "monitor",
                    "text": "Emergency response complete; return to monitoring."
                }
            ]
        },
        {
            "id": "outcome",
            "text": "With stable logs and steady feeding, run the grow-out process and confirm the brood reached juvenile stage before closure.",
            "options": [
                {
                    "type": "process",
                    "process": "raise-guppy-fry",
                    "text": "Advance fry to juvenile stage.",
                    "goto": "finish"
                },
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Juveniles are ready to rehome with stable log evidence.",
                    "requiresItems": [
                        {
                            "id": "18a20f4e-a351-448e-837b-3caca90f71f4",
                            "count": 1
                        },
                        {
                            "id": "9c60b34c-f0f0-4ed4-b490-e1d781ecb83c",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Graduation review complete; close breeding cycle."
                }
            ]
        },
        {
            "id": "finish",
            "text": "Nice work. You staged habitat, handled feeding discipline, and validated brood health with real water-quality evidence before graduation.",
            "options": [
                {
                    "type": "finish",
                    "text": "Time to share healthy guppies."
                }
            ]
        }
    ],
    "rewards": [
        {
            "id": "c5a7574e-515f-4e9a-83fc-350703131f25",
            "count": 1
        }
    ],
    "requiresQuests": ["aquaria/guppy", "aquaria/floating-plants"],
