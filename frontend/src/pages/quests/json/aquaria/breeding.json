{
    "id": "aquaria/breeding",
    "title": "Breed your guppies",
    "description": "Stage fry cover, portion food, and verify juvenile survival with a contingency branch for stress events.",
    "image": "/assets/quests/aquaria_guppy_breeding_plants.jpg",
    "npc": "/assets/npc/vega.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Guppies can breed fast, but survival depends on setup discipline. We need shelter first, then feeding cadence, then a timed juvenile check.",
            "options": [
                {
                    "type": "grantsItems",
                    "grantsItems": [
                        {
                            "id": "0704e829-ce72-4c7d-91b0-8a774b11575d",
                            "count": 1
                        },
                        {
                            "id": "a7ba3f18-510d-47cb-b73f-91b8e2a72e73",
                            "count": 1
                        }
                    ],
                    "text": "Send extra stems to weave in."
                },
                {
                    "type": "goto",
                    "goto": "cover",
                    "text": "Floating mat and warm tank are ready.",
                    "requiresItems": [
                        {
                            "id": "21247ab3-427f-4448-8b68-4d8ad742cb7a",
                            "count": 1
                        },
                        {
                            "id": "1bdcb22a-17e2-42f8-b990-b842f9684169",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "cover",
            "text": "Pack hornwort and guppy grass at the surface so fry can hide. Keep intake lanes clear so babies are not pulled into the filter.",
            "options": [
                {
                    "type": "process",
                    "process": "prepare-guppy-fry-cover",
                    "text": "Build dense fry cover.",
                    "goto": "feed",
                    "requiresItems": [
                        {
                            "id": "21247ab3-427f-4448-8b68-4d8ad742cb7a",
                            "count": 1
                        },
                        {
                            "id": "1bdcb22a-17e2-42f8-b990-b842f9684169",
                            "count": 1
                        },
                        {
                            "id": "a7ba3f18-510d-47cb-b73f-91b8e2a72e73",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "feed",
                    "text": "Cover is dense and sheltering fry.",
                    "requiresItems": [
                        {
                            "id": "bda9e450-499d-41d6-ab32-df73528dc68f",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "feed",
            "text": "Crush flakes to powder and feed tiny pinches 2-3 times daily. Remove leftovers so ammonia spikes do not wipe out fry.",
            "options": [
                {
                    "type": "process",
                    "process": "portion-fry-food",
                    "text": "Portion a week of fry food.",
                    "goto": "raise",
                    "requiresItems": [
                        {
                            "id": "8807f2f1-3ca2-48da-9b2b-1915604a63e2",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "stress-check",
                    "text": "Fry are gasping or adults are hunting them."
                }
            ]
        },
        {
            "id": "stress-check",
            "text": "Pause feeding, check flow and temperature, and separate aggressive adults if needed. Resume only when fry behavior normalizes for a full day.",
            "options": [
                {
                    "type": "goto",
                    "goto": "cover",
                    "text": "Habitat corrected; re-verify shelter before feeding again."
                },
                {
                    "type": "goto",
                    "goto": "feed",
                    "text": "Behavior stabilized; restart small feeding cadence.",
                    "requiresItems": [
                        {
                            "id": "eb0f7f00-98dc-44b0-bf7c-9c8d998cbbcb",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "raise",
            "text": "Now run a timed grow-out window and document outcome. Juvenile proof is required before this quest can close.",
            "options": [
                {
                    "type": "process",
                    "process": "raise-guppy-fry",
                    "text": "Track fry through the grow-out period.",
                    "goto": "verify",
                    "requiresItems": [
                        {
                            "id": "bda9e450-499d-41d6-ab32-df73528dc68f",
                            "count": 1
                        },
                        {
                            "id": "eb0f7f00-98dc-44b0-bf7c-9c8d998cbbcb",
                            "count": 1
                        },
                        {
                            "id": "21247ab3-427f-4448-8b68-4d8ad742cb7a",
                            "count": 1
                        },
                        {
                            "id": "8e81b5e5-4aee-402c-bd04-fed9188f8c07",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "verify",
            "text": "Verify result quality: juveniles should be active, feeding, and large enough to avoid predation. If not, loop back through stress controls.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Juveniles are healthy and ready to rehome.",
                    "requiresItems": [
                        {
                            "id": "18a20f4e-a351-448e-837b-3caca90f71f4",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "stress-check",
                    "text": "Survival rate is low; run contingency and re-check."
                }
            ]
        },
        {
            "id": "finish",
            "text": "Nice work. You staged habitat, controlled feeding, and validated a healthy brood before rehoming.",
            "options": [
                {
                    "type": "finish",
                    "text": "Share the juvenile guppies."
                }
            ]
        }
    ],
    "rewards": [
        {
            "id": "b281360b-2ecc-4fea-a248-36a61c5f7399",
            "count": 1
        }
    ],
    "requiresQuests": ["aquaria/guppy", "aquaria/floating-plants"],
