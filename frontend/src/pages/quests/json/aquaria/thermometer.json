{
    "id": "aquaria/thermometer",
    "title": "Attach Aquarium Thermometer",
    "description": "Attach a stick-on strip thermometer outside the aquarium glass to monitor water temperature.",
    "image": "/assets/quests/stick_on_aquarium_thermometer.jpg",
    "npc": "/assets/npc/vega.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Wash and dry your hands. Unplug gear, wipe a 5 cm patch on the outside glass, and keep cords away from water while you work.",
            "options": [
                {
                    "type": "goto",
                    "goto": "attach",
                    "text": "Glass is clean and dry",
                    "requiresItems": [
                        {
                            "id": "785fa6f3-bb66-4197-a43f-52fea9cebd48",
                            "count": 1
                        },
                        {
                            "id": "8e81b5e5-4aee-402c-bd04-fed9188f8c07",
                            "count": 1
                        },
                        {
                            "id": "b16cd6c7-dfeb-49bf-8758-0cb3563b0d50",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "attach",
            "text": "Peel the backing without touching adhesive. Align the strip at eye level below the waterline and press top to bottom for 30 seconds so bubbles don't form.",
            "options": [
                {
                    "type": "process",
                    "process": "attach-aquarium-thermometer",
                    "text": "Attach the strip thermometer"
                },
                {
                    "type": "goto",
                    "goto": "check",
                    "text": "Strip is attached and seated",
                    "requiresItems": [
                        {
                            "id": "4e8db808-927f-4ac7-9d1f-1c8400c7f5d7",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "check",
            "text": "Wait a few minutes for the strip to stabilize. Read it straight on and log the temperature so you can catch swings while the tank cycles.",
            "options": [
                {
                    "type": "process",
                    "process": "log-walstad-temperature",
                    "text": "Capture the first reading"
                },
                {
                    "type": "goto",
                    "goto": "interpret",
                    "text": "Reading recorded",
                    "requiresItems": [
                        {
                            "id": "7f9d9d21-a4f2-4c48-b0e5-9a7483ab05d2",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "interpret",
            "text": "Interpret the reading before moving on: the target band is 24-28\u00b0C. If it drifts outside that range, do not proceed until you've corrected and rechecked.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Reading is stable in the 24-28\u00b0C band",
                    "requiresItems": [
                        {
                            "id": "7f9d9d21-a4f2-4c48-b0e5-9a7483ab05d2",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "troubleshoot",
                    "text": "Reading is unstable or out of band"
                }
            ]
        },
        {
            "id": "troubleshoot",
            "text": "Pause stocking. Check for air bubbles, direct sun, and poor strip contact. Re-seat the strip, dry the glass again, and run another logged reading before resuming.",
            "options": [
                {
                    "type": "process",
                    "process": "attach-aquarium-thermometer",
                    "text": "Re-seat the strip and reattach it",
                    "goto": "recheck",
                    "requiresItems": [
                        {
                            "id": "785fa6f3-bb66-4197-a43f-52fea9cebd48",
                            "count": 1
                        },
                        {
                            "id": "8e81b5e5-4aee-402c-bd04-fed9188f8c07",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "recheck",
                    "text": "Strip is re-seated and ready for a fresh reading",
                    "requiresItems": [
                        {
                            "id": "4e8db808-927f-4ac7-9d1f-1c8400c7f5d7",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "recheck",
            "text": "Run a second logged reading and confirm the number is repeatable before you close this quest.",
            "options": [
                {
                    "type": "process",
                    "process": "log-walstad-temperature",
                    "text": "Record the verification reading"
                },
                {
                    "type": "goto",
                    "goto": "interpret",
                    "text": "Verification reading captured",
                    "requiresItems": [
                        {
                            "id": "7f9d9d21-a4f2-4c48-b0e5-9a7483ab05d2",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "finish",
            "text": "Plug equipment back in with dry hands. Keep the strip away from direct sun and check it daily until the heater is installed.",
            "options": [
                {
                    "type": "finish",
                    "text": "Temperature logged"
                }
            ]
        }
    ],
    "rewards": [
        {
            "id": "b281360b-2ecc-4fea-a248-36a61c5f7399",
            "count": 1
        }
    ],
    "requiresQuests": ["aquaria/walstad"],
    "hardening": {
        "passes": 0,
        "score": 95,
        "emoji": "\ud83d\udee0\ufe0f",
        "history": []
    }
}
