                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "release",
                    "text": "Water is matched."
                }
            ]
        },
        {
            "id": "release",
            "text": "Use an aquarium net to move the shrimp into the tank. Pour the bag water down a drain, rinse the bucket, and wash your hands to avoid contamination.",
            "options": [
