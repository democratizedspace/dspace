{
    "id": "aquaria/shrimp",
    "title": "Add dwarf shrimp",
    "description": "Introduce hardy shrimp with drip acclimation to keep the tank clean and water stable.",
    "image": "/assets/quests/dwarf_shrimp_drip_acclimation.jpg",
    "npc": "/assets/npc/vega.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Your Walstad tank reads 0 ammonia and nitrite when checked with a liquid test kit. Dwarf shrimp graze algae and reveal any stability issues.",
            "options": [
                {
                    "type": "goto",
                    "goto": "acquire",
                    "text": "Tank checks passed and I'm ready to stage acclimation gear.",
                    "requiresItems": [
                        {
                            "id": "8d30133e-0fbb-4e0f-845b-44d721a1f6b2",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "acquire",
            "text": "Pick up healthy shrimp in a sealed, shaded bag. Verify the water shows 0 ammonia and nitrite, then float it in your tank for 15 minutes to match temperature.",
            "options": [
                {
                    "type": "goto",
                    "goto": "acclimate",
                    "text": "Bag is floating and temperature equalization started."
                },
                {
                    "type": "goto",
                    "goto": "stress-response",
                    "text": "Bag temperature drifted or shrimp look stressed during float."
                }
            ]
        },
        {
            "id": "acclimate",
            "text": "Set up drip acclimation with airline tubing and a clean 5 gallon bucket reserved for aquarium use. Start a siphon at 2–4 drops per second for about an hour until parameters match.",
            "options": [
                {
                    "type": "process",
                    "process": "drip-acclimate-shrimp",
                    "text": "Start drip acclimation",
                    "requiresItems": [
                        {
                            "id": "60e517b4-5807-4983-afb8-e2aad1566587",
                            "count": 1
                        },
                        {
                            "id": "0564d441-7367-412e-b709-dad770814a39",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "release",
                    "text": "Water is matched and shrimp behavior stayed calm.",
                    "requiresItems": [
                        {
                            "id": "73f5e4b3-21dd-4d79-9a64-42624a123fc8",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "release",
                    "text": "Skip drip acclimation and add the shrimp right away.",
                    "requiresItems": [
                        {
                            "id": "b494f643-a77a-4edf-be7e-5f7ff2dfba6a",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "stress-response",
                    "text": "Shrimp are darting, lying still, or breathing rapidly."
                }
            ]
        },
        {
            "id": "stress-response",
            "text": "Pause transfer. Dim lights, recheck heater stability, and extend acclimation in 15-minute blocks until movement normalizes. Never dump bag water into the display tank.",
            "options": [
                {
                    "type": "process",
                    "process": "log-heated-walstad-temperature",
                    "text": "Log a stability reading before retrying.",
                    "goto": "stress-response"
                },
                {
                    "type": "goto",
                    "goto": "acclimate",
                    "text": "Reading logged and behavior recovered; resume controlled acclimation.",
                    "requiresItems": [
                        {
                            "id": "7f9d9d21-a4f2-4c48-b0e5-9a7483ab05d2",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "release",
            "text": "Use an aquarium net to move the shrimp into the tank. Drip-acclimated shrimp settle in, while skipping acclimation can cause fatal osmotic shock.",
            "options": [
                {
                    "type": "process",
                    "process": "stock-drip-acclimated-shrimp",
                    "text": "Add drip-acclimated shrimp with the net.",
                    "requiresItems": [
                        {
                            "id": "ee7d437d-7426-47cd-b691-386dd20f4e47",
                            "count": 1
                        },
                        {
                            "id": "73f5e4b3-21dd-4d79-9a64-42624a123fc8",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "process",
                    "process": "stock-unacclimated-shrimp",
                    "text": "Add non-acclimated shrimp directly to the tank.",
                    "requiresItems": [
                        {
                            "id": "ee7d437d-7426-47cd-b691-386dd20f4e47",
                            "count": 1
                        },
                        {
                            "id": "b494f643-a77a-4edf-be7e-5f7ff2dfba6a",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "verify",
                    "text": "Shrimp were added after drip acclimation.",
                    "requiresItems": [
                        {
                            "id": "f8b6339e-807c-48d0-9aa9-f2c1baad61a2",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "loss-recovery",
                    "text": "Shrimp died after direct transfer; begin cleanup.",
                    "requiresItems": [
                        {
                            "id": "cb3b52dc-9156-456b-84e3-7546768c5978",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "loss-recovery",
            "text": "The unacclimated shrimp died from transfer shock. Net out the carcasses and complete a partial water change before trying again—lesson learned: always drip acclimate.",
            "options": [
                {
                    "type": "process",
                    "process": "cleanup-shrimp-die-off",
                    "text": "Remove shrimp carcasses and run a cleanup water change.",
                    "requiresItems": [
                        {
                            "id": "cb3b52dc-9156-456b-84e3-7546768c5978",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "acclimate",
                    "text": "Cleanup completed; retry with proper drip acclimation.",
                    "requiresItems": [
                        {
                            "id": "8c0f72a2-db79-4238-b80f-97721def169f",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "verify",
            "text": "Run a post-release observation window and capture a fresh reading before closure. If shrimp hide unusually or gasp at the surface, go back to recovery.",
            "options": [
                {
                    "type": "process",
                    "process": "log-heated-walstad-temperature",
                    "text": "Capture post-release verification reading.",
                    "goto": "verify"
                },
                {
                    "type": "goto",
                    "goto": "stress-response",
                    "text": "Stress signs observed; pause and recover before finishing."
                },
                {
                    "type": "finish",
                    "text": "Shrimp are active, temperature is logged, and transfer is stable.",
                    "requiresItems": [
                        {
                            "id": "7f9d9d21-a4f2-4c48-b0e5-9a7483ab05d2",
                            "count": 1
                        },
                        {
                            "id": "f8b6339e-807c-48d0-9aa9-f2c1baad61a2",
                            "count": 1
                        }
                    ]
                }
            ]
        }
    ],
    "rewards": [
        {
            "id": "b494f643-a77a-4edf-be7e-5f7ff2dfba6a",
            "count": 3
        }
    ],
    "requiresQuests": [
