{
    "id": "aquaria/shrimp",
    "title": "Add dwarf shrimp",
    "description": "Introduce hardy shrimp to help clean the tank while keeping water parameters stable.",
    "image": "/assets/quests/shrimp.svg",
    "npc": "/assets/npc/vega.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Your Walstad tank is fully cycled now. A small colony of dwarf shrimp will graze on algae and warn you if water quality slips.",
            "options": [
                {
                    "type": "goto",
                    "goto": "acquire",
                    "text": "Sounds good!"
                }
            ]
        },
        {
            "id": "acquire",
            "text": "Pick up a few healthy shrimp from a reputable store. Keep the bag sealed, use an aquarium test kit to confirm your tank reads 0 ppm ammonia and nitrite, then float the sealed bag for 15 minutes to equalize temperature.",
            "options": [
                {
                    "type": "process",
                    "process": "test-aquarium-water",
                    "text": "Check ammonia and nitrite",
                    "requiresItems": [
                        {
                            "id": "cbc4edb1-54a7-4f03-9a59-c7f84b977322",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "acclimate",
                    "text": "Bag is floating and parameters read 0 ppm"
                }
            ]
        },
        {
            "id": "acclimate",
            "text": "Set up a drip acclimation using a clean bucket and airline tubing so tank water drips into the bag at roughly one drop per second for about an hour.",
            "options": [
                {
                    "type": "process",
                    "process": "drip-acclimate-shrimp",
                    "text": "Start drip acclimation",
                    "requiresItems": [
                        {
                            "id": "60e517b4-5807-4983-afb8-e2aad1566587",
                            "count": 1
                        },
                        {
                            "id": "0564d441-7367-412e-b709-dad770814a39",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "release",
                    "text": "Water is matched."
                }
            ]
        },
        {
            "id": "release",
            "text": "Use an aquarium net to transfer the shrimp into the tank. Never pour store water in to avoid contamination.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Shrimp moved with net",
                    "requiresItems": [
                        {
                            "id": "ee7d437d-7426-47cd-b691-386dd20f4e47",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "finish",
            "text": "Great! Monitor them closely for the first day and feed sparingly.",
            "options": [
                {
                    "type": "finish",
                    "text": "They're settling in."
                }
            ]
        }
    ],
    "rewards": [
        {
            "id": "b494f643-a77a-4edf-be7e-5f7ff2dfba6a",
            "count": 3
        }
    ],
