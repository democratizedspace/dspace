{
    "id": "aquaria/shrimp",
    "title": "Add dwarf shrimp",
    "description": "Introduce hardy shrimp with drip acclimation to keep the tank clean and water stable.",
    "image": "/assets/quests/dwarf_shrimp_drip_acclimation.jpg",
    "npc": "/assets/npc/vega.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Your Walstad tank reads 0 ammonia and nitrite when checked with a liquid test kit. Dwarf shrimp graze algae and reveal any stability issues.",
            "options": [
                {
                    "type": "goto",
                    "goto": "acquire",
                    "text": "Tank checks passed and I'm ready to stage acclimation gear."
                }
            ]
        },
        {
            "id": "acquire",
            "text": "Pick up healthy shrimp in a sealed, shaded bag. Verify the water shows 0 ammonia and nitrite, then float it in your tank for 15 minutes to match temperature.",
            "options": [
                {
                    "type": "goto",
                    "goto": "acclimate",
                    "text": "Bag is floating and temperature equalization started."
                },
                {
                    "type": "goto",
                    "goto": "stress-response",
                    "text": "Bag temperature drifted or shrimp look stressed during float."
                }
            ]
        },
        {
            "id": "acclimate",
            "text": "Set up drip acclimation with airline tubing and a clean 5 gallon bucket reserved for aquarium use. Start a siphon at 2\u20134 drops per second for about an hour until parameters match.",
            "options": [
                {
                    "type": "process",
                    "process": "drip-acclimate-shrimp",
                    "goto": "release",
                    "text": "Start drip acclimation and match parameters.",
                    "requiresItems": [
                        {
                            "id": "60e517b4-5807-4983-afb8-e2aad1566587",
                            "count": 1
                        },
                        {
                            "id": "0564d441-7367-412e-b709-dad770814a39",
                            "count": 1
                        },
                        {
                            "id": "b494f643-a77a-4edf-be7e-5f7ff2dfba6a",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "release",
                    "text": "Water is matched and drip-acclimated shrimp are ready for transfer.",
                    "requiresItems": [
                        {
                            "id": "c6d10826-cb00-45f6-8e6d-8247423fa978",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "process",
                    "process": "dump-unacclimated-shrimp",
                    "goto": "die-off",
                    "text": "Skip drip acclimation and add shrimp directly (unsafe).",
                    "requiresItems": [
                        {
                            "id": "b494f643-a77a-4edf-be7e-5f7ff2dfba6a",
                            "count": 1
                        },
                        {
                            "id": "785fa6f3-bb66-4197-a43f-52fea9cebd48",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "die-off",
                    "text": "Direct-add attempt caused immediate losses.",
                    "requiresItems": [
                        {
                            "id": "f98cd334-df1f-4e31-83d0-1246738f5f9a",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "stress-response",
                    "text": "Shrimp are darting, lying still, or breathing rapidly."
                }
            ]
        },
        {
            "id": "stress-response",
            "text": "Pause transfer. Dim lights, recheck heater stability, and extend acclimation in 15-minute blocks until movement normalizes. Never dump bag water into the display tank.",
            "options": [
                {
                    "type": "process",
                    "process": "log-heated-walstad-temperature",
                    "text": "Log a stability reading before retrying.",
                    "goto": "stress-response"
                },
                {
                    "type": "goto",
                    "goto": "acclimate",
                    "text": "Reading logged and behavior recovered; resume controlled acclimation.",
                    "requiresItems": [
                        {
                            "id": "7f9d9d21-a4f2-4c48-b0e5-9a7483ab05d2",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "release",
            "text": "Use an aquarium net to move drip-acclimated shrimp into the tank. Never pour store water into your aquarium; discard it down a drain, rinse the bucket, and wash your hands.",
            "options": [
                {
                    "type": "process",
                    "process": "stock-drip-acclimated-shrimp",
                    "goto": "verify",
                    "text": "Net in drip-acclimated shrimp for a safe transfer."
                },
                {
                    "type": "goto",
                    "goto": "verify",
                    "text": "Drip-acclimated shrimp were released without adding store water.",
                    "requiresItems": [
                        {
                            "id": "f7d1e4dd-4ba7-4d15-a66c-e3773b1fcb59",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "die-off",
            "text": "Adding non-acclimated shrimp directly shocked them. Remove carcasses immediately, refresh water, and reset before trying again.",
            "options": [
                {
                    "type": "process",
                    "process": "recover-walstad-after-shrimp-die-off",
                    "goto": "lesson-learned",
                    "text": "Net out losses and run a cleanup water change."
                },
                {
                    "type": "goto",
                    "goto": "lesson-learned",
                    "text": "Cleanup is complete and I can retry acclimation.",
                    "requiresItems": [
                        {
                            "id": "785fa6f3-bb66-4197-a43f-52fea9cebd48",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "lesson-learned",
            "text": "Lesson learned: rapid parameter swings can kill shrimp. Re-stage acclimation gear and retry with a controlled drip method.",
            "options": [
                {
                    "type": "goto",
                    "goto": "acclimate",
                    "text": "I understand\u2014return to drip acclimation and do it correctly.",
                    "requiresItems": [
                        {
                            "id": "785fa6f3-bb66-4197-a43f-52fea9cebd48",
                            "count": 1
                        }
                    ],
                    "grantsItems": [
                        {
                            "id": "b494f643-a77a-4edf-be7e-5f7ff2dfba6a",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "verify",
            "text": "Run a post-release observation window and capture a fresh reading before closure. If shrimp hide unusually or gasp at the surface, go back to recovery.",
            "options": [
                {
                    "type": "process",
                    "process": "log-heated-walstad-temperature",
                    "text": "Capture post-release verification reading.",
                    "goto": "verify"
                },
                {
                    "type": "goto",
                    "goto": "stress-response",
                    "text": "Stress signs observed; pause and recover before finishing."
                },
                {
                    "type": "goto",
                    "text": "Shrimp are active, temperature is logged, and transfer is stable.",
                    "requiresItems": [
                        {
                            "id": "7f9d9d21-a4f2-4c48-b0e5-9a7483ab05d2",
                            "count": 1
                        },
                        {
                            "id": "f7d1e4dd-4ba7-4d15-a66c-e3773b1fcb59",
                            "count": 1
                        }
                    ],
                    "goto": "finish"
                }
            ]
        },
        {
            "id": "finish",
            "text": "Great recovery and execution. Controlled acclimation keeps shrimp alive and your tank stable.",
            "options": [
                {
                    "type": "finish",
                    "text": "Complete shrimp stocking with lessons learned."
                }
            ]
        }
    ],
    "rewards": [
        {
            "id": "b494f643-a77a-4edf-be7e-5f7ff2dfba6a",
            "count": 3
        }
    ],
    "requiresQuests": [
        "aquaria/ph-strip-test",
        "aquaria/heater-install",
        "aquaria/log-water-parameters"
    ],
