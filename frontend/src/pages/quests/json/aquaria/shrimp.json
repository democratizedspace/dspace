    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Your Walstad tank should read 0 ammonia and nitrite. Dwarf shrimp graze algae and expose any issues.",
            "options": [
                {
                    "type": "goto",
                    "goto": "acquire",
                    "text": "Sounds good!"
                }
            ]
        },
        {
            "id": "acquire",
            "text": "Pick up healthy shrimp in a sealed bag. Test for 0 ammonia and nitrite, keep it shaded, and float it in your tank for 15 minutes to match temperature.",
            "options": [
                {
                    "type": "goto",
                    "goto": "acclimate",
                    "text": "Bag is floating."
                }
            ]
        },
        {
            "id": "acclimate",
            "text": "Set up a drip acclimation with a clean 5 gallon bucket and airline tubing reserved for aquarium use. Siphon tank water 2–4 drops per second into the bag for about an hour to match chemistry.",
            "options": [
                {
                    "type": "process",
                    "process": "drip-acclimate-shrimp",
                    "text": "Start drip acclimation",
