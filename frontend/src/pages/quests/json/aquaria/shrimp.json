                {
                    "type": "goto",
                    "goto": "acclimate",
                    "text": "Bag is floating."
                }
            ]
        },
        {
            "id": "acclimate",
            "text": "Set up a drip acclimation using a clean bucket and airline tubing so tank water drips into the bag for about an hour.",
            "options": [
