{
    "id": "aquaria/sponge-filter",
    "title": "Install a sponge filter",
    "description": "Install and verify gentle biological filtration with evidence gates and a contamination recovery loop.",
    "image": "/assets/quests/install_sponge_filter_aquarium.jpg",
    "npc": "/assets/npc/vega.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "A sponge filter keeps shrimp safe, but only if we prep rinse water and prove stable flow after startup. Let's stage gear before we touch the tank.",
            "options": [
                {
                    "type": "goto",
                    "goto": "prep",
                    "text": "Gear staged and PPE on.",
                    "requiresItems": [
                        {
                            "id": "496b4ebb-43c8-42d7-a921-fc6ee9d6ae56",
                            "count": 1
                        },
                        {
                            "id": "60e517b4-5807-4983-afb8-e2aad1566587",
                            "count": 1
                        },
                        {
                            "id": "5d5e4e29-94b7-4a03-b73d-7420841ae686",
                            "count": 1
                        },
                        {
                            "id": "0564d441-7367-412e-b709-dad770814a39",
                            "count": 1
                        },
                        {
                            "id": "16eb261b-9d93-4aff-ab31-40f6a78d04f1",
                            "count": 1
                        },
                        {
                            "id": "997eaba9-25ee-43d5-bbdc-5d6adf03adfa",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "prep",
            "text": "First decision: condition a fresh bucket for a conservative rinse, or continue if you already staged dechlorinated water. Never rinse bio-media in raw chlorinated tap water.",
            "options": [
                {
                    "type": "process",
                    "process": "condition-bucket-water",
                    "text": "Condition a fresh rinse bucket.",
                    "goto": "rinse"
                },
                {
                    "type": "goto",
                    "goto": "rinse",
                    "text": "Bucket is already dechlorinated and ready.",
                    "requiresItems": [
                        {
                            "id": "71efa72a-8c87-4dc2-8e2c-9119bb28fe50",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "rinse",
            "text": "Squeeze the sponge gently in the bucket and keep the core wet. If sludge stays dark or sour, branch to contamination recovery before restart.",
            "options": [
                {
                    "type": "process",
                    "process": "rinse-aquarium-filter",
                    "text": "Run standard rinse cycle.",
                    "goto": "restart"
                },
                {
                    "type": "goto",
                    "goto": "contamination",
                    "text": "Rinse water looks foul; take contamination branch."
                },
                {
                    "type": "goto",
                    "goto": "restart",
                    "text": "Core is rinsed and still wet.",
                    "requiresItems": [
                        {
                            "id": "606c4f47-ca8f-4458-bc7f-0ab2957ef641",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "contamination",
            "text": "Good catch. Discard dirty rinse water, stage fresh dechlorinated water, and repeat a gentler squeeze pattern. Pause if livestock is gasping and restore aeration first.",
            "options": [
                {
                    "type": "process",
                    "process": "condition-bucket-water",
                    "text": "Prepare fresh dechlorinated rinse water.",
                    "goto": "rinse"
                },
                {
                    "type": "goto",
                    "goto": "rinse",
                    "text": "Fresh bucket staged and livestock behavior is stable.",
                    "requiresItems": [
                        {
                            "id": "71efa72a-8c87-4dc2-8e2c-9119bb28fe50",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "restart",
            "text": "Reconnect airline and pump, then tune airflow for steady bubbles without blasting shrimp. Verify the outflow before closing maintenance.",
            "options": [
                {
                    "type": "process",
                    "process": "restart-sponge-filter",
                    "text": "Restart and tune filter flow.",
                    "goto": "verify"
                },
                {
                    "type": "goto",
                    "goto": "verify",
                    "text": "Flow is restored without splashing.",
                    "requiresItems": [
                        {
                            "id": "6f08e704-1086-4fef-ad0a-f48922a5cfd0",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "verify",
            "text": "Final verification: if flow remains weak or noisy, return to rinse troubleshooting. Close only when restored-flow evidence is present.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Restored-flow proof captured and livestock behavior is normal.",
                    "requiresItems": [
                        {
                            "id": "6f08e704-1086-4fef-ad0a-f48922a5cfd0",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "rinse",
                    "text": "Flow is still weak; repeat rinse and restart loop."
                }
            ]
        },
        {
            "id": "finish",
            "text": "Great work. You preserved the bacteria colony, verified safe flow, and documented a recovery path if contamination returns.",
            "options": [
                {
                    "type": "finish",
                    "text": "Filter installed and verified."
                }
            ]
        }
    ],
    "rewards": [
        {
            "id": "a07b75e3-f828-4cb1-81d6-1ab0e9857a79",
            "count": 1
        }
    ],
    "requiresQuests": [
        "aquaria/position-tank"
    ],
