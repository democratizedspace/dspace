{
    "id": "aquaria/aquarium-light",
    "title": "Install an aquarium light",
    "description": "Install and verify LED lighting so plants get stable growth without overheating the tank.",
    "image": "/assets/quests/aquarium_light.jpg",
    "npc": "/assets/npc/vega.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Your Walstad tank is cycling, but plants need a reliable light window. We'll mount the lamp, verify a timed run, and fix glare or flicker before we call it done.",
            "options": [
                {
                    "type": "goto",
                    "goto": "mount",
                    "text": "Let's mount and cable-manage it.",
                    "requiresItems": [
                        {
                            "id": "62757412-be94-48c0-a1c0-8fad9bdb8c4a",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "troubleshoot-power",
                    "text": "Lamp flickers when I plug it in.",
                    "requiresItems": [
                        {
                            "id": "62757412-be94-48c0-a1c0-8fad9bdb8c4a",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "mount",
            "text": "Clip the light to the rim, route the cable with a drip loop, and keep the power brick above splash level.",
            "options": [
                {
                    "type": "goto",
                    "goto": "schedule",
                    "text": "Mount is secure and cable is dry-routed.",
                    "requiresItems": [
                        {
                            "id": "62757412-be94-48c0-a1c0-8fad9bdb8c4a",
                            "count": 1
                        },
                        {
                            "id": "5d5e4e29-94b7-4a03-b73d-7420841ae686",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "schedule",
            "text": "Set the photoperiod to 8 hours. If algae blooms, cut to 6 hours for a week before stepping back up.",
            "options": [
                {
                    "type": "goto",
                    "goto": "verify",
                    "text": "Timer set and first light cycle logged.",
                    "requiresItems": [
                        {
                            "id": "9c392043-4067-4f49-8038-38eef00e0b24",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "troubleshoot-glare",
                    "text": "Shrimp are hiding; flow and glare look too intense."
                }
            ]
        },
        {
            "id": "troubleshoot-power",
            "text": "Good catch. Unplug, dry hands, inspect connectors, and reseat the plug with the drip loop lower than the outlet.",
            "options": [
                {
                    "type": "goto",
                    "goto": "schedule",
                    "text": "Power is stable after reseating.",
                    "requiresItems": [
                        {
                            "id": "62757412-be94-48c0-a1c0-8fad9bdb8c4a",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "troubleshoot-power",
                    "text": "Still flickering; I'll re-check cable strain and moisture."
                }
            ]
        },
        {
            "id": "troubleshoot-glare",
            "text": "Raise the fixture slightly or dim it, then confirm fish resume normal behavior before extending the schedule.",
            "options": [
                {
                    "type": "goto",
                    "goto": "verify",
                    "text": "Intensity adjusted and livestock behavior normalized.",
                    "requiresItems": [
                        {
                            "id": "9c392043-4067-4f49-8038-38eef00e0b24",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "verify",
            "text": "Interpret the reading: hold pH and temperature steady while plants pearl or open leaves under the scheduled light. If values drift, troubleshoot before finishing.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Stable cycle confirmed with a logged check.",
                    "requiresItems": [
                        {
                            "id": "9c392043-4067-4f49-8038-38eef00e0b24",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "troubleshoot-glare",
                    "text": "Plants or livestock still look stressed; tune intensity and retry."
                }
            ]
        },
        {
            "id": "finish",
            "text": "Great work. You didn't just flip a switch\u2014you validated safe wiring, schedule discipline, and biological response.",
            "options": [
                {
                    "type": "finish",
                    "text": "Lock in the lighting routine."
                }
            ]
        }
    ],
    "rewards": [
        {
            "id": "c5a7574e-515f-4e9a-83fc-350703131f25",
            "count": 1
        }
    ],
    "requiresQuests": [
        "aquaria/sponge-filter"
    ],
    "hardening": {
        "passes": 0,
        "score": 80,
        "emoji": "\ud83d\udee0\ufe0f",
        "history": []
    }
}
