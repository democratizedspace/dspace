{
    "id": "aquaria/aquarium-light",
    "title": "Install an aquarium light",
    "description": "Mount the light safely, verify stable photoperiod setup, and recover if heat or glare stresses livestock.",
    "image": "/assets/quests/aquarium_light.jpg",
    "npc": "/assets/npc/vega.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Your Walstad tank needs a consistent day-night cycle. We'll do this in stages: safe mount, verify timer behavior, then stress check before we call it done.",
            "options": [
                {
                    "type": "goto",
                    "goto": "mount",
                    "text": "Stage tools and start the install plan."
                },
                {
                    "type": "goto",
                    "goto": "mount",
                    "text": "I already staged a dry cable route and splash loop.",
                    "requiresItems": [
                        {
                            "id": "62757412-be94-48c0-a1c0-8fad9bdb8c4a",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "mount",
            "text": "Clip the light above open water, keep the power strip above flood level, and leave a drip loop so condensation cannot run into the outlet.",
            "options": [
                {
                    "type": "goto",
                    "goto": "verify",
                    "text": "Mount is stable and cable routing is dry.",
                    "requiresItems": [
                        {
                            "id": "62757412-be94-48c0-a1c0-8fad9bdb8c4a",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "verify",
            "text": "Run one timer cycle check. Confirm light on/off behavior and watch fish for darting, surface gasping, or intense glare zones.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Cycle check passed and livestock behavior is calm.",
                    "requiresItems": [
                        {
                            "id": "62757412-be94-48c0-a1c0-8fad9bdb8c4a",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "troubleshoot",
                    "text": "There is glare, excess heat, or stressed behavior to correct.",
                    "requiresItems": [
                        {
                            "id": "62757412-be94-48c0-a1c0-8fad9bdb8c4a",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "troubleshoot",
            "text": "Raise or angle the fixture, reduce photoperiod to 6 hours for 48 hours, and re-check temperature drift before returning to the full schedule.",
            "options": [
                {
                    "type": "goto",
                    "goto": "verify",
                    "text": "Adjusted and ready for a new cycle check.",
                    "requiresItems": [
                        {
                            "id": "62757412-be94-48c0-a1c0-8fad9bdb8c4a",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "finish",
            "text": "Perfect. You installed with electrical safety, validated the schedule, and closed the loop on stress checks before finishing.",
            "options": [
                {
                    "type": "finish",
                    "text": "Lighting baseline locked in."
                }
            ]
        }
    ],
    "rewards": [
        {
            "id": "c5a7574e-515f-4e9a-83fc-350703131f25",
            "count": 1
        }
    ],
    "requiresQuests": ["aquaria/sponge-filter"],
