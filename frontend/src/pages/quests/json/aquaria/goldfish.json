{
    "id": "aquaria/goldfish",
    "title": "Set up an aquarium for a goldfish",
    "description": "Stage a goldfish habitat, verify safety checks, and resolve early stress signals before declaring the setup stable.",
    "image": "/assets/quests/goldfish_aquarium_setup.jpg",
    "npc": "/assets/npc/vega.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Goldfish transfer starts with water safety: confirm ammonia and nitrite are both 0 ppm, then prep a bucket and dim lights so acclimation stays calm.",
            "options": [
                {
                    "type": "goto",
                    "goto": "stage",
                    "text": "Let's stage the equipment checklist."
                }
            ]
        },
        {
            "id": "stage",
            "text": "Gather the 150 L tank, stand, heater, sponge filter, gravel, light, thermometer, and dechlorinated water. Then run setup as a single controlled process.",
            "options": [
                {
                    "type": "process",
                    "process": "prepare-aquarium",
                    "text": "Run full aquarium setup process.",
                    "goto": "verify"
                },
                {
                    "type": "goto",
                    "goto": "verify",
                    "text": "Habitat assembled and filled.",
                    "requiresItems": [
                        {
                            "id": "ca7c1069-4ba3-4339-9a10-0b690a690e60",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "verify",
            "text": "Before transfer, log a baseline reading and reconfirm ammonia/nitrite at 0 ppm so you can prove water stayed safe after reintroduction.",
            "options": [
                {
                    "type": "goto",
                    "goto": "stock",
                    "text": "Habitat checks pass and water looks stable.",
                    "requiresItems": [
                        {
                            "id": "ca7c1069-4ba3-4339-9a10-0b690a690e60",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "troubleshoot",
                    "text": "Temperature or filtration drift detected; pause stocking."
                }
            ]
        },
        {
            "id": "troubleshoot",
            "text": "Use one steady scoop, keep the net submerged, and run a short acclimation pause in the bucket with matching water. Stop immediately if the fish thrashes against the mesh.",
            "options": [
                {
                    "type": "process",
                    "process": "check-aquarium-temperature",
                    "text": "Re-check temperature before retrying.",
                    "goto": "verify"
                },
                {
                    "type": "goto",
                    "goto": "verify",
                    "text": "System stabilized; return to pre-stock verification.",
                    "requiresItems": [
                        {
                            "id": "ca7c1069-4ba3-4339-9a10-0b690a690e60",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "observe",
                    "text": "Stocked tank stabilized; continue post-stock observation.",
                    "requiresItems": [
                        {
                            "id": "76307a8e-4e0e-4dfa-abc2-7917d384d82c",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "stock",
            "text": "Now stock the fish with a net, then feed lightly and observe behavior for stress signs. The quest closes only after a stable stocked-tank artifact exists.",
            "options": [
                {
                    "type": "process",
                    "process": "add-goldfish",
                    "text": "Net and release the goldfish.",
                    "goto": "observe"
                },
                {
                    "type": "goto",
                    "goto": "observe",
                    "text": "Goldfish is in the tank and swimming.",
                    "requiresItems": [
                        {
                            "id": "76307a8e-4e0e-4dfa-abc2-7917d384d82c",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "observe",
            "text": "Observe the first feed and breathing pattern. If fish gasps at surface or clamps fins, branch back to troubleshooting and re-verify environment before closing.",
            "options": [
                {
                    "type": "process",
                    "process": "feed-goldfish",
                    "text": "Feed a small starter portion."
                },
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Fish behavior is normal after feed and setup is stable.",
                    "requiresItems": [
                        {
                            "id": "76307a8e-4e0e-4dfa-abc2-7917d384d82c",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "troubleshoot",
                    "text": "Stress signs detected; troubleshoot before proceeding."
                }
            ]
        },
        {
            "id": "finish",
            "text": "Nice husbandry. You staged the habitat, verified safety, and handled early stress checks before celebrating.",
            "options": [
                {
                    "type": "finish",
                    "text": "Goldfish habitat is stable."
                }
            ]
        }
    ],
    "rewards": [
        {
            "id": "a07b75e3-f828-4cb1-81d6-1ab0e9857a79",
            "count": 1
        }
    ],
