                    ]
                }
            ]
        },
        {
            "id": "lift",
            "text": "I'll take most of the weight. On three—one, two, three. Keep the tank level and your back straight.",
            "options": [
                {
                    "type": "goto",
                    "goto": "place",
                    "text": "Heave-ho!"
                }
            ]
        },
        {
            "id": "place",
