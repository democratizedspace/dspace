{
    "id": "aquaria/position-tank",
    "title": "Move the Walstad tank",
    "description": "Atlas helps you lift the empty 80 L Walstad aquarium onto a sturdy stand. Clear the path, lift with your legs and keep the glass supported.",
    "image": "/assets/quests/position_tank.jpg",
    "npc": "/assets/npc/atlas.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Atlas here. Vega wants the empty 80 L tank on the stand. We'll stage the route first so no one twists while carrying glass.",
            "options": [
                {
                    "type": "goto",
                    "goto": "route-check",
                    "text": "Yes please, it's heavy.",
                    "requiresItems": [
                        {
                            "id": "4e8db808-927f-4ac7-9d1f-1c8400c7f5d7",
                            "count": 1
                        },
                        {
                            "id": "98609b23-4811-4275-8d83-ad59a2797753",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "route-check",
            "text": "Clear cords and wet spots, then check the stand feet and floor are level before lifting.",
            "options": [
                {
                    "type": "goto",
                    "goto": "lift",
                    "text": "Path is clear and stand is stable.",
                    "requiresItems": [
                        {
                            "id": "98609b23-4811-4275-8d83-ad59a2797753",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "route-fix",
                    "text": "Route is blocked or the stand rocks; pause and fix it first."
                }
            ]
        },
        {
            "id": "route-fix",
            "text": "Good pause. Dry the path, remove trip hazards, shim the stand, and confirm no wobble before another lift attempt.",
            "options": [
                {
                    "type": "goto",
                    "goto": "lift",
                    "text": "Route reset complete. Retry the move.",
                    "requiresItems": [
                        {
                            "id": "98609b23-4811-4275-8d83-ad59a2797753",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "lift",
            "text": "On three—one, two, three. Keep the tank level and elbows close so the seams stay supported.",
            "options": [
                {
                    "type": "goto",
                    "goto": "place",
                    "text": "Lift is stable."
                },
                {
                    "type": "goto",
                    "goto": "grip-reset",
                    "text": "The grip slipped or glass started to twist. Set down and reset."
                }
            ]
        },
        {
            "id": "grip-reset",
            "text": "Set the tank down on padding, reset hand positions, and only retry once both carriers can hold level.",
            "options": [
                {
                    "type": "goto",
                    "goto": "lift",
                    "text": "Grip reset complete. Lift again."
                }
            ]
        },
        {
            "id": "place",
            "text": "Set the tank gently on the stand and check all corners are seated with no rocking.",
            "options": [
                {
                    "type": "goto",
                    "goto": "heat",
                    "text": "Tank is seated and level."
                },
                {
                    "type": "goto",
                    "goto": "route-fix",
                    "text": "One corner rocks; fix stand level before heater setup."
                }
            ]
        },
        {
            "id": "heat",
            "text": "Warm the tank before livestock. Heater must be submerged and powered from a GFCI outlet with a drip loop.",
            "options": [
                {
                    "type": "process",
                    "process": "heat-walstad",
                    "text": "Install the heater and set it to 26°C",
                    "requiresItems": [
                        {
                            "id": "0b85f058-38f2-4e9a-93e9-d47441608619",
                            "count": 1
                        },
                        {
                            "id": "4e8db808-927f-4ac7-9d1f-1c8400c7f5d7",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "verify",
                    "text": "Heater installed and running.",
                    "requiresItems": [
                        {
                            "id": "8c0f72a2-db79-4238-b80f-97721def169f",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "verify",
            "text": "Verify final state: tank level, outlet dry, and heater holding steady before moving on.",
            "options": [
                {
                    "type": "finish",
                    "text": "Move complete and heater verified.",
                    "requiresItems": [
                        {
                            "id": "8c0f72a2-db79-4238-b80f-97721def169f",
                            "count": 1
                        }
                    ]
                }
            ]
        }
    ],
    "requiresQuests": ["aquaria/walstad", "aquaria/thermometer"],
