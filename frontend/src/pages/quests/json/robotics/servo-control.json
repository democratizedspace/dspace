{
    "id": "robotics/servo-control",
    "title": "Control a Servo Motor",
    "description": "Wire a hobby servo to your Arduino and use the Sweep example to understand position control.",
    "image": "/assets/quests/arduino_servo_control.jpg",
    "npc": "/assets/npc/orion.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Orion again! Ready to add some movement to your projects? We'll wire a servo test rig and sweep it safely—ESD strap on, and keep fingers clear of the horn.",
            "options": [
                {
                    "type": "goto",
                    "goto": "hookup",
                    "text": "Gear is ready—let's wire it.",
                    "requiresItems": [
                        {
                            "id": "e976bae6-e33c-428a-a20d-0aa8fde13c6c",
                            "count": 1
                        },
                        {
                            "id": "72b4448e-27d9-4746-bd3a-967ff13f501b",
                            "count": 1
                        },
                        {
                            "id": "d1105b87-8185-4a30-ba55-406384be169f",
                            "count": 1
                        },
                        {
                            "id": "3cd82744-d2aa-414e-9f03-80024b624066",
                            "count": 4
                        },
                        {
                            "id": "be3aaed8-13cc-4937-95d5-6e2c952c6612",
                            "count": 1
                        },
                        {
                            "id": "8299ac3f-c232-46d4-a007-2ad86ec70361",
                            "count": 1
                        },
                        {
                            "id": "d30d7a65-bd11-42a2-89c1-2828e990a3b2",
                            "count": 1
                        },
                        {
                            "id": "b6fc1ed6-f399-4fdb-9f9d-3913f893f43d",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "hookup",
            "text": "Mount the servo so it can't twist loose. Connect signal to pin 9, power and ground to the rails, and strain-relieve the jumpers so the horn doesn't yank them.",
            "options": [
                {
                    "type": "process",
                    "process": "wire-servo-test-rig",
                    "text": "Wire and secure the servo rig"
                },
                {
                    "type": "goto",
                    "goto": "safety-check",
                    "text": "Wiring is tidy and strain relief is done.",
                    "requiresItems": [
                        {
                            "id": "b3857812-f50c-4880-810d-c929698599b3",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "safety-check",
            "text": "Before movement, verify horn clearance, confirm no exposed conductors, and set a low-angle test (30° to 150°) so the first sweep cannot slam hard stops.",
            "options": [
                {
                    "type": "goto",
                    "goto": "code",
                    "text": "Safety checks pass; run the first sweep.",
                    "requiresItems": [
                        {
                            "id": "b3857812-f50c-4880-810d-c929698599b3",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "recovery",
                    "text": "I hear chatter or see the horn binding—pause and fix before sweeping."
                }
            ]
        },
        {
            "id": "code",
            "text": "Load the Sweep example, start with conservative limits, and log one full motion cycle. Keep your hand near power in case the servo stalls.",
            "options": [
                {
                    "type": "process",
                    "process": "log-servo-sweep",
                    "text": "Log a clean sweep"
                },
                {
                    "type": "goto",
                    "goto": "evidence",
                    "text": "Sweep log captured.",
                    "requiresItems": [
                        {
                            "id": "8a4ccbcf-ee7d-42ff-bfd8-2ed242379872",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "recovery",
            "text": "Troubleshoot in this order: reseat ground/power, recenter the horn, then reduce sweep range by 10° each side. Re-run only after the rig is stable and quiet.",
            "options": [
                {
                    "type": "goto",
                    "goto": "hookup",
                    "text": "Reworked wiring and mounting—repeat hookup verification."
                },
                {
                    "type": "goto",
                    "goto": "safety-check",
                    "text": "Mechanical issue fixed—repeat safety gate."
                }
            ]
        },
        {
            "id": "evidence",
            "text": "Capture a second sweep after your limit tuning. Finish only when both cycles are quiet and center return stays repeatable.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Two clean sweeps recorded; center return is stable.",
                    "requiresItems": [
                        {
                            "id": "8a4ccbcf-ee7d-42ff-bfd8-2ed242379872",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "recovery",
                    "text": "Second sweep drifted or buzzed—apply recovery before retrying."
                }
            ]
        },
        {
            "id": "finish",
            "text": "Nice work! Label the rig, coil the USB cable, and park the horn at center so future tests start safe.",
            "options": [
                {
                    "type": "finish",
                    "text": "Servo rig ready for action"
                }
            ]
        }
    ],
    "requiresQuests": ["electronics/arduino-blink"],
