        {
            "id": "preflight",
            "text": "Preflight safety stop: power off, center the horn by hand, and verify 5V/GND orientation before plugging signal into pin 9.",
            "options": [
                {
                    "type": "goto",
                    "goto": "hookup",
                    "text": "Preflight checks are complete; continue with wiring.",
                    "requiresItems": [
                        {
                            "id": "d30d7a65-bd11-42a2-89c1-2828e990a3b2",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "hookup",
            "text": "Mount the servo so it cannot twist loose. Connect signal to pin 9, power and ground to rails, and strain-relieve jumpers so horn motion cannot yank them free.",
            "options": [
                {
                    "type": "process",
                    "process": "wire-servo-test-rig",
                    "text": "Wire and secure the servo rig"
                },
                {
                    "type": "goto",
                    "goto": "code",
                    "text": "Wiring is tidy and strain relief is done.",
                    "requiresItems": [
                        {
                            "id": "b3857812-f50c-4880-810d-c929698599b3",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "code",
            "text": "Load Sweep, set soft limits to avoid stalling, and log one smooth cycle. If you hear chatter or brownouts, stop and branch to recovery.",
            "options": [
                {
                    "type": "process",
                    "process": "log-servo-sweep",
                    "text": "Log a clean sweep"
                },
                {
                    "type": "goto",
                    "goto": "verify",
                    "text": "Sweep log captured.",
                    "requiresItems": [
                        {
                            "id": "8a4ccbcf-ee7d-42ff-bfd8-2ed242379872",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "verify",
            "text": "Interpretation gate: pass only if motion returns to center cleanly and current draw stays stable during repeated sweeps.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "PASS: sweep is repeatable and quiet.",
                    "requiresItems": [
                        {
                            "id": "8a4ccbcf-ee7d-42ff-bfd8-2ed242379872",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "recover",
                    "text": "FAIL: chatter, overshoot, or reset occurred."
                }
            ]
        },
        {
            "id": "recover",
            "text": "Recovery loop: cut power, inspect ground/common reference, lower sweep range, and re-run the log until one clean pass is recorded.",
            "options": [
                {
                    "type": "goto",
                    "goto": "code",
                    "text": "Recovery complete; rerun sweep logging."
                }
            ]
        },
        {
            "id": "finish",
            "text": "Nice work! Label the rig, coil the USB cable, and park the horn at center so future tests start safe.",
