{
    "id": "robotics/obstacle-avoidance",
    "title": "Add Obstacle Avoidance",
    "description": "Mount an ultrasonic sensor so your line follower can spot obstacles and steer around them.",
    "image": "/assets/quests/robot_obstacle_avoidance.jpg",
    "npc": "/assets/npc/orion.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Your line follower works! Let's teach it to dodge obstacles using an ultrasonic sensor mounted out front and wired to your Arduino.",
            "options": [
                {
                    "type": "goto",
                    "goto": "build",
                    "text": "Sounds challenging."
                }
            ]
        },
        {
            "id": "build",
            "text": "Build a low-profile bracket to hold the ultrasonic sensor facing forward. Wire trig and echo to Arduino pins, keep the leads tidy so they don't catch the wheels, and route power through the breadboard.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "It's dodging nicely!",
                    "requiresItems": [
                        {
                            "id": "e976bae6-e33c-428a-a20d-0aa8fde13c6c",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "finish",
            "text": "Great! With obstacle avoidance your bot can explore more complex tracks.",
            "options": [
                {
                    "type": "finish",
                    "text": "Thanks, Orion!"
                }
            ]
        }
    ],
    "rewards": [],
