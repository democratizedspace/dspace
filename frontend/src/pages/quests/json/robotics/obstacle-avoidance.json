{
    "id": "robotics/obstacle-avoidance",
    "title": "Add Obstacle Avoidance",
    "description": "Give your line follower the awareness to pause, scan, and steer around boxes without leaving the track.",
    "image": "/assets/quests/robot_obstacle_avoidance.jpg",
    "npc": "/assets/npc/orion.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Your line follower works! Now we'll add obstacle handling that keeps people, pets, and hardware safe while staying on mission.",
            "options": [
                {
                    "type": "goto",
                    "goto": "strategy",
                    "text": "Prioritize safe slowdowns and clean bypasses."
                },
                {
                    "type": "goto",
                    "goto": "strategy",
                    "text": "Prioritize faster reroutes with tighter control."
                }
            ]
        },
        {
            "id": "strategy",
            "text": "Pick your detection strategy. Conservative mode slows early for safer bypasses; agile mode reacts later but needs cleaner tuning.",
            "options": [
                {
                    "type": "goto",
                    "goto": "build",
                    "text": "Use conservative mode first."
                },
                {
                    "type": "goto",
                    "goto": "build",
                    "text": "Use agile mode with tighter thresholds."
                }
            ]
        },
        {
            "id": "build",
            "text": "Mount the ultrasonic sensor up front, route cables clear of wheels, and implement a stop-scan-turn routine.",
            "options": [
                {
                    "type": "goto",
                    "goto": "safety",
                    "text": "Wiring and avoidance routine are ready.",
                    "requiresItems": [
                        {
                            "id": "e976bae6-e33c-428a-a20d-0aa8fde13c6c",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "troubleshoot",
                    "text": "It false-triggers or clips obstacles."
                }
            ]
        },
        {
            "id": "safety",
            "text": "Safety gate: set a hard stop distance and verify behavior near table edges and tight corners before full-speed runs.",
            "options": [
                {
                    "type": "goto",
                    "goto": "ops-check",
                    "text": "Safety checks pass; run operator lockout checks.",
                    "requiresItems": [
                        {
                            "id": "e976bae6-e33c-428a-a20d-0aa8fde13c6c",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "troubleshoot",
                    "text": "Need to retune stop distance first."
                }
            ]
        },
        {
            "id": "ops-check",
            "text": "Operational check: confirm remote kill switch response and no-go zones around bystanders before obstacle-course validation.",
            "options": [
                {
                    "type": "goto",
                    "goto": "evidence",
                    "text": "Ops checks pass; run the obstacle course.",
                    "requiresItems": [
                        {
