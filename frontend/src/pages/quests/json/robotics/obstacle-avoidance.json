                {
                    "type": "goto",
                    "goto": "troubleshoot",
                    "text": "Kill switch drill failed; return to troubleshooting."
                }
            ]
        },
        {
            "id": "troubleshoot",
            "text": "Recovery loop: check sensor angle, filter noisy pings, and lower turn speed. Re-run a short two-obstacle trial after each fix.",
            "options": [
                {
                    "type": "goto",
                    "goto": "strategy",
                    "text": "Switch strategy and retune."
                },
