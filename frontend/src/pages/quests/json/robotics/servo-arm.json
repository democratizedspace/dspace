                    ]
                }
            ]
        },
        {
            "id": "safety",
            "text": "Safety stop: disconnect USB power, confirm no hard-stop interference in both joints, and route all jumpers with enough slack for full sweep.",
            "options": [
                {
                    "type": "goto",
                    "goto": "build",
                    "text": "Safety checks pass; continue assembly.",
                    "requiresItems": [
                        {
                            "id": "8299ac3f-c232-46d4-a007-2ad86ec70361",
                            "count": 1
                        },
                        {
                            "id": "d30d7a65-bd11-42a2-89c1-2828e990a3b2",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "build",
            "text": "Bolt the base servo, stack the elbow servo, and fasten the gripper plate. Keep cable loops clear so they cannot snag at full extension.",
            "options": [
                {
                    "type": "process",
                    "process": "assemble-servo-arm-kit",
                    "text": "Assemble the two-servo arm"
                },
                {
                    "type": "goto",
                    "goto": "tune",
                    "text": "Arm swings freely and the gripper opens.",
                    "requiresItems": [
                        {
                            "id": "8efbfdc9-3725-46b4-baaf-9b070ca99a5d",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "tune",
            "text": "Upload smooth-motion control, set soft limits, and test with a light payload. If joints heat up or jitter, branch to recovery before final verification.",
            "options": [
                {
                    "type": "process",
                    "process": "calibrate-servo-arm",
                    "text": "Tune limits and gripper timing"
                },
                {
                    "type": "goto",
                    "goto": "verify",
                    "text": "Calibration saved.",
                    "requiresItems": [
                        {
                            "id": "b73ddc8a-b0cf-43ee-8d1e-189e50ac3d96",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "verify",
            "text": "Verification gate: complete three pick/place cycles without stall alarms and park at center with motors below thermal warning levels.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "PASS: three stable cycles and safe thermal behavior.",
                    "requiresItems": [
                        {
                            "id": "b73ddc8a-b0cf-43ee-8d1e-189e50ac3d96",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "recover",
                    "text": "FAIL: jitter, binding, or heat spike detected."
                }
            ]
        },
        {
            "id": "recover",
            "text": "Recovery branch: unload payload, reduce acceleration, inspect cable drag, then rerun calibration and verification. Abort if heat warning repeats.",
            "options": [
                {
                    "type": "goto",
                    "goto": "tune",
                    "text": "Recovery actions complete; re-test calibration."
                }
            ]
        },
        {
            "id": "finish",
            "text": "Great job! Label the axes, park the arm at center, and coil the USB cable so you're ready for the next pick-and-place drill.",
