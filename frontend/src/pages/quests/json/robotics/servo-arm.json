                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "strategy",
            "text": "Choose your assembly order. Base-first gives easy cable routing; elbow-first helps verify gripper alignment before locking the base.",
            "options": [
                {
                    "type": "goto",
                    "goto": "base-first",
                    "text": "Assemble base-first for cable management."
                },
                {
                    "type": "goto",
                    "goto": "elbow-first",
                    "text": "Assemble elbow-first to verify gripper alignment early."
                }
            ]
        },
        {
            "id": "base-first",
            "text": "Bolt the base servo first, route power and signal lines with slack loops, then mount the elbow servo and gripper plate.",
            "options": [
                {
                    "type": "process",
                    "process": "assemble-servo-arm-kit",
                    "text": "Build the arm with base-first order"
                },
                {
                    "type": "goto",
                    "goto": "safety-check",
                    "text": "Arm swings freely and the gripper opens.",
                    "requiresItems": [
                        {
                            "id": "8efbfdc9-3725-46b4-baaf-9b070ca99a5d",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "troubleshoot",
                    "text": "Cable snags or joints bind during sweep."
                }
            ]
        },
        {
            "id": "elbow-first",
            "text": "Mount elbow + gripper module first, verify neutral angle and jaw clearance, then bolt the base servo and route wiring.",
            "options": [
                {
                    "type": "process",
                    "process": "assemble-servo-arm-kit",
                    "text": "Build the arm with elbow-first order"
                },
                {
                    "type": "goto",
                    "goto": "safety-check",
                    "text": "Assembly complete and movement is unobstructed.",
                    "requiresItems": [
                        {
                            "id": "8efbfdc9-3725-46b4-baaf-9b070ca99a5d",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "troubleshoot",
                    "text": "Alignment drifts when both joints move."
                }
            ]
        },
        {
            "id": "safety-check",
            "text": "Safety gate: set conservative soft limits, confirm emergency stop access, and keep tools out of the arm's operating envelope before tuning.",
            "options": [
                {
                    "type": "process",
