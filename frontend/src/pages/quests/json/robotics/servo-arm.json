    "dialogue": [
        {
            "id": "start",
            "text": "You're getting comfortable with servos. Next step: build a small robotic arm with a gripper. Clear a stable bench, strap in for ESD, and keep cables away from moving joints.",
            "options": [
                {
                    "type": "goto",
                    "goto": "safety",
                    "text": "Bench prep first: lock power and verify workspace.",
                    "requiresItems": [
                        {
                            "id": "f69a6eb1-3ef5-4f3e-97e8-5e5f395c2363",
                            "count": 1
