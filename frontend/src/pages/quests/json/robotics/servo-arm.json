    "dialogue": [
        {
            "id": "start",
            "text": "You're getting comfortable with servos. Let's build a two-joint arm and prove it can run repeatable pick-and-place cycles. Keep ESD strap on and clear the sweep zone.",
            "options": [
                {
                    "type": "goto",
                    "goto": "strategy",
                    "text": "Kit and tools are ready.",
                    "requiresItems": [
                        {
                            "id": "f69a6eb1-3ef5-4f3e-97e8-5e5f395c2363",
                            "count": 1
                        },
                        {
