                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "build",
                    "text": "I already preflighted and documented the bench setup.",
                    "requiresItems": [
                        {
                            "id": "f69a6eb1-3ef5-4f3e-97e8-5e5f395c2363",
                            "count": 1
