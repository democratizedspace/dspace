{
    "id": "robotics/ultrasonic-rangefinder",
    "title": "Measure distance with an ultrasonic sensor",
    "description": "Wire and test an HC-SR04 so your Arduino can report clear distance readings for navigation code.",
    "image": "/assets/quests/ultrasonic_distance_sensor_setup.jpg",
    "npc": "/assets/npc/orion.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Orion here! Let's make your robot sense distance with an ultrasonic sensor.",
            "options": [
                {
                    "type": "goto",
                    "goto": "approach",
                    "text": "Let's set up a measurement plan."
                }
            ]
        },
        {
            "id": "approach",
            "text": "Choose a setup style: bench-test first for clean data, or mount directly on the robot for integration-first testing.",
            "options": [
                {
                    "type": "goto",
                    "goto": "bench-setup",
                    "text": "Bench-test first."
                },
                {
                    "type": "goto",
                    "goto": "mounted-setup",
                    "text": "Integrate directly on the robot."
                }
            ]
        },
        {
            "id": "bench-setup",
            "text": "Wire HC-SR04 on pins 2-5 and keep the sensor face clear of cables and sharp edges that can reflect echoes.",
            "options": [
                {
                    "type": "goto",
                    "goto": "safety-check",
                    "text": "Bench wiring is complete.",
                    "requiresItems": [
                        {
                            "id": "17edf3f2-8b4a-4c62-b3f5-c17236d53430",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "mounted-setup",
            "text": "Mount the sensor forward-facing, avoid servo horn obstruction, and secure jumper strain relief before power-on.",
            "options": [
                {
                    "type": "goto",
                    "goto": "safety-check",
                    "text": "Robot-mounted wiring is complete.",
                    "requiresItems": [
                        {
                            "id": "17edf3f2-8b4a-4c62-b3f5-c17236d53430",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "safety-check",
            "text": "Safety gate: confirm low-voltage wiring polarity and keep hands clear during ping tests to avoid false readings and accidental collisions.",
            "options": [
                {
                    "type": "goto",
                    "goto": "measurement",
                    "text": "Safety checks complete; start distance sampling.",
                    "requiresItems": [
                        {
                            "id": "17edf3f2-8b4a-4c62-b3f5-c17236d53430",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "troubleshoot",
                    "text": "I need to fix wiring or mounting first."
                }
            ]
        },
        {
            "id": "measurement",
            "text": "Collect repeated measurements at near, mid, and far targets. Accept only runs where values are stable enough for obstacle logic.",
            "options": [
                {
                    "type": "finish",
                    "text": "Distance readings are stable across all target ranges.",
                    "requiresItems": [
                        {
                            "id": "17edf3f2-8b4a-4c62-b3f5-c17236d53430",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "troubleshoot",
                    "text": "Readings are noisy or inconsistent."
                }
            ]
        },
        {
            "id": "troubleshoot",
            "text": "Recovery path: increase target spacing, damp motor vibration, and retest after each change until echoes stabilize.",
            "options": [
                {
                    "type": "goto",
                    "goto": "safety-check",
                    "text": "Corrections applied; repeat safety checks and retry."
                }
            ]
        }
    ],
