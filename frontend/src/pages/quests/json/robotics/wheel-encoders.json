                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "wire-first",
                    "text": "Route and label signal harness first, then mount.",
                    "requiresItems": [
                        {
                            "id": "71fafa9a-3998-4763-a63a-279acc4ca603",
                            "count": 2
                        },
                        {
                            "id": "72b4448e-27d9-4746-bd3a-967ff13f501b",
