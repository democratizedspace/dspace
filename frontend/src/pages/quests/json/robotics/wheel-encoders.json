                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "troubleshoot",
                    "text": "Need to correct wiring before test runs."
                }
            ]
        },
        {
            "id": "troubleshoot",
            "text": "Recovery loop: re-seat connectors, swap miswired channels, and rerun a hand-spin test until left/right pulse counts are independent and stable.",
