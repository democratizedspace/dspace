                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "mount-first",
            "text": "Raise the robot and secure both encoder brackets to the wheel hubs. Confirm each wheel spins freely before routing signal lines to pins 2 and 3.",
            "options": [
                {
                    "type": "goto",
                    "goto": "safety-check",
                    "text": "Mount-first path complete; wiring is clear of moving parts.",
                    "requiresItems": [
                        {
                            "id": "71fafa9a-3998-4763-a63a-279acc4ca603",
                            "count": 2
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "troubleshoot",
                    "text": "One wheel rubs or cable strain is too high."
                }
            ]
        },
        {
            "id": "wire-first",
            "text": "Route 5V/GND and signal wires first, label left/right channels, then mount encoders and verify no pinch points across full suspension travel.",
            "options": [
                {
                    "type": "goto",
                    "goto": "safety-check",
                    "text": "Wire-first path complete; channels are labeled and stable.",
                    "requiresItems": [
                        {
                            "id": "71fafa9a-3998-4763-a63a-279acc4ca603",
                            "count": 2
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "troubleshoot",
                    "text": "Pulse stream is noisy or channels are swapped."
                }
            ]
        },
        {
            "id": "safety-check",
            "text": "Safety gate: keep wheels lifted for first power-on, verify emergency cutoff, and cap motor PWM while validating encoder pulses.",
            "options": [
                {
                    "type": "goto",
                    "goto": "evidence",
                    "text": "Safety checks done; begin pulse validation runs.",
                    "requiresItems": [
