        },
        {
            "id": "triage",
            "text": "Skim the log entry. Green run? Note duration and coverage. Failures? Split by package with `npm run test:root -- --filter <suite>` and rerun to isolate. Keep notes so teammates can replay your path.",
            "options": [
                {
                    "type": "goto",
