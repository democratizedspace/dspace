                    "text": "npm run test:pr"
                },
                {
                    "type": "goto",
                    "goto": "retry-pr",
                    "text": "npm run qa:smoke only"
                },
                {
                    "type": "goto",
                    "goto": "retry-pr",
                    "text": "Skip tests and rely on CI"
                }
            ]
        },
