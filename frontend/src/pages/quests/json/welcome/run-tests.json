{
    "id": "welcome/run-tests",
    "title": "Run the Test Suite",
    "description": "Learn how to run DSPACE's automated tests to ensure your changes are correct.",
    "image": "/assets/quests/run_tests_terminal_dashboard.jpg",
    "npc": "/assets/npc/dChat.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Tests keep DSPACE stable for everyone. Catch regressions early and reviews go faster.",
            "options": [
                {
                    "type": "goto",
                    "goto": "primer",
                    "text": "Show me the command map"
                }
            ]
        },
        {
            "id": "primer",
            "text": "From docs/qa/v3.md: npm run qa:smoke (fast sanity check + CI parity without Playwright), npm run test:pr (full pre-PR suite with grouped Playwright), plus targeted checks like npm run lint, npm run type-check, npm run build, and npm run coverage.",
            "options": [
                {
                    "type": "goto",
                    "goto": "quiz-1",
                    "text": "Quiz me"
                }
            ]
        },
        {
            "id": "quiz-1",
            "text": "Which command is the fastest sanity check while matching CI parity without Playwright?",
            "options": [
                {
                    "type": "goto",
                    "goto": "quiz-2",
                    "text": "npm run qa:smoke"
                },
                {
                    "type": "goto",
                    "goto": "quiz-1-wrong",
                    "text": "npm run test:pr"
                },
                {
                    "type": "goto",
                    "goto": "quiz-1-wrong",
                    "text": "npm run build"
                }
            ]
        },
        {
            "id": "quiz-1-wrong",
            "text": "qa:smoke is the quick CI-parity sweep. test:pr is the full suite, and build is just compilation.",
            "options": [
                {
                    "type": "goto",
                    "goto": "quiz-1",
                    "text": "Try again"
                }
            ]
        },
        {
            "id": "quiz-2",
            "text": "Which command runs the full pre-PR suite with grouped Playwright tests?",
            "options": [
                {
                    "type": "goto",
                    "goto": "quiz-3",
                    "text": "npm run test:pr"
                },
                {
                    "type": "goto",
                    "goto": "quiz-2-wrong",
                    "text": "npm run qa:smoke"
                },
                {
                    "type": "goto",
                    "goto": "quiz-2-wrong",
                    "text": "npm run lint"
                }
            ]
        },
        {
            "id": "quiz-2-wrong",
            "text": "test:pr is the full pre-PR run, including grouped Playwright. qa:smoke skips E2E.",
            "options": [
                {
                    "type": "goto",
                    "goto": "quiz-2",
                    "text": "Try again"
                }
            ]
        },
        {
            "id": "quiz-3",
            "text": "Playwright browsers missing—what command skips E2E tests?",
            "options": [
                {
                    "type": "goto",
                    "goto": "wrap",
                    "text": "SKIP_E2E=1 npm test"
                },
                {
                    "type": "goto",
                    "goto": "quiz-3-wrong",
                    "text": "E2E_SKIP=1 npm test"
                },
                {
                    "type": "goto",
                    "goto": "quiz-3-wrong",
                    "text": "npm test --no-e2e"
                }
            ]
        },
        {
            "id": "quiz-3-wrong",
            "text": "Use SKIP_E2E=1 with npm test when browsers aren't installed.",
            "options": [
                {
                    "type": "goto",
                    "goto": "quiz-3",
                    "text": "Try again"
                }
            ]
        },
        {
            "id": "wrap",
            "text": "You're ready to run the suite. Log a clean run and your PRs will glide through review.",
            "options": [
                {
                    "type": "process",
                    "process": "execute-dspace-tests",
                    "text": "Run the full local suite"
                },
                {
                    "type": "finish",
                    "text": "Finish quest"
                }
            ]
        }
    ],
    "rewards": [
        {
            "id": "82b369fe-0ef4-4ca1-881c-14e5a7feeff5",
            "count": 1
        }
    ],
    "requiresQuests": ["welcome/connect-github"],
