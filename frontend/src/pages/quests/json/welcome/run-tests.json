{
    "id": "welcome/run-tests",
    "title": "Run the Test Suite",
    "description": "Learn the real DSPACE test commands before opening a PR.",
    "image": "/assets/quests/run_tests_terminal_dashboard.jpg",
    "npc": "/assets/npc/dChat.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Before you ship code, run tests. They catch regressions early and make reviews faster.",
            "options": [
                {
                    "type": "goto",
                    "goto": "commands",
                    "text": "Show me the command playbook"
                }
            ]
        },
        {
            "id": "commands",
            "text": "Use the real repo commands: npm run qa:smoke for a fast sanity pass, npm run test:ci for CI-parity checks without Playwright E2E, and npm run test:pr for the full pre-PR suite including grouped Playwright runs.",
            "options": [
                {
                    "type": "goto",
                    "goto": "quiz-1",
                    "text": "Quiz me"
                }
            ]
        },
        {
            "id": "quiz-1",
            "text": "Which command is the fastest sanity-check pass?",
            "options": [
                {
                    "type": "goto",
                    "goto": "quiz-2",
                    "text": "npm run qa:smoke"
                },
                {
                    "type": "goto",
                    "goto": "retry-smoke",
                    "text": "npm run test:pr"
                },
                {
                    "type": "goto",
                    "goto": "retry-smoke",
                    "text": "npm run lint"
                }
            ]
        },
        {
            "id": "retry-smoke",
            "text": "Almost. qa:smoke is the quick bundled sanity check before deeper runs.",
            "options": [
                {
                    "type": "goto",
                    "goto": "start",
                    "text": "Retry from start"
                }
            ]
        },
        {
            "id": "quiz-2",
            "text": "Which command is CI parity (build + verify stamp + test:pr with SKIP_E2E=1)?",
            "options": [
                {
                    "type": "goto",
                    "goto": "quiz-3",
                    "text": "npm run test:ci"
                },
                {
                    "type": "goto",
                    "goto": "retry-ci",
                    "text": "npm run test:pr"
                },
                {
                    "type": "goto",
                    "goto": "retry-ci",
                    "text": "npm run link-check"
                }
            ]
        },
        {
            "id": "retry-ci",
            "text": "Close. test:ci is the CI-parity command; it mirrors the non-E2E CI path.",
            "options": [
                {
                    "type": "goto",
                    "goto": "start",
                    "text": "Retry from start"
                }
            ]
        },
        {
            "id": "quiz-3",
            "text": "What should you run before opening a PR when you want the full local gate?",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "npm run test:pr"
                },
                {
                    "type": "goto",
                    "goto": "retry-pr",
                    "text": "npm run qa:smoke only"
                },
                {
                    "type": "goto",
                    "goto": "retry-pr",
                    "text": "Skip tests and rely on CI"
                }
            ]
        },
        {
            "id": "retry-pr",
            "text": "Good instinct to be fast, but before a PR you should run test:pr for the full local pre-PR suite.",
            "options": [
                {
                    "type": "goto",
                    "goto": "start",
                    "text": "Retry from start"
                }
            ]
        },
        {
            "id": "finish",
            "text": "Verified mindset unlocked. You now know the test ladder from smoke check to full pre-PR confidence.",
            "options": [
                {
                    "type": "finish",
                    "text": "Claim testing trophy"
                }
            ]
        }
    ],
