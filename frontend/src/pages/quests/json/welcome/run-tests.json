                    "type": "goto",
                    "goto": "start",
                    "text": "Back to start"
                }
            ]
        },
        {
            "id": "quiz-2",
            "text": "Which command runs the full pre-PR suite with grouped Playwright tests?",
            "options": [
                {
                    "type": "goto",
                    "goto": "quiz-3",
                    "text": "npm run test:pr"
                },
                {
                    "type": "goto",
                    "goto": "retry-pr",
                    "text": "npm run qa:smoke"
                },
                {
                    "type": "goto",
