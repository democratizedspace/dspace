                    "text": "npm run qa:smoke only"
                },
                {
                    "type": "goto",
                    "goto": "retry-pr",
                    "text": "Skip tests and rely on CI"
                }
            ]
        },
        {
            "id": "retry-pr",
            "text": "Good instinct to be fast, but before a PR you should run test:pr for the full local pre-PR suite.",
            "options": [
                {
                    "type": "goto",
                    "goto": "start",
                    "text": "Retry from start"
                }
            ]
        },
        {
