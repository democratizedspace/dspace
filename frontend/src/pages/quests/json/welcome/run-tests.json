    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Before you ship code, run tests. They catch regressions early and make reviews faster.",
            "options": [
                {
                    "type": "goto",
                    "goto": "commands",
                    "text": "Show me the command playbook"
                }
            ]
        },
        {
            "id": "commands",
            "text": "Quick map:\n• `npm run qa:smoke` (`type-check` + `link-check` + `itemValidation` + `test:ci`)\n• `npm run test:pr` (full pre-PR suite with grouped Playwright)\nFocused checks include `npm run lint`, `npm run type-check`, and `npm run build`.\n`test:ci` runs build + `verify:chat-build-stamp` and then `test:pr` with `SKIP_E2E=1` so Playwright E2E is skipped when the runner honors the flag.",
            "options": [
                {
                    "type": "goto",
                    "goto": "quiz-1",
                    "text": "Quiz me"
                }
            ]
        },
        {
            "id": "quiz-1",
            "text": "Which command is the quick smoke that chains `type-check`, `link-check`, `itemValidation`, and `test:ci`?",
            "options": [
                {
                    "type": "goto",
                    "goto": "quiz-2",
                    "text": "npm run qa:smoke"
                },
                {
                    "type": "goto",
                    "goto": "retry-smoke",
                    "text": "npm run test:pr"
                },
                {
                    "type": "goto",
                    "goto": "retry-smoke",
                    "text": "npm run lint"
                }
            ]
        },
        {
            "id": "retry-smoke",
            "text": "`qa:smoke` is the fast check that bundles `type-check`, `link-check`, `itemValidation`, and `test:ci`.",
            "options": [
                {
                    "type": "goto",
                    "goto": "start",
                    "text": "Retry from start"
                }
            ]
        },
        {
            "id": "quiz-2",
            "text": "Which command is CI parity (build + verify stamp + test:pr with SKIP_E2E=1)?",
            "options": [
                {
                    "type": "goto",
                    "goto": "quiz-3",
                    "text": "npm run test:ci"
                },
                {
                    "type": "goto",
                    "goto": "retry-pr",
                    "text": "npm run qa:smoke"
                },
                {
                    "type": "goto",
                    "goto": "retry-pr",
                    "text": "npm run lint"
                }
            ]
        },
        {
            "id": "retry-pr",
            "text": "`test:pr` is the full pre-PR suite, including grouped Playwright E2E runs.",
            "options": [
                {
                    "type": "goto",
                    "goto": "start",
                    "text": "Back to start"
                }
            ]
        },
        {
            "id": "quiz-3",
            "text": "Which command mirrors CI checks by running build + `verify:chat-build-stamp` and then `test:pr` with `SKIP_E2E=1`?",
            "options": [
                {
                    "type": "goto",
                    "goto": "prep-repo",
                    "text": "npm run test:ci"
                },
                {
                    "type": "goto",
                    "goto": "retry-ci",
                    "text": "npm run test:pr"
                },
                {
                    "type": "goto",
                    "goto": "retry-ci",
                    "text": "npm run link-check"
                }
            ]
        },
        {
            "id": "retry-ci",
            "text": "`test:ci` runs build + `verify:chat-build-stamp` and then `test:pr` with `SKIP_E2E=1`; `qa:smoke` wraps that with `type-check`, `link-check`, and `itemValidation`.",
            "options": [
                {
                    "type": "goto",
                    "goto": "start",
                    "text": "Retry from start"
                }
            ]
        },
        {
            "id": "quiz-3",
            "text": "What should you run before opening a PR when you want the full local gate?",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "npm run test:pr"
                },
                {
                    "type": "goto",
