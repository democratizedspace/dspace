{
    "id": "welcome/run-tests",
    "title": "Run the Test Suite",
    "description": "Learn how to run DSPACE's automated tests to ensure your changes are correct.",
    "image": "/assets/quests/run_tests_terminal_dashboard.jpg",
    "npc": "/assets/npc/dChat.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Testing keeps DSPACE cooperative for everyone. First quiz: which command runs the full pre-PR suite?",
            "options": [
                {
                    "type": "goto",
                    "goto": "clone",
                    "text": "npm run test:pr"
                },
                {
                    "type": "goto",
                    "goto": "start",
                    "text": "npm run test:e2e:groups"
                },
                {
                    "type": "goto",
                    "goto": "start",
                    "text": "npm run lint"
                }
            ]
        },
        {
            "id": "clone",
            "text": "Grab the repo and keep it handy. You'll need a laptop to clone and a GitHub repo to work from.",
            "options": [
                {
                    "type": "goto",
                    "goto": "setup",
                    "text": "Clone the repo",
                    "process": "clone-github-repo",
                    "requiresItems": [
                        {
                            "id": "b6fc1ed6-f399-4fdb-9f9d-3913f893f43d",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "start",
                    "text": "I need the command again."
                }
            ]
        },
        {
            "id": "setup",
            "text": "Next quiz: if browsers are unavailable, how do you skip the E2E portion when running the full suite?",
            "options": [
                {
                    "type": "goto",
                    "goto": "workflow",
                    "text": "SKIP_E2E=1 npm test"
                },
                {
                    "type": "goto",
                    "goto": "start",
                    "text": "SKIP_E2E=1 npm run lint"
                },
                {
                    "type": "goto",
                    "goto": "start",
                    "text": "npm run test:e2e"
                }
            ]
        },
        {
            "id": "workflow",
            "text": "Add the CI workflow file so local commands mirror the PR pipeline.",
            "options": [
                {
                    "type": "goto",
                    "goto": "workspace",
                    "text": "Create the workflow file",
                    "process": "create-ci-workflow",
                    "requiresItems": [
                        {
                            "id": "52593d07-908b-4109-92cf-826b2184ef6f",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "start",
                    "text": "Start the quiz over."
                }
            ]
        },
        {
            "id": "workspace",
            "text": "Install dependencies and warm caches. This is what makes the test run fast and consistent.",
            "options": [
                {
                    "type": "goto",
                    "goto": "quiz-ci",
                    "text": "Prepare the local testbed",
                    "process": "prepare-local-testbed",
                    "requiresItems": [
                        {
                            "id": "52593d07-908b-4109-92cf-826b2184ef6f",
                            "count": 1
                        },
                        {
                            "id": "b6fc1ed6-f399-4fdb-9f9d-3913f893f43d",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "start",
                    "text": "Back to the quiz."
                }
            ]
        },
        {
            "id": "quiz-ci",
            "text": "Which commands show up in the CI checklist before tests run?",
            "options": [
                {
                    "type": "goto",
                    "goto": "suite",
                    "text": "npm run lint, npm run type-check, npm run build"
                },
                {
                    "type": "goto",
                    "goto": "start",
                    "text": "npm run audit:ci only"
                },
                {
                    "type": "goto",
                    "goto": "start",
                    "text": "npm run test:e2e only"
                }
            ]
        },
        {
            "id": "suite",
            "text": "Run lint, type checks, build, and the full test suite. Capture the log so we know what passed.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Report captured and green.",
                    "process": "execute-dspace-tests",
                    "requiresItems": [
                        {
                            "id": "c4807e67-4e40-452f-8cdc-e326f3e34444",
                            "count": 1
                        },
                        {
                            "id": "306793ac-e420-4859-9742-9076fff6ab57",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "workspace",
                    "text": "Dependencies changed—reinstall and retry."
                }
            ]
        },
        {
            "id": "finish",
            "text": "Nice work. With a clean report and CI parity, your changes are ready to share without surprising the fleet.",
            "options": [
                {
                    "type": "finish",
                    "text": "Ship the passing run.",
                    "requiresItems": [
                        {
                            "id": "1486e0df-f01e-4c9e-bdd8-ef272df0b9ef",
                            "count": 1
                        }
                    ]
                }
            ]
        }
    ],
