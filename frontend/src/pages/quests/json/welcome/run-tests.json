{
    "id": "welcome/run-tests",
    "title": "Run the Test Suite",
    "description": "Learn how to run DSPACE's automated tests to ensure your changes are correct.",
    "image": "/assets/quests/run_tests_terminal_dashboard.jpg",
    "npc": "/assets/npc/dChat.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Testing keeps DSPACE cooperative for everyone. The repo docs call out `npm test` for the PR suite, `npm run lint`, `npm run type-check`, `npm run build`, and `npm run coverage`. If Playwright browsers are unavailable, use `SKIP_E2E=1 npm test`.",
            "options": [
                {
                    "type": "goto",
                    "goto": "quiz1",
                    "text": "Quiz me."
                }
            ]
        },
        {
            "id": "quiz1",
            "text": "Which command runs the PR test suite locally?",
            "options": [
                {
                    "type": "goto",
                    "goto": "quiz2",
                    "text": "`npm test`"
                },
                {
                    "type": "goto",
                    "goto": "start",
                    "text": "`npm run lint`"
                },
                {
                    "type": "goto",
                    "goto": "start",
                    "text": "`npm run type-check`"
                }
            ]
        },
        {
            "id": "quiz2",
            "text": "What do you run when browsers are unavailable for Playwright?",
            "options": [
                {
                    "type": "goto",
                    "goto": "quiz3",
                    "text": "`SKIP_E2E=1 npm test`"
                },
                {
                    "type": "goto",
                    "goto": "start",
                    "text": "`npm test --skip-e2e`"
                },
                {
                    "type": "goto",
                    "goto": "start",
                    "text": "`SKIP_E2E=1 npm run lint`"
                }
            ]
        },
        {
            "id": "quiz3",
            "text": "Which command checks lint issues before you open a PR?",
            "options": [
                {
                    "type": "goto",
                    "goto": "prep",
                    "text": "`npm run lint`"
                },
                {
                    "type": "goto",
                    "goto": "start",
                    "text": "`npm run build`"
                },
                {
                    "type": "goto",
                    "goto": "start",
                    "text": "`npm run coverage`"
                }
            ]
        },
        {
            "id": "prep",
            "text": "Time to set up the workspace. Buy a laptop in the inventory shop, then clone the repo so you have a GitHub repository ready for CI parity.",
            "options": [
                {
                    "type": "process",
                    "process": "clone-github-repo",
                    "text": "Clone the DSPACE repo."
                },
                {
                    "type": "goto",
                    "goto": "workflow",
                    "text": "Repo cloned.",
                    "requiresItems": [
                        {
