    "dialogue": [
        {
            "id": "start",
            "text": "Tests catch regressions early and make reviews faster. Let’s learn the exact commands used in this repo.",
            "options": [
                {
                    "type": "goto",
                    "goto": "commands",
                    "text": "Show command guide"
                }
            ]
        },
        {
            "id": "commands",
            "text": "Command guide: npm run qa:smoke is the fast sanity pass (type-check + link-check + itemValidation + test:ci). npm run test:pr is the full pre-PR suite. npm run test:ci mirrors CI basics by running build + verify:chat-build-stamp and then test:pr with SKIP_E2E=1.",
            "options": [
                {
                    "type": "goto",
                    "goto": "quiz-1",
                    "text": "Start quiz"
                }
            ]
        },
        {
            "id": "quiz-1",
            "text": "Which command is the fastest sanity-check pass?",
            "options": [
                {
                    "type": "goto",
                    "goto": "quiz-2",
                    "text": "npm run qa:smoke"
                },
                {
                    "type": "goto",
                    "goto": "retry-smoke",
                    "text": "npm run test:pr"
                },
                {
                    "type": "goto",
                    "goto": "retry-smoke",
                    "text": "npm run lint"
                }
            ]
        },
        {
            "id": "retry-smoke",
            "text": "Close—qa:smoke is the quick pipeline check before deeper runs.",
            "options": [
                {
                    "type": "goto",
                    "goto": "start",
                    "text": "Retry from start"
                }
            ]
        },
        {
            "id": "quiz-2",
            "text": "Which command best matches CI parity on local runs?",
            "options": [
                {
                    "type": "goto",
                    "goto": "quiz-3",
                    "text": "npm run test:ci"
                },
                {
                    "type": "goto",
                    "goto": "retry-ci",
                    "text": "npm run build"
                },
                {
                    "type": "goto",
                    "goto": "retry-ci",
                    "text": "npm run test:e2e"
                }
            ]
        },
        {
            "id": "retry-ci",
            "text": "Not quite. test:ci is the scripted CI-parity command (build + verify stamp + SKIP_E2E test:pr).",
            "options": [
                {
                    "type": "goto",
                    "goto": "start",
                    "text": "Retry from start"
                }
            ]
        },
        {
            "id": "quiz-3",
            "text": "Before opening a PR, which command runs the full local pre-PR suite?",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "npm run test:pr"
                },
                {
                    "type": "goto",
                    "goto": "retry-pr",
                    "text": "npm run link-check"
                },
                {
                    "type": "goto",
                    "goto": "retry-pr",
                    "text": "npm run type-check"
                }
            ]
        },
        {
            "id": "retry-pr",
            "text": "Helpful checks, but test:pr is the full pre-PR gate.",
            "options": [
                {
                    "type": "goto",
                    "goto": "start",
                    "text": "Retry from start"
                }
            ]
        },
        {
            "id": "finish",
            "text": "Excellent. You’re now using the same testing language as the CI pipeline—tested, verified, and ready to ship.",
            "options": [
                {
                    "type": "finish",
                    "text": "Claim test trophy"
                }
            ]
        }
