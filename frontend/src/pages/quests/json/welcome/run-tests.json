{
    "id": "welcome/run-tests",
    "title": "Run the Test Suite",
    "description": "Learn the real DSPACE test commands before opening a PR.",
    "image": "/assets/quests/run_tests_terminal_dashboard.jpg",
    "npc": "/assets/npc/dChat.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Before you ship code, run tests. They catch regressions early and make reviews faster.",
            "options": [
                {
                    "type": "goto",
                    "goto": "commands",
                    "text": "Show me the command playbook"
                }
            ]
        },
        {
            "id": "commands",
            "text": "Command ladder:\n\u2022 `npm run qa:smoke` for the fastest sanity pass\n\u2022 `npm run test:ci` for CI-parity checks from the repo scripts\n\u2022 `npm run test:pr` for the full pre-PR suite\nUse focused checks like `npm run lint`, `npm run type-check`, and `npm run build` when debugging.",
            "options": [
                {
                    "type": "goto",
                    "goto": "quiz-1",
                    "text": "Quiz me"
                }
            ]
        },
        {
            "id": "quiz-1",
            "text": "Which command is fastest to sanity-check your changes?",
            "options": [
                {
                    "type": "goto",
                    "goto": "quiz-2",
                    "text": "npm run qa:smoke"
                },
                {
                    "type": "goto",
                    "goto": "retry-smoke",
                    "text": "npm run test:pr"
                },
                {
                    "type": "goto",
                    "goto": "retry-smoke",
                    "text": "npm run lint"
                }
            ]
        },
        {
            "id": "retry-smoke",
            "text": "Not quite. Start with `npm run qa:smoke` when you want the quickest sanity pass.",
            "options": [
                {
                    "type": "goto",
                    "goto": "start",
                    "text": "Retry from start"
                }
            ]
        },
        {
            "id": "quiz-2",
            "text": "Which command best matches CI parity?",
            "options": [
                {
                    "type": "goto",
                    "goto": "quiz-3",
                    "text": "npm run test:ci"
                },
                {
                    "type": "goto",
                    "goto": "retry-pr",
                    "text": "npm run qa:smoke"
                },
                {
                    "type": "goto",
                    "goto": "retry-pr",
                    "text": "npm run lint"
                }
            ]
        },
        {
            "id": "retry-pr",
            "text": "Close. `npm run test:ci` is the CI-parity command from the repo scripts.",
            "options": [
                {
                    "type": "goto",
                    "goto": "start",
                    "text": "Back to start"
                }
            ]
        },
        {
            "id": "quiz-3",
            "text": "What do you run before opening a PR?",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "npm run test:pr"
                },
                {
                    "type": "goto",
                    "goto": "retry-full-gate",
                    "text": "npm run qa:smoke only"
                },
                {
                    "type": "goto",
                    "goto": "retry-full-gate",
                    "text": "Skip tests and rely on CI"
                }
            ]
        },
        {
            "id": "retry-full-gate",
            "text": "Before you open a PR, run `npm run test:pr` for the full local gate.",
            "options": [
                {
                    "type": "goto",
                    "goto": "start",
                    "text": "Retry from start"
                }
            ]
        },
        {
            "id": "finish",
            "text": "Verified mindset unlocked. You now know the test ladder from smoke check to full pre-PR confidence.",
            "options": [
                {
                    "type": "finish",
                    "text": "Claim testing trophy"
                }
            ]
        }
    ],
