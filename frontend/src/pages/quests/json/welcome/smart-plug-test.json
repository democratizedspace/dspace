                {
                    "type": "goto",
                    "goto": "measure",
                    "text": "Sounds fun!"
                }
            ]
        },
        {
            "id": "measure",
            "text": "Run outlet-dWatt-1e3 with the smart plug. dWatt is the in-game energy you can spend; dCarbon is the fossil debt created by grid power. When you sell dWatt, a dCarbon tax is deducted—look for the Sell button showing something like “Sell for … (-X%)” and the note that says there’s a tax applied with a link to dCarbon below it.",
            "options": [
                {
                    "type": "process",
                    "process": "outlet-dWatt-1e3",
                    "text": "Start outlet-dWatt-1e3"
                },
                {
                    "type": "goto",
                    "goto": "wrapup",
                    "requiresItems": [
                        {
                            "id": "061fd221-404a-4bd1-9432-3e25b0f17a2c",
                            "count": 1000
                        }
                    ],
                    "text": "dWatt received!"
                }
            ]
        },
        {
            "id": "wrapup",
            "text": "That was the easy, fossil-fueled path. Later you’ll earn dWatt from renewables or stored energy to avoid dCarbon.",
