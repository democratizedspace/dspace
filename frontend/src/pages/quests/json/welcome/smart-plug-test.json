                {
                    "type": "goto",
                    "goto": "measure",
                    "text": "Sounds fun!"
                }
            ]
        },
        {
            "id": "measure",
            "text": "Run outlet-dWatt-1e3 until you reach 10,000 dWatt. dWatt is your spendable in-game energy for machines and processes. dCarbon tracks fossil-fuel impact from grid power. When you sell dWatt, a dCarbon tax is deducted from the payout. In /inventory, open dWatt and check the Sell action—the button preview shows the reduced return and links to dCarbon details.",
            "options": [
                {
                    "type": "process",
                    "process": "outlet-dWatt-1e3",
                    "text": "Start outlet-dWatt-1e3"
                },
                {
                    "type": "goto",
                    "goto": "wrapup",
                    "requiresItems": [
                        {
                            "id": "061fd221-404a-4bd1-9432-3e25b0f17a2c",
                            "count": 10000
                        }
                    ],
                    "text": "dWatt received!"
                }
            ]
        },
        {
            "id": "wrapup",
            "text": "Nice run. Grid power is the easy path for early progress, but renewables and batteries let you earn dWatt with less dCarbon later.",
