    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "The smart plug lets you buy grid energy on demand. It is convenient, but it adds dCarbon. Ready for a quick demo?",
            "options": [
                {
                    "type": "goto",
                    "goto": "measure",
                    "text": "Sounds fun!"
                }
            ]
        },
        {
            "id": "measure",
            "text": "Run outlet-dWatt-1e3 with the smart plug. dWatt is usable energy for processes. dCarbon is the fossil-use tag that comes with grid power.",
            "options": [
                {
                    "type": "process",
                    "process": "outlet-dWatt-1e3",
                    "text": "Start outlet-dWatt-1e3"
                },
                {
                    "type": "goto",
                    "goto": "tax",
                    "requiresItems": [
                        {
                            "id": "061fd221-404a-4bd1-9432-3e25b0f17a2c",
                            "count": 1000
                        }
                    ],
                    "text": "dWatt generated!"
                }
            ]
        },
        {
            "id": "tax",
            "text": "When you sell energy, a dCarbon tax is deducted. You can see the tax line in the /inventory Sell panel before confirming a sale.",
            "options": [
                {
                    "type": "goto",
                    "goto": "wrapup",
                    "text": "Got it."
                }
            ]
        },
        {
            "id": "wrapup",
            "text": "That was the fast, fossil-fueled path. Early on it helps you earn dWatt quickly, but renewables are meant to replace it.",
            "options": [
                {
                    "type": "finish",
                    "text": "Neat!"
                }
            ]
        }
    ],
