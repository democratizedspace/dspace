    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Use the smart plug to buy 1 kWh from the grid. It's the quick, always-available way to earn dWatt, but it adds dCarbon.",
            "options": [
                {
                    "type": "goto",
                    "goto": "measure",
                    "text": "Let's do it."
                }
            ]
        },
        {
            "id": "measure",
            "text": "Run outlet-dWatt-1e3. dWatt is usable energy for machines; dCarbon is your fossil-fuel footprint.",
            "options": [
                {
                    "type": "process",
                    "process": "outlet-dWatt-1e3",
                    "text": "Start outlet-dWatt-1e3"
                },
                {
                    "type": "goto",
                    "goto": "tax",
                    "requiresItems": [
                        {
                            "id": "061fd221-404a-4bd1-9432-3e25b0f17a2c",
                            "count": 1000
                        }
                    ],
                    "text": "dWatt received!"
                }
            ]
        },
        {
            "id": "tax",
            "text": "dCarbon isn't just a score—it taxes selling. For every 1,000 dCarbon, your sell prices drop by 1% (up to 90%). You can see the reduced sell price preview on /inventory when you toggle Sell.",
            "options": [
                {
                    "type": "goto",
                    "goto": "wrapup",
                    "text": "Got it."
                }
            ]
        },
        {
            "id": "wrapup",
            "text": "Nice work. Grid energy is convenient, but renewables are how you scale without the dCarbon drag.",
            "options": [
                {
                    "type": "finish",
                    "text": "On to cleaner power."
                }
            ]
        }
    ],
