{
    "id": "welcome/smart-plug-test",
    "title": "Smart Plug Test",
    "description": "Learn how grid energy turns dUSD into dWatt, and why that convenience creates dCarbon.",
    "hardening": {
        "passes": 1,
        "score": 100,
        "emoji": "🌀",
        "history": [
            {
                "task": "codex-quest-hardening-2025-08-15",
