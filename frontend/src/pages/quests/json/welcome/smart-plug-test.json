{
    "id": "welcome/smart-plug-test",
    "title": "Smart Plug Test",
    "description": "Use the smart plug to buy grid energy and learn the dWatt ↔ dCarbon tradeoff.",
    "hardening": {
        "passes": 1,
        "score": 100,
        "emoji": "🌀",
        "history": [
            {
                "task": "codex-quest-hardening-2025-08-15",
