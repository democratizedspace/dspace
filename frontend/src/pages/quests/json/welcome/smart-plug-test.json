            }
        ]
    },
    "image": "/assets/quests/smart_plug_test_dwatt_kwh.jpg",
    "npc": "/assets/npc/dChat.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Quick tutorial: the smart plug lets you buy grid energy anytime. It's convenient, but that convenience adds dCarbon.",
            "options": [
                {
                    "type": "goto",
                    "goto": "teach-resources",
                    "text": "Teach me the tradeoff"
                }
            ]
        },
        {
            "id": "teach-resources",
            "text": "In DSPACE, dWatt is your spendable energy resource for running processes. dCarbon tracks fossil-fuel impact from grid energy. When you sell dWatt, a dCarbon tax reduces your payout; open the Sell flow for dWatt and look for the tax note beside the sell value.",
            "options": [
                {
                    "type": "goto",
                    "goto": "run-process",
                    "text": "Got it—let's earn dWatt"
                }
            ]
        },
        {
            "id": "run-process",
            "text": "Now run outlet-dWatt-1e3 until your balance reaches 10,000 dWatt. Later quests introduce cleaner ways to generate energy with less dCarbon.",
            "options": [
                {
                    "type": "process",
                    "process": "outlet-dWatt-1e3",
                    "text": "Start outlet-dWatt-1e3"
                },
                {
                    "type": "goto",
                    "goto": "wrapup",
                    "requiresItems": [
                        {
                            "id": "061fd221-404a-4bd1-9432-3e25b0f17a2c",
                            "count": 10000
                        }
                    ],
                    "text": "I reached 10,000 dWatt"
                }
            ]
        },
        {
            "id": "wrapup",
            "text": "Nice work. You can always buy grid energy in a pinch, but long-term progress means generating dWatt with lower dCarbon.",
            "options": [
                {
                    "type": "finish",
                    "text": "On to cleaner power"
                }
            ]
        }
    ],
