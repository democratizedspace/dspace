{
    "id": "welcome/connect-github",
    "title": "Connect GitHub",
    "description": "Link your GitHub account to enable cloud sync and quest submissions.",
    "image": "/assets/quests/connect_github_integration.jpg",
    "npc": "/assets/npc/dChat.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Let’s link GitHub so your progress can sync, quests can be submitted, and your work stays portable.",
            "options": [
                {
                    "type": "goto",
                    "goto": "why",
                    "text": "Why does GitHub matter?"
                },
                {
                    "type": "goto",
                    "goto": "steps",
                    "text": "Show me the steps"
                },
                {
                    "type": "goto",
                    "goto": "quiz-1",
                    "text": "Quiz me first"
                }
            ]
        },
        {
            "id": "why",
            "text": "GitHub keeps your quests and progress backed up in the cloud, unlocks submissions, and lets you move between machines without losing work. We’ll use a classic personal access token (PAT).",
            "options": [
                {
                    "type": "goto",
                    "goto": "steps",
                    "text": "Got it—show me the steps"
                },
                {
                    "type": "goto",
                    "goto": "quiz-1",
                    "text": "I’m ready for the quiz"
                }
            ]
        },
        {
            "id": "steps",
            "text": "PAT steps: GitHub Settings → Developer settings → Personal access tokens → Tokens (classic). Generate a new token with repo + gist scopes, copy it, then paste it into /cloudsync and click Save.",
            "options": [
                {
                    "type": "goto",
                    "goto": "quiz-1",
                    "text": "Got it—quiz me"
                }
            ]
        },
        {
            "id": "quiz-1",
            "text": "What do PAT scopes control?",
            "options": [
                {
                    "type": "goto",
                    "goto": "quiz-2",
                    "text": "They define what the token is allowed to do"
                },
                {
                    "type": "goto",
                    "goto": "retry-scopes",
                    "text": "They pick which repo name I have to use"
                },
                {
                    "type": "goto",
                    "goto": "retry-scopes",
                    "text": "They change my GitHub username"
                }
            ]
        },
        {
            "id": "retry-scopes",
            "text": "Scopes are permissions. Choose only what DSPACE needs so your token isn’t overpowered.",
            "options": [
                {
                    "type": "goto",
                    "goto": "start",
                    "text": "Back to start"
                }
            ]
        },
        {
            "id": "quiz-2",
            "text": "How should you handle a personal access token?",
            "options": [
                {
                    "type": "goto",
                    "goto": "quiz-3",
                    "text": "Treat it like a password and keep it secret"
                },
                {
                    "type": "goto",
                    "goto": "retry-secret",
                    "text": "Share it in chat so teammates can use it"
                },
                {
                    "type": "goto",
                    "goto": "retry-secret",
                    "text": "Paste it into issue comments for backup"
                }
            ]
        },
        {
            "id": "retry-secret",
            "text": "Tokens are sensitive. Store them only where needed (like /cloudsync) and never share them publicly.",
            "options": [
                {
                    "type": "goto",
                    "goto": "start",
                    "text": "Back to start"
                }
            ]
        },
        {
            "id": "quiz-3",
            "text": "What does connecting GitHub unlock in DSPACE?",
            "options": [
                {
                    "type": "goto",
                    "goto": "quiz-4",
                    "text": "Cloud sync and quest submissions"
                },
                {
                    "type": "goto",
                    "goto": "retry-why",
                    "text": "Unlimited dUSD and instant quest skips"
                },
                {
                    "type": "goto",
                    "goto": "retry-why",
                    "text": "Private multiplayer servers"
                }
            ]
        },
        {
            "id": "retry-why",
            "text": "Connecting GitHub is about syncing and sharing your work—not granting gameplay power-ups.",
            "options": [
                {
                    "type": "goto",
                    "goto": "start",
                    "text": "Back to start"
                }
            ]
        },
        {
            "id": "quiz-4",
            "text": "If you ever want to revoke the token, where do you do it?",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "GitHub Settings → Developer settings → Personal access tokens"
                },
                {
                    "type": "goto",
                    "goto": "retry-revoke",
                    "text": "Delete the repo on your machine"
                },
                {
                    "type": "goto",
                    "goto": "retry-revoke",
                    "text": "Email GitHub support to reset it"
                }
            ]
        },
        {
            "id": "retry-revoke",
            "text": "Revoking happens in GitHub’s token list. You can delete or regenerate a token anytime.",
            "options": [
                {
                    "type": "goto",
                    "goto": "start",
                    "text": "Back to start"
                }
            ]
        },
        {
            "id": "finish",
            "text": "Great! Your GitHub account is connected. The finish button unlocks once a valid token is saved.",
            "options": [
                {
                    "type": "finish",
                    "text": "All set!",
                    "requiresGitHub": true
                }
            ]
        }
    ],
    "rewards": [
        {
            "id": "d5d62069-c77d-44b1-8848-b355f8410f74",
            "count": 1
        }
    ],
    "requiresQuests": ["welcome/intro-inventory"],
    "hardening": {
        "passes": 0,
        "score": 90,
        "emoji": "🛠️",
        "history": []
    }
}
