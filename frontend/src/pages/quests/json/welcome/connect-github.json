{
    "id": "welcome/connect-github",
    "title": "Connect GitHub",
    "description": "Link your GitHub account to enable cloud sync and quest submissions.",
    "image": "/assets/quests/connect_github_integration.jpg",
    "npc": "/assets/npc/dChat.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Time to connect GitHub. This unlocks cloud sync, quest submissions, and easy switching between machines.",
            "options": [
                {
                    "type": "goto",
                    "goto": "steps",
                    "text": "Show me the PAT steps"
                },
                {
                    "type": "goto",
                    "goto": "quiz-1",
                    "text": "I know the basics—quiz me"
                }
            ]
        },
        {
            "id": "steps",
            "text": "Quick setup: GitHub Settings → Developer settings → Personal access tokens → Tokens (classic) → Generate new token. Give it a short expiration, grant only the required scopes (`gist` for cloud sync, plus `repo` if you also want to use this token for quest submissions), copy it once, then paste it into /cloudsync and press Save.",
            "options": [
                {
                    "type": "goto",
                    "goto": "quiz-1",
                    "text": "Done—start quiz"
                }
            ]
        },
        {
            "id": "quiz-1",
            "text": "What do PAT scopes mean?",
            "options": [
                {
                    "type": "goto",
                    "goto": "quiz-2",
                    "text": "They define what the token is allowed to access"
                },
                {
                    "type": "goto",
                    "goto": "retry-scopes",
                    "text": "They rename my GitHub account"
                },
                {
                    "type": "goto",
                    "goto": "retry-scopes",
                    "text": "They increase my storage quota"
                }
            ]
        },
        {
            "id": "retry-scopes",
            "text": "Close—scopes are permissions. Keep them minimal so the token has only the access DSPACE needs.",
            "options": [
                {
                    "type": "goto",
                    "goto": "start",
                    "text": "Retry from start"
                }
            ]
        },
        {
            "id": "quiz-2",
            "text": "How should you treat your PAT?",
            "options": [
                {
                    "type": "goto",
                    "goto": "quiz-3",
                    "text": "Like a password—private and never shared"
                },
                {
                    "type": "goto",
                    "goto": "retry-secret",
                    "text": "Paste it in chat so collaborators can use it"
                },
                {
                    "type": "goto",
                    "goto": "retry-secret",
                    "text": "Commit it to a repo for backup"
                }
            ]
        },
        {
            "id": "retry-secret",
            "text": "Nope. A leaked token is a security incident. Store it only in secure settings and rotate if exposed.",
            "options": [
                {
                    "type": "goto",
                    "goto": "start",
                    "text": "Retry from start"
                }
            ]
        },
        {
            "id": "quiz-3",
            "text": "What does GitHub connection enable in DSPACE?",
            "options": [
                {
                    "type": "goto",
                    "goto": "quiz-4",
                    "text": "Cloud sync and quest submissions"
                },
                {
                    "type": "goto",
                    "goto": "retry-benefits",
                    "text": "Instantly maxed currencies"
                },
                {
                    "type": "goto",
                    "goto": "retry-benefits",
                    "text": "Offline mode without local saves"
                }
            ]
        },
        {
            "id": "retry-benefits",
            "text": "Good guess, but GitHub connection is about portability and collaboration—not gameplay boosts.",
            "options": [
                {
                    "type": "goto",
                    "goto": "start",
                    "text": "Retry from start"
                }
            ]
        },
        {
            "id": "quiz-4",
            "text": "Need to revoke a token later? Where do you do it?",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "In GitHub token settings (Developer settings → Personal access tokens)"
                },
                {
                    "type": "goto",
                    "goto": "retry-revoke",
                    "text": "By deleting the local repo"
                },
                {
                    "type": "goto",
                    "goto": "retry-revoke",
                    "text": "By reinstalling DSPACE"
                }
            ]
        },
        {
            "id": "retry-revoke",
            "text": "Not quite. Revoke or regenerate PATs directly in GitHub token settings.",
            "options": [
                {
                    "type": "goto",
                    "goto": "start",
                    "text": "Retry from start"
                }
            ]
        },
        {
            "id": "finish",
            "text": "Excellent. Save a valid token in /cloudsync to complete this quest and claim your connection trophy.",
            "options": [
                {
                    "type": "finish",
                    "text": "GitHub connected",
                    "requiresGitHub": true
                }
            ]
        }
    ],
    "rewards": [
        {
            "id": "d5d62069-c77d-44b1-8848-b355f8410f74",
            "count": 1
        }
    ],
    "requiresQuests": ["welcome/intro-inventory"],
    "hardening": {
        "passes": 0,
        "score": 90,
        "emoji": "🛠️",
        "history": []
    }
}
