                    "text": "Classic PAT with repo + gist scopes."
                },
                {
                    "type": "goto",
                    "goto": "token",
                    "text": "Fine-grained token with no scopes."
                },
                {
                    "type": "goto",
                    "goto": "token",
                    "text": "OAuth device code with default scopes."
                }
            ]
        },
        {
            "id": "quiz-2",
            "text": "Where do you paste the token to connect in DSPACE?",
