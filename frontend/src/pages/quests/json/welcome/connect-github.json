{
    "id": "welcome/connect-github",
    "title": "Connect GitHub",
    "description": "Link your GitHub account to enable cloud sync and quest submissions.",
    "image": "/assets/quests/connect_github_integration.jpg",
    "npc": "/assets/npc/dChat.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Let's connect GitHub for cloud sync and quest submissions. You'll use a classic Personal Access Token (PAT).",
            "options": [
                {
                    "type": "goto",
                    "goto": "token",
                    "text": "Show me how"
                }
            ]
        },
        {
            "id": "token",
            "text": "Open the Cloud Sync page, generate a classic PAT on GitHub, and paste it. Tokens are stored locally and can be cleared any time.",
            "options": [
                {
                    "type": "goto",
                    "goto": "quiz-pat",
                    "text": "Token saved"
                }
            ]
        },
        {
            "id": "quiz-pat",
            "text": "Quick check: which GitHub token type does DSPACE want?",
            "options": [
                {
                    "type": "goto",
                    "goto": "quiz-storage",
                    "text": "Classic personal access token (PAT)"
                },
                {
                    "type": "goto",
                    "goto": "start",
                    "text": "Fine-grained PAT with org-wide admin scopes"
                },
                {
                    "type": "goto",
                    "goto": "start",
                    "text": "OAuth app client secret"
                }
            ]
        },
        {
            "id": "quiz-storage",
            "text": "Where does DSPACE store your token?",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Locally on this device"
                },
                {
                    "type": "goto",
                    "goto": "start",
                    "text": "In a shared server database"
                },
                {
                    "type": "goto",
                    "goto": "start",
                    "text": "In a public GitHub gist"
                }
            ]
        },
        {
            "id": "finish",
            "text": "Great! Your GitHub account is connected.",
            "options": [
                {
                    "type": "finish",
                    "text": "All set!",
                    "requiresGitHub": true
                }
            ]
        }
    ],
    "rewards": [
