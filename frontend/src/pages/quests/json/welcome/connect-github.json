                    "text": "Inside the /inventory item editor."
                },
                {
                    "type": "goto",
                    "goto": "token",
                    "text": "In the /quests/create form."
                }
            ]
        },
        {
            "id": "finish",
            "text": "Great! Your GitHub account is connected.",
            "options": [
