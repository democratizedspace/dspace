{
    "id": "welcome/connect-github",
    "title": "Connect GitHub",
    "description": "Connect GitHub for cloud sync, submissions, and portable progress.",
    "image": "/assets/quests/connect_github_integration.jpg",
    "npc": "/assets/npc/dChat.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "GitHub connection is your portability unlock: sync progress to the cloud, submit quests, and keep moving between machines.",
            "options": [
                {
                    "type": "goto",
                    "goto": "steps",
                    "text": "Show me PAT setup"
                },
                {
                    "type": "goto",
                    "goto": "quiz-1",
                    "text": "I know the basics—quiz me"
                }
            ]
        },
        {
            "id": "steps",
            "text": "Classic PAT setup: GitHub Settings → Developer settings → Personal access tokens → Tokens (classic) → Generate new token. Grant only the scopes DSPACE needs (typically repo + gist), copy once, then paste it into /cloudsync and press Save.",
            "options": [
                {
                    "type": "goto",
                    "goto": "quiz-1",
                    "text": "Done—start quiz"
                }
            ]
        },
        {
            "id": "quiz-1",
            "text": "What do PAT scopes mean?",
            "options": [
                {
                    "type": "goto",
                    "goto": "quiz-2",
                    "text": "They define token permissions"
                },
                {
                    "type": "goto",
                    "goto": "retry-scopes",
                    "text": "They choose repository names"
                },
                {
                    "type": "goto",
                    "goto": "retry-scopes",
                    "text": "They change my GitHub username"
                }
            ]
        },
        {
            "id": "retry-scopes",
            "text": "Close! Scopes are permissions. Keep them minimal so your token has only what DSPACE needs.",
            "options": [
                {
                    "type": "goto",
                    "goto": "start",
                    "text": "Retry from start"
                }
            ]
        },
        {
            "id": "quiz-2",
            "text": "How should you handle your PAT?",
            "options": [
                {
                    "type": "goto",
                    "goto": "quiz-3",
                    "text": "Keep it secret like a password"
                },
                {
                    "type": "goto",
                    "goto": "retry-secret",
                    "text": "Post it in a team chat for backup"
                },
                {
                    "type": "goto",
                    "goto": "retry-secret",
                    "text": "Put it in a public issue comment"
                }
            ]
        },
        {
            "id": "retry-secret",
            "text": "Nope—tokens are sensitive credentials. Store them only in trusted settings like /cloudsync and rotate if exposed.",
            "options": [
                {
                    "type": "goto",
                    "goto": "start",
                    "text": "Retry from start"
                }
            ]
        },
        {
            "id": "quiz-3",
            "text": "What does connecting GitHub enable in DSPACE?",
            "options": [
                {
                    "type": "goto",
                    "goto": "quiz-4",
                    "text": "Cloud sync and quest submissions"
                },
                {
                    "type": "goto",
                    "goto": "retry-purpose",
                    "text": "Free dUSD and instant quest skips"
                },
                {
                    "type": "goto",
                    "goto": "retry-purpose",
                    "text": "Private multiplayer rooms"
                }
            ]
        },
        {
            "id": "retry-purpose",
            "text": "Not this time. GitHub connection is for syncing and contribution workflows, not gameplay boosts.",
            "options": [
                {
                    "type": "goto",
                    "goto": "start",
                    "text": "Retry from start"
                }
            ]
        },
        {
            "id": "quiz-4",
            "text": "If a token is no longer needed, where do you revoke it?",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "In GitHub's Personal access tokens settings"
                },
                {
                    "type": "goto",
                    "goto": "retry-revoke",
                    "text": "By deleting the local repo clone"
                },
                {
                    "type": "goto",
                    "goto": "retry-revoke",
                    "text": "By reinstalling DSPACE"
                }
            ]
        },
        {
            "id": "retry-revoke",
            "text": "Revocation is managed in GitHub token settings. Delete or regenerate the token there whenever needed.",
            "options": [
                {
                    "type": "goto",
                    "goto": "start",
                    "text": "Retry from start"
                }
            ]
        },
        {
            "id": "finish",
            "text": "Great work. Save a valid token in /cloudsync, then finish to claim your integration trophy.",
            "options": [
                {
                    "type": "finish",
                    "text": "GitHub connected!",
                    "requiresGitHub": true
                }
            ]
        }
    ],
    "rewards": [
