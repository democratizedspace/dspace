{
    "id": "welcome/connect-github",
    "title": "Connect GitHub",
    "description": "Link your GitHub account to enable cloud sync and quest submissions.",
    "image": "/assets/quests/connect_github_integration.jpg",
    "npc": "/assets/npc/dChat.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Let's hook up your GitHub account so you can back up progress and share quests. We'll use a classic personal access token.",
            "options": [
                {
                    "type": "goto",
                    "goto": "steps",
                    "text": "Show me the steps"
                },
                {
                    "type": "goto",
                    "goto": "quiz-1",
                    "text": "Quiz me first"
                }
            ]
        },
        {
            "id": "steps",
            "text": "Go to GitHub Settings → Developer settings → Personal access tokens → Tokens (classic). Create a token with repo + gist scopes, then paste it into /cloudsync and click Save.",
            "options": [
                {
                    "type": "goto",
                    "goto": "quiz-1",
                    "text": "Got it—quiz me"
                }
            ]
        },
        {
            "id": "quiz-1",
            "text": "Where do you create the personal access token?",
            "options": [
                {
                    "type": "goto",
                    "goto": "quiz-2",
                    "text": "GitHub Settings → Developer settings → Personal access tokens"
                },
                {
                    "type": "goto",
                    "goto": "start",
                    "text": "Inside the DSPACE settings page"
                },
                {
                    "type": "goto",
                    "goto": "start",
                    "text": "From the GitHub repository README"
                }
            ]
        },
        {
            "id": "quiz-2",
            "text": "Which classic PAT scopes cover quest submissions and Cloud Sync?",
            "options": [
                {
                    "type": "goto",
                    "goto": "quiz-3",
                    "text": "repo + gist"
                },
                {
                    "type": "goto",
                    "goto": "start",
                    "text": "public_repo only"
                },
                {
                    "type": "goto",
                    "goto": "start",
                    "text": "admin:org"
                }
            ]
        },
        {
            "id": "quiz-3",
            "text": "Where do you paste the token in DSPACE to enable GitHub features?",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "/cloudsync (then click Save)"
                },
                {
                    "type": "goto",
                    "goto": "start",
                    "text": "/quests/submit"
                },
                {
                    "type": "goto",
                    "goto": "start",
                    "text": "/inventory"
                }
            ]
        },
        {
            "id": "finish",
            "text": "Great! Your GitHub account is connected. The finish button unlocks once a valid token is saved.",
            "options": [
                {
                    "type": "finish",
                    "text": "All set!",
                    "requiresGitHub": true
                }
            ]
        }
    ],
    "rewards": [
        {
            "id": "d5d62069-c77d-44b1-8848-b355f8410f74",
            "count": 1
        }
    ],
    "requiresQuests": ["welcome/intro-inventory"],
    "hardening": {
        "passes": 0,
        "score": 90,
        "emoji": "🛠️",
        "history": []
    }
}
