{
    "id": "welcome/connect-github",
    "title": "Connect GitHub",
    "description": "Link your GitHub account to enable cloud sync and quest submissions.",
    "image": "/assets/quests/connect_github_integration.jpg",
    "npc": "/assets/npc/dChat.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Connecting GitHub unlocks cloud sync, quest submissions, and portable progress across devices. We'll use a classic personal access token (PAT).",
            "options": [
                {
                    "type": "goto",
                    "goto": "steps",
                    "text": "Show me the steps"
                },
                {
                    "type": "goto",
                    "goto": "quiz-1",
                    "text": "Quiz me first"
                }
            ]
        },
        {
            "id": "steps",
            "text": "GitHub Settings → Developer settings → Personal access tokens → Tokens (classic). Generate a token, set an expiration, select repo + gist scopes, copy it, then paste it into /cloudsync and click Save.",
            "options": [
                {
                    "type": "goto",
                    "goto": "quiz-1",
                    "text": "Got it—quiz me"
                }
            ]
        },
        {
            "id": "quiz-1",
            "text": "What do PAT scopes represent?",
            "options": [
                {
                    "type": "goto",
                    "goto": "quiz-2",
                    "text": "They limit what the token can access."
                },
                {
                    "type": "goto",
                    "goto": "retry-scopes",
                    "text": "They speed up API requests."
                },
                {
                    "type": "goto",
                    "goto": "retry-scopes",
                    "text": "They are cosmetic labels."
                }
            ]
        },
        {
            "id": "retry-scopes",
            "text": "Scopes are permission boundaries. The smaller the scope, the safer the token.",
            "options": [
                {
                    "type": "goto",
                    "goto": "quiz-1",
                    "text": "Try that again"
                }
            ]
        },
        {
            "id": "quiz-2",
            "text": "How should you handle your token?",
            "options": [
                {
                    "type": "goto",
                    "goto": "quiz-3",
                    "text": "Keep it secret and only store it in DSPACE."
                },
                {
                    "type": "goto",
                    "goto": "retry-secret",
                    "text": "Share it in chat if you lose it."
                },
                {
                    "type": "goto",
                    "goto": "retry-secret",
                    "text": "Post it in a repo issue for safekeeping."
                }
            ]
        },
        {
            "id": "retry-secret",
            "text": "Tokens are like passwords. Keep them private and rotate them if they leak.",
            "options": [
                {
                    "type": "goto",
                    "goto": "quiz-2",
                    "text": "Got it—back to the quiz"
                }
            ]
        },
        {
            "id": "quiz-3",
            "text": "What does connecting GitHub enable in DSPACE?",
            "options": [
                {
                    "type": "goto",
                    "goto": "quiz-4",
                    "text": "Cloud sync and quest submissions."
                },
                {
                    "type": "goto",
                    "goto": "retry-enable",
                    "text": "Unlimited dUSD bonuses."
                },
                {
                    "type": "goto",
                    "goto": "retry-enable",
                    "text": "Unlocking private chat models."
                }
            ]
        },
        {
            "id": "retry-enable",
            "text": "GitHub connects saves and lets you submit quests. It does not grant free currency.",
            "options": [
                {
                    "type": "goto",
                    "goto": "quiz-3",
                    "text": "Understood—continue"
                }
            ]
        },
        {
            "id": "quiz-4",
            "text": "If a token is compromised, what is the safest fix?",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Revoke it in GitHub Settings and make a new one."
                },
                {
                    "type": "goto",
                    "goto": "retry-revoke",
                    "text": "Change your DSPACE username."
                },
                {
                    "type": "goto",
                    "goto": "retry-revoke",
                    "text": "Wait for it to expire and keep using it."
                }
            ]
        },
        {
            "id": "retry-revoke",
            "text": "Revoking the token in GitHub stops it immediately. Then generate a fresh one.",
            "options": [
                {
                    "type": "goto",
                    "goto": "quiz-4",
                    "text": "Retry that question"
                }
            ]
        },
        {
            "id": "finish",
            "text": "Great! Your GitHub account is connected. The finish button unlocks once a valid token is saved.",
            "options": [
                {
                    "type": "finish",
                    "text": "All set!",
                    "requiresGitHub": true
                }
            ]
        }
    ],
    "rewards": [
        {
            "id": "d5d62069-c77d-44b1-8848-b355f8410f74",
            "count": 1
        }
    ],
    "requiresQuests": ["welcome/intro-inventory"],
