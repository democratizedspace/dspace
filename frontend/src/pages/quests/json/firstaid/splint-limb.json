{
    "id": "firstaid/splint-limb",
    "title": "Splint a Minor Fracture",
    "description": "Practice immobilizing a minor limb injury with supplies from a first aid kit. Only attempt this on stable injuries and call emergency services for serious fractures.",
    "image": "/assets/quests/firstaid_splint_minor_limb_practice.jpg",
    "npc": "/assets/npc/dChat.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Before splinting, confirm scene safety and rule out life-threatening bleeding. Splints support transport; they do not replace medical care.",
            "options": [
                {
                    "type": "goto",
                    "goto": "assess",
                    "text": "Run injury triage"
                }
            ]
        },
        {
            "id": "assess",
            "text": "Check pulse, color, warmth, and sensation below the injury. If severe deformity, open fracture, or absent pulse is present, stop and call emergency services.",
            "options": [
                {
                    "type": "goto",
                    "goto": "prep",
                    "text": "Minor closed injury with circulation intact"
                },
                {
                    "type": "goto",
                    "goto": "safety-stop",
                    "text": "Red-flag symptoms detected"
                }
            ]
        },
        {
            "id": "prep",
            "text": "Pad the limb, place rigid supports on both sides, and stage wrap material before tightening anything.",
            "options": [
                {
                    "type": "goto",
                    "goto": "secure",
                    "text": "Supplies staged",
                    "requiresItems": [
                        {
                            "id": "09af703f-7054-4b33-a67d-4035d58bdfb7",
                            "count": 1
                        },
                        {
                            "id": "0dde854e-7fcb-40ac-88ea-9afd9196f856",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "troubleshoot",
                    "text": "Padding or wraps are missing"
                }
            ]
        },
        {
            "id": "secure",
            "text": "Tie above and below the injury, avoid direct pressure on the fracture site, and leave fingertips or toes visible for circulation checks.",
            "options": [
                {
                    "type": "goto",
                    "goto": "verify",
                    "text": "Splint secured",
                    "requiresItems": [
                        {
                            "id": "09af703f-7054-4b33-a67d-4035d58bdfb7",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "troubleshoot",
                    "text": "Wrap slipped or feels too tight"
                }
            ]
        },
        {
            "id": "troubleshoot",
            "text": "If numbness, cool skin, or increasing pain appears, loosen and re-pad immediately, then re-secure and re-check circulation.",
            "options": [
                {
                    "type": "goto",
                    "goto": "prep",
                    "text": "Reset and reapply splint"
                },
                {
                    "type": "goto",
                    "goto": "safety-stop",
                    "text": "Symptoms worsen after adjustment"
                }
            ]
        },
        {
            "id": "verify",
            "text": "Re-check pulse, warmth, and sensation below the splint after 5-10 minutes. Keep limb elevated and arrange medical evaluation.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Circulation remains stable",
                    "requiresItems": [
                        {
                            "id": "09af703f-7054-4b33-a67d-4035d58bdfb7",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "troubleshoot",
                    "text": "Need another fit adjustment"
                }
            ]
        },
        {
            "id": "safety-stop",
            "text": "Pause home care and hand off to emergency professionals for definitive stabilization.",
            "options": [
                {
                    "type": "goto",
                    "goto": "assess",
                    "text": "Return after professional reassessment"
                }
            ]
        },
        {
            "id": "finish",
            "text": "Nice work. Immobilization held and follow-up care is arranged.",
            "options": [
                {
                    "type": "finish",
                    "text": "Splinting practice complete"
                }
            ]
        }
    ],
    "rewards": [
        {
            "id": "b281360b-2ecc-4fea-a248-36a61c5f7399",
            "count": 1
        }
    ],
    "requiresQuests": ["firstaid/wound-care"],
