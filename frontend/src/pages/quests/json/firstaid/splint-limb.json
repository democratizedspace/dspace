{
    "id": "firstaid/splint-limb",
    "title": "Splint a Minor Fracture",
    "description": "Practice immobilizing a minor limb injury with supplies from a first aid kit. Only attempt this on stable injuries and call emergency services for serious fractures.",
    "image": "/assets/quests/firstaid_splint_minor_limb_practice.jpg",
    "npc": "/assets/npc/dChat.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Start with a safety triage: check for severe bleeding, deformity, or numbness before attempting any splinting.",
            "options": [
                {
                    "type": "goto",
                    "goto": "prep",
                    "text": "Minor, stable injury for practice"
                },
                {
                    "type": "goto",
                    "goto": "safety-stop",
                    "text": "Serious injury signs are present"
                }
            ]
        },
        {
            "id": "prep",
            "text": "Pad the limb and align supports above and below the injury. Keep fingers or toes visible for circulation checks.",
            "options": [
                {
                    "type": "goto",
                    "goto": "secure",
                    "text": "Padding and supports are staged",
                    "requiresItems": [
                        {
                            "id": "09af703f-7054-4b33-a67d-4035d58bdfb7",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "troubleshoot",
                    "text": "Supports slipped or alignment is uncertain"
                }
            ]
        },
        {
            "id": "secure",
            "text": "Tie bandages snugly without cutting circulation, then reassess pulse, warmth, and color beyond the splint.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Splint secured and circulation re-check passed",
                    "requiresItems": [
                        {
                            "id": "09af703f-7054-4b33-a67d-4035d58bdfb7",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "troubleshoot",
                    "text": "Circulation check failed or pain increased"
                }
            ]
        },
        {
            "id": "troubleshoot",
            "text": "Loosen and re-pad, then re-apply the splint with less tension. Re-check circulation before proceeding.",
            "options": [
                {
                    "type": "goto",
                    "goto": "prep",
                    "text": "Adjusted and ready to retry"
                }
            ]
        },
        {
            "id": "safety-stop",
            "text": "Stop here and escalate to emergency care. Severe injury signs require professional treatment, not practice.",
            "options": [
                {
                    "type": "finish",
                    "text": "Escalate to emergency services"
                }
            ]
        },
        {
            "id": "finish",
            "text": "Well done. You completed a safer splinting routine with a circulation verification check.",
            "options": [
                {
                    "type": "finish",
                    "text": "Practice complete"
                }
            ]
        }
    ],
    "rewards": [
        {
            "id": "b281360b-2ecc-4fea-a248-36a61c5f7399",
            "count": 1
        }
    ],
    "requiresQuests": ["firstaid/wound-care"],
