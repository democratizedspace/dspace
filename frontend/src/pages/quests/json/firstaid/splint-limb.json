{
    "id": "firstaid/splint-limb",
    "title": "Splint a Minor Fracture",
    "description": "Practice immobilizing a minor limb injury with supplies from a first aid kit. Only attempt this on stable injuries and call emergency services for serious fractures.",
    "image": "/assets/quests/firstaid_splint_minor_limb_practice.jpg",
    "npc": "/assets/npc/dChat.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Accidents happen fast. We'll triage first, then build a stable splint with a circulation check before transport.",
            "options": [
                {
                    "type": "goto",
                    "goto": "assess",
                    "text": "Begin fracture response"
                }
            ]
        },
        {
            "id": "assess",
            "text": "If bone is exposed, bleeding is uncontrolled, or sensation is absent, stop and escalate immediately.",
            "options": [
                {
                    "type": "goto",
                    "goto": "prep",
                    "text": "Stable minor injury"
                },
                {
                    "type": "goto",
                    "goto": "safety-stop",
                    "text": "Red-flag signs present"
                }
            ]
        },
        {
            "id": "prep",
            "text": "Pad the limb, gather rigid supports, and check distal pulse/color before securing any wrap.",
            "options": [
                {
                    "type": "goto",
                    "goto": "secure",
                    "text": "Prep complete with kit and bandages",
                    "requiresItems": [
                        {
                            "id": "09af703f-7054-4b33-a67d-4035d58bdfb7",
                            "count": 1
                        },
                        {
                            "id": "997eaba9-25ee-43d5-bbdc-5d6adf03adfa",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "secure",
            "text": "Tie above and below the injury snugly enough to immobilize, but not so tight that circulation drops.",
            "options": [
                {
                    "type": "goto",
                    "goto": "verify",
                    "text": "Splint secured and pulse rechecked",
                    "requiresItems": [
                        {
                            "id": "09af703f-7054-4b33-a67d-4035d58bdfb7",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "recover",
                    "text": "Wrap feels too tight or alignment shifted"
                }
            ]
        },
        {
            "id": "recover",
            "text": "Loosen ties, re-pad pressure points, and retest warmth/color before trying again. Worsening pain means stop and escalate.",
            "options": [
                {
                    "type": "goto",
                    "goto": "secure",
                    "text": "Rebuild splint with safer tension",
                    "requiresItems": [
                        {
                            "id": "09af703f-7054-4b33-a67d-4035d58bdfb7",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "safety-stop",
                    "text": "Symptoms are worsening"
                }
            ]
        },
        {
            "id": "verify",
            "text": "Confirm immobilization held during a brief movement check and that fingers/toes remain warm, pink, and responsive.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Splint stable and circulation normal",
                    "requiresItems": [
                        {
                            "id": "09af703f-7054-4b33-a67d-4035d58bdfb7",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "recover",
                    "text": "Need to adjust and recheck"
                }
            ]
        },
        {
            "id": "safety-stop",
            "text": "Correct call. Serious fracture indicators need professional treatment and monitored transport.",
            "options": [
                {
                    "type": "goto",
                    "goto": "assess",
                    "text": "Return after medical guidance"
                }
            ]
        },
        {
            "id": "finish",
            "text": "Nice work. Keep the limb immobilized and continue monitoring until clinical care takes over.",
            "options": [
                {
                    "type": "finish",
                    "text": "Will do."
                }
            ]
        }
    ],
    "rewards": [
        {
            "id": "b281360b-2ecc-4fea-a248-36a61c5f7399",
            "count": 1
        }
    ],
    "requiresQuests": ["firstaid/wound-care"],
