{
    "id": "firstaid/splint-limb",
    "title": "Splint a Minor Fracture",
    "description": "Practice immobilizing a minor limb injury with staged checks, circulation verification, and recovery loops before closure.",
    "image": "/assets/quests/firstaid_splint_minor_limb_practice.jpg",
    "npc": "/assets/npc/dChat.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Accidents happen. We'll triage first, then build a splint and verify circulation before transport.",
            "options": [
                {
                    "type": "goto",
                    "goto": "assess",
                    "text": "Begin fracture support drill"
                }
            ]
        },
        {
            "id": "assess",
            "text": "Check for severe bleeding, open fractures, loss of sensation, or deformity with absent pulse. Those are emergency signs.",
            "options": [
                {
                    "type": "goto",
                    "goto": "stage",
                    "text": "Injury appears minor and patient is stable",
                    "requiresItems": [
                        {
                            "id": "09af703f-7054-4b33-a67d-4035d58bdfb7",
                            "count": 1
                        },
                        {
                            "id": "997eaba9-25ee-43d5-bbdc-5d6adf03adfa",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "safety-stop",
                    "text": "Emergency red flags present"
                }
            ]
        },
        {
            "id": "stage",
            "text": "Stage padding and rigid supports on both sides of the limb. Avoid forcing realignment.",
            "options": [
                {
                    "type": "goto",
                    "goto": "secure",
                    "text": "Supplies staged and padding in place",
                    "requiresItems": [
                        {
                            "id": "09af703f-7054-4b33-a67d-4035d58bdfb7",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "secure",
            "text": "Tie bandages above and below the injury until the splint is snug but not constricting.",
            "options": [
                {
                    "type": "goto",
                    "goto": "verify",
                    "text": "Splint secured; ready to verify circulation",
                    "requiresItems": [
                        {
                            "id": "09af703f-7054-4b33-a67d-4035d58bdfb7",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "adjust",
                    "text": "Splint slipped or feels too tight"
                }
            ]
        },
        {
            "id": "adjust",
            "text": "Loosen and retie with added padding. Recheck color, warmth, and sensation in fingers/toes before transport.",
            "options": [
                {
                    "type": "goto",
                    "goto": "verify",
                    "text": "Adjusted and ready to recheck"
                }
            ]
        },
        {
            "id": "verify",
            "text": "Verify distal circulation and comfort. If numbness increases, pain spikes, or discoloration appears, adjust again and reassess.",
            "options": [
                {
                    "type": "finish",
                    "text": "Circulation stable and limb immobilized",
                    "requiresItems": [
                        {
                            "id": "09af703f-7054-4b33-a67d-4035d58bdfb7",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "adjust",
                    "text": "Circulation check failed; re-adjust splint"
                },
                {
                    "type": "goto",
                    "goto": "safety-stop",
                    "text": "Symptoms worsening despite adjustment"
                }
            ]
        },
        {
            "id": "safety-stop",
            "text": "Safety stop: keep the limb immobilized and seek urgent medical care for severe pain, deformity, bleeding, numbness, or skin color change.",
            "options": [
                {
                    "type": "goto",
                    "goto": "assess",
                    "text": "Stabilized scene; re-run triage for practice"
                }
            ]
        }
    ],
    "rewards": [
        {
            "id": "b281360b-2ecc-4fea-a248-36a61c5f7399",
            "count": 1
        }
    ],
    "requiresQuests": ["firstaid/wound-care"],
