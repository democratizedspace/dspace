{
    "id": "firstaid/splint-limb",
    "title": "Splint a Minor Fracture",
    "description": "Practice immobilizing a minor limb injury with supplies from a first aid kit. Only attempt this on stable injuries and call emergency services for serious fractures.",
    "image": "/assets/quests/firstaid_splint_minor_limb_practice.jpg",
    "npc": "/assets/npc/dChat.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Accidents happen. Make sure the area is safe and call for help before touching the injury. Let's practice applying a simple splint.",
            "options": [
                {
                    "type": "goto",
                    "goto": "assess",
                    "text": "Okay, walk me through it."
                }
            ]
        },
        {
            "id": "assess",
            "text": "First safety gate: do not move the limb if there is severe deformity, uncontrolled bleeding, numbness, or suspected spine injury. In those cases call emergency services and monitor breathing.",
            "options": [
                {
                    "type": "goto",
                    "goto": "wrap",
                    "text": "Injury is stable for first-aid splint practice"
                },
                {
                    "type": "goto",
                    "goto": "emergency",
                    "text": "Serious red flags are present"
                }
            ]
        },
        {
            "id": "wrap",
            "text": "Place soft padding around the injury, then position rigid supports on each side. Tie two to three bandages above and below the injury, snug enough to immobilize but not cut circulation.",
            "options": [
                {
                    "type": "goto",
                    "goto": "circulation-check",
                    "text": "Splint secured for circulation check",
                    "requiresItems": [
                        {
                            "id": "09af703f-7054-4b33-a67d-4035d58bdfb7",
                            "count": 1
                        },
                        {
                            "id": "cc7d36e7-c66d-466f-9390-f7a365d857b9",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "retry-wrap",
                    "text": "Supports shifted while tying"
                }
            ]
        },
        {
            "id": "circulation-check",
            "text": "Verification gate: compare color, warmth, capillary refill, and sensation in fingers/toes before vs after splinting.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Circulation and sensation are stable"
                },
                {
                    "type": "goto",
                    "goto": "loosen-recheck",
                    "text": "Digits are cold, pale, or numb"
                }
            ]
        },
        {
            "id": "retry-wrap",
            "text": "Troubleshooting: keep the limb still, re-pad pressure points, and reapply the supports with fresh ties before repeating the circulation check.",
            "options": [
                {
                    "type": "goto",
                    "goto": "wrap",
                    "text": "Reapply splint"
                }
            ]
        },
        {
            "id": "loosen-recheck",
            "text": "Recovery path: loosen one tie at a time, elevate if tolerated, and reassess circulation. If symptoms persist, stop and seek urgent medical care.",
            "options": [
                {
                    "type": "goto",
                    "goto": "circulation-check",
                    "text": "Re-check after adjustment"
                },
                {
                    "type": "goto",
                    "goto": "emergency",
                    "text": "Symptoms persist after adjustment"
                }
            ]
        },
        {
            "id": "emergency",
            "text": "Safety stop: hold the limb still, call emergency services, and do not force realignment. Keep the person warm and monitored until help arrives.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Emergency escalation complete"
                }
            ]
        },
        {
            "id": "finish",
            "text": "Nice work! Keep the limb immobilized, monitor fingers or toes for color and warmth, and seek medical attention.",
            "options": [
                {
                    "type": "finish",
                    "text": "Will do."
                }
            ]
        }
    ],
    "rewards": [
        {
            "id": "cc7d36e7-c66d-466f-9390-f7a365d857b9",
            "count": 1
        }
    ],
    "requiresQuests": [
        "firstaid/wound-care"
    ],
