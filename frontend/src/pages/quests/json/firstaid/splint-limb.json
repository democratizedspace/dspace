{
    "id": "firstaid/splint-limb",
    "title": "Splint a Minor Fracture",
    "description": "Practice immobilizing a minor limb injury with supplies from a first aid kit. Only attempt this on stable injuries and call emergency services for serious fractures.",
    "image": "/assets/quests/firstaid_splint_minor_limb_practice.jpg",
    "npc": "/assets/npc/dChat.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Accidents happen. First make sure the scene is safe and call for help before touching the injury. We'll practice splinting only for stable, minor injuries.",
            "options": [
                {
                    "type": "goto",
                    "goto": "assess",
                    "text": "Run initial safety assessment"
                }
            ]
        },
        {
            "id": "assess",
            "text": "If there's deformity with severe pain, open fracture, numbness, or uncontrolled bleeding, stop and seek emergency care immediately.",
            "options": [
                {
                    "type": "goto",
                    "goto": "prep",
                    "text": "Injury appears minor and stable"
                },
                {
                    "type": "goto",
                    "goto": "safety-stop",
                    "text": "Danger signs are present"
                }
            ]
        },
        {
            "id": "prep",
            "text": "Pad above and below the injury, prepare rigid supports, and keep the limb still. Check pulse/color/warmth before applying ties so you can compare after splinting.",
            "options": [
                {
                    "type": "goto",
                    "goto": "apply",
                    "text": "Supplies staged; begin splinting",
                    "requiresItems": [
                        {
                            "id": "09af703f-7054-4b33-a67d-4035d58bdfb7",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "troubleshoot",
                    "text": "Missing support or circulation already looks poor"
                }
            ]
        },
        {
            "id": "apply",
            "text": "Position supports on both sides of the limb and tie bandages snugly without compressing the injury site. Immobilize joints above and below when possible.",
            "options": [
                {
                    "type": "goto",
                    "goto": "verify",
                    "text": "Splint secured with padding in place",
                    "requiresItems": [
                        {
                            "id": "09af703f-7054-4b33-a67d-4035d58bdfb7",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "troubleshoot",
                    "text": "Wrap slipped or pain increased during application"
                }
            ]
        },
        {
            "id": "troubleshoot",
            "text": "Loosen and re-pad if ties are too tight. If fingers or toes turn pale, cold, or numb, remove pressure and escalate to urgent medical care before retrying.",
            "options": [
                {
                    "type": "goto",
                    "goto": "apply",
                    "text": "Retry splinting with better padding"
                },
                {
                    "type": "goto",
                    "goto": "safety-stop",
                    "text": "Circulation warning signs persist"
                }
            ]
        },
        {
            "id": "verify",
            "text": "Re-check pulse, skin color, warmth, and sensation beyond the splint. The limb should be immobilized but still perfused.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Circulation stable and limb immobilized",
                    "requiresItems": [
                        {
                            "id": "09af703f-7054-4b33-a67d-4035d58bdfb7",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "troubleshoot",
                    "text": "Re-check failed; adjust and reassess"
                }
            ]
        },
        {
            "id": "safety-stop",
            "text": "Good call. Keep the limb supported, avoid movement, and hand off to emergency or urgent care professionals.",
            "options": [
                {
                    "type": "goto",
                    "goto": "assess",
                    "text": "Return after professional assessment"
                }
            ]
        },
        {
            "id": "finish",
            "text": "Nice work. Continue monitoring circulation and seek follow-up medical care even when the splint looks stable.",
            "options": [
                {
                    "type": "finish",
                    "text": "Splinting drill complete"
                }
            ]
        }
    ],
    "rewards": [
        {
            "id": "b281360b-2ecc-4fea-a248-36a61c5f7399",
            "count": 1
        }
    ],
    "requiresQuests": [
        "firstaid/wound-care"
    ],
    "hardening": {
        "passes": 0,
        "score": 100,
        "emoji": "\ud83d\udee0\ufe0f",
        "history": []
    }
}
