{
    "id": "firstaid/restock-kit",
    "title": "Restock Your First Aid Kit",
    "description": "Replace used supplies so you're ready for emergencies.",
    "image": "/assets/quests/firstaid_restock_kit_supplies.jpg",
    "npc": "/assets/npc/dChat.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Let's run a disciplined restock: inventory audit, replacement branch, and final readiness check.",
            "options": [
                {
                    "type": "goto",
                    "goto": "audit",
                    "text": "Start kit audit."
                }
            ]
        },
        {
            "id": "audit",
            "text": "Audit the kit and list what is low, expired, or opened. Keep gloves on while sorting used materials.",
            "options": [
                {
                    "type": "goto",
                    "goto": "replace",
                    "text": "Audit complete; proceed to replacement."
                },
                {
                    "type": "goto",
                    "goto": "sanitize-reset",
                    "text": "I contaminated supplies during sorting."
                }
            ]
        },
        {
            "id": "sanitize-reset",
            "text": "Recovery path: sanitize hands and work surface, then redo the audit with sealed replacements only.",
            "options": [
                {
                    "type": "process",
                    "process": "wash-hands",
                    "text": "Sanitized and ready",
                    "goto": "audit"
                }
            ]
        },
        {
            "id": "replace",
            "text": "Replace core consumables: adhesive bandages, sterile gauze pads, antiseptic wipes.",
            "options": [
                {
                    "type": "goto",
                    "goto": "verify",
                    "text": "Core supplies replaced",
                    "requiresItems": [
                        {
                            "id": "1b1030bf-9767-4b16-9ff6-a8e7de28b689",
                            "count": 1
                        },
                        {
                            "id": "cc7d36e7-c66d-466f-9390-f7a365d857b9",
                            "count": 1
                        },
                        {
                            "id": "b0f10930-53aa-4d45-8bb7-9c7b17f14a5a",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "shortage",
                    "text": "I am missing one or more replacements."
                }
            ]
        },
        {
            "id": "shortage",
            "text": "Troubleshooting shortage: borrow from backup stock or postpone non-critical use, then re-run replacement once items are available.",
            "options": [
                {
                    "type": "goto",
                    "goto": "replace",
                    "text": "Replacement items acquired; retry."
                }
            ]
        },
        {
            "id": "verify",
            "text": "Operational check: confirm expiry dates, reseal kit, and stage it in an accessible spot.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Readiness verified."
                },
                {
                    "type": "goto",
                    "goto": "audit",
                    "text": "Found another issue; re-audit before closing."
                }
            ]
        },
        {
            "id": "finish",
            "text": "Restock complete. Your kit is revalidated and ready for the next incident.",
            "options": [
                {
                    "type": "finish",
                    "text": "Kit is mission-ready."
                }
            ]
        }
    ],
    "rewards": [
        {
            "id": "b281360b-2ecc-4fea-a248-36a61c5f7399",
            "count": 1
        }
    ],
    "requiresQuests": [
        "firstaid/assemble-kit"
    ],
