{
    "id": "firstaid/assemble-kit",
    "title": "Assemble a First Aid Kit",
    "description": "Assemble a basic first aid kit so you're ready for minor injuries.",
    "image": "/assets/quests/firstaid_assemble_basic_kit.jpg",
    "npc": "/assets/npc/dChat.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "dChat here! Minor cuts happen. A first aid kit and clean hands help you respond fast.",
            "options": [
                {
                    "type": "goto",
                    "goto": "gather",
                    "text": "What do I need?"
                }
            ]
        },
        {
            "id": "gather",
            "text": "Wash with soap and water 20s, then dry with a paper towel. Set out bandages, gauze pads, antiseptic wipes, and nitrile gloves.",
            "options": [
                {
                    "type": "process",
                    "process": "wash-hands",
                    "text": "Hands are clean",
                    "goto": "dry"
                },
                {
                    "type": "goto",
                    "goto": "dry",
                    "text": "I already washed my hands."
                }
            ]
        },
        {
            "id": "dry",
            "text": "Dry your hands before handling supplies. Moisture can contaminate sterile items.",
            "options": [
                {
                    "type": "process",
                    "process": "dry-hands",
                    "text": "Hands are dry",
                    "goto": "inspect"
                },
                {
                    "type": "goto",
                    "goto": "start",
                    "text": "Let me restart the checklist before handling supplies."
                },
                {
                    "type": "goto",
                    "goto": "inspect",
                    "text": "My hands are already dry."
                }
            ]
        },
        {
            "id": "inspect",
            "text": "Inspect wrappers and expiry labels before packing. If anything is torn, damp, or expired, set it aside and restock first.",
            "options": [
                {
                    "type": "goto",
                    "goto": "pack",
                    "text": "All supplies look sealed and in date."
                },
                {
                    "type": "goto",
                    "goto": "replace-supplies",
                    "text": "I found damaged or expired supplies."
                }
            ]
        },
        {
            "id": "replace-supplies",
            "text": "Good catch. Replace compromised items before storing anything. Never seal a kit with uncertain supplies.",
            "options": [
                {
                    "type": "goto",
                    "goto": "inspect",
                    "text": "Replacements are ready; re-check the kit.",
                    "requiresItems": [
                        {
                            "id": "2f4db9f6-c6d0-4004-a348-33b87f084fdb",
                            "count": 1
                        },
                        {
                            "id": "ff1c6f6a-cfa2-40ac-af15-2c07944c85af",
                            "count": 1
                        },
                        {
                            "id": "95085935-8e9d-4d08-89e0-b4dab153376f",
                            "count": 1
                        },
                        {
                            "id": "0ecf2145-b5e2-4953-916c-10fc4bf5ec8d",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "pack",
            "text": "Pack items in a dry box with a label and tight lid. Keep trauma supplies separate from daily-use meds.",
            "options": [
                {
                    "type": "process",
                    "process": "pack-first-aid-kit",
                    "text": "Packing now",
                    "goto": "stage-storage"
                },
                {
                    "type": "goto",
                    "goto": "stage-storage",
                    "requiresItems": [
                        {
                            "id": "09af703f-7054-4b33-a67d-4035d58bdfb7",
                            "count": 1
                        }
                    ],
                    "text": "Supplies are already packed."
                }
            ]
        },
        {
            "id": "stage-storage",
            "text": "Before finishing, place the kit in a dry, accessible location away from children and heat sources.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Kit is staged in a safe location.",
                    "requiresItems": [
                        {
                            "id": "09af703f-7054-4b33-a67d-4035d58bdfb7",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "inspect",
                    "text": "I found moisture risk where I planned to store it. Re-check and repack if needed."
                }
            ]
        },
        {
            "id": "finish",
            "text": "Great work! Restock after each use and call emergency services for serious injuries.",
            "options": [
                {
                    "type": "finish",
                    "text": "Will do!"
                }
            ]
        }
    ],
    "rewards": [
        {
            "id": "b281360b-2ecc-4fea-a248-36a61c5f7399",
            "count": 1
        }
    ],
