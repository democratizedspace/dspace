{
    "id": "firstaid/assemble-kit",
    "title": "Assemble a First Aid Kit",
    "description": "Assemble a basic first aid kit so you're ready for minor injuries.",
    "image": "/assets/quests/basic_circuit.svg",
    "npc": "/assets/npc/dChat.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "dChat here! Minor cuts happen. A first aid kit and clean hands help you respond fast.",
            "options": [
                {
                    "type": "goto",
                    "goto": "gather",
                    "text": "What do I need?"
                }
            ]
        },
        {
            "id": "gather",
            "text": "Wash with soap and water 20s, then dry with a paper towel. Set out bandages, gauze pads, antiseptic wipes, nitrile gloves.",
            "options": [
                {
                    "type": "process",
                    "process": "wash-hands",
                    "text": "Hands are clean",
                    "goto": "dry"
                }
            ]
        },
        {
            "id": "dry",
            "text": "Dry your hands before handling supplies.",
            "options": [
                {
                    "type": "process",
                    "process": "dry-hands",
                    "text": "Hands are dry",
                    "goto": "pack"
                }
            ]
        },
        {
            "id": "pack",
            "text": "Check for damage or expiry. Pack items in a dry box with a label and tight lid.",
            "options": [
                {
                    "type": "process",
                    "process": "pack-first-aid-kit",
                    "text": "Packing now",
                    "goto": "finish"
                },
                {
                    "type": "goto",
                    "goto": "finish",
                    "requiresItems": [
                        {
                            "id": "09af703f-7054-4b33-a67d-4035d58bdfb7",
                            "count": 1
                        }
                    ],
                    "text": "Supplies packed"
                }
            ]
        },
        {
            "id": "finish",
            "text": "Great! Keep kit dry out of reach; restock supplies and call emergency services for serious injuries.",
            "options": [
                {
                    "type": "finish",
                    "text": "Will do!"
                }
            ]
        }
    ],
    "rewards": [],
    "requiresQuests": [],
