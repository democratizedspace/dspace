{
    "id": "firstaid/assemble-kit",
    "title": "Assemble a First Aid Kit",
    "description": "Assemble a basic first aid kit so you're ready for minor injuries.",
    "image": "/assets/quests/firstaid_assemble_basic_kit.jpg",
    "npc": "/assets/npc/dChat.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "dChat here! Minor cuts happen. We'll build a clean, labeled kit and confirm it's actually ready before we call it done.",
            "options": [
                {
                    "type": "goto",
                    "goto": "inventory-check",
                    "text": "Let's build it"
                }
            ]
        },
        {
            "id": "inventory-check",
            "text": "Check your supplies first: bandages, gauze, antiseptic wipes, nitrile gloves, and a dry kit box with a lid.",
            "options": [
                {
                    "type": "goto",
                    "goto": "hygiene",
                    "text": "Supplies are complete and in date",
                    "requiresItems": [
                        { "id": "7f2d7f53-5fe2-4955-8830-71158388af0f", "count": 1 },
                        { "id": "cc7d36e7-c66d-466f-9390-f7a365d857b9", "count": 1 },
                        { "id": "b0f10930-53aa-4d45-8bb7-9c7b17f14a5a", "count": 1 },
                        { "id": "997eaba9-25ee-43d5-bbdc-5d6adf03adfa", "count": 1 },
                        { "id": "09af703f-7054-4b33-a67d-4035d58bdfb7", "count": 1 }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "missing-supplies",
                    "text": "I'm missing something or found expired supplies"
                }
            ]
        },
        {
            "id": "missing-supplies",
            "text": "Good catch. Replace expired items and restock before assembly. Don't seal a kit with questionable supplies.",
            "options": [
                {
                    "type": "goto",
                    "goto": "inventory-check",
                    "text": "Supplies replaced; re-run inventory check"
                }
            ]
        },
        {
            "id": "hygiene",
            "text": "Safety first: wash for 20 seconds, dry hands fully, and only then handle sterile items.",
            "options": [
                {
                    "type": "process",
                    "process": "wash-hands",
                    "text": "Hands washed",
                    "goto": "dry"
                },
                {
                    "type": "goto",
                    "goto": "contamination-restart",
                    "text": "I touched a dirty surface while setting up"
                }
            ]
        },
        {
            "id": "contamination-restart",
            "text": "Pause assembly and wash again. Contamination control is non-negotiable.",
            "options": [
                {
                    "type": "goto",
                    "goto": "hygiene",
                    "text": "Understood; washing again"
                }
            ]
        },
        {
            "id": "dry",
            "text": "Dry your hands completely before you touch sterile gauze and wipes.",
            "options": [
                {
                    "type": "process",
                    "process": "dry-hands",
                    "text": "Hands are dry",
                    "goto": "pack"
                }
            ]
        },
        {
            "id": "pack",
            "text": "Pack the kit with sterile supplies, close the lid tightly, and label today's date for inspection tracking.",
            "options": [
                {
                    "type": "process",
                    "process": "pack-first-aid-kit",
                    "text": "Pack and seal the kit",
                    "goto": "verify"
                },
                {
                    "type": "goto",
                    "goto": "verify",
                    "text": "Kit is already packed and sealed",
                    "requiresItems": [
                        { "id": "09af703f-7054-4b33-a67d-4035d58bdfb7", "count": 1 }
                    ]
                }
            ]
        },
        {
            "id": "verify",
            "text": "Final check: lid sealed, label readable, and kit stored dry/out of direct heat. If any check fails, reopen and repack.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Seal and storage checks pass",
                    "requiresItems": [
                        { "id": "09af703f-7054-4b33-a67d-4035d58bdfb7", "count": 1 }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "pack",
                    "text": "Seal failed; reopen and repack"
                }
            ]
        },
        {
            "id": "finish",
            "text": "Great work. Your first aid kit is stocked, sealed, and safely stored. Recheck monthly and replace expired supplies immediately.",
            "options": [
                {
                    "type": "finish",
                    "text": "Kit is mission-ready"
                }
            ]
        }
    ],
    "rewards": [
        {
            "id": "b281360b-2ecc-4fea-a248-36a61c5f7399",
            "count": 1
        }
    ],
    "requiresQuests": ["welcome/howtodoquests"],
