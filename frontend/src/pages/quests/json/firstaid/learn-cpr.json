    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Place the manikin on a firm surface. Put on nitrile gloves, set the pocket mask and open antiseptic wipes from your first aid kit. Check for hazards, call emergency services, then begin.",
            "options": [
                {
                    "type": "goto",
                    "goto": "steps",
                    "text": "I'm ready."
                }
            ]
        },
        {
            "id": "steps",
            "text": "With the manikin on its back, place the heel of one hand on the chest center and interlock your fingers. Keep arms straight and push 2 inches deep at 100–120 compressions per minute, letting the chest rise fully. After 30 compressions, tilt the head, seal the mask and give two breaths if trained. Stop if anything seems unsafe.",
            "options": [
                {
                    "type": "process",
                    "process": "practice-cpr",
                    "text": "Practicing now.",
