                        { "id": "b397aa70-3503-4e40-b84a-4d5609578d2b", "count": 1 }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "finish",
                    "requiresItems": [
                        { "id": "09af703f-7054-4b33-a67d-4035d58bdfb7", "count": 1 },
                        { "id": "997eaba9-25ee-43d5-bbdc-5d6adf03adfa", "count": 1 },
