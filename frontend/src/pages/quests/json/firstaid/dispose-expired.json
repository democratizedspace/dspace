{
    "id": "firstaid/dispose-expired",
    "title": "Dispose Expired First Aid Supplies",
    "description": "Clear out old items so your first aid kit stays reliable.",
    "image": "/assets/quests/firstaid_dispose_expired_supplies.jpg",
    "npc": "/assets/npc/dChat.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Expired supplies can fail when needed most. First, confirm this is routine cleanup and not an active emergency.",
            "options": [
                {
                    "type": "goto",
                    "goto": "prep",
                    "text": "Routine kit cleanup only"
                },
                {
                    "type": "goto",
                    "goto": "safety-stop",
                    "text": "Someone may need care right now"
                }
            ]
        },
        {
            "id": "prep",
            "text": "Wash your hands, put on nitrile gloves and safety goggles, and stage a disposal bag beside the kit.",
            "options": [
                {
                    "type": "process",
                    "process": "wash-hands",
                    "text": "Prep and PPE complete",
                    "goto": "audit",
                    "requiresItems": [
                        {
                            "id": "997eaba9-25ee-43d5-bbdc-5d6adf03adfa",
                            "count": 1
                        },
                        {
                            "id": "c9b51052-4594-42d7-a723-82b815ab8cc2",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "troubleshoot",
                    "text": "I am missing one of those supplies"
                }
            ]
        },
        {
            "id": "audit",
            "text": "Use expiration dates and damaged packaging to separate safe-to-keep from must-discard supplies.",
            "options": [
                {
                    "type": "goto",
                    "goto": "sort",
                    "text": "I identified expired or damaged items"
                },
                {
                    "type": "goto",
                    "goto": "troubleshoot",
                    "text": "I am not sure what qualifies as expired"
                }
            ]
        },
        {
            "id": "sort",
            "text": "Seal expired supplies in the disposal bag, then re-check that the kit keeps only in-date items.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Expired supplies sealed and kit re-checked",
                    "requiresItems": [
                        {
                            "id": "997eaba9-25ee-43d5-bbdc-5d6adf03adfa",
                            "count": 1
                        },
                        {
                            "id": "c9b51052-4594-42d7-a723-82b815ab8cc2",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "troubleshoot",
                    "text": "A bag tore or contamination occurred"
                }
            ]
        },
        {
            "id": "troubleshoot",
            "text": "Stop and recover: replace damaged PPE, sanitize the workspace, and restart the audit to avoid cross-contamination.",
            "options": [
                {
                    "type": "goto",
                    "goto": "prep",
                    "text": "Supplies replaced, restarting prep"
                }
            ]
        },
        {
            "id": "safety-stop",
            "text": "Do not spend time on disposal during an emergency. Prioritize patient care and emergency services first.",
            "options": [
                {
                    "type": "finish",
                    "text": "Understood, safety first"
                }
            ]
        },
        {
            "id": "finish",
            "text": "Great work. Your kit is now safer, with expired supplies removed and contamination risks controlled.",
            "options": [
                {
                    "type": "finish",
                    "text": "Kit hygiene verified"
                }
            ]
        }
    ],
    "rewards": [
