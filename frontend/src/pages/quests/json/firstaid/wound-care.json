{
    "id": "firstaid/wound-care",
    "title": "Practice Basic Wound Care",
    "description": "Practice cleaning a minor cut with soap, gloves, an antiseptic wipe, antibiotic ointment and a bandage.",
    "image": "/assets/quests/basic_wound_care_practice.jpg",
    "npc": "/assets/npc/dChat.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Minor scrapes happen. We'll triage first, then run a clean-and-dress flow with a contamination fallback.",
            "options": [
                {
                    "type": "goto",
                    "goto": "assess",
                    "text": "Start wound-care drill"
                }
            ]
        },
        {
            "id": "assess",
            "text": "If bleeding will not stop after pressure, edges are gaping, or numbness spreads, stop and seek clinical care.",
            "options": [
                {
                    "type": "goto",
                    "goto": "prep",
                    "text": "This is a minor wound"
                },
                {
                    "type": "goto",
                    "goto": "safety-stop",
                    "text": "Escalation signs present"
                }
            ]
        },
        {
            "id": "prep",
            "text": "Scrub hands, glove up, and stage clean supplies before touching the wound bed.",
            "options": [
                {
                    "type": "process",
                    "process": "wash-hands",
                    "text": "Run hygiene prep",
                    "goto": "clean"
                },
                {
                    "type": "goto",
                    "goto": "clean",
                    "text": "Prep complete with sterile supplies",
                    "requiresItems": [
                        {
                            "id": "55ace400-79ee-4b24-b7da-0b0435ab7d72",
                            "count": 1
                        },
                        {
                            "id": "997eaba9-25ee-43d5-bbdc-5d6adf03adfa",
                            "count": 1
                        },
                        {
                            "id": "b0f10930-53aa-4d45-8bb7-9c7b17f14a5a",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "clean",
            "text": "Rinse the cut, wipe surrounding skin, apply ointment, then cover with a fresh dressing. Bag contaminated waste.",
            "options": [
                {
                    "type": "process",
                    "process": "clean-minor-cut",
                    "text": "Run full clean-and-dress process",
                    "goto": "verify"
                },
                {
                    "type": "goto",
                    "goto": "verify",
                    "text": "Completed manual cleaning workflow",
                    "requiresItems": [
                        {
                            "id": "55ace400-79ee-4b24-b7da-0b0435ab7d72",
                            "count": 1
                        },
                        {
                            "id": "997eaba9-25ee-43d5-bbdc-5d6adf03adfa",
                            "count": 1
                        },
                        {
                            "id": "b0f10930-53aa-4d45-8bb7-9c7b17f14a5a",
                            "count": 1
                        },
                        {
                            "id": "0dde854e-7fcb-40ac-88ea-9afd9196f856",
                            "count": 1
                        },
                        {
                            "id": "1b1030bf-9767-4b16-9ff6-a8e7de28b689",
                            "count": 1
                        },
                        {
                            "id": "7a4b8892-365f-4a56-93ce-127aa989f50d",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "recover",
                    "text": "Supplies contaminated or dressing failed"
                }
            ]
        },
        {
            "id": "recover",
            "text": "Discard compromised supplies, rewash hands, and restart with fresh dressings. Escalate if redness or pain spikes.",
            "options": [
                {
                    "type": "process",
                    "process": "wash-hands",
                    "text": "Reset hygiene and retry care",
                    "goto": "clean"
                },
                {
                    "type": "goto",
                    "goto": "safety-stop",
                    "text": "Symptoms are worsening"
                }
            ]
        },
        {
            "id": "verify",
            "text": "Confirm dressing is clean, secured, and dry; then log warning signs to monitor over the next day.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Wound dressed and monitoring plan set",
                    "requiresItems": [
                        {
                            "id": "09af703f-7054-4b33-a67d-4035d58bdfb7",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "recover",
                    "text": "Need one more clean cycle"
                }
            ]
        },
        {
            "id": "safety-stop",
            "text": "Good safety call. Deep, uncontrolled, or infected wounds need professional treatment.",
            "options": [
                {
                    "type": "goto",
                    "goto": "assess",
                    "text": "Return after clinical guidance"
                }
            ]
        },
        {
            "id": "finish",
            "text": "Great job. Keep the site clean, change dressings daily, and escalate promptly if infection signs appear.",
            "options": [
                {
                    "type": "finish",
                    "text": "Will do."
                }
            ]
        }
    ],
    "rewards": [
        {
            "id": "b281360b-2ecc-4fea-a248-36a61c5f7399",
            "count": 1
        }
    ],
