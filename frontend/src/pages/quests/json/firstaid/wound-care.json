{
    "id": "firstaid/wound-care",
    "title": "Practice Basic Wound Care",
    "description": "Practice cleaning a minor cut with soap, gloves, an antiseptic wipe, antibiotic ointment and a bandage.",
    "image": "/assets/quests/basic_wound_care_practice.jpg",
    "npc": "/assets/npc/dChat.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Minor scrapes happen. We'll clean and dress a small cut with supplies from a first aid kit. If it's deep, gaping, or spurting blood, stop and seek medical care.",
            "options": [
                {
                    "type": "goto",
                    "goto": "assess",
                    "text": "Start wound assessment"
                }
            ]
        },
        {
            "id": "assess",
            "text": "Confirm this is minor wound care only: bleeding is controlled, no foreign object is embedded, and no loss of sensation is present.",
            "options": [
                {
                    "type": "goto",
                    "goto": "prep",
                    "text": "Minor wound confirmed"
                },
                {
                    "type": "goto",
                    "goto": "safety-stop",
                    "text": "Escalation signs detected"
                }
            ]
        },
        {
            "id": "prep",
            "text": "Wash hands and stage gloves, antiseptic, ointment, and a fresh bandage before opening sterile supplies.",
            "options": [
                {
                    "type": "process",
                    "process": "wash-hands",
                    "text": "Run hygiene prep",
                    "goto": "clean"
                },
                {
                    "type": "goto",
                    "goto": "clean",
                    "text": "Already washed and staged",
                    "requiresItems": [
                        {
                            "id": "55ace400-79ee-4b24-b7da-0b0435ab7d72",
                            "count": 1
                        },
                        {
                            "id": "997eaba9-25ee-43d5-bbdc-5d6adf03adfa",
                            "count": 1
                        },
                        {
                            "id": "b0f10930-53aa-4d45-8bb7-9c7b17f14a5a",
                            "count": 1
                        },
                        {
                            "id": "0dde854e-7fcb-40ac-88ea-9afd9196f856",
                            "count": 1
                        },
                        {
                            "id": "1b1030bf-9767-4b16-9ff6-a8e7de28b689",
                            "count": 1
                        },
                        {
                            "id": "7a4b8892-365f-4a56-93ce-127aa989f50d",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "clean",
            "text": "Rinse the cut, clean around it with antiseptic, apply a thin ointment layer, then place a clean bandage.",
            "options": [
                {
                    "type": "process",
                    "process": "clean-minor-cut",
                    "text": "Complete clean-and-dress cycle",
                    "goto": "verify",
                    "requiresItems": [
                        {
                            "id": "55ace400-79ee-4b24-b7da-0b0435ab7d72",
                            "count": 1
                        },
                        {
                            "id": "997eaba9-25ee-43d5-bbdc-5d6adf03adfa",
                            "count": 1
                        },
                        {
                            "id": "b0f10930-53aa-4d45-8bb7-9c7b17f14a5a",
                            "count": 1
                        },
                        {
                            "id": "0dde854e-7fcb-40ac-88ea-9afd9196f856",
                            "count": 1
                        },
                        {
                            "id": "1b1030bf-9767-4b16-9ff6-a8e7de28b689",
                            "count": 1
                        },
                        {
                            "id": "7a4b8892-365f-4a56-93ce-127aa989f50d",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "verify",
                    "text": "Wound cleaned and bandaged manually",
                    "requiresItems": [
                        {
                            "id": "09af703f-7054-4b33-a67d-4035d58bdfb7",
                            "count": 1
                        },
                        {
                            "id": "1b1030bf-9767-4b16-9ff6-a8e7de28b689",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "troubleshoot",
                    "text": "Bandage contaminated or wound re-opened"
                }
            ]
        },
        {
            "id": "troubleshoot",
            "text": "Discard contaminated materials, rewash hands, and restart care with fresh supplies. Escalate if pain, swelling, or redness is worsening.",
            "options": [
                {
                    "type": "goto",
                    "goto": "prep",
                    "text": "Reset and retry with new supplies"
                },
                {
                    "type": "goto",
                    "goto": "safety-stop",
                    "text": "Symptoms now require clinician evaluation"
                }
            ]
        },
        {
            "id": "verify",
            "text": "Check that bleeding is controlled, dressing is clean and secure, and follow-up monitoring is planned.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Wound is stable and dressed",
                    "requiresItems": [
                        {
                            "id": "09af703f-7054-4b33-a67d-4035d58bdfb7",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "troubleshoot",
                    "text": "Need another clean-and-dress attempt"
                }
            ]
        },
        {
            "id": "safety-stop",
            "text": "Good call. Pause self-care and seek medical help for definitive treatment.",
            "options": [
                {
                    "type": "goto",
                    "goto": "assess",
                    "text": "Resume once a clinician confirms home care is appropriate"
                }
            ]
        },
        {
            "id": "finish",
            "text": "Great job. Keep the wound clean and dry, and replace the bandage daily.",
            "options": [
                {
                    "type": "finish",
                    "text": "Wound care complete"
                }
            ]
        }
    ],
