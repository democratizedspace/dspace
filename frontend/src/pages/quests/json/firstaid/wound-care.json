{
    "id": "firstaid/wound-care",
    "title": "Practice Basic Wound Care",
    "description": "Practice cleaning a minor cut with soap, gloves, an antiseptic wipe, antibiotic ointment and a bandage.",
    "image": "/assets/quests/basic_wound_care_practice.jpg",
    "npc": "/assets/npc/dChat.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Minor scrapes happen. We'll clean and dress a shallow cut with first aid supplies. If the wound is deep, gaping, or heavily bleeding, this quest should pause for professional care.",
            "options": [
                {
                    "type": "goto",
                    "goto": "assess",
                    "text": "Run safety triage"
                }
            ]
        },
        {
            "id": "assess",
            "text": "Check for heavy bleeding, embedded debris, numbness, or loss of movement. Those are stop signs for home treatment.",
            "options": [
                {
                    "type": "goto",
                    "goto": "prep",
                    "text": "Looks minor; continue home care"
                },
                {
                    "type": "goto",
                    "goto": "safety-stop",
                    "text": "Warning signs detected"
                }
            ]
        },
        {
            "id": "prep",
            "text": "Wash hands for 20 seconds, put on nitrile gloves, and lay out antiseptic wipe, ointment, and fresh bandage on a clean surface.",
            "options": [
                {
                    "type": "process",
                    "process": "wash-hands",
                    "text": "Do full hygiene prep",
                    "goto": "clean"
                },
                {
                    "type": "goto",
                    "goto": "clean",
                    "text": "Already prepped with clean supplies",
                    "requiresItems": [
                        {
                            "id": "997eaba9-25ee-43d5-bbdc-5d6adf03adfa",
                            "count": 1
                        },
                        {
                            "id": "09af703f-7054-4b33-a67d-4035d58bdfb7",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "clean",
            "text": "Rinse the cut with clean water, wipe around it with a fresh antiseptic wipe, let it air dry, then apply a thin layer of antibiotic ointment before dressing.",
            "options": [
                {
                    "type": "process",
                    "process": "clean-minor-cut",
                    "text": "Run clean-and-dress process",
                    "goto": "verify",
                    "requiresItems": [
                        {
                            "id": "55ace400-79ee-4b24-b7da-0b0435ab7d72",
                            "count": 1
                        },
                        {
                            "id": "b0f10930-53aa-4d45-8bb7-9c7b17f14a5a",
                            "count": 1
                        },
                        {
                            "id": "0dde854e-7fcb-40ac-88ea-9afd9196f856",
                            "count": 1
                        },
                        {
                            "id": "1b1030bf-9767-4b16-9ff6-a8e7de28b689",
                            "count": 1
                        },
                        {
                            "id": "7a4b8892-365f-4a56-93ce-127aa989f50d",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "verify",
                    "text": "Completed manual clean-and-bandage cycle",
                    "requiresItems": [
                        {
                            "id": "09af703f-7054-4b33-a67d-4035d58bdfb7",
                            "count": 1
                        },
                        {
                            "id": "1b1030bf-9767-4b16-9ff6-a8e7de28b689",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "troubleshoot",
                    "text": "Bandage contaminated or wound keeps oozing"
                }
            ]
        },
        {
            "id": "troubleshoot",
            "text": "Discard contaminated supplies, re-clean with fresh materials, and recheck pain/swelling. If redness spreads, pus appears, or fever starts, stop and escalate care.",
            "options": [
                {
                    "type": "goto",
                    "goto": "clean",
                    "text": "Retry with new sterile supplies"
                },
                {
                    "type": "goto",
                    "goto": "safety-stop",
                    "text": "Signs of infection are present"
                }
            ]
        },
        {
            "id": "verify",
            "text": "Confirm the dressing is secure, skin is warm with normal color, and bleeding is controlled. Plan a daily bandage change and symptom check.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Stable dressing and aftercare plan ready",
                    "requiresItems": [
                        {
                            "id": "09af703f-7054-4b33-a67d-4035d58bdfb7",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "troubleshoot",
                    "text": "Need another cleaning or dressing attempt"
                }
            ]
        },
        {
            "id": "safety-stop",
            "text": "Good stop. Keep pressure on the wound if needed and contact a clinician or urgent care for next steps.",
            "options": [
                {
                    "type": "goto",
                    "goto": "assess",
                    "text": "Return after medical guidance"
                }
            ]
        },
        {
            "id": "finish",
            "text": "Great job. Keep the wound clean and dry, and watch for worsening symptoms over the next 24 hours.",
            "options": [
                {
                    "type": "finish",
                    "text": "Wound-care drill complete"
                }
            ]
        }
    ],
    "rewards": [
        {
            "id": "b281360b-2ecc-4fea-a248-36a61c5f7399",
            "count": 1
        }
    ],
    "requiresQuests": [
        "firstaid/learn-cpr"
    ],
