{
    "id": "firstaid/flashlight-battery",
    "title": "Check Flashlight Battery",
    "description": "Measure your emergency flashlight's 9 V battery with a digital multimeter.",
    "image": "/assets/quests/firstaid_flashlight_battery_check.jpg",
    "npc": "/assets/npc/dChat.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Power failures happen. Let's make sure your red flashlight still has juice.",
            "options": [
                {
                    "type": "goto",
                    "goto": "meter-setup",
                    "text": "Grab the multimeter."
                }
            ]
        },
        {
            "id": "meter-setup",
            "text": "Set the meter to 20 V DC. Confirm the red lead is in the V port and black lead in COM.",
            "options": [
                {
                    "type": "goto",
                    "goto": "measure",
                    "text": "Meter setup confirmed."
                },
                {
                    "type": "goto",
                    "goto": "lead-fix",
                    "text": "Lead ports look wrong."
                }
            ]
        },
        {
            "id": "lead-fix",
            "text": "Good catch. Move leads to the correct ports before touching the battery terminals.",
            "options": [
                {
                    "type": "goto",
                    "goto": "meter-setup",
                    "text": "Leads corrected; re-check setup."
                }
            ]
        },
        {
            "id": "measure",
            "text": "Measure across the 9 V battery terminals and note the reading.",
            "options": [
                {
                    "type": "process",
                    "process": "check-flashlight-battery",
                    "goto": "interpret",
                    "text": "Run measurement now.",
                    "requiresItems": [
                        {
                            "id": "9a72fb16-fc69-45c5-beca-f25c27028977",
                            "count": 1
                        },
                        {
                            "id": "5127e156-3009-4db4-85ac-e3ea070b68f2",
                            "count": 1
                        },
                        {
                            "id": "80d30825-a42b-4add-b715-322e1713952c",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "interpret",
                    "text": "I already measured and logged a reading.",
                    "requiresItems": [
                        {
                            "id": "9a72fb16-fc69-45c5-beca-f25c27028977",
                            "count": 1
                        },
                        {
                            "id": "5127e156-3009-4db4-85ac-e3ea070b68f2",
                            "count": 1
                        },
                        {
                            "id": "80d30825-a42b-4add-b715-322e1713952c",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "interpret",
            "text": "Interpretation: ≥8.5 V = ready, 7.5–8.4 V = backup-only, <7.5 V = replace now.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Reading is 8.5 V or higher; flashlight is ready.",
                    "requiresItems": [
                        {
                            "id": "9a72fb16-fc69-45c5-beca-f25c27028977",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "backup-tag",
                    "text": "Reading is 7.5–8.4 V; mark as backup only."
                },
                {
                    "type": "goto",
                    "goto": "replace-battery",
                    "text": "Reading is under 7.5 V; replace battery now."
                }
            ]
        },
        {
            "id": "backup-tag",
            "text": "Tag the flashlight as backup-only and schedule a battery swap before your next drill.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Tag added and replacement planned."
                }
            ]
        },
        {
            "id": "replace-battery",
            "text": "Install a fresh 9 V battery, then re-test. If voltage is still low, check terminal corrosion and clean contacts before another test.",
            "options": [
                {
                    "type": "goto",
                    "goto": "measure",
                    "text": "Battery replaced; run the measurement again.",
                    "requiresItems": [
                        {
                            "id": "80d30825-a42b-4add-b715-322e1713952c",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "meter-setup",
                    "text": "I suspect a meter setup problem; verify leads and range again."
                }
            ]
        },
        {
            "id": "finish",
            "text": "Nice work. Record the reading date so your emergency kit checks stay predictable.",
            "options": [
                {
                    "type": "finish",
                    "text": "Flashlight check logged."
                }
            ]
        }
    ],
