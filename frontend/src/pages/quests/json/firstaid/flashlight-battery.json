{
    "id": "firstaid/flashlight-battery",
    "title": "Check Flashlight Battery",
    "description": "Measure your emergency flashlight's 9 V battery with a digital multimeter.",
    "image": "/assets/quests/firstaid_flashlight_battery_check.jpg",
    "npc": "/assets/npc/dChat.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Power failures happen. Let's make sure your red flashlight still has juice.",
            "options": [
                {
                    "type": "goto",
                    "goto": "prep",
                    "text": "Grab the multimeter."
                }
            ]
        },
        {
            "id": "prep",
            "text": "Safety first: remove the battery, inspect for corrosion, and avoid shorting both terminals with one probe sweep.",
            "options": [
                {
                    "type": "goto",
                    "goto": "measure",
                    "text": "Battery and probes are positioned safely.",
                    "requiresItems": [
                        {
                            "id": "9a72fb16-fc69-45c5-beca-f25c27028977",
                            "count": 1
                        },
                        {
                            "id": "5127e156-3009-4db4-85ac-e3ea070b68f2",
                            "count": 1
                        },
                        {
                            "id": "80d30825-a42b-4add-b715-322e1713952c",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "troubleshoot",
                    "text": "Reading is unstable or terminals look dirty.",
                    "requiresItems": [
                        {
                            "id": "5127e156-3009-4db4-85ac-e3ea070b68f2",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "measure",
            "text": "Set the meter to 20 V DC and measure across the 9 V battery terminals. Record the voltage and classify it before packing the kit.",
            "options": [
                {
                    "type": "process",
                    "process": "check-flashlight-battery",
                    "text": "Take and log a battery reading"
                },
                {
                    "type": "goto",
                    "goto": "good",
                    "text": "Reading is 8.8-9.6 V (ready).",
                    "requiresItems": [
                        {
                            "id": "9a72fb16-fc69-45c5-beca-f25c27028977",
                            "count": 1
                        },
                        {
                            "id": "5127e156-3009-4db4-85ac-e3ea070b68f2",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "replace",
                    "text": "Reading is below 8.8 V or drops under load.",
                    "requiresItems": [
                        {
                            "id": "9a72fb16-fc69-45c5-beca-f25c27028977",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "troubleshoot",
            "text": "Clean terminals, reseat the battery, and retake the reading. If corrosion is heavy, isolate that battery and do not return it to the kit.",
            "options": [
                {
                    "type": "goto",
                    "goto": "measure",
                    "text": "Contacts cleaned; re-test now.",
                    "requiresItems": [
                        {
                            "id": "80d30825-a42b-4add-b715-322e1713952c",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "replace",
            "text": "Replace weak batteries before storage. Re-test after replacement so your emergency light is deployment-ready.",
            "options": [
                {
                    "type": "goto",
                    "goto": "troubleshoot",
                    "text": "Replacement installed; confirm with another reading.",
                    "requiresItems": [
                        {
                            "id": "80d30825-a42b-4add-b715-322e1713952c",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "good",
            "text": "Great. Label the battery check date and store the flashlight with terminals protected so it is ready during outages.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Battery status logged and flashlight stored safely.",
                    "requiresItems": [
                        {
                            "id": "9a72fb16-fc69-45c5-beca-f25c27028977",
                            "count": 1
                        },
                        {
                            "id": "5127e156-3009-4db4-85ac-e3ea070b68f2",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "finish",
            "text": "Nice work. You've got a verified flashlight power source and a safer emergency routine.",
            "options": [
                {
                    "type": "finish",
                    "text": "Will do."
                }
            ]
        }
    ],
    "rewards": [
