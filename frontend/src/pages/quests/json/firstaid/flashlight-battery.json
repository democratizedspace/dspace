{
    "id": "firstaid/flashlight-battery",
    "title": "Check Flashlight Battery",
    "description": "Measure your emergency flashlight's 9 V battery with a digital multimeter.",
    "image": "/assets/quests/firstaid_flashlight_battery_check.jpg",
    "npc": "/assets/npc/dChat.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Power failures don't schedule themselves. Let's verify your flashlight under real readiness checks.",
            "options": [
                {
                    "type": "goto",
                    "goto": "setup",
                    "text": "Run the battery check"
                }
            ]
        },
        {
            "id": "setup",
            "text": "Gather the red flashlight, digital multimeter, and 9 V battery. Set the meter to 20 V DC before probing.",
            "options": [
                {
                    "type": "goto",
                    "goto": "measure",
                    "text": "Gear staged and meter configured",
                    "requiresItems": [
                        {
                            "id": "9a72fb16-fc69-45c5-beca-f25c27028977",
                            "count": 1
                        },
                        {
                            "id": "5127e156-3009-4db4-85ac-e3ea070b68f2",
                            "count": 1
                        },
                        {
                            "id": "80d30825-a42b-4add-b715-322e1713952c",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "safety-stop",
                    "text": "I see corrosion or damaged leads"
                }
            ]
        },
        {
            "id": "safety-stop",
            "text": "Stop and isolate damaged hardware. Do not probe questionable terminals; replace damaged parts before retesting.",
            "options": [
                {
                    "type": "goto",
                    "goto": "setup",
                    "text": "Damaged parts replaced, retry setup"
                }
            ]
        },
        {
            "id": "measure",
            "text": "Take a reading with stable probe contact and log the result before deciding next action.",
            "options": [
                {
                    "type": "process",
                    "process": "check-flashlight-battery",
                    "text": "Run measurement and log reading",
                    "goto": "interpret",
                    "requiresItems": [
                        {
                            "id": "9a72fb16-fc69-45c5-beca-f25c27028977",
                            "count": 1
                        },
                        {
                            "id": "5127e156-3009-4db4-85ac-e3ea070b68f2",
                            "count": 1
                        },
                        {
                            "id": "80d30825-a42b-4add-b715-322e1713952c",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "interpret",
            "text": "Interpret your reading: 8.0 V+ is ready, 7.5-7.9 V is marginal, and below 7.5 V requires replacement.",
            "options": [
                {
                    "type": "goto",
                    "goto": "verify-beam",
                    "text": "Reading is 8.0 V or higher"
                },
                {
                    "type": "goto",
                    "goto": "recover",
                    "text": "Reading is 7.5-7.9 V or unstable"
                },
                {
                    "type": "goto",
                    "goto": "recover",
                    "text": "Reading is below 7.5 V"
                }
            ]
        },
        {
            "id": "recover",
            "text": "Troubleshoot before closure: reseat probes, clean contacts, and replace the battery if voltage stays low.",
            "options": [
                {
                    "type": "goto",
                    "goto": "measure",
                    "text": "Corrective action done, re-measure now"
                }
            ]
        },
        {
            "id": "verify-beam",
            "text": "Run a brief beam test and store a spare 9 V nearby so this check is operational, not theoretical.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Beam test passed and backup plan set"
                }
            ]
        },
        {
            "id": "finish",
            "text": "Great. You completed setup, evidence logging, interpretation, and recovery checks for flashlight readiness.",
            "options": [
                {
                    "type": "finish",
                    "text": "Emergency light is verified"
                }
            ]
        }
    ],
