{
    "id": "firstaid/change-bandage",
    "title": "Change a Bandage",
    "description": "Swap an old bandage for a fresh one to keep a minor cut clean.",
    "image": "/assets/quests/change_bandage_first_aid.jpg",
    "npc": "/assets/npc/dChat.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Bandages should be changed daily so wounds heal cleanly.",
            "options": [
                {
                    "type": "goto",
                    "goto": "safety-check",
                    "text": "Let's change it"
                }
            ]
        },
        {
            "id": "safety-check",
            "text": "Before touching the wound, verify there is no severe bleeding, spreading redness, or deep puncture. Escalate if any red flag is present.",
            "options": [
                {
                    "type": "goto",
                    "goto": "change",
                    "text": "No red flags. Continue with routine change.",
                    "requiresItems": [
                        {
                            "id": "09af703f-7054-4b33-a67d-4035d58bdfb7",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "escalate",
                    "text": "Red flags found; escalate care now."
                }
            ]
        },
        {
            "id": "change",
            "text": "Wash hands, remove the old bandage, clean the cut, and apply a fresh adhesive bandage.",
            "options": [
                {
                    "type": "process",
                    "process": "clean-minor-cut",
                    "text": "Bandage changed",
                    "goto": "verify",
                    "requiresItems": [
                        {
                            "id": "b0f10930-53aa-4d45-8bb7-9c7b17f14a5a",
                            "count": 1
                        },
                        {
                            "id": "1b1030bf-9767-4b16-9ff6-a8e7de28b689",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "contamination",
                    "text": "I touched a non-clean surface while changing it."
                }
            ]
        },
        {
            "id": "contamination",
            "text": "Pause and reset: discard compromised supplies, sanitize hands, then restart with fresh materials.",
            "options": [
                {
                    "type": "goto",
                    "goto": "change",
                    "text": "Supplies reset; retry clean bandage change.",
                    "requiresItems": [
                        {
                            "id": "b0f10930-53aa-4d45-8bb7-9c7b17f14a5a",
                            "count": 2
                        },
                        {
                            "id": "1b1030bf-9767-4b16-9ff6-a8e7de28b689",
                            "count": 2
                        }
                    ]
                }
            ]
        },
        {
            "id": "verify",
            "text": "Verify the new bandage is secure, dry, and the wound edges remain closed before you sign off.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "requiresItems": [
                        {
                            "id": "09af703f-7054-4b33-a67d-4035d58bdfb7",
                            "count": 1
                        }
                    ],
                    "text": "Fresh bandage is on and checks out."
                },
                {
                    "type": "goto",
                    "goto": "change",
                    "text": "Bandage fit failed; redo the change."
                }
            ]
        },
        {
            "id": "escalate",
            "text": "Good call. Stop home treatment and seek professional care. Return to this routine only after the wound is cleared for normal dressing changes.",
            "options": [
                {
                    "type": "goto",
                    "goto": "safety-check",
                    "text": "Symptoms resolved; run the safety check again."
                }
            ]
        },
        {
            "id": "finish",
            "text": "Great! Keep the area clean and swap the bandage again tomorrow if needed.",
            "options": [
                {
                    "type": "finish",
                    "text": "Got it!"
                }
            ]
        }
    ],
    "rewards": [
        {
            "id": "b281360b-2ecc-4fea-a248-36a61c5f7399",
            "count": 1
        }
    ],
    "requiresQuests": ["firstaid/wound-care"],
    "hardening": {
        "passes": 0,
        "score": 100,
        "emoji": "🛠️",
        "history": []
    }
}
