{
    "id": "firstaid/change-bandage",
    "title": "Change a Bandage",
    "description": "Swap an old bandage for a fresh one to keep a minor cut clean.",
    "image": "/assets/quests/change_bandage_first_aid.jpg",
    "npc": "/assets/npc/dChat.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Bandages should be changed daily so wounds heal cleanly. Let's prep safely before we remove anything.",
            "options": [
                {
                    "type": "goto",
                    "goto": "screen",
                    "text": "Start a clean bandage change"
                }
            ]
        },
        {
            "id": "screen",
            "text": "Quick safety screen: if bleeding is heavy, the wound is deep, or redness is spreading fast, stop home care and seek medical help.",
            "options": [
                {
                    "type": "goto",
                    "goto": "prep",
                    "text": "No red flags. Continue with bandage change."
                },
                {
                    "type": "goto",
                    "goto": "escalate",
                    "text": "Red flags present. Escalate care now."
                }
            ]
        },
        {
            "id": "prep",
            "text": "Wash hands, set out supplies, and remove the old bandage slowly so you can inspect drainage and skin irritation.",
            "options": [
                {
                    "type": "process",
                    "process": "wash-hands",
                    "text": "Wash hands before touching the wound",
                    "goto": "change"
                },
                {
                    "type": "goto",
                    "goto": "shortage",
                    "text": "I'm missing clean supplies"
                }
            ]
        },
        {
            "id": "shortage",
            "text": "Do not reuse old dressings. Restock adhesive bandages and antiseptic wipes before continuing.",
            "options": [
                {
                    "type": "goto",
                    "goto": "prep",
                    "text": "Supplies restocked; restart prep",
                    "requiresItems": [
                        {
                            "id": "b0f10930-53aa-4d45-8bb7-9c7b17f14a5a",
                            "count": 1
                        },
                        {
                            "id": "1b1030bf-9767-4b16-9ff6-a8e7de28b689",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "change",
            "text": "Clean around the cut, apply a fresh bandage, then check that drainage is controlled and the bandage is secure.",
            "options": [
                {
                    "type": "process",
                    "process": "clean-minor-cut",
                    "text": "Complete full clean-and-redress workflow",
                    "goto": "verify",
                    "requiresItems": [
                        {
                            "id": "b0f10930-53aa-4d45-8bb7-9c7b17f14a5a",
                            "count": 1
                        },
                        {
                            "id": "1b1030bf-9767-4b16-9ff6-a8e7de28b689",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "verify",
                    "text": "Bandage is already changed and secure",
                    "requiresItems": [
                        {
                            "id": "09af703f-7054-4b33-a67d-4035d58bdfb7",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "verify",
            "text": "Verification check: if bleeding leaked through quickly or pain increased, troubleshoot before you finish.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Bandage is dry, secure, and comfortable"
                },
                {
                    "type": "goto",
                    "goto": "troubleshoot",
                    "text": "Bandage soaked through or pain worsened"
                }
            ]
        },
        {
            "id": "troubleshoot",
            "text": "Apply direct pressure with clean gauze, reassess after 10 minutes, and escalate if bleeding does not slow.",
            "options": [
                {
                    "type": "goto",
                    "goto": "change",
                    "text": "Bleeding controlled; re-clean and re-bandage"
                },
                {
                    "type": "goto",
                    "goto": "escalate",
                    "text": "Bleeding not controlled; seek urgent care"
                }
            ]
        },
        {
            "id": "escalate",
            "text": "Good call. Keep pressure on the wound and get professional help. Home-care quest ends here for safety.",
            "options": [
                {
                    "type": "finish",
                    "text": "Escalated to medical care"
                }
            ]
        },
        {
            "id": "finish",
            "text": "Great work. Keep the area clean and swap the bandage again tomorrow or sooner if it gets wet.",
            "options": [
                {
                    "type": "finish",
                    "text": "Got it!"
                }
            ]
        }
    ],
    "rewards": [
        {
            "id": "b281360b-2ecc-4fea-a248-36a61c5f7399",
            "count": 1
        }
    ],
    "requiresQuests": ["firstaid/wound-care"],
    "hardening": {
        "passes": 0,
        "score": 100,
        "emoji": "🛠️",
        "history": []
    }
}
