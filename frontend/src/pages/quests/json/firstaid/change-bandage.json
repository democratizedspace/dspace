{
    "id": "firstaid/change-bandage",
    "title": "Change a Bandage",
    "description": "Swap an old bandage for a fresh one to keep a minor cut clean.",
    "image": "/assets/quests/change_bandage_first_aid.jpg",
    "npc": "/assets/npc/dChat.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Bandages should be changed daily so wounds heal cleanly.",
            "options": [
                {
                    "type": "goto",
                    "goto": "triage",
                    "text": "Let's change it"
                }
            ]
        },
        {
            "id": "triage",
            "text": "Safety check: if the wound is deeply reopened, bleeding through fast, or has red streaks and fever, skip home care and seek urgent medical help.",
            "options": [
                {
                    "type": "goto",
                    "goto": "prep",
                    "text": "Looks minor; continue with a clean bandage change."
                },
                {
                    "type": "goto",
                    "goto": "escalate",
                    "text": "Symptoms look severe; escalate to urgent care."
                }
            ]
        },
        {
            "id": "escalate",
            "text": "Good call. Keep pressure on the wound and get professional care instead of continuing this quest path.",
            "options": [
                {
                    "type": "finish",
                    "text": "Escalating care now."
                }
            ]
        },
        {
            "id": "prep",
            "text": "Wash your hands, stage clean supplies, and remove the old bandage without tearing healing skin.",
            "options": [
                {
                    "type": "process",
                    "process": "clean-minor-cut",
                    "text": "Supplies staged and wound cleaned with the process checklist.",
                    "goto": "verify",
                    "requiresItems": [
                        {
                            "id": "b0f10930-53aa-4d45-8bb7-9c7b17f14a5a",
                            "count": 1
                        },
                        {
                            "id": "1b1030bf-9767-4b16-9ff6-a8e7de28b689",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "missing-supplies",
                    "text": "I am missing wipes or fresh adhesive bandages."
                }
            ]
        },
        {
            "id": "missing-supplies",
            "text": "Troubleshooting branch: restock before changing the dressing. Never reuse dirty gauze or old adhesive strips.",
            "options": [
                {
                    "type": "goto",
                    "goto": "prep",
                    "text": "Supplies restored; retry the clean bandage change."
                }
            ]
        },
        {
            "id": "verify",
            "text": "Evidence gate: confirm the new bandage is dry, secure, and not too tight.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "requiresItems": [
                        {
                            "id": "09af703f-7054-4b33-a67d-4035d58bdfb7",
                            "count": 1
                        }
                    ],
                    "text": "Fresh bandage is on and the full first aid kit is available for follow-up checks."
                },
                {
                    "type": "goto",
                    "goto": "reclean",
                    "text": "Bandage is damp, slipping, or painful; redo cleaning and placement."
                }
            ]
        },
        {
            "id": "reclean",
            "text": "Recovery loop: remove the failed dressing, clean the area again, and apply a new sterile bandage before re-checking fit.",
            "options": [
                {
                    "type": "goto",
                    "goto": "prep",
                    "text": "Restart clean replacement sequence."
                }
            ]
        },
        {
            "id": "finish",
            "text": "Great! Keep the area clean and replace the bandage again tomorrow or sooner if it gets wet/dirty.",
            "options": [
                {
                    "type": "finish",
                    "text": "Got it!"
                }
            ]
        }
    ],
    "rewards": [
        {
            "id": "b281360b-2ecc-4fea-a248-36a61c5f7399",
            "count": 1
        }
    ],
    "requiresQuests": ["firstaid/wound-care"],
    "hardening": {
        "passes": 0,
        "score": 100,
        "emoji": "🛠️",
        "history": []
    }
}
