{
    "id": "firstaid/sanitize-pocket-mask",
    "title": "Sanitize Your CPR Pocket Mask",
    "description": "Clean and disinfect your CPR mask so it's safe for the next emergency.",
    "image": "/assets/quests/firstaid_sanitize_cpr_pocket_mask.jpg",
    "npc": "/assets/npc/dChat.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Your CPR pocket mask needs post-training decontamination. We'll run a full clean-disinfect-verify cycle.",
            "options": [
                {
                    "type": "goto",
                    "goto": "precheck",
                    "text": "Start sanitation checklist"
                }
            ]
        },
        {
            "id": "precheck",
            "text": "Confirm PPE and tools: nitrile gloves, antiseptic wipes, and the mask itself. If the valve is cracked, retire the mask.",
            "options": [
                {
                    "type": "goto",
                    "goto": "wash",
                    "text": "PPE ready and mask is intact",
                    "requiresItems": [
                        { "id": "997eaba9-25ee-43d5-bbdc-5d6adf03adfa", "count": 1 },
                        { "id": "b0f10930-53aa-4d45-8bb7-9c7b17f14a5a", "count": 1 },
                        { "id": "a1c7f153-5b2e-443d-936a-47f396a7d191", "count": 1 }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "replace-mask",
                    "text": "Mask is cracked or cloudy"
                }
            ]
        },
        {
            "id": "replace-mask",
            "text": "Do not sanitize damaged rescue gear. Replace the pocket mask first, then restart this quest.",
            "options": [
                {
                    "type": "goto",
                    "goto": "precheck",
                    "text": "Replacement mask ready"
                }
            ]
        },
        {
            "id": "wash",
            "text": "Wash your hands before handling the mask. Keep gloves on during the disinfect phase.",
            "options": [
                {
                    "type": "process",
                    "process": "wash-hands",
                    "text": "Hands washed",
                    "goto": "disinfect"
                }
            ]
        },
        {
            "id": "disinfect",
            "text": "Wash the mask with warm soapy water, rinse, then disinfect (1:10 bleach soak for 2 minutes). Air-dry fully.",
            "options": [
                {
                    "type": "goto",
                    "goto": "verify",
                    "text": "Sanitization complete",
                    "requiresItems": [
                        { "id": "a1c7f153-5b2e-443d-936a-47f396a7d191", "count": 1 },
                        { "id": "b0f10930-53aa-4d45-8bb7-9c7b17f14a5a", "count": 1 }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "rinse-retry",
                    "text": "Still smells like bleach or looks dirty"
                }
            ]
        },
        {
            "id": "rinse-retry",
            "text": "Rinse again and repeat the disinfection cycle. Never store a damp or residue-covered mask.",
            "options": [
                {
                    "type": "goto",
                    "goto": "disinfect",
                    "text": "Repeat sanitize cycle"
                }
            ]
        },
        {
            "id": "verify",
            "text": "Final safety check: mask is dry, clear, and resealed in a clean pouch inside your first aid kit.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Verified and stored",
                    "requiresItems": [
                        { "id": "a1c7f153-5b2e-443d-936a-47f396a7d191", "count": 1 },
                        { "id": "09af703f-7054-4b33-a67d-4035d58bdfb7", "count": 1 }
                    ]
                }
            ]
        },
        {
            "id": "finish",
            "text": "Mask sanitation complete. Clean gear and clear storage logs keep CPR response safer for everyone.",
            "options": [
                {
                    "type": "finish",
                    "text": "Pocket mask is ready"
                }
            ]
        }
    ],
    "rewards": [
        {
            "id": "b281360b-2ecc-4fea-a248-36a61c5f7399",
            "count": 1
        }
    ],
    "requiresQuests": ["firstaid/learn-cpr"],
    "hardening": {
        "passes": 0,
        "score": 75,
        "emoji": "🛠️",
        "history": []
    }
}
