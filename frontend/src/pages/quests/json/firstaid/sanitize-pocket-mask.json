{
    "id": "firstaid/sanitize-pocket-mask",
    "title": "Sanitize Your CPR Pocket Mask",
    "description": "Wash, disinfect, and log your CPR mask so it's ready for the next emergency.",
    "image": "/assets/quests/firstaid_sanitize_cpr_pocket_mask.jpg",
    "npc": "/assets/npc/dChat.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Your CPR pocket mask came out during training. Let's decon it before it goes back in the kit.",
            "options": [
                {
                    "type": "goto",
                    "goto": "wash",
                    "text": "Start cleaning it."
                }
            ]
        },
        {
            "id": "wash",
            "text": "Separate the valve, wash with warm soapy water, rinse, and log that the shell and valve are clean before disinfecting.",
            "options": [
                {
                    "type": "goto",
                    "goto": "disinfect",
                    "process": "wash-pocket-mask",
                    "text": "Wash and rinse the mask.",
                    "requiresItems": [
                        { "id": "a1c7f153-5b2e-443d-936a-47f396a7d191", "count": 1 },
                        { "id": "997eaba9-25ee-43d5-bbdc-5d6adf03adfa", "count": 1 },
                        { "id": "70bb8d86-2c4e-4330-9705-371891934686", "count": 1 }
                    ]
                }
            ]
        },
        {
            "id": "disinfect",
            "text": "Soak components in a 1:10 bleach solution for two minutes, air dry, and bag with the valve facing out.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "process": "sanitize-pocket-mask",
                    "text": "Disinfect and bag the mask.",
                    "requiresItems": [
                        { "id": "a1c7f153-5b2e-443d-936a-47f396a7d191", "count": 1 },
                        { "id": "280ed361-ac70-4ab9-bcd9-aee481790faf", "count": 1 },
