        },
        {
            "id": "finish",
            "text": "Nice work. Dispose of the sealed bag with your regular trash.",
            "options": [
                {
                    "type": "finish",
                    "text": "All clean!"
                }
            ]
        }
    ],
    "rewards": [],
    "requiresQuests": ["firstaid/change-bandage"]
