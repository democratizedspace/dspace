            "options": [
                {
                    "type": "process",
                    "process": "wash-hands",
                    "text": "Wash hands",
                    "goto": "bag"
                },
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Supplies bagged",
                    "requiresItems": [
                        {
                            "id": "7a4b8892-365f-4a56-93ce-127aa989f50d",
                            "count": 1
                        }
                    ]
                }
