{
    "id": "firstaid/dispose-bandages",
    "title": "Bag Used Bandages",
    "description": "Use a biohazard bag to discard used bandages and wash up.",
    "image": "/assets/rescue.jpg",
    "npc": "/assets/npc/dChat.jpg",
    "start": "start",
    "dialogue": [
