{
    "id": "firstaid/remove-splinter",
    "title": "Remove a Splinter",
    "description": "Take out a small splinter to prevent infection.",
    "image": "/assets/quests/remove_splinter_first_aid.jpg",
    "npc": "/assets/npc/dChat.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Splinters can fester if ignored. We'll do this with sterile prep and a fallback plan.",
            "options": [
                {
                    "type": "goto",
                    "goto": "assess",
                    "text": "Begin splinter assessment"
                }
            ]
        },
        {
            "id": "assess",
            "text": "If the splinter is deep, near the eye, or bleeding heavily, stop and seek professional care.",
            "options": [
                {
                    "type": "goto",
                    "goto": "prep",
                    "text": "Minor and accessible"
                },
                {
                    "type": "goto",
                    "goto": "safety-stop",
                    "text": "This needs a clinician"
                }
            ]
        },
        {
            "id": "prep",
            "text": "Wash hands, wear gloves, and stage tweezers plus antiseptic before touching skin.",
            "options": [
                {
                    "type": "process",
                    "process": "wash-hands",
                    "text": "Complete sterile prep",
                    "goto": "remove"
                },
                {
                    "type": "goto",
                    "goto": "remove",
                    "text": "Prep complete with available kit",
                    "requiresItems": [
                        {
                            "id": "997eaba9-25ee-43d5-bbdc-5d6adf03adfa",
                            "count": 1
                        },
                        {
                            "id": "b0f10930-53aa-4d45-8bb7-9c7b17f14a5a",
                            "count": 1
                        },
                        {
                            "id": "fc9301ec-674f-4b0d-b85e-c47140d5ae00",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "remove",
            "text": "Grasp the exposed end with tweezers and pull with steady pressure in the entry direction.",
            "options": [
                {
                    "type": "goto",
                    "goto": "verify",
                    "text": "Splinter removed and site cleaned",
                    "requiresItems": [
                        {
                            "id": "997eaba9-25ee-43d5-bbdc-5d6adf03adfa",
                            "count": 1
                        },
                        {
                            "id": "b0f10930-53aa-4d45-8bb7-9c7b17f14a5a",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "recover",
                    "text": "Tip broke or fragment remains"
                }
            ]
        },
        {
            "id": "recover",
            "text": "Do not dig blindly. Re-clean, improve lighting, and retry once; persistent fragments need clinical removal.",
            "options": [
                {
                    "type": "process",
                    "process": "wash-hands",
                    "text": "Reset and retry with clean tools",
                    "goto": "remove"
                },
                {
                    "type": "goto",
                    "goto": "safety-stop",
                    "text": "Escalate to professional care"
                }
            ]
        },
        {
            "id": "verify",
            "text": "Confirm no visible fragment remains and redness is stable after antiseptic wipe and light bandage.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Site looks clean and controlled",
                    "requiresItems": [
                        {
                            "id": "09af703f-7054-4b33-a67d-4035d58bdfb7",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "recover",
                    "text": "Need one more attempt"
                }
            ]
        },
        {
            "id": "safety-stop",
            "text": "Good judgment. Escalate when depth, bleeding, or pain exceeds home-care limits.",
            "options": [
                {
                    "type": "goto",
                    "goto": "assess",
                    "text": "Return after medical guidance"
                }
            ]
        },
        {
            "id": "finish",
            "text": "Great! Keep the area clean and watch for worsening redness, swelling, or heat.",
            "options": [
                {
                    "type": "finish",
                    "text": "Splinter protocol complete"
                }
            ]
        }
    ],
    "rewards": [
        {
            "id": "1b1030bf-9767-4b16-9ff6-a8e7de28b689",
            "count": 1
        }
    ],
    "requiresQuests": [
        "firstaid/wound-care"
    ],
    "hardening": {
        "passes": 0,
        "score": 100,
        "emoji": "\ud83d\udee0\ufe0f",
        "history": []
    }
}
