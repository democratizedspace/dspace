{
    "id": "firstaid/treat-burn",
    "title": "Treat a Minor Burn",
    "description": "Cool the burn for a full 20 minutes, document it, and dress it so it heals cleanly.",
    "image": "/assets/quests/firstaid_treat_minor_burn.jpg",
    "npc": "/assets/npc/dChat.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Quick check: it's under 3 inches, not on the face or joints, and skin isn't broken. We'll cool it completely, then cover lightly.",
            "options": [
                {
                    "type": "goto",
                    "goto": "cool",
                    "text": "Start cooling now."
                }
            ]
        },
        {
            "id": "cool",
            "text": "Remove rings or watches, run cool water for 20 minutes, and jot the times so you don't rush the flush.",
            "options": [
                {
                    "type": "goto",
                    "goto": "dress",
                    "process": "cool-minor-burn",
                    "text": "Cool and log the burn.",
                    "requiresItems": [
                        {
                            "id": "09af703f-7054-4b33-a67d-4035d58bdfb7",
                            "count": 1
                        },
                        {
                            "id": "997eaba9-25ee-43d5-bbdc-5d6adf03adfa",
                            "count": 1
                        },
                        {
                            "id": "70bb8d86-2c4e-4330-9705-371891934686",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "dress",
            "text": "Blot dry, swipe antiseptic around intact skin, and cover with a loose sterile gauze so you can keep watching for infection.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "process": "dress-minor-burn",
                    "text": "Dress and bag the waste.",
                    "requiresItems": [
                        {
                            "id": "99e2caf9-c3b0-4bc1-b7da-a920f03e0fb4",
                            "count": 1
                        },
                        {
                            "id": "09af703f-7054-4b33-a67d-4035d58bdfb7",
                            "count": 1
                        },
                        {
                            "id": "b0f10930-53aa-4d45-8bb7-9c7b17f14a5a",
                            "count": 1
                        },
                        {
                            "id": "cc7d36e7-c66d-466f-9390-f7a365d857b9",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "finish",
            "text": "Burn is cooled, covered, and logged. Keep the dressing dry, redo it daily, and watch for spreading redness or pain.",
            "options": [
                {
                    "type": "finish",
                    "text": "Monitor and rest.",
                    "requiresItems": [
                        {
                            "id": "55d9b626-402e-4a12-8eb2-35037fdd20af",
                            "count": 1
                        }
                    ]
                }
            ]
        }
