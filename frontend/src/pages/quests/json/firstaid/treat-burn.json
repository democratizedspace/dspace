            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Cooled off and ready to cover",
                    "requiresItems": [
                        {
                            "id": "09af703f-7054-4b33-a67d-4035d58bdfb7",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "finish",
            "text": "Great! Apply a sterile dressing from your kit and watch for signs of infection.",
            "options": [
                {
                    "type": "finish",
                    "text": "I'll keep an eye on it."
                }
            ]
        }
    ],
