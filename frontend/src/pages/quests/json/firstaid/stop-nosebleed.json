{
    "id": "firstaid/stop-nosebleed",
    "title": "Stop a Nosebleed",
    "description": "Sit upright, lean forward, and pinch the soft part of your nose with a sterile gauze pad. Wear nitrile gloves from a first aid kit, use an antiseptic wipe around your nostrils after bleeding slows, and keep your head tilted forward the whole time. Never tilt your head back or insert anything into the nostrils.",
    "image": "/assets/quests/stop_nosebleed_first_aid.jpg",
    "npc": "/assets/npc/dChat.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "You're bleeding from the nose. Stay calm, sit upright, and grab your first aid kit.",
            "options": [
                {
                    "type": "goto",
                    "goto": "assess",
                    "text": "Run a quick safety triage"
                }
            ]
        },
        {
            "id": "assess",
            "text": "If bleeding follows major trauma, won't slow, or you feel faint, escalate to urgent care immediately.",
            "options": [
                {
                    "type": "goto",
                    "goto": "pressure",
                    "text": "No red flags, start first-aid care"
                },
                {
                    "type": "goto",
                    "goto": "safety-stop",
                    "text": "Red-flag symptoms present"
                }
            ]
        },
        {
            "id": "pressure",
            "text": "Lean forward about 30°. Put on nitrile gloves, fold a sterile gauze pad over the soft part of your nose, and pinch firmly for a full 10 minutes without releasing early.",
            "options": [
                {
                    "type": "process",
                    "process": "stop-nosebleed",
                    "text": "Run the guided pressure timer",
                    "goto": "check",
                    "requiresItems": [
                        {
                            "id": "09af703f-7054-4b33-a67d-4035d58bdfb7",
                            "count": 1
                        },
                        {
                            "id": "cc7d36e7-c66d-466f-9390-f7a365d857b9",
                            "count": 1
                        },
                        {
                            "id": "997eaba9-25ee-43d5-bbdc-5d6adf03adfa",
                            "count": 1
                        },
                        {
                            "id": "b0f10930-53aa-4d45-8bb7-9c7b17f14a5a",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "check",
                    "text": "Holding pressure now",
                    "requiresItems": [
                        {
                            "id": "09af703f-7054-4b33-a67d-4035d58bdfb7",
                            "count": 1
                        },
                        {
                            "id": "cc7d36e7-c66d-466f-9390-f7a365d857b9",
                            "count": 1
                        },
                        {
                            "id": "997eaba9-25ee-43d5-bbdc-5d6adf03adfa",
                            "count": 1
                        },
                        {
                            "id": "b0f10930-53aa-4d45-8bb7-9c7b17f14a5a",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "check",
            "text": "Release pressure once and inspect. If bleeding slows, wipe around nostrils only; never pack the nostril or tilt your head back.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Bleeding controlled after first cycle"
                },
                {
                    "type": "goto",
                    "goto": "retry",
                    "text": "Still bleeding"
                }
            ]
        },
        {
            "id": "retry",
            "text": "Apply another 10-minute pressure cycle with fresh gauze. If bleeding persists after 20 minutes total, escalate.",
            "options": [
                {
                    "type": "goto",
                    "goto": "pressure",
                    "text": "Repeat pressure cycle with new gauze",
                    "requiresItems": [
                        {
                            "id": "cc7d36e7-c66d-466f-9390-f7a365d857b9",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "safety-stop",
                    "text": "Escalate to urgent care now"
                }
            ]
        },
        {
            "id": "safety-stop",
            "text": "Good escalation. Seek urgent medical help now and keep leaning forward during transport.",
            "options": [
                {
                    "type": "goto",
                    "goto": "assess",
                    "text": "Resume guidance after clinician clearance"
                }
            ]
        },
        {
            "id": "finish",
            "text": "Great work. Rest with head elevated, discard used supplies, and avoid nose blowing for the rest of the day.",
            "options": [
                {
                    "type": "finish",
                    "text": "Bleed controlled safely"
                }
            ]
        }
    ],
