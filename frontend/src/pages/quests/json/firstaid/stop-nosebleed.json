{
    "id": "firstaid/stop-nosebleed",
    "title": "Stop a Nosebleed",
    "description": "Sit upright, lean forward, and pinch the soft part of your nose with sterile supplies while monitoring for escalation triggers.",
    "image": "/assets/quests/stop_nosebleed_first_aid.jpg",
    "npc": "/assets/npc/dChat.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "You're bleeding from the nose. Stay calm, sit upright, and grab your first aid kit.",
            "options": [
                {
                    "type": "goto",
                    "goto": "safety-check",
                    "text": "How do I stop it?"
                }
            ]
        },
        {
            "id": "safety-check",
            "text": "Safety gate: if there was major trauma, bleeding is very heavy, or the person feels faint, escalate immediately instead of home treatment.",
            "options": [
                {
                    "type": "goto",
                    "goto": "pressure",
                    "text": "No red flags; begin controlled pressure protocol."
                },
                {
                    "type": "goto",
                    "goto": "escalate",
                    "text": "Red flags present; seek urgent medical help now."
                }
            ]
        },
        {
            "id": "escalate",
            "text": "Correct escalation. Keep leaning forward, maintain pressure, and contact emergency services or urgent care.",
            "options": [
                {
                    "type": "finish",
                    "text": "Escalation complete; transferring to professional care."
                }
            ]
        },
        {
            "id": "pressure",
            "text": "Lean forward about 30°, put on nitrile gloves, fold sterile gauze over the soft part of the nose, and pinch continuously for 10 minutes without checking early.",
            "options": [
                {
                    "type": "process",
                    "process": "stop-nosebleed",
                    "goto": "recheck",
                    "text": "Pressure cycle completed with clean supplies.",
                    "requiresItems": [
                        {
                            "id": "09af703f-7054-4b33-a67d-4035d58bdfb7",
                            "count": 1
                        },
                        {
                            "id": "cc7d36e7-c66d-466f-9390-f7a365d857b9",
                            "count": 1
                        },
                        {
                            "id": "997eaba9-25ee-43d5-bbdc-5d6adf03adfa",
                            "count": 1
                        },
                        {
                            "id": "b0f10930-53aa-4d45-8bb7-9c7b17f14a5a",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "supply-reset",
                    "text": "I lost sterile supplies or broke pressure protocol."
                }
            ]
        },
        {
            "id": "supply-reset",
            "text": "Troubleshooting: replace contaminated gauze/gloves and restart the full 10-minute timer. Never tilt the head back or pack the nostrils.",
            "options": [
                {
                    "type": "goto",
                    "goto": "pressure",
                    "text": "Supplies reset; restart pressure cycle."
                }
            ]
        },
        {
            "id": "recheck",
            "text": "Verification checkpoint: bleeding should be slowing after a full cycle. Clean around the nostrils only after pressure is released.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Bleeding controlled; move to aftercare."
                },
                {
                    "type": "goto",
                    "goto": "repeat-cycle",
                    "text": "Still bleeding lightly; repeat one more controlled cycle."
                },
                {
                    "type": "goto",
                    "goto": "escalate",
                    "text": "Still heavy after repeat or symptoms worsening; escalate now."
                }
            ]
        },
        {
            "id": "repeat-cycle",
            "text": "Recovery branch: run a second pressure cycle with fresh gauze, then reassess.",
            "options": [
                {
                    "type": "goto",
                    "goto": "pressure",
                    "text": "Begin second cycle."
                }
            ]
        },
        {
            "id": "finish",
            "text": "Aftercare complete: rest with head elevated, discard used supplies safely, and avoid blowing or picking your nose for the rest of the day.",
            "options": [
                {
                    "type": "finish",
                    "text": "Will do."
                }
            ]
        }
    ],
