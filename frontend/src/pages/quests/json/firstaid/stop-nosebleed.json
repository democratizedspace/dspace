{
    "id": "firstaid/stop-nosebleed",
    "title": "Stop a Nosebleed",
    "description": "Sit upright, lean forward, and pinch the soft part of your nose with a sterile gauze pad. Wear nitrile gloves from a first aid kit, use an antiseptic wipe around your nostrils after bleeding slows, and keep your head tilted forward the whole time. Never tilt your head back or insert anything into the nostrils.",
    "image": "/assets/quests/stop_nosebleed_first_aid.jpg",
    "npc": "/assets/npc/dChat.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "You're managing a nosebleed. Stay calm, sit upright, and keep the person leaning forward so blood drains out of the nose, not down the throat.",
            "options": [
                {
                    "type": "goto",
                    "goto": "assess",
                    "text": "Run a quick severity check"
                }
            ]
        },
        {
            "id": "assess",
            "text": "If there was major trauma, blood is pouring rapidly, the person is on blood thinners, or they feel faint, stop home care and seek urgent medical help now.",
            "options": [
                {
                    "type": "goto",
                    "goto": "prep",
                    "text": "No red flags; continue first aid"
                },
                {
                    "type": "goto",
                    "goto": "safety-stop",
                    "text": "Red flags present"
                }
            ]
        },
        {
            "id": "prep",
            "text": "Put on nitrile gloves, prepare sterile gauze, and set a timer. Pinch the soft part of the nose continuously for 10 minutes without checking early.",
            "options": [
                {
                    "type": "goto",
                    "goto": "pressure",
                    "text": "Begin timed pressure hold",
                    "requiresItems": [
                        {
                            "id": "09af703f-7054-4b33-a67d-4035d58bdfb7",
                            "count": 1
                        },
                        {
                            "id": "cc7d36e7-c66d-466f-9390-f7a365d857b9",
                            "count": 1
                        },
                        {
                            "id": "997eaba9-25ee-43d5-bbdc-5d6adf03adfa",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "troubleshoot",
                    "text": "Pressure slipped or posture changed"
                }
            ]
        },
        {
            "id": "pressure",
            "text": "Maintain forward lean and steady pinch. When bleeding slows, wipe around the nostrils with an antiseptic wipe\u2014never insert anything into the nose and never tilt the head back.",
            "options": [
                {
                    "type": "process",
                    "process": "stop-nosebleed",
                    "text": "Log the controlled-pressure step",
                    "goto": "verify",
                    "requiresItems": [
                        {
                            "id": "b0f10930-53aa-4d45-8bb7-9c7b17f14a5a",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "verify",
                    "text": "Pressure hold complete; move to verification",
                    "requiresItems": [
                        {
                            "id": "b0f10930-53aa-4d45-8bb7-9c7b17f14a5a",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "troubleshoot",
                    "text": "Bleeding resumed during hold"
                }
            ]
        },
        {
            "id": "troubleshoot",
            "text": "Reset with a fresh gauze pad and another full 10-minute pressure cycle. If bleeding persists after two cycles or symptoms worsen, escalate care immediately.",
            "options": [
                {
                    "type": "goto",
                    "goto": "prep",
                    "text": "Retry with full timed technique"
                },
                {
                    "type": "goto",
                    "goto": "safety-stop",
                    "text": "Still uncontrolled after retries"
                }
            ]
        },
        {
            "id": "verify",
            "text": "Check that bleeding is controlled, breathing is comfortable, and there is no dizziness. Continue rest with head elevated and avoid nose blowing for the day.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Bleeding controlled and aftercare understood",
                    "requiresItems": [
                        {
                            "id": "b0f10930-53aa-4d45-8bb7-9c7b17f14a5a",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "troubleshoot",
                    "text": "Needs another pressure cycle"
                }
            ]
        },
        {
            "id": "safety-stop",
            "text": "Good stop. Contact urgent care or emergency services and keep the person leaning forward while waiting for help.",
            "options": [
                {
                    "type": "goto",
                    "goto": "assess",
                    "text": "Return if medically cleared for self-care"
                }
            ]
        },
        {
            "id": "finish",
            "text": "Well done. Dispose of used supplies, wash hands, and log what happened so future responders can follow the same safe steps.",
            "options": [
                {
                    "type": "finish",
                    "text": "Nosebleed response complete"
                }
            ]
        }
    ],
    "rewards": [
        {
            "id": "b281360b-2ecc-4fea-a248-36a61c5f7399",
            "count": 1
        }
    ],
