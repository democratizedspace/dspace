{
    "id": "firstaid/stop-nosebleed",
    "title": "Stop a Nosebleed",
    "description": "Sit upright, lean forward, and pinch the soft part of your nose with a sterile gauze pad. Wear nitrile gloves from a first aid kit, use an antiseptic wipe around your nostrils after bleeding slows, and keep your head tilted forward the whole time. Never tilt your head back or insert anything into the nostrils.",
    "image": "/assets/quests/stop_nosebleed_first_aid.jpg",
    "npc": "/assets/npc/dChat.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "You're bleeding from the nose. Stay calm. We'll run a fast safety triage before first aid steps.",
            "options": [
                {
                    "type": "goto",
                    "goto": "safety-triage",
                    "text": "Start triage"
                }
            ]
        },
        {
            "id": "safety-triage",
            "text": "Check danger signs first: heavy flow, head injury, blood thinners, or faintness. If any are present, seek urgent medical help.",
            "options": [
                {
                    "type": "goto",
                    "goto": "prep",
                    "text": "No danger signs; proceed with first aid"
                },
                {
                    "type": "goto",
                    "goto": "emergency",
                    "text": "Danger signs present"
                }
            ]
        },
        {
            "id": "emergency",
            "text": "Stop self-treatment and contact emergency care now. Keep leaning forward and avoid packing the nostril.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Escalated to emergency care"
                }
            ]
        },
        {
            "id": "prep",
            "text": "Sit upright, lean forward ~30°, glove up, and prepare gauze + antiseptic wipe from your first aid kit.",
            "options": [
                {
                    "type": "goto",
                    "goto": "pressure",
                    "text": "Supplies ready",
                    "requiresItems": [
                        { "id": "09af703f-7054-4b33-a67d-4035d58bdfb7", "count": 1 },
                        { "id": "cc7d36e7-c66d-466f-9390-f7a365d857b9", "count": 1 },
                        { "id": "997eaba9-25ee-43d5-bbdc-5d6adf03adfa", "count": 1 },
                        { "id": "b0f10930-53aa-4d45-8bb7-9c7b17f14a5a", "count": 1 }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "restock",
                    "text": "Missing supplies"
                }
            ]
        },
        {
            "id": "restock",
            "text": "Restock before treatment so you can stay clean and apply steady pressure safely.",
            "options": [
                {
                    "type": "goto",
                    "goto": "prep",
                    "text": "Supplies restocked"
                }
            ]
        },
        {
            "id": "pressure",
            "text": "Pinch the soft part of your nose with gauze and hold for 10 full minutes without checking early. Breathe through your mouth.",
            "options": [
                {
                    "type": "process",
                    "process": "stop-nosebleed",
                    "text": "Run 10-minute pressure cycle",
                    "goto": "recheck"
                }
            ]
        },
        {
            "id": "recheck",
            "text": "After 10 minutes, release pressure once and reassess. Keep leaning forward.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Bleeding stopped"
                },
                {
                    "type": "goto",
                    "goto": "retry",
                    "text": "Bleeding continues"
                }
            ]
        },
        {
            "id": "retry",
            "text": "Apply a second 10-minute pressure cycle. If it still doesn't stop, escalate to medical care.",
            "options": [
                {
                    "type": "process",
                    "process": "stop-nosebleed",
                    "text": "Run second pressure cycle",
                    "goto": "escalate-check"
                }
            ]
        },
        {
            "id": "escalate-check",
            "text": "If bleeding remains after 20 minutes total, call emergency services or go to urgent care.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Bleeding stopped after second cycle"
                },
                {
                    "type": "goto",
                    "goto": "emergency",
                    "text": "Still bleeding; escalate now"
                }
            ]
        },
        {
            "id": "finish",
            "text": "Good closeout: dispose used supplies, wash hands, avoid nose blowing/picking for the day, and monitor for re-bleeding.",
            "options": [
                {
                    "type": "finish",
                    "text": "Done"
                }
            ]
        }
    ],
    "rewards": [
        {
            "id": "b281360b-2ecc-4fea-a248-36a61c5f7399",
            "count": 1
        }
    ],
    "requiresQuests": ["firstaid/restock-kit"],
