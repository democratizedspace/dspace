{
    "id": "electronics/check-battery-voltage",
    "title": "Check a battery pack's voltage",
    "description": "Use a digital multimeter to verify the voltage of a 12 V 200 Wh LiFePO4 battery pack.",
    "image": "/assets/battery.jpg",
    "npc": "/assets/npc/orion.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Hey! Let's confirm your 12 V pack is healthy. Work on a non-conductive surface, wear safety goggles, and keep metal tools away. We'll measure its voltage with a digital multimeter.",
            "options": [
                {
                    "type": "goto",
                    "goto": "measure",
                    "text": "I'm ready."
                }
            ]
        },
        {
            "id": "measure",
            "text": "Set the digital multimeter to the 20 V DC range. Insert the red lead into the VΩ port and the black lead into COM. Hold probes by the insulated grips, touch red to the positive terminal and black to the negative without letting them short. A charged pack should read around 12.6 V.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "It reads about 12.6 V.",
                    "requiresItems": [
                        {
                            "id": "cfe87611-623a-45b0-9243-422cd8a73a16",
                            "count": 1
                        },
                        {
                            "id": "5127e156-3009-4db4-85ac-e3ea070b68f2",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "finish",
            "text": "Nice work! Disconnect the probes, turn off the meter, and store the battery safely.",
            "options": [
                {
                    "type": "finish",
                    "text": "Thanks, Orion!"
                }
            ]
        }
    ],
    "rewards": [
