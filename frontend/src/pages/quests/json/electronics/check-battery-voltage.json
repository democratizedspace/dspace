{
    "id": "electronics/check-battery-voltage",
    "title": "Check a battery pack's voltage",
    "description": "Use a digital multimeter to check a 12 V LiFePO4 battery pack, classify the reading against safe bounds, and run a corrective retest loop when values drift.",
    "image": "/assets/quests/electronics_check_battery_pack_voltage.jpg",
    "npc": "/assets/npc/orion.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Ensure the pack is disconnected and free of damage. Put on safety goggles, set the battery on a dry, non-conductive surface, then prepare to take a measured reading with your multimeter.",
            "options": [
                {
                    "type": "goto",
                    "goto": "measure",
                    "text": "Bench and PPE are ready.",
                    "requiresItems": [
                        {
                            "id": "cfe87611-623a-45b0-9243-422cd8a73a16",
                            "count": 1
                        },
                        {
                            "id": "5127e156-3009-4db4-85ac-e3ea070b68f2",
                            "count": 1
                        },
                        {
                            "id": "c9b51052-4594-42d7-a723-82b815ab8cc2",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "measure",
            "text": "Set the multimeter to the 20 V DC range and confirm probes are in the voltage ports. Keep fingers behind the guards, touch red to positive and black to negative, and stop immediately if leads spark or warm.",
            "options": [
                {
                    "type": "process",
                    "process": "measure-battery-voltage",
                    "text": "Capture the battery voltage reading.",
                    "goto": "interpret",
                    "requiresItems": [
                        {
                            "id": "cfe87611-623a-45b0-9243-422cd8a73a16",
                            "count": 1
                        },
                        {
                            "id": "5127e156-3009-4db4-85ac-e3ea070b68f2",
                            "count": 1
                        },
                        {
                            "id": "c9b51052-4594-42d7-a723-82b815ab8cc2",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "interpret",
                    "text": "Reading captured and ready to interpret.",
                    "requiresItems": [
                        {
                            "id": "cfe87611-623a-45b0-9243-422cd8a73a16",
                            "count": 1
                        },
                        {
                            "id": "5127e156-3009-4db4-85ac-e3ea070b68f2",
                            "count": 1
                        },
                        {
                            "id": "c9b51052-4594-42d7-a723-82b815ab8cc2",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "interpret",
            "text": "Classify the reading. Pass range is 12.4-13.6 V at rest. Out-of-range or drifting values require a controlled safety branch and mandatory retest.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Voltage is stable within 12.4-13.6 V.",
                    "requiresItems": [
                        {
                            "id": "5127e156-3009-4db4-85ac-e3ea070b68f2",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "corrective",
                    "text": "Voltage is out of range or unstable.",
                    "requiresItems": [
                        {
                            "id": "5127e156-3009-4db4-85ac-e3ea070b68f2",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "corrective",
            "text": "Safety stop: disconnect loads, move the pack to a fire-safe area, and inspect for swelling, heat, or odor. If any hazard sign appears, quarantine the pack and stop. If clear, wait 10 minutes and retest.",
            "options": [
                {
                    "type": "goto",
                    "goto": "measure",
                    "text": "No hazard signs; run the verification retest.",
                    "requiresItems": [
                        {
                            "id": "cfe87611-623a-45b0-9243-422cd8a73a16",
                            "count": 1
                        },
                        {
                            "id": "c9b51052-4594-42d7-a723-82b815ab8cc2",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Hazard signs present; quarantine and replace the pack.",
                    "requiresItems": [
                        {
                            "id": "c9b51052-4594-42d7-a723-82b815ab8cc2",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "finish",
            "text": "Nice work. Power down the meter, cap probe tips, and record the final state so the next maintenance cycle starts with evidence.",
            "options": [
                {
                    "type": "finish",
                    "text": "Thanks, Orion!"
                }
            ]
        }
    ],
