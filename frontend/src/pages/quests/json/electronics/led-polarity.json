{
    "id": "electronics/led-polarity",
    "title": "Check LED polarity with a multimeter",
    "description": "Use a digital multimeter's diode mode to find which lead of a loose 5 mm LED is positive. Disconnect power, work on a dry non-conductive surface, wear safety goggles, and only use the meter's built-in diode test.",
    "image": "/assets/quests/electronics_led_polarity_multimeter_diode_test.jpg",
    "npc": "/assets/npc/orion.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Place a loose 5 mm LED, digital multimeter, and safety goggles on a dry non-conductive surface. Confirm all external power sources are disconnected before testing.",
            "options": [
                {
                    "type": "goto",
                    "goto": "method-select",
                    "text": "Bench is safe. Choose a polarity identification method.",
                    "requiresItems": [
                        {
                            "id": "48cf736e-184c-4bd1-b9b0-15b7e9721646",
                            "count": 1
                        },
                        {
                            "id": "5127e156-3009-4db4-85ac-e3ea070b68f2",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "safety-stop",
                    "text": "I still need to isolate power and prep PPE."
                }
            ]
        },
        {
            "id": "method-select",
            "text": "Main path: diode-mode verification. Alternate path: visual pre-check (long leg = likely anode, flat edge = likely cathode) followed by diode-mode confirmation.",
            "options": [
                {
                    "type": "goto",
                    "goto": "diode-test",
                    "text": "Use diode-mode as primary test."
                },
                {
                    "type": "goto",
                    "goto": "visual-check",
                    "text": "Start with visual cues, then confirm electrically."
                }
            ]
        },
        {
            "id": "visual-check",
            "text": "Inspect the LED body for flat-edge/cathode marks and leg length mismatch. Record your hypothesis before touching probes.",
            "options": [
                {
                    "type": "goto",
                    "goto": "diode-test",
                    "text": "Hypothesis logged. Confirm with diode-mode measurement.",
                    "requiresItems": [
                        {
                            "id": "c9b51052-4594-42d7-a723-82b815ab8cc2",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "diode-test",
            "text": "Set the meter to diode mode, keep fingers behind probe guards, and touch red to suspected anode / black to cathode. Pass expectation: LED glows faintly or reads ~1.8–3.3V in one direction, and shows OL/no glow when reversed.",
            "options": [
                {
                    "type": "process",
                    "process": "check-led-polarity",
                    "text": "Run diode-mode confirmation."
                },
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "One-way conduction confirmed and polarity documented.",
                    "requiresItems": [
                        {
                            "id": "48cf736e-184c-4bd1-b9b0-15b7e9721646",
                            "count": 1
                        },
                        {
                            "id": "5127e156-3009-4db4-85ac-e3ea070b68f2",
                            "count": 1
                        },
                        {
                            "id": "c9b51052-4594-42d7-a723-82b815ab8cc2",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "troubleshoot",
                    "text": "Reading is ambiguous or fails expectations."
                }
            ]
        },
        {
            "id": "troubleshoot",
            "text": "Troubleshoot: verify diode mode (not continuity), reseat probes, then retest with a known-good LED to confirm meter behavior. Safety stop if LED heats, smokes, or sparks.",
            "options": [
                {
                    "type": "goto",
                    "goto": "diode-test",
                    "text": "Meter and probes verified. Retry polarity test."
                },
                {
                    "type": "goto",
                    "goto": "safety-stop",
                    "text": "Component damage detected; stop and isolate it."
                }
            ]
        },
        {
            "id": "safety-stop",
            "text": "Good call. Remove power sources, isolate damaged parts, and replace the LED before retrying.",
            "options": [
                {
                    "type": "goto",
                    "goto": "start",
                    "text": "Replacement LED ready. Restart safely."
                }
            ]
        },
        {
            "id": "finish",
            "text": "Nice work. You confirmed polarity with evidence and followed a safe troubleshooting loop.",
            "options": [
                {
                    "type": "finish",
                    "text": "LED polarity verified."
                }
            ]
        }
    ],
    "rewards": [
