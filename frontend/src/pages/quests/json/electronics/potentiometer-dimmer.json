    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Orion here again! Let's add interactivity by twisting a 10 kΩ potentiometer to control an LED. Work on a dry, static-safe surface, wear safety goggles, and keep the Arduino unplugged while wiring.",
            "options": [
                {
                    "type": "goto",
                    "goto": "materials",
                    "text": "What do I need?"
                }
            ]
        },
        {
            "id": "materials",
            "text": "Gather an Arduino Uno, breadboard, three jumper wires, a 5 mm LED, a 220 Ω resistor, a 10 kΩ potentiometer, USB cable, and a laptop with Arduino IDE. Verify resistor bands and LED polarity before power-up.",
            "options": [
                {
                    "type": "process",
                    "process": "arduino-ide-install",
                    "text": "Install the Arduino IDE"
                },
                {
                    "type": "goto",
                    "goto": "wiring-strategy",
                    "text": "Parts ready.",
                    "requiresItems": [
                        {
                            "id": "72b4448e-27d9-4746-bd3a-967ff13f501b",
                            "count": 1
                        },
                        {
                            "id": "d1105b87-8185-4a30-ba55-406384be169f",
                            "count": 1
                        },
                        {
                            "id": "3cd82744-d2aa-414e-9f03-80024b624066",
                            "count": 3
                        },
                        {
                            "id": "48cf736e-184c-4bd1-b9b0-15b7e9721646",
                            "count": 1
                        },
                        {
                            "id": "037e6065-68a7-4ad1-9b0b-7778ecfe0662",
                            "count": 1
                        },
                        {
                            "id": "2a767901-6d4d-4a90-b520-50f0076a9c7d",
                            "count": 1
                        },
                        {
                            "id": "fb60696a-6c94-4e5e-9277-b62377ee6d73",
                            "count": 1
                        },
                        {
                            "id": "b6fc1ed6-f399-4fdb-9f9d-3913f893f43d",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "wiring-strategy",
            "text": "Choose a wiring strategy: use the stock AnalogInOutSerial path for quick validation or build a custom sketch flow for tighter smoothing control. Either path must prove stable dimming before finish.",
            "options": [
                {
                    "type": "goto",
                    "goto": "wire-standard",
                    "text": "Use the stock AnalogInOutSerial route."
                },
                {
                    "type": "goto",
                    "goto": "wire-custom",
                    "text": "Use a custom smoothing route."
                }
            ]
        },
        {
            "id": "wire-standard",
            "text": "Disconnect USB. Wire potentiometer outer legs to 5V and GND, center wiper to A0, and LED anode to pin 9 through the 220 Ω resistor with cathode to GND. Tug-test jumpers and confirm no exposed shorts.",
            "options": [
                {
                    "type": "goto",
                    "goto": "program-standard",
                    "text": "Standard circuit complete."
                },
                {
                    "type": "goto",
                    "goto": "troubleshoot-wiring",
                    "text": "I found a loose lead or possible short."
                }
            ]
        },
        {
            "id": "wire-custom",
            "text": "Disconnect USB. Build the same base circuit, then reserve an extra jumper for a test point so you can inspect the A0 signal if dimming jitters. Keep wire runs short to reduce noise pickup.",
            "options": [
                {
                    "type": "goto",
                    "goto": "program-custom",
                    "text": "Custom circuit complete."
                },
                {
                    "type": "goto",
                    "goto": "troubleshoot-wiring",
                    "text": "Need to rework wiring before power-up."
                }
            ]
        },
        {
            "id": "program-standard",
            "text": "Reconnect USB and load File > Examples > 03.Analog > AnalogInOutSerial. Upload, rotate the knob through full travel, and confirm smooth brightness response with no dead zones.",
            "options": [
                {
                    "type": "goto",
                    "goto": "evidence-check",
                    "text": "Upload complete and dimming works.",
                    "process": "arduino-potentiometer-dimmer"
                },
                {
                    "type": "goto",
                    "goto": "troubleshoot-output",
                    "text": "Dimming is unstable or stuck."
                }
            ]
        },
        {
            "id": "program-custom",
            "text": "Reconnect USB and upload a custom sketch that averages multiple analogRead(A0) samples before analogWrite(9, mappedValue). Record whether smoothing improves response near low brightness.",
            "options": [
                {
                    "type": "goto",
                    "goto": "evidence-check",
                    "text": "Custom sketch runs with smooth dimming.",
                    "process": "arduino-potentiometer-dimmer"
                },
                {
                    "type": "goto",
                    "goto": "troubleshoot-output",
                    "text": "Custom route still jitters."
                }
            ]
        },
        {
            "id": "troubleshoot-wiring",
            "text": "Recovery checklist: power down, reseat potentiometer legs, verify resistor is on LED anode path, and ensure pin 9 is not shorted to ground. Only repower once continuity looks correct.",
            "options": [
                {
                    "type": "goto",
                    "goto": "wiring-strategy",
                    "text": "Wiring corrected. Retry a strategy."
                }
            ]
        },
        {
            "id": "troubleshoot-output",
            "text": "If output jitters or sticks, reduce wire length, confirm shared ground, and test raw analogRead values in Serial Monitor. Re-run after one change at a time so you can identify the fix.",
            "options": [
                {
                    "type": "goto",
                    "goto": "wiring-strategy",
                    "text": "Apply fixes and retry."
                }
            ]
        },
        {
            "id": "evidence-check",
            "text": "Evidence gate: prove full-range behavior by showing dim-to-bright-to-dim travel and stable response at both low and high knob positions. If either end fails, do not finish yet.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Evidence captured. System is stable.",
                    "requiresItems": [
                        {
                            "id": "2a767901-6d4d-4a90-b520-50f0076a9c7d",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "troubleshoot-output",
                    "text": "Low/high-end behavior still fails."
                }
            ]
        },
        {
            "id": "finish",
            "text": "Nice work! You validated both wiring discipline and control stability. Unplug before rework, label your tested pin map, and store components for your next control project.",
            "options": [
                {
                    "type": "process",
                    "process": "arduino-potentiometer-dimmer",
                    "text": "Review the full potentiometer dimmer process"
                },
                {
                    "type": "finish",
                    "text": "Thanks, Orion!"
                }
            ]
        }
    ],
