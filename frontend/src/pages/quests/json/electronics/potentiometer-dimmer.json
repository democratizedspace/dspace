    "dialogue": [
        {
            "id": "start",
            "text": "Orion here again! Let's add interactivity by twisting a 10 kΩ potentiometer to control an LED. Work on a dry, static-safe surface, wear safety goggles, and keep the Arduino unplugged while wiring.",
            "options": [
                {
                    "type": "goto",
                    "goto": "materials",
                    "text": "What do I need?"
                }
            ]
        },
        {
            "id": "materials",
            "text": "Gather an Arduino Uno, breadboard, three jumper wires, a 5 mm LED, a 220 Ω resistor, a 10 kΩ potentiometer, a USB Type-A to USB-B cable, and a laptop with the Arduino IDE installed.",
            "options": [
                {
                    "type": "process",
                    "process": "arduino-ide-install",
                    "text": "Install the Arduino IDE"
                },
                {
                    "type": "goto",
