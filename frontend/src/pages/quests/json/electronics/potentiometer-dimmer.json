        {
            "id": "wire-main",
            "text": "Seat the potentiometer on the breadboard with its flat side toward you. Wire outer legs to 5 V and GND, route the center wiper to A0, and connect LED anode to pin 9 through the 220 Ω resistor with cathode to GND.",
            "options": [
                {
                    "type": "goto",
                    "goto": "verify-wiring",
                    "text": "Main wiring complete."
                }
            ]
        },
        {
            "id": "wire-fallback",
            "text": "Alternate strategy: move the potentiometer to an isolated row block, route short jumpers first, and clip a label to the center wiper lead so A0 cannot be confused with power rails.",
            "options": [
                {
                    "type": "goto",
                    "goto": "verify-wiring",
                    "text": "Fallback wiring complete."
                }
            ]
        },
        {
            "id": "verify-wiring",
            "text": "Before plugging USB in, inspect every connection against a checklist: no exposed leads touching, resistor in series with LED, and wiper on A0. If any uncertainty remains, stay powered down and re-check.",
            "options": [
                {
                    "type": "goto",
                    "goto": "program",
                    "text": "Checklist passed; safe to power up.",
                    "requiresItems": [
                        {
                            "id": "48cf736e-184c-4bd1-b9b0-15b7e9721646",
                            "count": 1
                        },
                        {
                            "id": "037e6065-68a7-4ad1-9b0b-7778ecfe0662",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "troubleshoot",
                    "text": "I found a possible short or miswire."
                }
            ]
        },
        {
            "id": "program",
            "text": "Reconnect USB and load File > Examples > 03.Analog > AnalogInOutSerial. Upload, then rotate the knob through full travel. Stop immediately if the LED flickers erratically, the board resets repeatedly, or components warm up.",
            "options": [
                {
                    "type": "goto",
                    "goto": "evidence",
                    "text": "Sketch uploaded and dimmer responds."
                },
                {
                    "type": "goto",
                    "goto": "troubleshoot",
                    "text": "Brightness is unstable or unresponsive."
                }
            ]
        },
        {
            "id": "troubleshoot",
            "text": "Troubleshooting branch: unplug power, inspect resistor placement, verify potentiometer outer pins are on 5 V/GND, and confirm the correct board/port in the IDE. After fixes, run the wiring verification again before upload.",
            "options": [
                {
                    "type": "goto",
                    "goto": "verify-wiring",
                    "text": "Fixes applied; re-verify safely."
                }
            ]
        },
        {
            "id": "evidence",
            "text": "Evidence gate: demonstrate a low, medium, and high brightness state while serial output tracks the analog value. Record that the full sweep maps roughly from 0 to 255.",
            "options": [
                {
                    "type": "process",
                    "process": "arduino-potentiometer-dimmer",
                    "text": "Capture the full potentiometer dimmer walkthrough"
                },
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Captured low/medium/high brightness evidence."
                }
            ]
        },
        {
            "id": "finish",
            "text": "Nice work! You completed either wiring strategy, validated safety checks, and closed only after reproducible dimming evidence.",
            "options": [
                {
                    "type": "finish",
                    "text": "Thanks, Orion!"
                }
            ]
        }
