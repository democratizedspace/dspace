                    "type": "goto",
                    "goto": "setup",
                    "text": "Proceed with standard USB serial setup."
                },
                {
                    "type": "goto",
                    "goto": "setup-alt",
                    "text": "Proceed with staged setup + quick serial smoke test."
                }
            ]
        },
        {
