                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "plan-log-fields",
            "text": "Define the logging artifact before running: each `temps.csv` row must include timestamp, °C reading, and a note field. Capture at least 5 samples at 1-minute cadence.",
            "options": [
                {
                    "type": "goto",
                    "goto": "run-logger",
                    "text": "Logging plan documented"
                }
            ]
        },
        {
            "id": "run-logger",
            "text": "Create `log_temp.py` for `/dev/ttyACM0` at 9600 baud and append readings to `temps.csv`. Safety stop: if cable disconnects or temperature jumps by >5°C between adjacent minutes, stop and classify the anomaly before continuing.",
            "options": [
                {
                    "type": "process",
                    "process": "raspberry-pi-serial-log",
                    "text": "Open the serial logging process"
                },
                {
                    "type": "goto",
                    "goto": "review-log",
                    "text": "Collected 5+ rows with timestamp, °C, and notes"
                },
                {
                    "type": "goto",
                    "goto": "anomaly-response",
                    "text": "Observed missing rows, serial drops, or >5°C jump"
                }
            ]
        },
        {
            "id": "anomaly-response",
            "text": "Classify anomaly source: sensor contact, USB instability, or script parse bug. Apply one fix at a time, then run a fresh 3-sample verification window before returning to full logging.",
            "options": [
                {
                    "type": "goto",
                    "goto": "run-logger",
                    "text": "Applied corrective action and ready to re-verify"
                }
            ]
        },
        {
            "id": "review-log",
            "text": "Review pass criteria: cadence held near one minute, no missing required fields, and no unresolved anomalies. This log artifact is your proof gate for completion.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Log review passed"
                }
            ]
        },
        {
            "id": "finish",
            "text": "Nice work. Stop the script with Ctrl+C, safely shut down the Pi, then unplug USB before moving the rig.",
            "options": [
                {
                    "type": "finish",
                    "text": "Thanks, Orion!"
                }
            ]
        }
    ],
