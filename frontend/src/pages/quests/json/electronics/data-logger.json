    "dialogue": [
        {
            "id": "start",
            "text": "Your thermistor circuit works. Set it on a dry, static-safe surface, wear safety goggles plus an anti-static wrist strap, and keep power disconnected until wiring is checked.",
            "options": [
                {
                    "type": "goto",
                    "goto": "setup",
                    "text": "Bench is safe and staged"
                }
            ]
        },
        {
            "id": "setup",
            "text": "Connect Arduino Uno to Raspberry Pi via USB. Install pyserial and verify cable strain relief so nothing can yank loose during logging.",
            "options": [
                {
                    "type": "process",
                    "process": "pyserial-install",
                    "text": "Install pyserial"
                },
                {
                    "type": "goto",
                    "goto": "plan-log-fields",
                    "text": "Install complete; hardware secured",
                    "requiresItems": [
                        {
                            "id": "fb60696a-6c94-4e5e-9277-b62377ee6d73",
                            "count": 1
