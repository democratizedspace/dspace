        {
            "id": "script",
            "text": "Build `log_temp.py` so each row includes timestamp, sensor ID, raw ADC/voltage, computed °C, and an anomaly flag. Collect at least 10 minutes at 1-minute cadence and keep the terminal output for review.",
            "options": [
                {
                    "type": "process",
                    "process": "raspberry-pi-serial-log",
                    "text": "Run the serial logging process"
                },
                {
                    "type": "goto",
                    "goto": "review",
                    "text": "Log artifact captured with required fields."
                },
                {
                    "type": "goto",
                    "goto": "anomaly",
                    "text": "Log has gaps/spikes or missing fields."
                }
            ]
        },
        {
            "id": "anomaly",
            "text": "Classify anomalies before retry: loose cable (intermittent gaps), bad calibration (consistent offset), or noisy power (spikes). Apply one fix, then rerun logging for another 10-minute window.",
            "options": [
                {
                    "type": "goto",
                    "goto": "script",
                    "text": "Corrective action applied. Re-log and verify."
                }
            ]
        },
        {
            "id": "review",
            "text": "Review checkpoint: cadence is consistent, required fields are present, and no unresolved anomaly flags remain. If any condition fails, return to anomaly handling.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Monitoring snapshot passes all criteria."
                },
                {
                    "type": "goto",
                    "goto": "anomaly",
                    "text": "Need another correction cycle."
                }
            ]
        },
        {
            "id": "finish",
            "text": "Excellent. Stop logging with Ctrl+C, shut down the Pi cleanly, and unplug USB before moving hardware. Your dataset is ready for plotting and alert thresholds.",
            "options": [
                {
                    "type": "finish",
                    "text": "Data logger validated."
                }
            ]
        }
