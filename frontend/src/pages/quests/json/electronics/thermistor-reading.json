                            "count": 1
                        },
                        {
                            "id": "ffe0b74a-f111-4d66-b4c3-d82965a976ac",
                            "count": 1
                        },
                        {
                            "id": "b6fc1ed6-f399-4fdb-9f9d-3913f893f43d",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "monitor",
            "text": "Reconnect the USB cable to your Laptop Computer and upload the sketch from the arduino-thermistor-read process to sample the voltage divider. Open the Arduino IDE's Serial Monitor to watch temperature readings and keep liquids and loose metal away from the powered board.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Readings look good.",
                    "process": "arduino-thermistor-read"
                }
            ]
        },
        {
            "id": "finish",
            "text": "Nice job! Logging data over time will help automate your experiments.",
            "options": [
                {
                    "type": "finish",
                    "text": "Neat!"
                }
            ]
        }
    ],
