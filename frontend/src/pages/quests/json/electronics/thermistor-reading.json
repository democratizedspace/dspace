{
    "id": "electronics/thermistor-reading",
    "title": "Read a Thermistor",
    "description": "Wire a thermistor to your Arduino and log temperature values.",
    "image": "/assets/quests/basic_circuit.svg",
    "npc": "/assets/npc/orion.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Let's expand your sensor skills. A 10 kΩ NTC thermistor with a matching resistor forms a simple voltage divider for an Arduino Uno. Work on a non-conductive surface and keep power disconnected while wiring.",
            "options": [
                {
                    "type": "process",
                    "process": "arduino-ide-install",
                    "text": "Install the Arduino IDE"
                },
                {
                    "type": "goto",
                    "goto": "wire",
                    "text": "Show me."
                }
            ]
        },
        {
            "id": "wire",
            "text": "Disconnect the USB cable before wiring. On the breadboard, place the thermistor and 10 kΩ resistor in series between 5 V and GND to form a voltage divider. Use jumper wires to link their junction to A0 on the Arduino Uno. Keep leads separated, verify resistor values and double-check connections before reconnecting power.",
            "options": [
                {
                    "type": "goto",
                    "goto": "monitor",
                    "text": "Circuit ready.",
                    "requiresItems": [
                        {
                            "id": "72b4448e-27d9-4746-bd3a-967ff13f501b",
                            "count": 1
                        },
                        {
                            "id": "d1105b87-8185-4a30-ba55-406384be169f",
                            "count": 1
                        },
                        {
                            "id": "3cd82744-d2aa-414e-9f03-80024b624066",
                            "count": 3
                        },
                        {
                            "id": "fb60696a-6c94-4e5e-9277-b62377ee6d73",
                            "count": 1
                        },
                        {
                            "id": "5a6bb713-ed34-4463-94ee-cfe7b8faa45c",
                            "count": 1
                        },
                        {
                            "id": "ffe0b74a-f111-4d66-b4c3-d82965a976ac",
                            "count": 1
                        },
                        {
                            "id": "b6fc1ed6-f399-4fdb-9f9d-3913f893f43d",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "monitor",
            "text": "Reconnect the USB cable to your Laptop Computer and upload the sketch from the arduino-thermistor-read process to sample the analog voltage and convert it to temperature. Open the Arduino IDE's Serial Monitor to watch the readings and keep liquids and loose metal away from the powered board.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Readings look good.",
                    "process": "arduino-thermistor-read"
                }
            ]
        },
        {
            "id": "finish",
            "text": "Nice job! Logging data over time will help automate your experiments.",
            "options": [
                {
                    "type": "finish",
                    "text": "Neat!"
                }
            ]
        }
    ],
    "rewards": [],
    "requiresQuests": ["electronics/potentiometer-dimmer"]
}
