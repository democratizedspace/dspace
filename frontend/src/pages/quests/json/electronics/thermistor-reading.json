                        {
                            "id": "fb60696a-6c94-4e5e-9277-b62377ee6d73",
                            "count": 1
                        },
                        {
                            "id": "5a6bb713-ed34-4463-94ee-cfe7b8faa45c",
                            "count": 1
                        },
                        {
                            "id": "ffe0b74a-f111-4d66-b4c3-d82965a976ac",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "monitor",
            "text": "Upload the sketch from the arduino-thermistor-read process to sample the analog value and convert it to temperature. Open the Arduino serial monitor to watch the values and keep liquids and loose metal away from the board.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Readings look good.",
                    "process": "arduino-thermistor-read"
                }
            ]
        },
        {
            "id": "finish",
            "text": "Nice job! Logging data over time will help automate your experiments.",
            "options": [
                {
                    "type": "finish",
                    "text": "Neat!"
                }
            ]
        }
