{
    "id": "electronics/thermistor-reading",
    "title": "Read a Thermistor",
    "description": "Wire a thermistor to your Arduino and log temperature values.",
    "image": "/assets/quests/basic_circuit.svg",
    "npc": "/assets/npc/orion.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Let's expand your sensor skills. A thermistor paired with a 10k Ω resistor can report ambient temperature for future automations.",
            "options": [
                {
                    "type": "goto",
                    "goto": "wire",
                    "text": "Show me."
                }
            ]
        },
        {
            "id": "wire",
            "text": "Unplug the USB cable before wiring. On the breadboard, form a voltage divider by connecting one thermistor lead to 5V, the other through the 10k Ω resistor to ground, then run the junction to A0 with jumper wires. Double-check connections before powering back up.",
            "options": [
                {
                    "type": "goto",
                    "goto": "monitor",
                    "text": "Circuit ready.",
                    "requiresItems": [
                        {
                            "id": "72b4448e-27d9-4746-bd3a-967ff13f501b",
                            "count": 1
                        },
                        {
                            "id": "d1105b87-8185-4a30-ba55-406384be169f",
