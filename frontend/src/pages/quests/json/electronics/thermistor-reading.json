{
    "id": "electronics/thermistor-reading",
    "title": "Read a Thermistor",
    "description": "Wire a thermistor to your Arduino and log temperature values.",
    "image": "/assets/quests/electronics_thermistor_reading_arduino.jpg",
    "npc": "/assets/npc/orion.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Let's level up sensor ops. We'll wire a thermistor divider, collect a baseline, and handle unstable readings with a recovery loop.",
            "options": [
                {
                    "type": "process",
                    "process": "arduino-ide-install",
                    "text": "Install/update Arduino IDE"
                },
                {
                    "type": "goto",
                    "goto": "wire",
                    "text": "Guide me through wiring."
                }
            ]
        },
        {
            "id": "wire",
            "text": "With USB unplugged, wire a 10k NTC thermistor and 10k resistor as a divider between 5V and GND, with the midpoint to A0. Keep exposed leads separated and verify resistor value before power-on.",
            "options": [
                {
                    "type": "goto",
                    "goto": "preflight",
                    "text": "Wiring complete.",
                    "requiresItems": [
                        {
                            "id": "72b4448e-27d9-4746-bd3a-967ff13f501b",
                            "count": 1
                        },
                        {
                            "id": "d1105b87-8185-4a30-ba55-406384be169f",
                            "count": 1
                        },
                        {
                            "id": "3cd82744-d2aa-414e-9f03-80024b624066",
                            "count": 3
                        },
                        {
                            "id": "fb60696a-6c94-4e5e-9277-b62377ee6d73",
                            "count": 1
                        },
                        {
                            "id": "5a6bb713-ed34-4463-94ee-cfe7b8faa45c",
                            "count": 1
                        },
                        {
                            "id": "ffe0b74a-f111-4d66-b4c3-d82965a976ac",
                            "count": 1
                        },
                        {
                            "id": "b6fc1ed6-f399-4fdb-9f9d-3913f893f43d",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "preflight",
            "text": "Safety gate: confirm goggles are on, board is dry, and no wire can short adjacent pins. If anything looks wrong, fix wiring before applying USB power.",
            "options": [
                {
                    "type": "goto",
                    "goto": "capture",
                    "text": "Preflight passed."
                },
                {
                    "type": "goto",
                    "goto": "rewire",
                    "text": "I need to correct the wiring first."
                }
            ]
        },
        {
            "id": "capture",
            "text": "Upload the thermistor sketch and open Serial Monitor. Evidence artifact: record three readings over one minute. Expected room-range for this quest is 15-35 °C with smooth changes.",
            "options": [
                {
                    "type": "process",
                    "process": "arduino-thermistor-read",
                    "text": "Run thermistor capture process"
                },
                {
                    "type": "goto",
                    "goto": "stable",
                    "text": "Readings are in range and stable."
                },
                {
                    "type": "goto",
                    "goto": "unstable",
                    "text": "Readings jump wildly or are out of range."
                }
            ]
        },
        {
            "id": "stable",
            "text": "Interpretation: stable values indicate the divider and sampling path are functioning. Save your notes for later plotting quests.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Log saved."
                }
            ]
        },
        {
            "id": "unstable",
            "text": "Troubleshooting branch: disconnect USB, reseat thermistor leads, verify 10k resistor, and remove airflow from hands or lamps. If board heats up, stop and inspect before continuing.",
            "options": [
                {
                    "type": "goto",
                    "goto": "retest",
                    "text": "Apply corrections and retest."
                },
                {
                    "type": "goto",
                    "goto": "rewire",
                    "text": "Rebuild divider from scratch."
                }
            ]
        },
        {
            "id": "retest",
            "text": "Re-test loop: capture another one-minute sample and compare to baseline notes.",
            "options": [
                {
                    "type": "process",
                    "process": "arduino-thermistor-read",
                    "text": "Run re-test capture"
                },
                {
                    "type": "goto",
                    "goto": "capture",
                    "text": "Return to interpretation with new readings."
                }
            ]
        },
        {
            "id": "rewire",
            "text": "Safe re-entry checkpoint: keep USB disconnected while rebuilding the divider, then repeat preflight before any new measurement.",
            "options": [
                {
                    "type": "goto",
                    "goto": "preflight",
                    "text": "Rewire done. Re-run preflight."
                }
            ]
        },
        {
            "id": "finish",
            "text": "Excellent. You produced a measurement log, interpreted thresholds, and used a safe retry path.",
            "options": [
                {
                    "type": "finish",
                    "text": "Neat!"
                }
            ]
        }
    ],
    "rewards": [
