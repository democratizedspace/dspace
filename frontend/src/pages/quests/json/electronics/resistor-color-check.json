{
    "id": "electronics/resistor-color-check",
    "title": "Verify resistor color bands",
    "description": "Confirm a resistor's value by decoding its color bands before installing it in a circuit.",
    "image": "/assets/quests/electronics_resistor_color_band_check.jpg",
    "npc": "/assets/npc/orion.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Need to confirm this resistor's value? Power down the circuit and keep soldering irons unplugged while we verify the part. We'll decode colors, validate with a meter, then decide if the resistor is safe to install.",
            "options": [
                {
                    "type": "goto",
                    "goto": "decode-bands",
                    "text": "Let's decode it safely."
                }
            ]
        },
        {
            "id": "decode-bands",
            "text": "Orient the gold tolerance band to the right. Red-red-brown-gold should decode to 220 Ω ±5%. Use the resistor chart and run verify-resistor-color-code so you have a repeatable artifact before installing anything.",
            "options": [
                {
                    "type": "goto",
                    "goto": "meter-check",
                    "text": "Bands decoded. Time to meter-check.",
                    "process": "verify-resistor-color-code",
                    "requiresItems": [
                        {
                            "id": "037e6065-68a7-4ad1-9b0b-7778ecfe0662",
                            "count": 1
                        },
                        {
                            "id": "bf3d2784-d48d-4b12-b12a-75f563b5dc88",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "recovery-orientation",
                    "text": "I can't identify the tolerance band yet."
                }
            ]
        },
        {
            "id": "meter-check",
            "text": "Set the multimeter to resistance mode and measure across the resistor leads while it's isolated from the circuit. Record a reading artifact and compare against the expected 220 Ω ±5% window (209 Ω to 231 Ω).",
            "options": [
                {
                    "type": "goto",
                    "goto": "in-range",
                    "text": "Measured value is 209–231 Ω.",
                    "requiresItems": [
                        {
                            "id": "bf3d2784-d48d-4b12-b12a-75f563b5dc88",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "out-of-range",
                    "text": "Measured value is outside tolerance."
                }
            ]
        },
        {
            "id": "recovery-orientation",
            "text": "Recovery step: improve lighting, rotate the resistor, and compare each stripe one at a time against the chart. If paint is damaged or ambiguous, do not install it yet—confirm with the meter first.",
            "options": [
                {
                    "type": "goto",
                    "goto": "meter-check",
                    "text": "Ready to verify with a meter."
                }
            ]
        },
        {
            "id": "out-of-range",
            "text": "Out-of-range means stop and troubleshoot before use. Clean probe tips, re-seat meter clips, and retest. If the reading still fails tolerance, quarantine this resistor and swap in a known-good 220 Ω component.",
            "options": [
                {
                    "type": "goto",
                    "goto": "meter-check",
                    "text": "Retest after troubleshooting."
                },
                {
                    "type": "goto",
                    "goto": "decode-bands",
                    "text": "Use a replacement resistor and re-run decoding."
                }
            ]
        },
        {
            "id": "in-range",
            "text": "Nice verification discipline. The resistor passed decode + meter evidence, so it's safe to label and stage for installation.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Log complete. Finish quest."
                }
            ]
        },
        {
            "id": "finish",
            "text": "Great. Label the resistor value and tolerance so your next build starts with verified parts.",
            "options": [
                {
                    "type": "finish",
                    "text": "Thanks, Orion!"
                }
            ]
        }
    ],
    "rewards": [
