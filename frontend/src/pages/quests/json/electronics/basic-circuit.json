{
    "id": "electronics/basic-circuit",
    "title": "Build a basic LED circuit",
    "description": "Wire a 5 mm LED and 220 \u03a9 resistor on a breadboard to learn basic circuits.",
    "image": "/assets/quests/electronics_basic_led_breadboard_circuit.jpg",
    "npc": "/assets/npc/orion.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Orion here. We'll build a basic LED circuit safely and prove it works before we call it done.",
            "options": [
                {
                    "type": "goto",
                    "goto": "materials",
                    "text": "What do I need?"
                }
            ]
        },
        {
            "id": "materials",
            "text": "Lay out a solderless breadboard, jumper wires, LED, 220 ohm resistor, resistor color chart, 5 V power supply, and safety goggles. Keep power disconnected while wiring.",
            "options": [
                {
                    "type": "goto",
                    "goto": "wire-main",
                    "text": "I have the parts and goggles.",
                    "requiresItems": [
                        {
                            "id": "d1105b87-8185-4a30-ba55-406384be169f",
                            "count": 1
                        },
                        {
                            "id": "3cd82744-d2aa-414e-9f03-80024b624066",
                            "count": 2
                        },
                        {
                            "id": "48cf736e-184c-4bd1-b9b0-15b7e9721646",
                            "count": 1
                        },
                        {
                            "id": "037e6065-68a7-4ad1-9b0b-7778ecfe0662",
                            "count": 1
                        },
                        {
                            "id": "bf3d2784-d48d-4b12-b12a-75f563b5dc88",
                            "count": 1
                        },
                        {
                            "id": "828d6c3b-66a5-4064-b221-97630274502b",
                            "count": 1
                        },
                        {
                            "id": "c9b51052-4594-42d7-a723-82b815ab8cc2",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "wire-main",
            "text": "Main path: place the resistor in series with the LED, then wire to 5 V and GND. Double-check LED polarity before power-up.",
            "options": [
                {
                    "type": "process",
                    "process": "verify-resistor-color-code",
                    "text": "Confirm resistor value and proceed to verification.",
                    "goto": "verify"
                },
                {
                    "type": "goto",
                    "goto": "alt-diagnose",
                    "text": "I am unsure about LED polarity."
                }
            ]
        },
        {
            "id": "alt-diagnose",
            "text": "Alternative strategy: test LED polarity with the multimeter diode mode first, then reinsert it with the anode toward positive rail.",
            "options": [
                {
                    "type": "process",
                    "process": "check-led-polarity",
                    "text": "Run polarity check and re-test circuit.",
                    "goto": "verify",
                    "requiresItems": [
                        {
                            "id": "5127e156-3009-4db4-85ac-e3ea070b68f2",
                            "count": 1
                        },
                        {
                            "id": "c9b51052-4594-42d7-a723-82b815ab8cc2",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "verify",
            "text": "Evidence gate: power on and confirm the LED lights steadily for 10 seconds with no heat/smell from parts.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "LED stays lit and stable."
                },
                {
                    "type": "goto",
                    "goto": "troubleshoot",
                    "text": "LED did not light or flickered."
                }
            ]
        },
        {
            "id": "troubleshoot",
            "text": "Power off first. Re-seat wires, verify resistor is in series (not bypassed), and inspect for reversed LED legs. If anything smells hot, stop and let components cool.",
            "options": [
                {
                    "type": "goto",
                    "goto": "wire-main",
                    "text": "I corrected wiring. Retry verification."
                }
            ]
        },
        {
            "id": "finish",
            "text": "Great work. You built and verified a safe baseline circuit. Remove power before making changes.",
            "options": [
                {
                    "type": "finish",
                    "text": "Thanks, Orion!"
                }
            ]
        }
    ],
    "requiresQuests": [
        "welcome/howtodoquests"
    ],
