{
    "id": "electronics/servo-sweep",
    "title": "Sweep a Servo",
    "description": "Use the Arduino IDE's Servo library 'Sweep' example to rotate a hobby servo from 0° to 180°.",
    "image": "/assets/quests/electronics_servo_sweep_arduino.jpg",
    "npc": "/assets/npc/orion.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Orion here. We'll run a safe servo sweep with a verify-and-recover loop. Keep power disconnected while wiring so the horn cannot move unexpectedly.",
            "options": [
                {
                    "type": "goto",
                    "goto": "preflight",
                    "text": "Start preflight."
                }
            ]
        },
        {
            "id": "preflight",
            "text": "Gather Arduino Uno, three jumper wires, USB cable, servo motor, and a 5 V supply. If expected current is above 500 mA, use external 5 V and common ground.",
            "options": [
                {
                    "type": "goto",
                    "goto": "wire",
                    "text": "Build primary wiring plan.",
                    "requiresItems": [
                        {
                            "id": "72b4448e-27d9-4746-bd3a-967ff13f501b",
                            "count": 1
                        },
                        {
                            "id": "3cd82744-d2aa-414e-9f03-80024b624066",
                            "count": 3
                        },
                        {
                            "id": "fb60696a-6c94-4e5e-9277-b62377ee6d73",
                            "count": 1
                        },
                        {
                            "id": "e976bae6-e33c-428a-a20d-0aa8fde13c6c",
                            "count": 1
                        },
                        {
                            "id": "828d6c3b-66a5-4064-b221-97630274502b",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "ide-path",
                    "text": "Use laptop-first path to prepare software before wiring.",
                    "requiresItems": [
                        {
                            "id": "72b4448e-27d9-4746-bd3a-967ff13f501b",
                            "count": 1
                        },
                        {
                            "id": "e976bae6-e33c-428a-a20d-0aa8fde13c6c",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "wire",
            "text": "Primary path: signal to pin 9, red to 5 V supply, black/brown to GND. Secure servo horn clearance so it cannot strike hands or tools during motion.",
            "options": [
                {
                    "type": "goto",
                    "goto": "upload",
                    "text": "Wiring complete. Continue to upload."
                }
            ]
        },
        {
            "id": "ide-path",
            "text": "Alternate path: install Arduino IDE and open Servo > Sweep sketch first so your code and board settings are ready before energizing hardware.",
            "options": [
                {
                    "type": "process",
                    "process": "arduino-ide-install",
                    "text": "Install the Arduino IDE."
                },
                {
                    "type": "goto",
                    "goto": "wire",
                    "text": "Software ready. Return to wiring path."
                }
            ]
        },
        {
            "id": "upload",
            "text": "Reconnect USB only after wiring checks pass. Upload the Sweep example and observe movement. Evidence gate: servo must reach both end points without chatter or stall.",
            "options": [
                {
                    "type": "process",
                    "process": "arduino-servo-sweep",
                    "text": "Run servo sweep process."
                },
                {
                    "type": "goto",
                    "goto": "verified",
                    "text": "Servo sweeps 0°↔180° smoothly."
                },
                {
                    "type": "goto",
                    "goto": "troubleshoot",
                    "text": "Jitter, stall, or reset observed."
                }
            ]
        },
        {
            "id": "troubleshoot",
            "text": "Recovery branch: cut power, recheck common ground, confirm supply current headroom, and reseat signal lead on pin 9. If horn binds mechanically, stop and reposition linkage before retry.",
            "options": [
                {
                    "type": "goto",
                    "goto": "upload",
                    "text": "Apply fixes and re-verify sweep."
                }
            ]
        },
        {
            "id": "verified",
            "text": "Verification complete. Log power source used, observed sweep range, and whether any corrective action was needed.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Log saved. Finish quest."
                }
            ]
        },
        {
            "id": "finish",
            "text": "Great work. You used a branched setup strategy, captured mechanical evidence, and closed with safe recovery handling.",
            "options": [
                {
                    "type": "finish",
                    "text": "Can't wait!"
                }
            ]
        }
    ],
