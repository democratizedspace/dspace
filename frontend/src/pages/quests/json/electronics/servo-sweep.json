{
    "id": "electronics/servo-sweep",
    "title": "Sweep a Servo",
    "description": "Use the Arduino IDE's Servo library 'Sweep' example to rotate a hobby servo from 0° to 180°.",
    "image": "/assets/quests/electronics_servo_sweep_arduino.jpg",
    "npc": "/assets/npc/orion.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Ready to move beyond LEDs? Gather an Arduino Uno, USB cable, servo motor, jumper wires, and a 5V supply. Keep fingers clear of the horn path and secure the servo before applying power.",
            "options": [
                {
                    "type": "goto",
                    "goto": "power-plan",
                    "text": "Let's plan power and wiring."
                }
            ]
        },
        {
            "id": "power-plan",
            "text": "Choose your power strategy before wiring: USB-only for light loads, or external 5V for servos that spike current. Both routes require a shared ground and a clean signal path on pin 9.",
            "options": [
                {
                    "type": "goto",
                    "goto": "wire-usb",
                    "text": "Use USB-only power (light-load test)."
                },
                {
                    "type": "goto",
                    "goto": "wire-external",
                    "text": "Use external 5V supply (higher stability).",
                    "requiresItems": [
                        {
                            "id": "828d6c3b-66a5-4064-b221-97630274502b",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "wire-usb",
            "text": "Disconnect USB first. Connect servo signal to D9, red to 5V, and brown/black to GND. Keep wire runs short and verify the horn area is clear before reconnecting power.",
            "options": [
                {
                    "type": "goto",
                    "goto": "code",
                    "text": "USB route wired."
                },
                {
                    "type": "goto",
                    "goto": "wiring-recovery",
                    "text": "I spotted a wiring risk."
                }
            ]
        },
        {
            "id": "wire-external",
            "text": "Disconnect USB first. Connect servo signal to D9, servo red to the external 5V rail, and servo ground to supply ground. Tie Arduino GND to supply ground to avoid control drift.",
            "options": [
                {
                    "type": "goto",
                    "goto": "code",
                    "text": "External route wired."
                },
                {
                    "type": "goto",
                    "goto": "wiring-recovery",
                    "text": "Need to correct shared-ground wiring."
                }
            ]
        },
        {
            "id": "code",
            "text": "Reconnect USB, open Arduino IDE, and load File > Examples > Servo > Sweep. If IDE is missing, install it first. Upload and watch for smooth 0°↔180° travel without buzzing stalls.",
            "options": [
                {
                    "type": "process",
                    "process": "arduino-ide-install",
                    "text": "Install the Arduino IDE"
                },
                {
                    "type": "goto",
                    "goto": "evidence",
                    "text": "Servo sweeps end-to-end.",
                    "process": "arduino-servo-sweep"
                },
                {
                    "type": "goto",
                    "goto": "runtime-recovery",
                    "text": "Servo jitters, resets, or stalls."
                }
            ]
        },
        {
            "id": "wiring-recovery",
            "text": "Recovery path: power off, verify D9 signal pin, reseat grounds, and remove mechanical obstructions. Do not test with loose horns or unsecured brackets.",
            "options": [
                {
                    "type": "goto",
                    "goto": "power-plan",
                    "text": "Wiring corrected. Re-select a power strategy."
                }
            ]
        },
        {
            "id": "runtime-recovery",
            "text": "Troubleshoot runtime faults by reducing servo load, confirming shared ground, and trying the external 5V route if USB browns out. Re-test after each change until motion is stable.",
            "options": [
                {
                    "type": "goto",
                    "goto": "power-plan",
                    "text": "Apply fix and retry sweep."
                }
            ]
        },
        {
            "id": "evidence",
            "text": "Evidence gate: verify at least three full sweeps with no collisions, no power resets, and repeatable end stops. If any criterion fails, route back to troubleshooting before finish.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Evidence captured and stable.",
                    "requiresItems": [
                        {
                            "id": "e976bae6-e33c-428a-a20d-0aa8fde13c6c",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "runtime-recovery",
                    "text": "Need to fix reliability issues first."
                }
            ]
        },
        {
            "id": "finish",
            "text": "Nice work! You proved repeatable servo control with safety checks and recovery discipline in place.",
            "options": [
                {
                    "type": "finish",
                    "text": "Can't wait to build more motion systems!"
                }
            ]
        }
    ],
    "rewards": [
        {
            "id": "b281360b-2ecc-4fea-a248-36a61c5f7399",
            "count": 1
        }
    ],
