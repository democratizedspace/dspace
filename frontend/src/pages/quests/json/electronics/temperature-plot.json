{
    "id": "electronics/temperature-plot",
    "title": "Plot Temperature Data",
    "description": "Generate a chart from your thermistor log using Python.",
    "image": "/assets/quests/electronics_temperature_plot_python.jpg",
    "npc": "/assets/npc/orion.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "You've been logging temperatures with your Pi. Let's turn that data into a chart you can use for decisions, not just pretty lines.",
            "options": [
                {
                    "type": "goto",
                    "goto": "prep",
                    "text": "I'm ready."
                }
            ]
        },
        {
            "id": "prep",
            "text": "Copy the log file, confirm timestamps are consistent, and keep a backup before editing. We need a complete dataset for the full review window.",
            "options": [
                {
                    "type": "goto",
                    "goto": "plot",
                    "text": "Log file copied and backed up.",
                    "requiresItems": [
                        {
                            "id": "fb60696a-6c94-4e5e-9277-b62377ee6d73",
                            "count": 1
                        },
                        {
                            "id": "ce140453-c7ef-42c9-b9f9-38acfb4219cf",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "repair-data",
                    "text": "Some rows are missing timestamps or look corrupted."
                }
            ]
        },
        {
            "id": "repair-data",
            "text": "Troubleshoot the dataset: remove duplicate timestamps, mark sensor dropouts, and rerun one short capture cycle so anomalies are explainable. Do not overwrite the original backup.",
            "options": [
                {
                    "type": "process",
                    "process": "plot-temperature-data",
                    "text": "Run a test parse to confirm the CSV is usable."
                },
                {
                    "type": "goto",
                    "goto": "plot",
                    "text": "Dataset cleaned and test parse succeeded."
                }
            ]
        },
        {
            "id": "plot",
            "text": "Generate a plot and record checkpoint metrics: average temperature, max-min spread, and any period above 35\u00b0C. These values are your evidence artifact.",
            "options": [
                {
                    "type": "process",
                    "process": "plot-temperature-data",
                    "text": "Generate chart and metrics snapshot."
                },
                {
                    "type": "goto",
                    "goto": "interpret",
                    "text": "Chart exported with metrics notes.",
                    "requiresItems": [
                        {
                            "id": "fb60696a-6c94-4e5e-9277-b62377ee6d73",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "interpret",
            "text": "Interpretation gate: pass when spread stays within your expected range and no unexplained >35\u00b0C spikes appear. If spikes exist, classify likely cause and verify with a rerun.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Metrics are within range and anomalies explained."
                },
                {
                    "type": "goto",
                    "goto": "repair-data",
                    "text": "Out-of-range spike detected; run corrective logging pass."
                }
            ]
        },
        {
            "id": "finish",
            "text": "Nice work. Save the chart and notes with date/time so future troubleshooting can compare trends. Structured evidence beats memory every time.",
            "options": [
                {
                    "type": "finish",
                    "text": "Temperature trends documented."
                }
            ]
        }
    ],
    "rewards": [
        {
            "id": "b281360b-2ecc-4fea-a248-36a61c5f7399",
            "count": 1
        }
    ],
