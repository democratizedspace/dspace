{
    "id": "electronics/temperature-plot",
    "title": "Plot Temperature Data",
    "description": "Generate a chart from your thermistor log using Python.",
    "image": "/assets/quests/electronics_temperature_plot_python.jpg",
    "npc": "/assets/npc/orion.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "You've been logging temperatures with your Pi. Let's turn that data into a chart and verify whether it stays inside a safe operating band.",
            "options": [
                {
                    "type": "goto",
                    "goto": "prep",
                    "text": "I'm ready."
                }
            ]
        },
        {
            "id": "prep",
            "text": "Copy the log file to your computer and install matplotlib. Keep a backup of the data and confirm your CSV has timestamp,temp_c headers.",
            "options": [
                {
                    "type": "goto",
                    "goto": "define-thresholds",
                    "text": "Log file copied.",
                    "requiresItems": [
                        {
                            "id": "fb60696a-6c94-4e5e-9277-b62377ee6d73",
                            "count": 1
                        },
                        {
                            "id": "ce140453-c7ef-42c9-b9f9-38acfb4219cf",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "define-thresholds",
            "text": "Use this threshold policy before plotting: expected temp range is 18-30 C. A run passes only if at least 90% of points are inside range and there are no sudden jumps over 5 C between adjacent points.",
            "options": [
                {
                    "type": "goto",
                    "goto": "plot",
                    "text": "Threshold policy documented."
                }
            ]
        },
        {
            "id": "plot",
            "text": "Run a short Python script to read the CSV and render a line chart of temperature over time.",
            "options": [
                {
                    "type": "process",
                    "process": "plot-temperature-data",
                    "text": "Run the plotting process."
                },
                {
                    "type": "goto",
                    "goto": "interpret",
                    "text": "Chart generated."
                }
            ]
        },
        {
            "id": "interpret",
            "text": "Interpret the chart against the thresholds. If data is in-band and stable, you can close the task. If not, classify the issue and collect a corrected run. Stop and investigate immediately if sensor wiring warms up or readings flatline unexpectedly.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "In-band and stable (>=90% inside 18-30 C, no >5 C jumps).",
                    "requiresItems": [
                        {
                            "id": "fb60696a-6c94-4e5e-9277-b62377ee6d73",
                            "count": 1
                        },
                        {
                            "id": "ce140453-c7ef-42c9-b9f9-38acfb4219cf",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "anomaly-response",
                    "text": "Out-of-band points or unstable jumps detected."
                }
            ]
        },
        {
            "id": "anomaly-response",
            "text": "Corrective branch: verify thermistor seating, inspect jumper connections, and confirm timestamps are monotonic. Re-run logging for at least 10 rows before plotting again.",
            "options": [
                {
                    "type": "goto",
                    "goto": "plot",
                    "text": "Applied fixes; generate a new chart."
                }
            ]
        },
        {
            "id": "finish",
            "text": "Nice! You generated a chart, interpreted it with explicit limits, and closed only after stable evidence.",
            "options": [
                {
                    "type": "finish",
                    "text": "Cool!"
                }
            ]
        }
    ],
    "rewards": [
        {
            "id": "b281360b-2ecc-4fea-a248-36a61c5f7399",
            "count": 1
        }
    ],
