{
    "id": "electronics/continuity-test",
    "title": "Check USB cable continuity",
    "description": "Use a digital multimeter in continuity mode to check an unplugged USB cable while wearing safety goggles.",
    "image": "/assets/quests/basic_circuit.svg",
    "npc": "/assets/npc/orion.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Never test a cable connected to power or equipment. Confirm the USB cable is unplugged from all devices. Check the insulation for cuts or frays. Put on safety goggles, then place the cable, a digital multimeter, wire cutters and electrical tape on a dry, non-conductive surface.",
            "options": [
                {
                    "type": "goto",
                    "goto": "probe",
                    "text": "Ready to test."
                }
            ]
        },
        {
            "id": "probe",
            "text": "Set the multimeter to continuity mode. Touch one probe to a pin on one end and the other probe to the matching pin on the opposite end. Keep fingers behind the probe guards and avoid touching other contacts.",
            "options": [
                {
                    "type": "process",
                    "process": "test-cable-continuity",
                    "text": "Run the continuity test."
                },
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "It beeped and read near zero ohms.",
                    "requiresItems": [
                        {
                            "id": "5127e156-3009-4db4-85ac-e3ea070b68f2",
                            "count": 1
                        },
                        {
                            "id": "fb60696a-6c94-4e5e-9277-b62377ee6d73",
                            "count": 1
                        },
                        {
                            "id": "c9b51052-4594-42d7-a723-82b815ab8cc2",
                            "count": 1
                        },
                        {
                            "id": "ce92a1a9-c817-40f0-92b1-24aff053903d",
                            "count": 1
                        },
                        {
                            "id": "946bc4dd-32ee-434c-a8ed-d70cdce617f4",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "finish",
            "text": "Turn off the meter. If every conductor beeps, coil the cable loosely and store it dry. If a conductor fails, cut the cable into short pieces with wire cutters and wrap the ends in electrical tape before recycling. Remove your goggles and take this GFCI outlet tester for future wiring checks.",
            "options": [
                {
                    "type": "finish",
                    "text": "Thanks, Orion!"
                }
            ]
        }
    ],
    "rewards": [
        {
            "id": "5562d728-8e62-43b2-9b3d-77cebd2ab481",
            "count": 1
        }
    ],
    "requiresQuests": ["electronics/solder-wire"],
