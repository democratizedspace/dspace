{
    "id": "electronics/continuity-test",
    "title": "Check USB cable continuity",
    "description": "Use a digital multimeter in continuity mode to check an unplugged USB cable while wearing safety goggles.",
    "image": "/assets/quests/electronics_usb_cable_continuity_test.jpg",
    "npc": "/assets/npc/orion.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Orion here. First safety gate: verify the USB cable is unplugged from every device, inspect for frayed insulation, and set up on a dry non-conductive surface.",
            "options": [
                {
                    "type": "goto",
                    "goto": "setup",
                    "text": "Area is safe and cable is isolated."
                }
            ]
        },
        {
            "id": "setup",
            "text": "Gather digital multimeter, USB cable, safety goggles, wire cutters, and electrical tape. Keep fingers behind probe guards and avoid touching two contacts at once.",
            "options": [
                {
                    "type": "goto",
                    "goto": "measure",
                    "text": "Gear ready. Run continuity checks.",
                    "requiresItems": [
                        {
                            "id": "5127e156-3009-4db4-85ac-e3ea070b68f2",
                            "count": 1
                        },
                        {
                            "id": "fb60696a-6c94-4e5e-9277-b62377ee6d73",
                            "count": 1
                        },
                        {
                            "id": "c9b51052-4594-42d7-a723-82b815ab8cc2",
                            "count": 1
                        },
                        {
                            "id": "ce92a1a9-c817-40f0-92b1-24aff053903d",
                            "count": 1
                        },
                        {
                            "id": "946bc4dd-32ee-434c-a8ed-d70cdce617f4",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "measure",
            "text": "Test each conductor end-to-end and log the reading. Pass band is a beep with ~0-1 ohm. Borderline is 1-5 ohms. Open or unstable readings above 5 ohms fail.",
            "options": [
                {
                    "type": "process",
                    "process": "test-cable-continuity",
                    "text": "Capture continuity measurements."
                },
                {
                    "type": "goto",
                    "goto": "pass",
                    "text": "All conductors are in the 0-1 ohm pass band."
                },
                {
                    "type": "goto",
                    "goto": "anomaly",
                    "text": "At least one conductor is borderline/open."
                }
            ]
        },
        {
            "id": "pass",
            "text": "Interpretation: low-resistance continuity confirms the cable can stay in service. Coil it loosely and label it tested.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Log complete. Close quest."
                }
            ]
        },
        {
            "id": "anomaly",
            "text": "Safety stop: do NOT connect this cable to powered equipment. Classify the issue as borderline (1-5 ohms) or open (>5 ohms/no beep).",
            "options": [
                {
                    "type": "goto",
                    "goto": "recover",
                    "text": "Run corrective checks and re-test."
                },
                {
                    "type": "goto",
                    "goto": "retire",
                    "text": "Retire and recycle the cable now."
                }
            ]
        },
        {
            "id": "recover",
            "text": "Corrective branch: clean connector pins, reseat probe contact, and retest each conductor. If any line remains >5 ohms after retest, retire the cable.",
            "options": [
                {
                    "type": "process",
                    "process": "test-cable-continuity",
                    "text": "Run mandatory re-test."
                },
                {
                    "type": "goto",
                    "goto": "measure",
                    "text": "Return to thresholds and classify again."
                }
            ]
        },
        {
            "id": "retire",
            "text": "Use wire cutters to chop the failed cable into short segments, wrap exposed ends with electrical tape, and send it to e-waste.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Retirement logged."
                }
            ]
        },
        {
            "id": "finish",
            "text": "Good work. You documented evidence, applied pass/fail bounds, and used a safe anomaly path before closure.",
            "options": [
                {
                    "type": "finish",
                    "text": "Thanks, Orion!"
                }
            ]
        }
    ],
    "rewards": [
        {
            "id": "5562d728-8e62-43b2-9b3d-77cebd2ab481",
            "count": 1
        }
    ],
