{
    "id": "electronics/continuity-test",
    "title": "Check USB cable continuity",
    "description": "Use a digital multimeter in continuity mode to check an unplugged USB cable while wearing safety goggles.",
    "image": "/assets/quests/electronics_usb_cable_continuity_test.jpg",
    "npc": "/assets/npc/orion.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Never test a cable connected to power or equipment. Confirm the USB cable is unplugged from all devices. Check the insulation for cuts or frays. Put on safety goggles, then place the cable, a digital multimeter, wire cutters and electrical tape on a dry, non-conductive surface.",
            "options": [
                {
                    "type": "goto",
                    "goto": "probe",
                    "text": "Ready to test."
                }
            ]
        },
        {
            "id": "probe",
            "text": "Set the multimeter to continuity mode. Test each conductor one-by-one (VBUS, D-, D+, GND) and write down either \"beep / <2 Ω\" or \"open / no beep\" for every pin pair. Keep fingers behind probe guards and never test a plugged-in cable.",
            "options": [
                {
                    "type": "process",
                    "process": "test-cable-continuity",
                    "text": "Run and log the continuity sweep."
                },
                {
                    "type": "goto",
                    "goto": "interpret",
                    "text": "All four conductors are logged.",
                    "requiresItems": [
                        {
                            "id": "5127e156-3009-4db4-85ac-e3ea070b68f2",
                            "count": 1
                        },
                        {
                            "id": "fb60696a-6c94-4e5e-9277-b62377ee6d73",
                            "count": 1
                        },
                        {
                            "id": "c9b51052-4594-42d7-a723-82b815ab8cc2",
                            "count": 1
                        },
                        {
                            "id": "ce92a1a9-c817-40f0-92b1-24aff053903d",
                            "count": 1
                        },
                        {
                            "id": "946bc4dd-32ee-434c-a8ed-d70cdce617f4",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "interpret",
            "text": "Interpret your log. Pass criteria: all four conductors beep and read under 2 Ω. If any line is open or above 2 Ω, treat the cable as failed and isolate it from service.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "All readings are <2 Ω and stable."
                },
                {
                    "type": "goto",
                    "goto": "repair-check",
                    "text": "At least one conductor failed continuity."
                }
            ]
        },
        {
            "id": "repair-check",
            "text": "Troubleshoot safely: inspect both connectors for bent pins or contamination, trim obviously damaged jacket sections with wire cutters, and retest with clean probes. If repeated failure persists, permanently retire and recycle the cable.",
            "options": [
                {
                    "type": "process",
                    "process": "test-cable-continuity",
                    "text": "Retest after corrective action."
                },
                {
                    "type": "goto",
                    "goto": "interpret",
                    "text": "I logged the second test cycle."
                }
            ]
        },
        {
            "id": "finish",
            "text": "Turn off the meter and archive your continuity notes with the cable label. Serviceable cables get coiled and stored dry; failed cables are cut, taped, and recycled so nobody plugs them in by accident. Remove your goggles and take this GFCI outlet tester for future wiring checks.",
            "options": [
                {
                    "type": "finish",
                    "text": "Thanks, Orion!"
                }
            ]
        }
    ],
    "rewards": [
        {
            "id": "5562d728-8e62-43b2-9b3d-77cebd2ab481",
            "count": 1
        }
    ],
