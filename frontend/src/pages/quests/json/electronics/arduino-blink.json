                            "count": 1
                        },
                        {
                            "id": "c9b51052-4594-42d7-a723-82b815ab8cc2",
                            "count": 1
                        },
                        {
                            "id": "be3aaed8-13cc-4937-95d5-6e2c952c6612",
                            "count": 1
                        },
                        {
                            "id": "b6fc1ed6-f399-4fdb-9f9d-3913f893f43d",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "upload",
            "text": "Connect the board with the USB cable. In the Arduino IDE open File > Examples > 01.Basics > Blink. Under Tools choose Board: Arduino Uno and the correct Port, then click Upload. Wait for 'Done uploading'; the LED blinks once per second. Avoid touching the circuit while it's powered.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Upload complete and the LED is blinking!"
                }
            ]
        },
        {
            "id": "finish",
            "text": "Nice work—you just programmed a microcontroller. Unplug the USB cable before adjusting wiring and avoid staring into the LED. For a detailed walkthrough, open the blink process. Try new patterns or sensors next.",
            "options": [
                {
                    "type": "process",
                    "process": "arduino-led-blink",
                    "text": "Open the detailed blink process"
                },
                {
                    "type": "finish",
                    "text": "Thanks Orion, that was awesome!"
                }
            ]
        }
    ],
