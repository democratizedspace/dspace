            "id": "splice-path",
            "text": "Choose a splice strategy: western-union twist for strain resistance or overlap splice for faster repair.",
            "options": [
                {
                    "type": "goto",
                    "goto": "western-union",
                    "text": "Use western-union twist with pliers."
                },
                {
                    "type": "goto",
                    "goto": "overlap",
                    "text": "Use overlap splice and reinforce with solder."
                }
            ]
        },
        {
            "id": "western-union",
            "text": "Twist conductors in opposite directions, apply flux, and solder until wetting is even across the splice.",
            "options": [
                {
                    "type": "process",
                    "process": "solder-wire-connection",
                    "text": "Run western-union solder workflow."
                },
                {
                    "type": "goto",
                    "goto": "verify",
                    "text": "Splice soldered; proceed to verification."
                },
                {
                    "type": "goto",
                    "goto": "fault",
                    "text": "Joint overheated, brittle, or misaligned."
                }
            ]
        },
        {
            "id": "overlap",
            "text": "Overlap stripped conductors, clamp with pliers, tack both sides, then fully wet the joint and slide heat-shrink into place.",
            "options": [
                {
                    "type": "process",
                    "process": "solder-wire-connection",
                    "text": "Run overlap splice workflow."
                },
                {
                    "type": "goto",
                    "goto": "verify",
                    "text": "Overlap splice complete; verify."
                },
                {
                    "type": "goto",
                    "goto": "fault",
                    "text": "Cold joint or exposed strands found."
                }
            ]
        },
        {
