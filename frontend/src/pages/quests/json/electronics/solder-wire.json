{
    "id": "electronics/solder-wire",
    "title": "Solder a Wire Connection",
    "description": "Repair a snapped jumper lead with staged prep, splice verification, and fault-recovery loops under solder safety controls.",
    "image": "/assets/quests/electronics_solder_wire_connection.jpg",
    "npc": "/assets/npc/orion.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "A lead snapped. Ventilate, enable the fume extractor, wear goggles, keep the hot iron on its stand, and clear flammables.",
