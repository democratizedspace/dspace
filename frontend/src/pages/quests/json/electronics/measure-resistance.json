{
    "id": "electronics/measure-resistance",
    "title": "Measure a Resistor",
    "description": "Use a digital multimeter to confirm a loose resistor's value. Disconnect all power, keep metal jewelry off, set components on a dry non-conductive surface, and wear safety goggles.",
    "image": "/assets/quests/electronics_measure_resistor_multimeter.jpg",
    "npc": "/assets/npc/orion.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Set up on a dry, non-conductive surface. Put on goggles, insert black probe into COM and red into VΩmA, then set the meter above expected resistance. Keep all circuit power disconnected.",
            "options": [
                {
                    "type": "goto",
                    "goto": "baseline-check",
                    "text": "Safety checks complete"
                }
            ]
        },
        {
            "id": "baseline-check",
            "text": "Before measuring, confirm the resistor color bands predict about 220 Ω and the leads are clean. This is your baseline expectation artifact.",
            "options": [
                {
                    "type": "goto",
                    "goto": "measure",
                    "text": "Baseline noted: target band is around 220 Ω",
                    "requiresItems": [
                        {
                            "id": "5127e156-3009-4db4-85ac-e3ea070b68f2",
                            "count": 1
                        },
                        {
                            "id": "037e6065-68a7-4ad1-9b0b-7778ecfe0662",
                            "count": 1
                        },
                        {
                            "id": "c9b51052-4594-42d7-a723-82b815ab8cc2",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "measure",
            "text": "Touch one probe per lead while holding only insulated handles. Wait for a stable reading and record it. Pass band for this quest is 200–240 Ω. Stop immediately if probes slip or the resistor warms.",
            "options": [
                {
                    "type": "goto",
                    "goto": "interpret",
                    "text": "Recorded reading is between 200 Ω and 240 Ω",
                    "process": "measure-resistance"
                },
                {
                    "type": "goto",
                    "goto": "out-of-range",
                    "text": "Recorded reading is outside 200–240 Ω",
                    "process": "measure-resistance"
                }
            ]
        },
        {
            "id": "out-of-range",
            "text": "Out-of-range troubleshooting: power remains disconnected, clean probe tips, re-seat leads, and rotate the resistor 90° to avoid hand contact noise. If still out of range, swap in a known-good resistor before retrying.",
            "options": [
                {
                    "type": "goto",
                    "goto": "measure",
                    "text": "Corrective action done; re-test now"
                }
            ]
        },
        {
            "id": "interpret",
            "text": "Interpretation check: the measured value aligns with the color-band estimate and tolerance window, so the component is serviceable for a 220 Ω circuit.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Value interpretation documented"
                }
            ]
        },
        {
            "id": "finish",
            "text": "Label the resistor value, turn off the meter, cap probe tips, and store tools dry.",
            "options": [
                {
                    "type": "finish",
                    "text": "Thanks, Orion!"
                }
            ]
        }
    ],
    "rewards": [
        {
            "id": "b281360b-2ecc-4fea-a248-36a61c5f7399",
            "count": 1
        }
    ],
