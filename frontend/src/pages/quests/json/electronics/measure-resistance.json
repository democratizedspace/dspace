{
    "id": "electronics/measure-resistance",
    "title": "Measure a Resistor",
    "description": "Use a digital multimeter to confirm a loose resistor's value. Disconnect all power, keep metal jewelry off, set components on a dry non-conductive surface, and wear safety goggles.",
    "image": "/assets/quests/electronics_measure_resistor_multimeter.jpg",
    "npc": "/assets/npc/orion.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Orion here. We'll verify resistor value with measurable bounds and a recovery loop. Keep all circuits unpowered before touching probes to component leads.",
            "options": [
                {
                    "type": "goto",
                    "goto": "setup",
                    "text": "Safe bench ready."
                }
            ]
        },
        {
            "id": "setup",
            "text": "Place a loose 220 ohm resistor, digital multimeter, and safety goggles on a dry surface. Black probe goes to COM, red to VΩmA, meter in resistance mode at 2 kΩ or higher range.",
            "options": [
                {
                    "type": "goto",
                    "goto": "measure",
                    "text": "Start measurement.",
                    "requiresItems": [
                        {
                            "id": "5127e156-3009-4db4-85ac-e3ea070b68f2",
                            "count": 1
                        },
                        {
                            "id": "037e6065-68a7-4ad1-9b0b-7778ecfe0662",
                            "count": 1
                        },
                        {
                            "id": "c9b51052-4594-42d7-a723-82b815ab8cc2",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "measure",
            "text": "Touch probes to opposite leads without finger contact on bare metal. Log the stabilized ohm reading. Pass window for this resistor is 198-242 ohms (±10%).",
            "options": [
                {
                    "type": "process",
                    "process": "measure-resistance",
                    "text": "Capture resistor reading."
                },
                {
                    "type": "goto",
                    "goto": "in-range",
                    "text": "Reading is between 198 and 242 ohms."
                },
                {
                    "type": "goto",
                    "goto": "out-of-range",
                    "text": "Reading is outside 198-242 ohms."
                }
            ]
        },
        {
            "id": "in-range",
            "text": "Interpretation: resistor matches expected tolerance and can be labeled as verified stock.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Value logged and labeled."
                }
            ]
        },
        {
            "id": "out-of-range",
            "text": "Safety stop: do not install this resistor into a live build yet. Classify as probe error, lead contamination, or likely wrong/damaged part.",
            "options": [
                {
                    "type": "goto",
                    "goto": "recover",
                    "text": "Clean leads, re-range meter, and re-test."
                },
                {
                    "type": "goto",
                    "goto": "quarantine",
                    "text": "Quarantine this resistor for later review."
                }
            ]
        },
        {
            "id": "recover",
            "text": "Corrective branch: wipe resistor leads, confirm meter range, and keep hands on probe insulation. Re-test once; if still out-of-range, quarantine.",
            "options": [
                {
                    "type": "process",
                    "process": "measure-resistance",
                    "text": "Run mandatory re-test."
                },
                {
                    "type": "goto",
                    "goto": "measure",
                    "text": "Re-evaluate against pass bounds."
                }
            ]
        },
        {
            "id": "quarantine",
            "text": "Bag and label the component as suspect, then use a known-good resistor for powered circuits.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Quarantine complete."
                }
            ]
        },
        {
            "id": "finish",
            "text": "Done. You produced a measurement artifact, interpreted tolerance, and handled out-of-range results safely.",
            "options": [
                {
                    "type": "finish",
                    "text": "Thanks, Orion!"
                }
            ]
        }
    ],
    "rewards": [
        {
            "id": "b281360b-2ecc-4fea-a248-36a61c5f7399",
            "count": 1
        }
    ],
    "requiresQuests": ["electronics/resistor-color-check"],
