{
    "id": "electronics/measure-resistance",
    "title": "Measure a Resistor",
    "description": "Use a digital multimeter to confirm a loose resistor's value. Disconnect all power, keep metal jewelry off, set components on a dry non-conductive surface, and wear safety goggles.",
    "image": "/assets/quests/electronics_measure_resistor_multimeter.jpg",
    "npc": "/assets/npc/orion.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Place the loose resistor, digital multimeter, and safety goggles on a dry non-conductive surface. Put goggles on, remove jewelry, and keep the resistor isolated from any powered circuit.",
            "options": [
                {
                    "type": "goto",
                    "goto": "baseline",
                    "text": "Bench is safe. Capture baseline reading.",
                    "requiresItems": [
                        {
                            "id": "5127e156-3009-4db4-85ac-e3ea070b68f2",
                            "count": 1
                        },
                        {
                            "id": "c9b51052-4594-42d7-a723-82b815ab8cc2",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "safety-stop",
                    "text": "I need to de-energize the work area first."
                }
            ]
        },
        {
            "id": "baseline",
            "text": "Set black probe to COM, red to VΩmA, and select a resistance range above the expected value. Measure without touching exposed metal and log the stabilized reading.",
            "options": [
                {
                    "type": "process",
                    "process": "measure-resistance",
                    "text": "Capture resistance measurement artifact."
                },
                {
                    "type": "goto",
                    "goto": "interpret",
                    "text": "Reading captured. Check tolerance.",
                    "requiresItems": [
                        {
                            "id": "037e6065-68a7-4ad1-9b0b-7778ecfe0662",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "interpret",
            "text": "Compare measured value to color-band expectation. Pass if inside ±5% (or component tolerance spec). If out of range, treat as fail and run corrective checks.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Within tolerance and documented.",
                    "requiresItems": [
                        {
                            "id": "037e6065-68a7-4ad1-9b0b-7778ecfe0662",
                            "count": 1
                        },
                        {
                            "id": "5127e156-3009-4db4-85ac-e3ea070b68f2",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "corrective",
                    "text": "Outside tolerance or unstable reading."
                }
            ]
        },
        {
            "id": "corrective",
            "text": "Corrective loop: clean probe tips, increase meter range if clipping, re-seat resistor leads, then re-measure. Safety stop if resistor is hot, cracked, or discolored.",
            "options": [
                {
                    "type": "goto",
                    "goto": "baseline",
                    "text": "Corrective action done. Re-test now.",
                    "requiresItems": [
                        {
                            "id": "5127e156-3009-4db4-85ac-e3ea070b68f2",
                            "count": 1
                        }
                    ]
                },
                {
                    "type": "goto",
                    "goto": "safety-stop",
                    "text": "Component damage observed; stop testing."
                }
            ]
        },
        {
            "id": "safety-stop",
            "text": "Pause the task. Quarantine the suspect resistor, verify the bench is de-energized, and restart only with a known-good component.",
            "options": [
                {
                    "type": "goto",
                    "goto": "start",
                    "text": "Known-good resistor ready. Restart measurement flow."
                }
            ]
        },
        {
            "id": "finish",
            "text": "Great work. You validated resistance with explicit tolerance bounds and a corrective re-test path.",
            "options": [
                {
                    "type": "finish",
                    "text": "Resistor value confirmed."
                }
            ]
        }
    ],
    "rewards": [
        {
            "id": "b281360b-2ecc-4fea-a248-36a61c5f7399",
            "count": 1
        }
    ],
