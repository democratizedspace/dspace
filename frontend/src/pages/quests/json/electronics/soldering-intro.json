                            "count": 1
                        },
                        {
                            "id": "cd0e1512-9b4e-4450-92ab-b298852ca5e7",
                            "count": 1
                        },
                        {
                            "id": "3dbf1701-5cc0-4443-b9bf-4275b33513d0",
                            "count": 1
                        }
                    ]
                }
            ]
        },
        {
            "id": "tin",
            "text": "Once the tip is hot, melt a little solder across it, then wipe on the damp sponge to leave a thin, shiny layer that resists oxidation.",
            "options": [
                {
                    "type": "goto",
                    "goto": "finish",
                    "text": "Tip looks shiny."
                }
            ]
        },
        {
            "id": "finish",
            "text": "Nice work! A tinned tip makes future joints easier and cleaner. Unplug the iron and let it cool safely.",
            "options": [
                {
                    "type": "finish",
                    "text": "All done."
                }
            ]
        }
