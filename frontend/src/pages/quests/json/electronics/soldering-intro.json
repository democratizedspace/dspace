{
    "id": "electronics/tin-soldering-iron",
    "title": "Tin a Soldering Iron",
    "description": "Prepare your soldering iron for clean joints by tinning the tip.",
    "image": "/assets/quests/basic_circuit.svg",
    "npc": "/assets/npc/orion.jpg",
    "start": "start",
    "dialogue": [
        {
            "id": "start",
            "text": "Good to see you progressing! Before soldering, lay out a silicone mat, secure your work in helping hands, plug in your station, keep a brass tip cleaner nearby, and have a damp sponge ready.",
            "options": [
                {
                    "type": "goto",
                    "goto": "tin",
                    "text": "Iron is heating up.",
                    "requiresItems": [
