---
import Page from '../../components/Page.astro';
import Quests from './svelte/Quests.svelte';
import { buildQuestGraph } from '../../lib/quests/questGraph';

const quests = await Astro.glob('./json/*/*.json');
const graph = buildQuestGraph();
---

<Page title="Quests">
    <Quests client:load quests={quests} graph={graph} />
</Page>
