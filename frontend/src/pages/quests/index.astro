---
import Page from '../../components/Page.astro';
import Quests from './svelte/Quests.svelte';
import QuestGraphVisualizer from '../../components/quests/QuestGraphVisualizer.svelte';
import { buildQuestGraph } from '../../lib/quests/questGraph';

const questModules = import.meta.glob('./json/*/*.json', { eager: true });
const quests = Object.entries(questModules)
    .sort(([a], [b]) => a.localeCompare(b))
    .map(([, mod]) => mod);
const graph = buildQuestGraph();
---

<Page title="Quests">
    <Quests client:load quests={quests}>
        <QuestGraphVisualizer slot="visualizer" client:visible graph={graph} />
    </Quests>
</Page>
