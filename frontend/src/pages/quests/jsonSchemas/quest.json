{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "properties": {
        "id": {
            "type": "string"
        },
        "title": {
            "type": "string"
        },
        "description": {
            "type": "string"
        },
        "image": {
            "type": "string"
        },
        "npc": {
            "type": "string"
        },
        "start": {
            "type": "string"
        },
        "dialogue": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "id": {
                        "type": "string"
                    },
                    "text": {
                        "type": "string"
                    },
                    "options": {
                        "type": "array",
                        "items": {
                            "type": "object",
                            "properties": {
                                "type": {
                                    "type": "string"
                                },
                                "goto": {
                                    "type": "string"
                                },
                                "process": {
                                    "type": "string"
                                },
                                "requiresItems": {
                                    "type": "array",
                                    "items": {
                                        "type": "object",
                                        "properties": {
                                            "id": {
                                                "type": "string"
                                            },
                                            "count": {
                                                "type": "number"
                                            }
                                        },
                                        "required": ["id", "count"]
                                    }
                                },
                                "requiresContainedItems": {
                                    "type": "array",
                                    "items": {
                                        "type": "object",
                                        "properties": {
                                            "containerItemId": {
                                                "type": "string"
                                            },
                                            "itemId": {
                                                "type": "string"
                                            },
                                            "id": {
                                                "type": "string"
                                            },
                                            "count": {
                                                "type": "number"
                                            }
                                        },
                                        "required": ["containerItemId", "count"],
                                        "anyOf": [
                                            {
                                                "required": ["itemId"]
                                            },
                                            {
                                                "required": ["id"]
                                            }
                                        ]
                                    }
                                },
                                "grantsItems": {
                                    "type": "array",
                                    "items": {
                                        "type": "object",
                                        "properties": {
                                            "id": {
                                                "type": "string"
                                            },
                                            "count": {
                                                "type": "number"
                                            }
                                        },
                                        "required": ["id", "count"]
                                    }
                                },
                                "requiresGitHub": {
                                    "type": "boolean"
                                },
                                "text": {
                                    "type": "string"
                                }
                            },
                            "required": ["type", "text"]
                        }
                    }
                },
                "required": ["id", "text"]
            }
        },
        "rewards": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "id": {
                        "type": "string"
                    },
                    "count": {
                        "type": "number"
                    }
                },
                "required": ["id", "count"]
            }
        },
        "requiresQuests": {
            "type": "array",
            "items": {
                "type": "string"
            }
        },
        "hardening": {
            "$ref": "https://dspace.local/schemas/hardening.json"
        }
    },
    "required": ["id", "title", "description", "image", "npc", "start", "dialogue", "hardening"]
}
