---
import Page from '../../components/Page.astro';
import QuestFormPage from '../../components/svelte/QuestFormPage.svelte';

const questModules = import.meta.glob('./json/*/*.json', { eager: true });
// Sort by file path for deterministic ordering across builds
const quests = Object.entries(questModules)
    .sort(([a], [b]) => a.localeCompare(b))
    .map(([, mod]) => mod);
---

<Page title="Create a New Quest">
    <QuestFormPage client:load existingQuests={quests.map((q) => q.default)} />
</Page>
