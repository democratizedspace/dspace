---
import Page from '../../components/Page.astro';
import Exporter from './svelte/Exporter.svelte';
import Importer from './svelte/Importer.svelte';
---

<Page title="Custom Content Backup" columns="1">
    <li class="page-section surface-plain">
        <div class="vertical">
            <Exporter client:idle />
            <Importer client:idle />
        </div>
    </li>
</Page>

<style>
    .vertical {
        display: flex;
        flex-direction: column;
		align-items: center;
		gap: 1.25rem;
		width: min(960px, 100%);
		margin: 0 auto;
    }

	.vertical :global(nav) {
		width: min(720px, 100%);
		display: flex;
		justify-content: center;
	}

	.vertical :global(nav button) {
		width: 100%;
		display: flex;
		flex-direction: column;
		align-items: stretch;
	}
</style>
