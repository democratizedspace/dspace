---
import Page from '../../components/Page.astro';
import Exporter from './svelte/Exporter.svelte';
import Importer from './svelte/Importer.svelte';
---

<Page title="Custom Content Backup" columns="1">
    <li class="page-section surface-plain">
        <div class="vertical">
            <Exporter client:idle />
            <Importer client:idle />
        </div>
    </li>
</Page>

<style>
    .vertical {
        display: flex;
        flex-direction: column;
        align-items: center;
        width: 100%;
    }
</style>
