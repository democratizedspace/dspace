---
import Card from '../../../../components/Card.astro';
import Page from '../../../../components/Page.astro';
import EditItem from '../../svelte/EditItem.svelte';

const { itemId } = Astro.params;
const title = 'Edit Custom Item';
---

<Page title={title} message="Update the details of your custom inventory item.">
    <Card title={title} textbox={true}>
        <div class="form-container">
            <EditItem {itemId} client:load />
        </div>
    </Card>
</Page>

<style>
    .form-container {
        margin-top: 0.5rem;
    }

    .form-container :global(form) {
        background: rgba(0, 0, 0, 0.3);
        border: 1px solid var(--color-border);
        border-radius: 16px;
        padding: 1.5rem;
        box-shadow: 0 10px 28px rgba(0, 0, 0, 0.22);
        color: var(--color-text);
    }

    @media (max-width: 480px) {
        .form-container :global(form) {
            padding: 10px;
        }
    }
</style>
