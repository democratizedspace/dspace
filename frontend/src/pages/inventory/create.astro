---
import Card from '../../components/Card.astro';
import Page from '../../components/Page.astro';
import ItemForm from '../../components/svelte/ItemForm.svelte';

const title = "Create Custom Item";
---

<Page title={title} message="Create custom items that can be used across quests, processes, and inventory.">
    <Card title={title} textbox={true}>
        <div class="form-container">
            <ItemForm client:load />
        </div>
    </Card>
</Page>

<style>
    .form-container {
        margin-top: 0.5rem;
    }

    .form-container :global(form) {
        background: rgba(0, 0, 0, 0.3);
        border: 1px solid var(--color-border);
        border-radius: 16px;
        padding: 1.5rem;
        box-shadow: 0 10px 28px rgba(0, 0, 0, 0.22);
        color: var(--color-text);
    }
</style>
