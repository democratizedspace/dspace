---
import Layout from '../../layouts/Layout.astro';
import ItemForm from '../../components/svelte/ItemForm.svelte';

const title = "Create Custom Item";
---

<Layout title={title}>
    <main>
        <h1>{title}</h1>
        <p class="description">
            Create a custom item that can be used in quests, processes, and added to your inventory.
        </p>
        
        <div class="form-container">
            <ItemForm client:load />
        </div>
    </main>
</Layout>

<style>
    main {
        max-width: 800px;
        margin: 0 auto;
        padding: 2rem;
        color: var(--color-text);
    }
    
    h1 {
        text-align: center;
        color: #0f2;
        margin-bottom: 1rem;
    }
    
    .description {
        text-align: center;
        margin-bottom: 2rem;
        color: #68d46d;
        font-size: 1.1rem;
        line-height: 1.6;
    }
    
    .form-container {
        margin-top: 2rem;
    }
</style> 