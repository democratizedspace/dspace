---
import Page from '../../components/Page.astro';
import TokenBadge from '../dchat/TokenBadge.svelte';
import Integrations from './svelte/Integrations.svelte';
import { resolveTokenPlaceRuntimeConfig } from '../../utils/tokenPlaceConfig.js';

const tokenPlace = resolveTokenPlaceRuntimeConfig(process.env);
---

<Page title="Chat" message="Talk with the game NPCs" columns="1">
    <TokenBadge client:load />
    <Integrations tokenPlace={tokenPlace} client:idle />
</Page>
