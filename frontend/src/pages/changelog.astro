---
import Page from '../components/Page.astro';
import { appendChangelogNotes } from '../utils/changelogNotes';

const changelogs = await Astro.glob('./docs/md/changelog/*.md');

const changelogsReversed = changelogs.reverse();

const slugToHeadingId = (slug) => (slug ? String(slug).toLowerCase() : 'changelog');

function prepareHtml(html, slug) {
    const withNotes = appendChangelogNotes(html, slug);
    return withNotes + `
        <style>
            img {
                width: 100%;
                border-radius: 20px;
            }

            .changelog-note {
                margin-top: 1.5rem;
                padding: 1rem;
                border-left: 4px solid var(--color-highlight, #5b21b6);
                background: rgba(91, 33, 182, 0.08);
                border-radius: 12px;
            }

            .changelog-note p {
                margin: 0.5rem 0 0;
            }
        </style>
    `;
}
---

<Page columns="1">
    {changelogsReversed.map((doc) => (
        <section id={slugToHeadingId(doc.frontmatter.slug)} class="changelog-entry">
            <div class="entry-header">
                <h3>{doc.frontmatter.title}</h3>
                <a
                    class="permalink"
                    href={`#${slugToHeadingId(doc.frontmatter.slug)}`}
                    aria-label={`Link to ${doc.frontmatter.title}`}
                >
                    #
                </a>
            </div>
            <span set:html={prepareHtml(doc.compiledContent(), doc.frontmatter.slug)}></span>
        </section>
    ))}
</Page>

<style>
    img {
        width: 100%;
        border-radius: 20px;
    }

    span {
        background-color: white;
        color: black;
        padding: 10px;
        border-radius: 20px;
    }

    .entry-header {
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .permalink {
        font-size: 1rem;
        text-decoration: none;
        color: inherit;
        opacity: 0.6;
    }

    .permalink:hover,
    .permalink:focus-visible {
        opacity: 1;
    }

    .changelog-entry {
        scroll-margin-top: 1.5rem;
    }

    .changelog-note {
        margin-top: 1.5rem;
        padding: 1rem;
        border-left: 4px solid var(--color-highlight, #5b21b6);
        background: rgba(91, 33, 182, 0.08);
        border-radius: 12px;
    }

    .changelog-note p {
        margin: 0.5rem 0 0;
    }
</style>
