---
import Page from '../components/Page.astro';
import { buildChangelogNotesHtml } from '../utils/changelogNotes.js';

const changelogs = await Astro.glob('./docs/md/changelog/*.md');

const changelogsReversed = changelogs.reverse();

function prepareHtml(doc) {
    const baseHtml = doc.compiledContent();
    const notesHtml = buildChangelogNotesHtml(doc.frontmatter?.notes);

    return baseHtml + notesHtml;
}
---

<Page columns="1">
    {changelogsReversed.map((doc) => {
        const slug = typeof doc?.frontmatter?.slug === 'string' ? doc.frontmatter.slug : '';
        const preparedHtml = prepareHtml(doc);

        return (
            <article id={slug ? `release-${slug}` : undefined}>
                <h3>{doc.frontmatter.title}</h3>
                <span set:html={preparedHtml}></span>
            </article>
        );
    })}
</Page>

<style>
    article {
        margin-bottom: 3rem;
    }

    img {
        width: 100%;
        border-radius: 20px;
    }

    span {
        background-color: white;
        color: black;
        padding: 10px;
        border-radius: 20px;
    }

    span .changelog-notes {
        margin-top: 1.5rem;
        padding: 1rem;
        border-left: 4px solid #1f2937;
        border-radius: 12px;
        background: #f3f4f6;
    }

    span .changelog-notes p {
        margin: 0;
        color: #111827;
        line-height: 1.5;
    }

    span .changelog-notes a {
        font-weight: 600;
    }
</style>
