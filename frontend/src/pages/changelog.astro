---
import Page from '../components/Page.astro';
import { appendChangelogNotes } from '../utils/changelogNotes';

const changelogs = await Astro.glob('./docs/md/changelog/*.md');

const changelogsReversed = changelogs.reverse();

const slugToHeadingId = (slug) => (slug ? String(slug).toLowerCase() : 'changelog');

function prepareHtml(html, slug) {
    return appendChangelogNotes(html, slug);
}
---

<Page columns="1">
    {changelogsReversed.map((doc) => (
        <article id={slugToHeadingId(doc.frontmatter.slug)} class="changelog-entry">
            <div class="changelog-card">
                <div class="entry-header">
                    <h3>{doc.frontmatter.title}</h3>
                    <a
                        class="permalink"
                        href={`#${slugToHeadingId(doc.frontmatter.slug)}`}
                        aria-label={`Link to ${doc.frontmatter.title}`}
                    >
                        <span class="permalink-label" aria-hidden="true">Permalink</span>
                        <span class="visually-hidden">Link to {doc.frontmatter.title}</span>
                    </a>
                </div>
                <div
                    class="changelog-body"
                    set:html={prepareHtml(doc.compiledContent(), doc.frontmatter.slug)}
                ></div>
            </div>
        </article>
    ))}
</Page>

<style>
    img {
        width: 100%;
        border-radius: 20px;
    }

    .entry-header {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        justify-content: space-between;
        flex-wrap: wrap;
    }

    .permalink {
        font-size: 1rem;
        text-decoration: none;
        color: inherit;
        opacity: 0.6;
    }

    .permalink:hover,
    .permalink:focus-visible {
        opacity: 1;
    }

    .changelog-card {
        background-color: var(--color-surface);
        color: var(--color-text, inherit);
        padding: 1.25rem;
        border-radius: 1rem;
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.25);
        border: 1px solid var(--color-border, rgba(255, 255, 255, 0.08));
    }

    .changelog-entry {
        scroll-margin-top: 1.5rem;
        margin-bottom: 1rem;
    }

    .changelog-note {
        margin-top: 1.5rem;
        padding: 1rem;
        border-left: 4px solid var(--color-highlight, #5b21b6);
        background: rgba(91, 33, 182, 0.08);
        border-radius: 12px;
    }

    .changelog-note p {
        margin: 0.5rem 0 0;
    }

    .changelog-body :global(p),
    .changelog-body :global(ul),
    .changelog-body :global(ol) {
        margin-top: 0.5rem;
        margin-bottom: 0.5rem;
    }

    .visually-hidden {
        position: absolute;
        width: 1px;
        height: 1px;
        padding: 0;
        margin: -1px;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        white-space: nowrap;
        border: 0;
    }
</style>
