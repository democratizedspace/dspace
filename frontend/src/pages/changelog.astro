---
import Page from '../components/Page.astro';
import { appendChangelogNotes } from '../utils/changelogNotes';

const changelogs = await Astro.glob('./docs/md/changelog/*.md');

const changelogsReversed = changelogs.reverse();

const slugToHeadingId = (slug) => (slug ? String(slug).toLowerCase() : 'changelog');

function prepareHtml(html, slug) {
    return appendChangelogNotes(html, slug);
}
---

<Page columns="1">
    {changelogsReversed.map((doc) => (
        <section id={slugToHeadingId(doc.frontmatter.slug)} class="changelog-entry">
            <div class="entry-header">
                <h3>{doc.frontmatter.title}</h3>
                <a
                    class="permalink"
                    href={`#${slugToHeadingId(doc.frontmatter.slug)}`}
                    aria-label={`Link to ${doc.frontmatter.title}`}
                >
                    <span class="permalink-label" aria-hidden="true">Permalink</span>
                    <span class="visually-hidden">Link to {doc.frontmatter.title}</span>
                </a>
            </div>
            <article
                class="changelog-body"
                set:html={prepareHtml(doc.compiledContent(), doc.frontmatter.slug)}
            ></article>
        </section>
    ))}
</Page>

<style>
    img {
        width: 100%;
        border-radius: 20px;
    }

    .changelog-entry {
        background-color: var(--color-surface, white);
        color: var(--color-text, black);
        border-radius: 20px;
        padding: 16px;
        box-shadow: 0 6px 24px rgba(0, 0, 0, 0.15);
    }

    .changelog-entry + .changelog-entry {
        margin-top: 16px;
    }

    .changelog-body {
        display: block;
        background-color: var(--color-surface, white);
        color: var(--color-text, black);
        padding: 12px;
        border-radius: 12px;
        overflow: auto;
    }

    .entry-header {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        margin-bottom: 0.75rem;
    }

    .permalink {
        font-size: 1rem;
        text-decoration: none;
        color: inherit;
        opacity: 0.6;
    }

    .permalink:hover,
    .permalink:focus-visible {
        opacity: 1;
    }

    .changelog-entry {
        scroll-margin-top: 1.5rem;
    }

    .changelog-note {
        margin-top: 1.5rem;
        padding: 1rem;
        border-left: 4px solid var(--color-highlight, #5b21b6);
        background: rgba(91, 33, 182, 0.08);
        border-radius: 12px;
    }

    .changelog-note p {
        margin: 0.5rem 0 0;
    }

    .visually-hidden {
        position: absolute;
        width: 1px;
        height: 1px;
        padding: 0;
        margin: -1px;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        white-space: nowrap;
        border: 0;
    }
</style>
