---
import Header from '../../components/Header.astro';
import Menu from '../../components/svelte/Menu.svelte';
import Updater from '../../components/svelte/Updater.svelte';
import Chip from '../../components/Chip.astro';
import Card from '../../components/Card.astro';
import Layout from '../../layouts/Layout.astro';
import { getCookieItems, parseCookie, prettyPrintNumber } from '../../utils.js';

const cookie = Astro.request.headers.get('cookie');
const itemList = getCookieItems(cookie);
const pathname = Astro.url.pathname;

const parsedCookie = parseCookie(cookie ?? '');
const cookieCurrencies = Object.entries(parsedCookie)
    .filter(([key]) => key.startsWith('currency-balance-'))
    .map(([key, value]) => {
        const symbol = key.replace('currency-balance-', '');
        const balance = Number.parseFloat(value);
        return {
            symbol,
            label: symbol,
            balance: Number.isFinite(balance) ? balance : 0,
        };
    });

const ensureSymbols = ['dUSD', 'dBI'];
const balances = new Map(
    ensureSymbols.map((symbol) => [symbol, { symbol, label: symbol, balance: 0 }])
);

for (const entry of cookieCurrencies) {
    balances.set(entry.symbol, entry);
}

const balanceList = Array.from(balances.values()).sort((a, b) => a.symbol.localeCompare(b.symbol));
---

<Layout title="Wallet">
    <main id="main" class="wallet-page">
        <Header title="" body="" href="" />
        <Updater shouldUpdate={itemList.length === 0} />
        <Menu pathname={pathname} client:idle />

        <section class="wallet" aria-labelledby="wallet-heading">
            <div class="wallet__intro">
                <div>
                    <p class="eyebrow">Finance</p>
                    <h1 id="wallet-heading">Wallet</h1>
                    <p class="lede">
                        Check your currencies, then launch the basic income process to keep payouts
                        flowing.
                    </p>
                </div>
            </div>

            <div class="wallet__grid">
                <section class="panel" data-testid="wallet-balance-section">
                    <div class="panel__header">
                        <h2>Balances</h2>
                        <p class="muted">
                            Stored on this device and used across shop and quest flows.
                        </p>
                    </div>

                    <div class="balance-grid">
                        {
                            balanceList.map((balance) => (
                                <article
                                    class="balance"
                                    data-testid={`wallet-balance-${balance.symbol.toLowerCase()}`}
                                >
                                    <div class="balance__label">
                                        <span class="balance__name">{balance.label}</span>
                                        <Chip
                                            text={balance.symbol}
                                            href={`/docs/${balance.symbol.toLowerCase()}`}
                                        />
                                    </div>
                                    <p class="balance__value">
                                        {prettyPrintNumber(balance.balance)}
                                    </p>
                                </article>
                            ))
                        }
                    </div>
                </section>

                <section class="panel" data-testid="wallet-process-card">
                    <ul class="wallet__actions" role="list">
                        <Card
                            title="Basic income"
                            body="Launch the daily payout process to collect dUSD and grow your dBI streak."
                            href="/process/basic-income"
                            duration="1d"
                        >
                            <p class="muted">
                                Start the process whenever you need a refill. Your balances update
                                here once the payout completes.
                            </p>
                        </Card>
                    </ul>
                </section>
            </div>
        </section>
    </main>
</Layout>

<style>
    .wallet-page {
        margin: 0 auto;
        max-width: 72ch;
        padding: 1.5rem 1.25rem 2.5rem;
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    .wallet {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .wallet__intro {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
    }

    .wallet__grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
        gap: 1rem;
    }

    .panel {
        background: rgba(23, 33, 48, 0.72);
        border-radius: 16px;
        border: 1px solid rgba(105, 140, 220, 0.35);
        padding: 1.25rem;
        display: flex;
        flex-direction: column;
        gap: 1rem;
        box-shadow: 0 12px 32px rgba(0, 0, 0, 0.25);
    }

    .panel__header {
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
    }

    .wallet__actions {
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .balance-grid {
        display: grid;
        gap: 0.75rem;
        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    }

    .balance {
        border: 1px solid rgba(105, 140, 220, 0.35);
        border-radius: 12px;
        padding: 0.75rem 0.85rem;
        background: rgba(255, 255, 255, 0.04);
        display: flex;
        flex-direction: column;
        gap: 0.4rem;
    }

    .balance__label {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 0.5rem;
    }

    .balance__name {
        font-weight: 700;
        color: var(--color-heading);
    }

    .balance__value {
        margin: 0;
        font-size: 1.5rem;
        font-weight: 800;
        color: #c7f9cc;
    }

    .eyebrow {
        text-transform: uppercase;
        letter-spacing: 0.08em;
        font-size: 0.8rem;
        margin: 0;
        color: var(--color-pill-active);
    }

    .lede {
        margin: 0.25rem 0 0;
        color: var(--color-text);
        line-height: 1.5;
    }

    .muted {
        margin: 0;
        color: #c7d7ff;
        line-height: 1.4;
    }

    h1 {
        margin: 0.15rem 0;
    }

    h2 {
        margin: 0;
    }

    :global(html[data-theme='light']) .panel {
        background: #f1fff4;
        border-color: #d2e8d8;
        box-shadow: 0 10px 18px rgba(0, 0, 0, 0.1);
    }

    :global(html[data-theme='light']) .balance {
        background: #ffffff;
        border-color: #d2e8d8;
    }

    :global(html[data-theme='light']) .balance__value {
        color: #0f5132;
    }

    :global(html[data-theme='light']) .muted {
        color: #3d5542;
    }

    @media (max-width: 640px) {
        .wallet-page {
            padding: 1rem 0.75rem 2rem;
        }

        .wallet__intro {
            flex-direction: column;
            align-items: flex-start;
        }
    }
</style>
