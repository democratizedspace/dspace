---
import Page from '../components/Page.astro';
import WhatsNew from '../components/WhatsNew.astro';
import UIResponsiveness from '../components/svelte/UIResponsiveness.svelte';
import FailoverStatus from '../components/svelte/FailoverStatus.svelte';
import { loadHomepageChangelogs, logHomepageError } from '../utils/homepageLogging';

let changelogs = [];
let changelogsReversed = [];

try {
    changelogs = await loadHomepageChangelogs({
        loader: () => Astro.glob('../pages/docs/md/changelog/*.md'),
        request: Astro.request,
        url: Astro.url,
    });
    changelogsReversed = [...changelogs].reverse();
} catch (error) {
    logHomepageError(Astro.request, Astro.url, error, { step: 'render' });
    throw error;
}
---

<Page columns="1">
    <script>
        window.dspaceStart = performance.now();
    </script>
    <WhatsNew changelogs={changelogsReversed} />
    <FailoverStatus client:load />
    <UIResponsiveness client:load />
</Page>

<style>
    div {
        background-color: white;
        padding: 20px;
        border-radius: 20px;
        color: black;
    }
</style>
