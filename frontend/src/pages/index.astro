---
import Page from '../components/Page.astro';
import WhatsNew from '../components/WhatsNew.astro';
import UIResponsiveness from '../components/svelte/UIResponsiveness.svelte';
import FailoverStatus from '../components/svelte/FailoverStatus.svelte';

const version =
    process.env.DSPACE_VERSION ??
    process.env.npm_package_version ??
    'unknown';
const environment = process.env.DSPACE_ENV ?? 'unknown';

// Component rendering errors (e.g., in <WhatsNew />) are caught by middleware. Add SSR
// preparation logic here if the homepage requires it in the future.
---

<Page title="Home" columns="1">
    <div class="home-shell">
        <div class="build-meta" aria-label="Build metadata">
            <span class="env">{environment}</span>
            <span class="version">{version}</span>
        </div>
        <script>
            window.dspaceStart = performance.now();
        </script>
        <WhatsNew />
        <FailoverStatus client:load />
        <UIResponsiveness client:load />
    </div>
</Page>

<style>
    div {
        background-color: white;
        padding: 20px;
        border-radius: 20px;
        color: black;
    }

    .fallback {
        text-align: center;
    }

    .home-shell {
        display: flex;
        flex-direction: column;
        gap: 1rem;
        width: 100%;
        max-width: 100%;
        min-width: 0;
        padding: 0;
        background: transparent;
        color: inherit;
        box-sizing: border-box;
    }

    .build-meta {
        display: inline-flex;
        gap: 0.5rem;
        align-items: center;
        padding: 0.25rem 0.75rem;
        margin-bottom: 0.5rem;
        font-size: 0.85rem;
        border-radius: 9999px;
        background-color: #f4f4f5;
        color: #1f2933;
        align-self: flex-end;
        width: fit-content;
        max-width: min(100%, 22rem);
        min-width: 0;
        box-sizing: border-box;
        flex-wrap: wrap;
        justify-content: flex-end;
    }

    .build-meta .env {
        font-weight: 600;
        text-transform: lowercase;
    }
</style>
