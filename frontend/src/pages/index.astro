---
import Page from '../components/Page.astro';
import WhatsNew from '../components/WhatsNew.astro';
import UIResponsiveness from '../components/svelte/UIResponsiveness.svelte';
import FailoverStatus from '../components/svelte/FailoverStatus.svelte';

const version = process.env.DSPACE_VERSION ?? process.env.npm_package_version ?? 'unknown';
const environment = process.env.DSPACE_ENV ?? 'unknown';

// Component rendering errors (e.g., in <WhatsNew />) are caught by middleware. Add SSR
// preparation logic here if the homepage requires it in the future.
---

<Page title="Home" columns="1">
    <li class="page-section">
        <WhatsNew />
    </li>
    <li class="page-section status-footer-section">
        <section class="status-footer" aria-label="Build and runtime status">
            <div class="build-meta-wrapper">
                <div class="build-meta">
                    <span class="env">{environment}</span>
                    <span class="version">{version}</span>
                </div>
            </div>
            <FailoverStatus client:load />
            <UIResponsiveness client:load />
        </section>
    </li>
</Page>

<script>
    window.dspaceStart = performance.now();
</script>

<style>
    div {
        background-color: white;
        padding: 20px;
        border-radius: 20px;
        color: black;
    }

    .fallback {
        text-align: center;
    }

    .status-footer-section {
        padding: 0.75rem 1rem;
    }

    .status-footer {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem 0.9rem;
        align-items: center;
    }

    .build-meta-wrapper {
        display: flex;
        min-width: 0;
        justify-content: flex-start;
    }

    .build-meta {
        display: inline-flex;
        gap: 0.5rem;
        align-items: center;
        padding: 0.25rem 0.75rem;
        font-size: 0.85rem;
        border-radius: 9999px;
        background-color: #f4f4f5;
        color: #1f2933;
        max-width: 100%;
        min-width: 0;
        flex-wrap: nowrap;
        justify-content: flex-start;
        text-align: left;
        overflow-wrap: anywhere;
    }

    .build-meta .env {
        font-weight: 600;
        text-transform: lowercase;
    }

    .build-meta > span {
        min-width: 0;
    }

    :global(.status-footer [data-testid='connection-status']),
    :global(.status-footer [data-testid='hydration-time']) {
        margin-top: 0;
    }

    @media (max-width: 720px) {
        .status-footer-section {
            padding: 0.6rem 0.8rem;
        }

        .build-meta {
            flex-wrap: wrap;
        }
    }
</style>
