---
import Page from '../components/Page.astro';
import WhatsNew from '../components/WhatsNew.astro';
import UIResponsiveness from '../components/svelte/UIResponsiveness.svelte';
import FailoverStatus from '../components/svelte/FailoverStatus.svelte';

// Component rendering errors (e.g., in <WhatsNew />) are caught by middleware. Add SSR
// preparation logic here if the homepage requires it in the future.
const version =
    import.meta.env?.DSPACE_VERSION ??
    process.env.DSPACE_VERSION ??
    process.env.npm_package_version ??
    'dev';
const env = import.meta.env?.DSPACE_ENV ?? process.env.DSPACE_ENV ?? 'unknown';
---

<Page columns="1">
    <script>
        window.dspaceStart = performance.now();
    </script>
    <div class="build-meta-wrapper" aria-label="Deployment metadata">
        <div class="build-meta">
            <span class="env">{env}</span>
            <span class="version">{version}</span>
        </div>
    </div>
    <WhatsNew />
    <FailoverStatus client:load />
    <UIResponsiveness client:load />
</Page>

<style>
    div {
        background-color: white;
        padding: 20px;
        border-radius: 20px;
        color: black;
    }

    .fallback {
        text-align: center;
    }

    .build-meta-wrapper {
        display: flex;
        justify-content: flex-end;
        margin-bottom: 12px;
    }

    .build-meta {
        display: inline-flex;
        gap: 8px;
        align-items: center;
        padding: 6px 12px;
        background: rgba(0, 0, 0, 0.06);
        border-radius: 999px;
        font-size: 0.9rem;
        color: #111;
        text-transform: lowercase;
        letter-spacing: 0.01em;
    }

    .build-meta .env {
        font-weight: 700;
    }

    .build-meta .version {
        color: rgba(0, 0, 0, 0.7);
    }
</style>
