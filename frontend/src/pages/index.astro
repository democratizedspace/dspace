---
import Page from '../components/Page.astro';
import WhatsNew from '../components/WhatsNew.astro';
import UIResponsiveness from '../components/svelte/UIResponsiveness.svelte';
import FailoverStatus from '../components/svelte/FailoverStatus.svelte';

const version = process.env.DSPACE_VERSION ?? process.env.npm_package_version ?? 'unknown';
const environment = process.env.DSPACE_ENV ?? 'unknown';

// Component rendering errors (e.g., in <WhatsNew />) are caught by middleware. Add SSR
// preparation logic here if the homepage requires it in the future.
---

<Page title="Home" columns="1">
    <li class="page-section">
        <section class="content-card">
            <WhatsNew />
        </section>
    </li>
    <li class="page-section">
        <section class="status-card" aria-label="Runtime status">
            <div class="build-meta-wrapper" aria-label="Build metadata">
                <div class="build-meta">
                    <span class="env">{environment}</span>
                    <span class="version">{version}</span>
                </div>
            </div>
            <FailoverStatus client:load />
            <UIResponsiveness client:load />
        </section>
    </li>
</Page>

<script>
    window.dspaceStart = performance.now();
</script>

<style>
    .content-card {
        background-color: white;
        padding: 20px;
        border-radius: 20px;
        color: black;
    }

    .fallback {
        text-align: center;
    }

    .status-card {
        background-color: white;
        padding: 12px 16px;
        border-radius: 20px;
        color: black;
    }

    .build-meta-wrapper {
        display: flex;
        justify-content: flex-end;
        width: 100%;
    }

    .build-meta {
        display: inline-flex;
        gap: 0.5rem;
        align-items: center;
        padding: 0.25rem 0.75rem;
        margin-bottom: 0.5rem;
        font-size: 0.85rem;
        border-radius: 9999px;
        background-color: #f4f4f5;
        color: #1f2933;
        max-width: min(100%, 100vw - 2rem);
        min-width: 0;
        flex-wrap: wrap;
        justify-content: flex-end;
        text-align: right;
        overflow-wrap: anywhere;
    }

    .build-meta .env {
        font-weight: 600;
        text-transform: lowercase;
    }

    .build-meta > span {
        min-width: 0;
    }

    @media (max-width: 720px) {
        .build-meta {
            display: flex;
        }
    }
</style>
