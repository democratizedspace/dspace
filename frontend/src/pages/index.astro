---
import Page from '../components/Page.astro';
import WhatsNew from '../components/WhatsNew.astro';
import UIResponsiveness from '../components/svelte/UIResponsiveness.svelte';
import FailoverStatus from '../components/svelte/FailoverStatus.svelte';

const version = process.env.DSPACE_VERSION ?? process.env.npm_package_version ?? 'unknown';
const environment = process.env.DSPACE_ENV ?? 'unknown';

// Component rendering errors (e.g., in <WhatsNew />) are caught by middleware. Add SSR
// preparation logic here if the homepage requires it in the future.
---

<Page title="Home" columns="1">
    <li class="page-section">
        <WhatsNew />
    </li>
    <li class="page-section status-strip" aria-label="Build and runtime metadata">
        <div class="status-strip-content">
            <div class="build-meta" aria-label="Build metadata">
                <span class="env">{environment}</span>
                <span class="version">{version}</span>
            </div>
            <FailoverStatus client:load />
            <UIResponsiveness client:load />
        </div>
    </li>
</Page>

<script>
    window.dspaceStart = performance.now();
</script>

<style>
    .status-strip {
        padding: 0.5rem 0.75rem;
    }

    .status-strip-content {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.75rem;
        flex-wrap: wrap;
    }

    .build-meta {
        display: inline-flex;
        gap: 0.5rem;
        align-items: center;
        padding: 0.25rem 0.75rem;
        font-size: 0.85rem;
        border-radius: 9999px;
        background-color: #f4f4f5;
        color: #1f2933;
        min-width: 0;
        flex-wrap: wrap;
        overflow-wrap: anywhere;
    }

    .build-meta .env {
        font-weight: 600;
        text-transform: lowercase;
    }

    .build-meta > span {
        min-width: 0;
    }

    .status-strip :global([data-testid='connection-status']),
    .status-strip :global([data-testid='hydration-time']) {
        margin-top: 0 !important;
        font-size: 0.9rem;
        white-space: nowrap;
    }

    @media (max-width: 720px) {
        .status-strip-content {
            align-items: flex-start;
            flex-direction: column;
        }
    }
</style>
