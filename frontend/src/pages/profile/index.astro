---
import Page from '../../components/Page.astro';
import Avatar from '../../components/svelte/Avatar.svelte';
import ProfileTitles from './ProfileTitles.svelte';
---

<Page title="Profile">
    <li class="profile-panel">
        <section class="avatar-card">
            <h1>Choose a default avatar</h1>
            <Avatar client:load />
            <p class="hint">Pick the avatar that represents you across quests, stats, and leaderboards.</p>
        </section>
        <section class="titles">
            <h2>Unlocked titles</h2>
            <p class="hint">Titles update automatically as you progress through quests.</p>
            <ProfileTitles client:load />
        </section>
    </li>
</Page>

<style>
    .profile-panel {
        list-style: none;
        display: grid;
        gap: 1.5rem;
        grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
        padding: 0;
        margin: 0;
    }

    .avatar-card {
        display: flex;
        flex-direction: column;
        gap: 1rem;
        background: rgba(3, 58, 3, 0.65);
        border-radius: 16px;
        padding: 1.5rem;
        border: 1px solid rgba(0, 255, 34, 0.35);
        box-shadow: 0 12px 32px rgba(0, 0, 0, 0.25);
    }

    h1 {
        margin: 0;
        font-size: 1.6rem;
        color: #f0f6ff;
    }

    h2 {
        margin: 0;
        color: var(--color-heading);
    }

    .hint {
        margin: 0;
        color: #c7d7ff;
        line-height: 1.4;
    }

    .titles {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
        background: rgba(3, 58, 3, 0.5);
        border: 1px solid rgba(0, 255, 34, 0.28);
        border-radius: 16px;
        padding: 1.25rem;
    }

    @media (max-width: 720px) {
        .profile-panel {
            grid-template-columns: 1fr;
        }
    }
</style>
