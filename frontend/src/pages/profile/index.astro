---
import Page from '../../components/Page.astro';
import Card from '../../components/Card.astro';
import Avatar from '../../components/svelte/Avatar.svelte';
import ProfileTitles from './ProfileTitles.svelte';
---

<Page title="Profile" message="Pick your avatar and review the titles you've unlocked.">
    <Card title="Profile" textbox={true}>
        <div class="profile-grid">
            <section class="panel">
                <h1>Choose a default avatar</h1>
                <Avatar client:load />
                <p class="hint">
                    Pick the avatar that represents you across quests, stats, and leaderboards.
                </p>
            </section>

            <section class="panel">
                <ProfileTitles client:load />
            </section>
        </div>
    </Card>
</Page>

<style>
    .profile-grid {
        display: grid;
        gap: 1.5rem;
        grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    }

    .panel {
        background: rgba(0, 0, 0, 0.3);
        border: 1px solid var(--color-border);
        border-radius: 16px;
        padding: 1.5rem;
        box-shadow: 0 10px 28px rgba(0, 0, 0, 0.24);
    }

    h1,
    h2 {
        margin: 0 0 0.75rem;
        color: var(--color-heading);
    }

    .section-heading {
        font-size: 1.25rem;
    }

    .hint {
        margin: 0;
        color: var(--color-text);
        line-height: 1.4;
    }
</style>
