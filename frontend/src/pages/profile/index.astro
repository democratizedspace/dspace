---
import Page from '../../components/Page.astro';
import Avatar from '../../components/svelte/Avatar.svelte';
import ProfileTitles from './ProfileTitles.svelte';
---

<Page title="Profile" message="Pick your avatar and review the titles you've unlocked.">
    <div class="profile-layout">
        <section class="panel">
            <div class="section-header">
                <h2>Avatar</h2>
                <p>Choose how you appear across quests, stats, and leaderboards.</p>
            </div>
            <div class="avatar-card">
                <Avatar client:load />
            </div>
        </section>

        <section class="panel">
            <div class="section-header">
                <h2>Titles</h2>
                <p>Show off what you've earned. Complete achievements to unlock more titles.</p>
            </div>
            <ProfileTitles client:load />
        </section>
    </div>
</Page>

<style>
    .profile-layout {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
        max-width: 960px;
        margin: 0 auto;
    }

    .panel {
        background: rgba(0, 0, 0, 0.35);
        border: 1px solid var(--color-border);
        border-radius: 18px;
        padding: 1.5rem;
        box-shadow: 0 14px 30px rgba(0, 0, 0, 0.25);
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .section-header {
        display: flex;
        flex-direction: column;
        gap: 0.35rem;
    }

    h2 {
        margin: 0;
        color: var(--color-heading);
        font-size: 1.35rem;
    }

    p {
        margin: 0;
        color: var(--color-text);
        line-height: 1.5;
    }

    .avatar-card {
        --avatar-accent-start: rgba(72, 123, 72, 0.35);
        --avatar-accent-end: rgba(46, 74, 46, 0.5);
        --avatar-accent-border: rgba(104, 212, 109, 0.35);
        --avatar-accent-shadow: rgba(104, 212, 109, 0.25);

        display: flex;
        justify-content: flex-start;
        padding: 1rem;
        border-radius: 14px;
        background: linear-gradient(145deg, var(--avatar-accent-start), var(--avatar-accent-end));
        border: 1px solid var(--avatar-accent-border);
    }

    .avatar-card :global(.avatar) {
        margin: 0;
        box-shadow: 0 0 0 4px var(--avatar-accent-shadow);
    }

    .avatar-card :global(p) {
        margin: 0.25rem 0 0;
        font-size: 0.9rem;
    }

    @media (min-width: 900px) {
        .profile-layout {
            flex-direction: row;
        }

        .panel {
            flex: 1;
        }
    }
</style>
