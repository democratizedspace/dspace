---
import Page from '../../components/Page.astro';
import Avatar from '../../components/svelte/Avatar.svelte';
import ProfileTitles from './ProfileTitles.svelte';
---

<Page title="Profile" columns="2">
    <section class="panel avatar-card">
        <div class="panel-header">
            <h1>Choose a default avatar</h1>
            <p class="hint">
                Pick the avatar that represents you across quests, stats, and leaderboards.
            </p>
        </div>
        <Avatar client:load />
    </section>

    <section class="panel profile-titles">
        <ProfileTitles client:load />
    </section>
</Page>

<style>
    .panel {
        background: var(--color-surface);
        border-radius: 16px;
        border: 1px solid var(--color-border);
        padding: 1.5rem;
        box-shadow: 0 12px 32px rgba(0, 0, 0, 0.2);
        display: grid;
        gap: 1rem;
    }

    .panel-header {
        display: grid;
        gap: 0.5rem;
    }

    h1 {
        margin: 0;
        font-size: 1.6rem;
        color: var(--color-heading);
    }

    .hint {
        margin: 0;
        color: var(--color-text);
        line-height: 1.4;
    }

    .avatar-card {
        align-self: start;
    }

    .profile-titles {
        grid-column: span 1;
    }

    @media (max-width: 900px) {
        .profile-titles,
        .avatar-card {
            grid-column: 1 / -1;
        }
    }
</style>
