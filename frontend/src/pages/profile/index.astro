---
/**
 * Profile Page
 * 
 * Main profile customization page where users can:
 * 1. Select an avatar to represent them across the game
 * 2. Choose an unlocked achievement title to display
 * 
 * The page uses a responsive two-panel layout that stacks vertically
 * on mobile and displays side-by-side on larger screens.
 * 
 * All styling uses CSS variables with color-mix() for theme consistency
 * and proper light/dark mode support.
 */
import Page from '../../components/Page.astro';
import Avatar from '../../components/svelte/Avatar.svelte';
import ProfileTitles from './ProfileTitles.svelte';
---

<Page title="Profile" message="Pick your avatar and review the titles you've unlocked.">
    <div class="profile-layout">
        <section class="panel">
            <div class="section-header">
                <h2>Avatar</h2>
                <p>Choose how you appear across quests, stats, and leaderboards.</p>
            </div>
            <div class="avatar-card">
                <Avatar client:load />
            </div>
        </section>

        <section class="panel">
            <div class="section-header">
                <h2>Titles</h2>
                <p>Show off what you've earned. Complete achievements to unlock more titles.</p>
            </div>
            <ProfileTitles client:load />
        </section>
    </div>
</Page>

<style>
    .profile-layout {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
        max-width: 960px;
        margin: 0 auto;
    }

    .panel {
        background: rgba(0, 0, 0, 0.35);
        border: 1px solid var(--color-border);
        border-radius: 18px;
        padding: 1.5rem;
        box-shadow: 0 14px 30px rgba(0, 0, 0, 0.25);
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .section-header {
        display: flex;
        flex-direction: column;
        gap: 0.35rem;
    }

    h2 {
        margin: 0;
        color: var(--color-heading);
        font-size: 1.35rem;
    }

    p {
        margin: 0;
        color: var(--color-text);
        line-height: 1.5;
    }

    .avatar-card {
        display: flex;
        justify-content: flex-start;
        padding: 1rem;
        border-radius: 14px;
        background: linear-gradient(
            145deg,
            color-mix(in srgb, var(--color-surface) 70%, transparent),
            color-mix(in srgb, var(--color-surface) 85%, black)
        );
        border: 1px solid color-mix(in srgb, var(--color-pill-active) 35%, transparent);
    }

    .avatar-card :global(.avatar) {
        margin: 0;
        box-shadow: 0 0 0 4px color-mix(in srgb, var(--color-pill-active) 25%, transparent);
    }

    .avatar-card :global(p) {
        margin: 0.25rem 0 0;
        font-size: 0.9rem;
    }

    @media (min-width: 900px) {
        .profile-layout {
            flex-direction: row;
        }

        .panel {
            flex: 1;
        }
    }
</style>
