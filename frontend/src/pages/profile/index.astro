---
import Page from '../../components/Page.astro';
import Avatar from '../../components/svelte/Avatar.svelte';
import ProfileTitles from './ProfileTitles.svelte';
---

<Page title="Profile" columns="2">
    <li class="profile">
        <section class="card">
            <h2>Choose a default avatar</h2>
            <Avatar client:load />
            <p class="hint">Pick the avatar that represents you across quests, stats, and leaderboards.</p>
        </section>

        <section class="card titles">
            <h2>Unlocked titles</h2>
            <ProfileTitles client:load />
        </section>
    </li>
</Page>

<style>
    .profile {
        display: grid;
        gap: 1.5rem;
        grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
        align-items: start;
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .card {
        display: flex;
        flex-direction: column;
        gap: 1rem;
        background: var(--color-surface);
        border-radius: 16px;
        padding: 1.25rem;
        border: 1px solid var(--color-border);
        box-shadow: 0 12px 32px rgba(0, 0, 0, 0.25);
    }

    h2 {
        margin: 0;
        font-size: 1.4rem;
        color: var(--color-heading);
    }

    .hint {
        margin: 0;
        color: var(--color-pill-text);
        line-height: 1.5;
        opacity: 0.85;
    }

    .titles {
        gap: 0.5rem;
    }
</style>
