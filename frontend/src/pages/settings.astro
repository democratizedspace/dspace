---
import Page from '../components/Page.astro';
import LogoutPanel from '../components/svelte/LogoutPanel.svelte';
import DataResetPanel from '../components/svelte/DataResetPanel.svelte';
---

<Page title="Settings" message="Manage your DSPACE session" columns="1">
    <div class="settings-content">
        <div class="panel-stack">
            <LogoutPanel client:idle />
            <DataResetPanel client:idle />
        </div>
    </div>
</Page>

<style>
    .settings-content {
        display: flex;
        justify-content: center;
        padding: 1rem;
    }

    .panel-stack {
        display: flex;
        flex-direction: column;
        gap: 16px;
        width: min(960px, 100%);
        align-items: center;
    }
</style>
