---
import Page from '../components/Page.astro';
import LogoutPanel from '../components/svelte/LogoutPanel.svelte';
import DataReset from '../components/svelte/DataReset.svelte';
import QaCheatsToggle from '../components/svelte/QaCheatsToggle.svelte';
import LegacySaveUpgrade from '../components/svelte/LegacySaveUpgrade.svelte';
import QuestGraphToggle from '../components/svelte/QuestGraphToggle.svelte';
import { getCheatsAvailabilityFlag, isStagingEnvironment } from '../utils/cheatsAvailability';
import { getCookieItemsFromStore, getCookieKeysFromStore } from '../utils/migrationCookies.js';

const cheatsAvailable = getCheatsAvailabilityFlag();
const stagingEnvironment = isStagingEnvironment();
const legacyV1Items = getCookieItemsFromStore(Astro.cookies);
const legacyCookieKeys = getCookieKeysFromStore(Astro.cookies);
---

<Page title="Settings" message="Manage your DSPACE session" columns="1">
    <section class="settings-content" aria-label="Settings controls">
        <div class="settings-item">
            <LogoutPanel client:idle />
        </div>
        <div class="settings-item">
            <QuestGraphToggle client:idle />
        </div>
        {
            cheatsAvailable ? (
                <div class="settings-item settings-item--wide">
                    <QaCheatsToggle
                        cheatsAvailable={cheatsAvailable}
                        stagingEnvironment={stagingEnvironment}
                        client:idle
                    />
                </div>
            ) : null
        }
        <div class="settings-item settings-item--wide">
            <LegacySaveUpgrade
                legacyV1Items={legacyV1Items}
                legacyCookieKeys={legacyCookieKeys}
                cheatsAvailable={cheatsAvailable}
                client:idle
            />
        </div>
        <div class="settings-item">
            <DataReset client:idle />
        </div>
    </section>
</Page>

<style>
    .settings-content {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
        gap: 1rem;
        width: min(100%, 1800px);
        margin: 0 auto;
        padding: 1rem;
        align-items: start;
    }

    .settings-item {
        min-width: 0;
    }

    .settings-item--wide {
        grid-column: 1 / -1;
    }

    .settings-item :global(.logout-panel),
    .settings-item :global(.panel),
    .settings-item :global(.qa-cheats),
    .settings-item :global(.legacy-upgrade),
    .settings-item :global(.data-reset) {
        max-width: none;
        width: 100%;
        height: 100%;
    }

    @media (max-width: 720px) {
        .settings-content {
            grid-template-columns: 1fr;
            padding: 0.75rem;
        }
    }
</style>
