{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "image": { "type": "string" },
        "duration": { "type": "string" },
        "requireItems": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "id": { "type": "string" },
                    "count": { "type": "number" }
                },
                "required": ["id", "count"],
                "additionalProperties": false
            }
        },
        "consumeItems": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "id": { "type": "string" },
                    "count": { "type": "number" }
                },
                "required": ["id", "count"],
                "additionalProperties": false
            }
        },
        "createItems": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "id": { "type": "string" },
                    "count": { "type": "number" }
                },
                "required": ["id", "count"],
                "additionalProperties": false
            }
        },
        "hardening": {
            "$ref": "https://democratizedspace.com/schemas/hardening.json"
        }
    },
    "required": ["id", "title", "duration", "hardening"],
    "additionalProperties": false
}
