{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "image": { "type": "string" },
        "requireItems": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "id": { "type": "string" },
                    "count": { "type": "number" }
                },
                "required": ["id", "count"],
                "additionalProperties": false
            },
            "default": []
        },
        "consumeItems": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "id": { "type": "string" },
                    "count": { "type": "number" }
                },
                "required": ["id", "count"],
                "additionalProperties": false
            },
            "default": []
        },
        "createItems": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "id": { "type": "string" },
                    "count": { "type": "number" }
                },
                "required": ["id", "count"],
                "additionalProperties": false
            },
            "default": []
        },
        "duration": { "type": "string" },
        "hardening": { "$ref": "https://dspace.local/schemas/hardening.json" }
    },
    "required": [
        "id",
        "title",
        "requireItems",
        "consumeItems",
        "createItems",
        "duration",
        "hardening"
    ],
    "additionalProperties": true
}
