{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "https://dspace.local/schemas/process.json",
    "type": "object",
    "properties": {
        "id": {
            "type": "string"
        },
        "title": {
            "type": "string"
        },
        "image": {
            "type": "string"
        },
        "requireItems": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "id": {
                        "type": "string"
                    },
                    "count": {
                        "type": "number"
                    }
                },
                "required": [
                    "id",
                    "count"
                ],
                "additionalProperties": false
            }
        },
        "consumeItems": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "id": {
                        "type": "string"
                    },
                    "count": {
                        "type": "number"
                    }
                },
                "required": [
                    "id",
                    "count"
                ],
                "additionalProperties": false
            }
        },
        "createItems": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "id": {
                        "type": "string"
                    },
                    "count": {
                        "type": "number"
                    }
                },
                "required": [
                    "id",
                    "count"
                ],
                "additionalProperties": false
            }
        },
        "duration": {
            "type": "string"
        },
        "hardening": {
            "$ref": "https://dspace.local/schemas/hardening.json"
        },
        "containerDeposit": {
            "type": "object",
            "properties": {
                "containerItemId": {
                    "type": "string"
                },
                "itemId": {
                    "type": "string"
                },
                "label": {
                    "type": "string"
                },
                "min": {
                    "type": "number",
                    "minimum": 0
                }
            },
            "required": [
                "containerItemId",
                "itemId"
            ],
            "additionalProperties": false
        },
        "containerWithdrawAll": {
            "type": "object",
            "properties": {
                "containerItemId": {
                    "type": "string"
                },
                "itemId": {
                    "type": "string"
                }
            },
            "required": [
                "containerItemId",
                "itemId"
            ],
            "additionalProperties": false
        },
        "itemCountOperations": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "operation": {
                        "type": "string",
                        "enum": [
                            "deposit",
                            "withdraw",
                            "withdraw-all"
                        ]
                    },
                    "containerItemId": {
                        "type": "string"
                    },
                    "itemId": {
                        "type": "string"
                    },
                    "count": {
                        "type": "number",
                        "exclusiveMinimum": 0
                    }
                },
                "required": [
                    "operation",
                    "containerItemId",
                    "itemId"
                ],
                "additionalProperties": false,
                "allOf": [
                    {
                        "if": {
                            "properties": {
                                "operation": {
                                    "enum": [
                                        "deposit",
                                        "withdraw"
                                    ]
                                }
                            }
                        },
                        "then": {
                            "required": [
                                "count"
                            ]
                        }
                    },
                    {
                        "if": {
                            "properties": {
                                "operation": {
                                    "const": "withdraw-all"
                                }
                            }
                        },
                        "then": {
                            "not": {
                                "required": [
                                    "count"
                                ]
                            }
                        }
                    }
                ]
            }
        }
    },
    "required": [
        "id",
        "title",
        "requireItems",
        "consumeItems",
        "createItems",
        "duration",
        "hardening"
    ],
    "additionalProperties": false
}
