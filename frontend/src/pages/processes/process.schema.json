{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "https://dspace.local/schemas/process.json",
    "type": "object",
    "properties": {
        "id": {
            "type": "string"
        },
        "title": {
            "type": "string"
        },
        "image": {
            "type": "string"
        },
        "requireItems": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "id": { "type": "string" },
                    "count": { "type": "number" }
                },
                "required": ["id", "count"],
                "additionalProperties": false
            }
        },
        "consumeItems": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "id": { "type": "string" },
                    "count": { "type": "number" }
                },
                "required": ["id", "count"],
                "additionalProperties": false
            }
        },
        "createItems": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "id": { "type": "string" },
                    "count": { "type": "number" }
                },
                "required": ["id", "count"],
                "additionalProperties": false
            }
        },
        "duration": {
            "type": "string"
        },
        "hardening": {
            "$ref": "https://dspace.local/schemas/hardening.json"
        },
        "itemCountOperations": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "operation": {
                        "type": "string",
                        "enum": ["deposit", "withdraw", "withdraw-all"]
                    },
                    "containerItemId": {
                        "type": "string"
                    },
                    "itemId": {
                        "type": "string"
                    },
                    "count": {
                        "type": "number",
                        "exclusiveMinimum": 0
                    }
                },
                "required": ["operation", "containerItemId", "itemId"],
                "allOf": [
                    {
                        "if": {
                            "properties": { "operation": { "enum": ["deposit", "withdraw"] } },
                            "required": ["operation"]
                        },
                        "then": { "required": ["count"] }
                    },
                    {
                        "if": {
                            "properties": { "operation": { "const": "withdraw-all" } },
                            "required": ["operation"]
                        },
                        "then": {
                            "not": {
                                "required": ["count"]
                            }
                        }
                    }
                ],
                "additionalProperties": false
            }
        }
    },
    "required": [
        "id",
        "title",
        "requireItems",
        "consumeItems",
        "createItems",
        "duration",
        "hardening"
    ],
    "additionalProperties": false
}
