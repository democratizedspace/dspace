{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "https://dspace.local/schemas/process.json",
    "type": "object",
    "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "image": { "type": "string" },
        "requireItems": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "id": { "type": "string" },
                    "count": { "type": "number" }
                },
                "required": ["id", "count"],
                "additionalProperties": false
            }
        },
        "consumeItems": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "id": { "type": "string" },
                    "count": { "type": "number" }
                },
                "required": ["id", "count"],
                "additionalProperties": false
            }
        },
        "createItems": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "id": { "type": "string" },
                    "count": { "type": "number" }
                },
                "required": ["id", "count"],
                "additionalProperties": false
            }
        },
        "itemCountTransfers": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "containerId": { "type": "string" },
                    "itemId": { "type": "string" },
                    "direction": {
                        "type": "string",
                        "enum": ["inventoryToContainer", "containerToInventory"]
                    },
                    "amount": {
                        "oneOf": [{ "type": "number", "exclusiveMinimum": 0 }, { "const": "all" }]
                    }
                },
                "required": ["containerId", "itemId", "direction"],
                "additionalProperties": false
            }
        },
        "duration": { "type": "string" },
        "hardening": { "$ref": "https://dspace.local/schemas/hardening.json" }
    },
    "required": [
        "id",
        "title",
        "requireItems",
        "consumeItems",
        "createItems",
        "duration",
        "hardening"
    ],
    "additionalProperties": false
}
