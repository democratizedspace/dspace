---
interface Props {
    text: string;
    href: string;
    ariaLabel?: string;
    target?: string;
}

const { text, href, ariaLabel, target }: Props = Astro.props;
---

<a
    href={href}
    aria-label={ariaLabel ?? text}
    class="button"
    target={target}
    rel={target === "_blank" ? "noopener noreferrer" : undefined}
>
    {text}
</a>

<style>
        .button {
                background-color: #2f5b2f;
                color: white;
                border-radius: 100px;
                text-decoration: none;
                white-space: nowrap;
                padding: 0.5rem 1rem;
                margin: 0.5rem;
                display: inline-flex;
                justify-content: center;
                align-items: center;
                width: fit-content;
        }

        .button:focus-visible {
                outline: 2px solid #fff;
                outline-offset: 2px;
        }
</style>
