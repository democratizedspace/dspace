---
import Button from './Button.astro';
import { appendChangelogNotes } from '../utils/changelogNotes';
import { logServerError } from '../utils/serverLogger';

let changelogs = [];

try {
    changelogs = await Astro.glob('../pages/docs/md/changelog/*.md');
} catch (error) {
    logServerError({
        route: '/',
        method: Astro.request.method ?? 'UNKNOWN',
        message: 'Failed to load changelog entries for homepage',
        error,
    });
    changelogs = [];
}

const changelogsReversed = [...changelogs].reverse();

function prepareHtml(html, slug) {
    const withNotes = appendChangelogNotes(html, slug);
    return withNotes + `
        <style>
            img {
                width: 100%;
                border-radius: 20px;
            }

            .changelog-note {
                margin-top: 1.5rem;
                padding: 1rem;
                border-left: 4px solid var(--color-highlight, #5b21b6);
                background: rgba(91, 33, 182, 0.08);
                border-radius: 12px;
            }

            .changelog-note p {
                margin: 0.5rem 0 0;
            }
        </style>
    `;
}
---

<span class="wrapper">   
    {changelogsReversed.slice(0, 1).map(doc => (
        <h3>Latest update: {doc.frontmatter.title}</h3>
        <span set:html={prepareHtml(doc.compiledContent(), doc.frontmatter.slug)}></span>
    ))}
    <Button href="/changelog" text="View all updates" />
</span>

<style>
    img {
        width: 100%;
        border-radius: 20px;
    }

    span {
        background-color: white;
        color: black; 
        padding: 10px;
        border-radius: 20px;
    }

    .wrapper {
		background-color: white;
        padding: 20px;
    }
</style>
