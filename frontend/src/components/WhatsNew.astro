---
import Button from './Button.astro';
import { appendChangelogNotes } from '../utils/changelogNotes';
import { logRouteError } from '../utils/logging';

let changelogError: Error | undefined;
let changelogs = [] as Awaited<ReturnType<typeof Astro.glob>>;

try {
    changelogs = await Astro.glob('../pages/docs/md/changelog/*.md');
} catch (error) {
    changelogError = error instanceof Error ? error : new Error(String(error));
    logRouteError({
        route: '/',
        method: Astro.request?.method ?? 'GET',
        message: 'Failed to load changelog entries for homepage',
        error: changelogError,
    });
}

const changelogsReversed = changelogs.slice().reverse();

function prepareHtml(html, slug) {
    const withNotes = appendChangelogNotes(html, slug);
    return withNotes + `
        <style>
            img {
                width: 100%;
                border-radius: 20px;
            }

            .changelog-note {
                margin-top: 1.5rem;
                padding: 1rem;
                border-left: 4px solid var(--color-highlight, #5b21b6);
                background: rgba(91, 33, 182, 0.08);
                border-radius: 12px;
            }

            .changelog-note p {
                margin: 0.5rem 0 0;
            }
        </style>
    `;
}
---

<span class="wrapper">
    {changelogError ? (
        <p class="error">We couldn't load the latest updates. Please try again shortly.</p>
    ) : (
        changelogsReversed.slice(0, 1).map((doc) => (
            <>
                <h3>Latest update: {doc.frontmatter.title}</h3>
                <span set:html={prepareHtml(doc.compiledContent(), doc.frontmatter.slug)}></span>
            </>
        ))
    )}
    <Button href="/changelog" text="View all updates" />
</span>

<style>
    img {
        width: 100%;
        border-radius: 20px;
    }

    span {
        background-color: white;
        color: black;
        padding: 10px;
        border-radius: 20px;
    }

    .wrapper {
                background-color: white;
        padding: 20px;
    }

    .error {
        color: #b91c1c;
        margin: 0;
    }
</style>
