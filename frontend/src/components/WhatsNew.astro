---
import Button from './Button.astro';
import { appendChangelogNotes } from '../utils/changelogNotes';
import { logServerError } from '../utils/serverLogger';

let changelogs = [];
let changelogError: Error | undefined;
let latestUpdateHtml: string | undefined;
let latestUpdateTitle: string | undefined;
let changelogRenderError: Error | undefined;
const route = Astro.url?.pathname ?? '/';
const method = Astro.request?.method ?? 'GET';

function prepareHtml(html, slug) {
    const withNotes = appendChangelogNotes(html, slug);
    return withNotes + `
        <style>
            img {
                width: 100%;
                border-radius: 20px;
            }

            .changelog-note {
                margin-top: 1.5rem;
                padding: 1rem;
                border-left: 4px solid var(--color-highlight, #5b21b6);
                background: rgba(91, 33, 182, 0.08);
                border-radius: 12px;
            }

            .changelog-note p {
                margin: 0.5rem 0 0;
            }
        </style>
    `;
}

try {
    changelogs = await Astro.glob('../pages/docs/md/changelog/*.md');
} catch (error) {
    changelogError = error instanceof Error ? error : new Error(String(error));
    logServerError({
        route,
        method,
        message: 'Failed to load homepage changelog entries',
        error: changelogError,
        context: { url: Astro.url?.toString() },
    });
    changelogs = [];
}

const changelogsReversed = [...changelogs].reverse();

try {
    if (changelogsReversed.length > 0) {
        const [latest] = changelogsReversed;
        latestUpdateTitle = latest?.frontmatter?.title;
        latestUpdateHtml = prepareHtml(latest?.compiledContent(), latest?.frontmatter?.slug);
    }
} catch (error) {
    changelogRenderError = error instanceof Error ? error : new Error(String(error));
    logServerError({
        route,
        method,
        message: 'Failed to prepare homepage changelog content',
        error: changelogRenderError,
        context: { url: Astro.url?.toString() },
    });
    latestUpdateHtml = undefined;
    latestUpdateTitle = undefined;
}
---

<span class="wrapper">
    {latestUpdateHtml && latestUpdateTitle ? (
        <>
            <h3>Latest update: {latestUpdateTitle}</h3>
            <span set:html={latestUpdateHtml}></span>
        </>
    ) : (
        <p class="fallback">Unable to load the latest updates right now.</p>
    )}
    <Button href="/changelog" text="View all updates" />
    {(changelogError || changelogRenderError) && (
        <p class="fallback">Please check back after a refresh.</p>
    )}
</span>

<style>
    img {
        width: 100%;
        border-radius: 20px;
    }

    span {
        background-color: white;
        color: black;
        padding: 10px;
        border-radius: 20px;
    }

    .wrapper {
        background-color: white;
        padding: 20px;
    }

    .fallback {
        margin: 0;
    }
</style>
