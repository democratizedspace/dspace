---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Menu from '../components/svelte/Menu.svelte';
import LegacyUpgradeBanner from '../components/svelte/LegacyUpgradeBanner.svelte';

const {
	title,
	message,
	columns = 1,
	contentTag = 'div',
	contentClass = '',
} = Astro.props;

// get path of URL
const pathname = Astro.url.pathname;
const ContentTag = contentTag;
const contentClasses = ['page-content', `columns-${columns}`, contentClass]
	.filter(Boolean)
	.join(' ');
---

<Layout title="DSPACE">
	<main id="main">
		<div class="page-shell" data-page-shell>
			<Header title="" body="" href="" />

			<!-- for each item in menu, if  -->
			<Menu pathname={pathname} client:idle />

			<LegacyUpgradeBanner client:idle />

			{title && <h2>{title}</h2>}

			{message && <h2>{message}</h2>}

			<ContentTag class={contentClasses} data-page-content>
				<slot />
			</ContentTag>
		</div>
	</main>
</Layout>

<style>
	:root {
		--astro-gradient: linear-gradient(0deg, #2c5837, #00ff22);
		--link-gradient: linear-gradient(45deg, #003a03, #003a03 30%, var(--color-border) 60%);
	}

	

	main {
		margin: 0 auto;
		padding: 0 1rem 1.5rem;
		max-width: 100%;
		width: 100%;
		box-sizing: border-box;
		overflow-x: clip;
	}

	.page-shell {
		margin: 0 auto;
		max-width: min(100%, 72rem);
		width: 100%;
	}

	.text-gradient {
		font-weight: 900;
		background-image: var(--astro-gradient);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-size: 100% 200%;
		background-position-y: 100%;
		border-radius: 0.4rem;
		animation: pulse 1s ease-in-out infinite;
	}

	@keyframes pulse {
		0%,
		100% {
			background-position-y: 0%;
		}
		50% {
			background-position-y: 25%;
		}
	}

	:global([data-page-content]) {
		display: grid;
		gap: 1rem;
		margin: 0;
		padding: 0;
		grid-template-columns: 1fr;
		width: 100%;
		list-style: none;
		box-sizing: border-box;
		overflow-wrap: anywhere;
		word-break: break-word;
	}

	:global([data-page-content] > *) {
		min-width: 0;
	}

	:global([data-page-content] a) {
		overflow-wrap: anywhere;
		word-break: break-word;
	}

	:global([data-page-content].columns-2) {
		grid-template-columns: repeat(2, minmax(0, 1fr));
	}

	@media (max-width: 720px) {
		:global([data-page-content].columns-2) {
			grid-template-columns: 1fr;
		}
	}
	
	.main-grid {
		list-style-type: none;
	}

	/* Navbar */
        h2 {
                color: var(--color-heading);
                text-align: center;
        }

	nav {
		text-align: center;
		display: inline-flex;
		flex-wrap: wrap;
		justify-content: center;
	}

        nav a {
                opacity: 0.8;
                background-color: var(--color-pill);
                border-radius: 0.4rem;
                color: var(--color-pill-text);
                text-decoration: none;
                flex-direction: row;
                margin: 1px;
		padding: 5px;
		text-align: center;
	}

	nav a:hover {
		opacity: 1;
	}

	canvas {
		position: fixed;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		z-index: -1;
	}

</style>
