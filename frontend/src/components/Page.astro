---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Menu from '../components/svelte/Menu.svelte';
import Updater from '../components/svelte/Updater.svelte';
import { getCookieItems } from '../utils.js';

const { title, message = '', columns = 1 } = Astro.props;

const cookie = Astro.request.headers.get('cookie');
const itemList = getCookieItems(cookie);
const pathname = Astro.url.pathname;

const numericColumns = Number.isFinite(Number(columns)) ? Number(columns) : 1;
const columnCount = Math.min(Math.max(numericColumns, 1), 3);
const maxWidth = `${60 + (columnCount - 1) * 20}ch`;
---

<Layout title="DSPACE">
        <main
                id="main"
                style={`--page-columns: ${columnCount}; --page-max-width: ${maxWidth};`}
        >
                <div class="page-shell">
                        <Header title="" body="" href="" />

                        <Updater shouldUpdate={itemList.length === 0} />

                        <Menu pathname={pathname} client:idle />

                        <h2>{title}</h2>

                        {message && <p class="page-message">{message}</p>}

                        <div class="page-content">
                                <slot />
                        </div>
                </div>
        </main>
</Layout>

<style>
        main {
                margin: auto;
                padding: 1em;
                max-width: var(--page-max-width, 60ch);
        }

        .page-shell {
                display: flex;
                flex-direction: column;
                gap: 1.5rem;
        }

        h2 {
                color: var(--color-heading);
                text-align: center;
                margin: 0;
        }

        .page-message {
                margin: 0;
                text-align: center;
                color: var(--color-heading);
        }

        .page-content {
                display: grid;
                gap: 1.25rem;
                grid-template-columns: repeat(var(--page-columns, 1), minmax(0, 1fr));
        }

        .page-content > * {
                min-width: 0;
        }

        .full-span {
                grid-column: 1 / -1;
        }

        @media (max-width: 720px) {
                main {
                        padding: 1rem;
                }

                .page-content {
                        grid-template-columns: 1fr;
                }
        }
</style>
