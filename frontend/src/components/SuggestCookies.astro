---
export interface Props {
    shouldSuggestCookies: boolean;
    redirect: string;
}

const { shouldSuggestCookies, redirect } = Astro.props as Props;
---

<p>
    {shouldSuggestCookies && (
        <span>
            Progress now saves locally. You can <a href={redirect}>return to your previous page</a>{' '}
            at any time.
        </span>
    )}
</p>
<br />

<style>
    a {
        opacity: 0.8;
		background-color: #84d484;
		border-radius: 100px;
		color: black;
		text-decoration: none;
		flex-direction: row;
		padding-left: 5px;
		padding-right: 5px;
        text-align: center;
        white-space: nowrap;
    }

    a:hover {
        opacity: 1;
    }

    span {
        color: white;
    }
</style>
