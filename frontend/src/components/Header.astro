---
import Logo from '../components/Logo.astro';
import ThemeToggle from './svelte/ThemeToggle.svelte';

export interface Props {
    title: string;
    body: string;
    href: string;
}
---

<a href="#main" class="skip-link">Skip to main content</a>

<header class="header">
    <div class="header__brand">
        <a href="/" aria-label="Go to homepage" class="brand" data-testid="brand-stack">
            <div class="vertical">
                <Logo />
                <span class="text-gradient title">DSPACE</span>
                <p class="domain">democratized.space</p>
            </div>
        </a>
    </div>
    <div class="header__toggle" aria-label="Theme selection">
        <ThemeToggle client:load />
    </div>
</header>

<style>
    :root {
        --astro-gradient: linear-gradient(0deg, #80df98, #00ff22);
    }

    a {
        text-decoration: none;
    }

    a:focus-visible {
        outline: 2px solid #fff;
        outline-offset: 2px;
    }

    .header {
        display: grid;
        grid-template-columns: 1fr auto 1fr;
        align-items: center;
        gap: 1rem;
        width: 100%;
        margin-inline: auto;
    }

    .header__brand {
        grid-column: 2;
        justify-self: center;
        text-align: center;
        min-width: 0;
    }

    .header__toggle {
        grid-column: 3;
        justify-self: end;
    }

    .text-gradient {
        font-weight: 900;
        background: var(--astro-gradient);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-size: 100% 200%;
        background-position-y: 100%;
        border-radius: 0.4rem;
        animation: pulse 2s ease-in-out infinite;
        display: table;
        margin: 0 auto;
        font-size: 2em;
        max-width: 100%;
    }

    .brand {
        display: inline-flex;
        justify-content: center;
        text-align: center;
    }

    @media (prefers-reduced-motion: reduce) {
        .text-gradient {
            animation: none;
        }
    }

    .default-size {
        font-size: 1em;
    }

    @keyframes pulse {
        0% {
            background-position-y: 0%;
        }
        100% {
            background-position-y: 200%;
        }
    }

    .horizontal {
        display: flex;
        flex-direction: row;
    }

    .vertical {
        display: flex;
        flex-direction: column;
        /* center */
        align-items: center;
    }

    .item {
        gap: 2px;
    }

    .right {
        align-items: flex-end;
    }

    .container {
        background: rgb(20, 20, 20);
        padding: 10px;
        border-radius: 10px;
        margin-top: 20px;
    }

    .domain {
        font-size: 0.8em;
        color: #00ff22;
        margin-top: 0px;
    }

    @media (max-width: 640px) {
        .header {
            grid-template-columns: 1fr auto;
            grid-template-rows: auto auto;
        }

        .header__brand {
            grid-column: 1 / -1;
        }

        .header__toggle {
            grid-column: 2;
        }
    }

    .skip-link {
        position: absolute;
        top: -40px;
        left: 0;
        background: #000;
        color: #fff;
        padding: 0.5rem 1rem;
        z-index: 1000;
    }

    .skip-link:focus {
        top: 0;
    }
</style>
