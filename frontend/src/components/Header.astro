---
import Logo from '../components/Logo.astro';
import ThemeToggle from './svelte/ThemeToggle.svelte';

export interface Props {
    title: string;
    body: string;
    href: string;
}
---

<a href="#main" class="skip-link">Skip to main content</a>

<header class="header">
    <div class="header-inner">
        <span aria-hidden="true" class="header-spacer"></span>
        <a href="/" aria-label="Go to homepage" class="brand" data-testid="brand">
            <div class="vertical">
                <Logo />
                <span class="text-gradient title">DSPACE</span>
                <p class="domain">democratized.space</p>
            </div>
        </a>
        <div class="header-actions" data-testid="header-actions">
            <ThemeToggle client:load />
        </div>
    </div>
</header>

<style>
    :root {
        --astro-gradient: linear-gradient(0deg, #80df98, #00ff22);
    }

    a {
        text-decoration: none;
    }

    a:focus-visible {
        outline: 2px solid #fff;
        outline-offset: 2px;
    }

    .header {
        padding: 0.25rem 0;
    }

    .header-inner {
        display: grid;
        grid-template-columns: 1fr auto 1fr;
        align-items: center;
        gap: 1rem;
    }

    .header-spacer {
        height: 1px;
    }

    .brand {
        min-width: 0;
        justify-self: center;
        text-align: center;
    }

    .header-actions {
        justify-self: end;
    }

    .text-gradient {
        font-weight: 900;
        background: var(--astro-gradient);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-size: 100% 200%;
        background-position-y: 100%;
        border-radius: 0.4rem;
        animation: pulse 2s ease-in-out infinite;
        display: table;
        margin: 0 auto;
        font-size: 2em;
        max-width: 100%;
    }

    @media (prefers-reduced-motion: reduce) {
        .text-gradient {
            animation: none;
        }
    }

    .default-size {
        font-size: 1em;
    }

    @keyframes pulse {
        0% {
            background-position-y: 0%;
        }
        100% {
            background-position-y: 200%;
        }
    }

    .horizontal {
        display: flex;
        flex-direction: row;
    }

    .vertical {
        display: flex;
        flex-direction: column;
        /* center */
        align-items: center;
    }

    .item {
        gap: 2px;
    }

    .right {
        align-items: flex-end;
    }

    .container {
        background: rgb(20, 20, 20);
        padding: 10px;
        border-radius: 10px;
        margin-top: 20px;
    }

    .domain {
        font-size: 0.8em;
        color: #00ff22;
        margin-top: 0px;
    }

    @media (max-width: 720px) {
        .header-inner {
            grid-template-columns: 1fr auto;
            grid-template-areas:
                'brand brand'
                'spacer actions';
            row-gap: 0.5rem;
        }

        .brand {
            grid-area: brand;
        }

        .header-spacer {
            grid-area: spacer;
        }

        .header-actions {
            grid-area: actions;
        }
    }

    .skip-link {
        position: absolute;
        top: -40px;
        left: 0;
        background: #000;
        color: #fff;
        padding: 0.5rem 1rem;
        z-index: 1000;
    }

    .skip-link:focus {
        top: 0;
    }
</style>
