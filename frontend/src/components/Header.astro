---
import Logo from '../components/Logo.astro';
import ThemeToggle from './svelte/ThemeToggle.svelte';
import HeaderAvatar from './svelte/HeaderAvatar.svelte';

export interface Props {
    title: string;
    body: string;
    href: string;
}
---

<a href="#main" class="skip-link">Skip to main content</a>

<header class="header">
    <div class="header-inner">
        <span aria-hidden="true" class="header-spacer"></span>
        <a href="/" aria-label="Go to homepage" class="brand" data-testid="brand">
            <div class="vertical">
                <Logo />
                <span class="text-gradient title">DSPACE</span>
                <p class="domain">democratized.space</p>
            </div>
        </a>
        <div class="header-actions" data-testid="header-actions">
            <div class="header-actions__stack" data-testid="header-actions-stack">
                <ThemeToggle client:load />
                <HeaderAvatar client:load />
            </div>
        </div>
    </div>
</header>

<style>
    :root {
        --astro-gradient: linear-gradient(0deg, #80df98, #00ff22);
    }

    a {
        text-decoration: none;
    }

    a:focus-visible {
        outline: 2px solid #fff;
        outline-offset: 2px;
    }

    .header {
        --header-actions-top: clamp(0.5rem, 1vw + 0.25rem, 1.25rem);
        --header-actions-right: clamp(0.75rem, 1vw + 0.25rem, 1.5rem);
        --header-actions-stack-height: 5.75rem;
        --header-actions-padding-buffer: 0.5rem;
        --header-actions-inline-padding: calc(
            var(--header-actions-right) + var(--header-actions-padding-buffer)
        );
        padding: 0.25rem 0;
    }

    .header-inner {
        position: relative;
        display: grid;
        grid-template-columns: 1fr auto 1fr;
        align-items: center;
        gap: 1rem;
        padding-top: calc(
            var(--header-actions-top) + var(--header-actions-stack-height) +
                var(--header-actions-padding-buffer)
        );
        padding-inline: var(--header-actions-inline-padding);
    }

    .header-spacer {
        height: 1px;
    }

    .brand {
        min-width: 0;
        justify-self: center;
        text-align: center;
    }

    .header-actions {
        position: fixed;
        top: var(--header-actions-top);
        right: var(--header-actions-right);
        z-index: 5;
    }

    .header-actions__stack {
        display: flex;
        flex-direction: column;
        align-items: flex-end;
        gap: 0.25rem;
    }

    .text-gradient {
        font-weight: 900;
        background: var(--astro-gradient);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-size: 100% 200%;
        background-position-y: 100%;
        border-radius: 0.4rem;
        animation: pulse 2s ease-in-out infinite;
        display: table;
        margin: 0 auto;
        font-size: 2em;
        max-width: 100%;
    }

    @media (prefers-reduced-motion: reduce) {
        .text-gradient {
            animation: none;
        }
    }

    .default-size {
        font-size: 1em;
    }

    @keyframes pulse {
        0% {
            background-position-y: 0%;
        }
        100% {
            background-position-y: 200%;
        }
    }

    .horizontal {
        display: flex;
        flex-direction: row;
    }

    .vertical {
        display: flex;
        flex-direction: column;
        /* center */
        align-items: center;
    }

    .item {
        gap: 2px;
    }

    .right {
        align-items: flex-end;
    }

    .container {
        background: rgb(20, 20, 20);
        padding: 10px;
        border-radius: 10px;
        margin-top: 20px;
    }

    .domain {
        font-size: 0.8em;
        color: #00ff22;
        margin-top: 0px;
    }

    @media (max-width: 720px) {
        .header-inner {
            grid-template-columns: 1fr;
            justify-items: center;
            row-gap: 0.5rem;
        }
    }

    .skip-link {
        position: absolute;
        top: -40px;
        left: 0;
        background: #000;
        color: #fff;
        padding: 0.5rem 1rem;
        z-index: 1000;
    }

    .skip-link:focus {
        top: 0;
    }
</style>
